@page
@model SmartAttendance.Web.Pages.Employees.DeleteModel

@{
    ViewData["Title"] = "إيقاف موظف";
}

<link rel="stylesheet" href="~/css/employee-lifecycle-action.css" asp-append-version="true" />

<div class="lifecycle-page">
    <div class="lifecycle-header">
        <div>
            <div class="lifecycle-eyebrow">NEXORA Employee Lifecycle</div>
            <h1>إيقاف موظف</h1>
            <p>لا يتم حذف الموظف نهائياً لأن لديه تاريخ حضور وطلبات وسجلات مرتبطة. هذا الإجراء يحافظ على كل التاريخ ويجعل الموظف غير فعال فقط.</p>
        </div>

        <a asp-page="./Index" class="hrms-btn-secondary">رجوع للموظفين</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="lifecycle-alert danger">
            @Model.ErrorMessage
        </div>
    }

    <div class="lifecycle-card">
        <div class="lifecycle-warning">
            <strong>تنبيه مهم</strong>
            <span>الحذف النهائي غير صحيح في أنظمة HR لأن الموظف مرتبط بسجلات حضور، طلبات، موافقات، وتاريخ وظيفي. سيتم إيقاف الموظف فقط.</span>
        </div>

        <div class="lifecycle-details">
            <div>
                <span>كود الموظف</span>
                <strong>@Model.Employee.EmployeeNo</strong>
            </div>

            <div>
                <span>اسم الموظف</span>
                <strong>@Model.Employee.FullName</strong>
            </div>

            <div>
                <span>القسم</span>
                <strong>@Model.Employee.DepartmentName</strong>
            </div>

            <div>
                <span>الفرع</span>
                <strong>@Model.Employee.BranchName</strong>
            </div>

            <div>
                <span>الهاتف</span>
                <strong>@Model.Employee.Phone</strong>
            </div>

            <div>
                <span>الحالة الحالية</span>
                <strong>@(Model.Employee.IsActive ? "فعال" : "غير فعال")</strong>
            </div>
        </div>

        <form method="post" class="lifecycle-actions">
            <input type="hidden" name="id" value="@Model.Employee.Id" />

            <button type="submit" class="lifecycle-btn-warning">إيقاف الموظف</button>
            <a asp-page="./Index" class="hrms-btn-secondary">إلغاء</a>
        </form>
    </div>
</div>

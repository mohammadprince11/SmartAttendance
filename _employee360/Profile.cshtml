@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel

@{
    ViewData["Title"] = "ملف الموظف";
}

<link rel="stylesheet" href="~/css/employee-360-profile.css" asp-append-version="true" />

<div class="employee360-page">
    <div class="employee360-header">
        <div>
            <div class="employee360-eyebrow">NEXORA Employee 360</div>
            <h1>ملف الموظف الشامل</h1>
            <p>عرض موحد لبيانات الموظف، الحضور، الشفتات، الطلبات، المستندات، وسجل التعديلات.</p>
        </div>

        <div class="employee360-actions">
            <a asp-page="./Index" class="hrms-btn-secondary">رجوع للموظفين</a>

            @if (Model.Employee != null)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Employee.Id" class="hrms-btn-primary">تعديل بيانات الموظف</a>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="employee360-alert">@Model.ErrorMessage</div>
    }

    @if (Model.Employee != null)
    {
        <section class="employee360-hero nexora-pattern">
            <div class="employee360-avatar">
                @(!string.IsNullOrWhiteSpace(Model.Employee.FullName) ? Model.Employee.FullName.Trim()[0] : 'N')
            </div>

            <div class="employee360-identity">
                <h2>@Model.Employee.FullName</h2>
                <div class="employee360-meta">
                    <span>@Model.Employee.EmployeeNo</span>
                    <span>@Model.Display(Model.Employee.Position)</span>
                    <span>@Model.Display(Model.Employee.DepartmentName)</span>
                    <span>@Model.Display(Model.Employee.BranchName)</span>
                </div>
            </div>

            <div class="employee360-status @(Model.Employee.IsActive ? "active" : "inactive")">
                @(Model.Employee.IsActive ? "فعال" : "غير فعال")
            </div>
        </section>

        <section class="employee360-kpis">
            <div class="employee360-kpi">
                <span>سجلات الحضور</span>
                <strong>@Model.AttendanceCount</strong>
                <small>ضمن الفترة المحددة</small>
            </div>

            <div class="employee360-kpi success">
                <span>حاضر</span>
                <strong>@Model.PresentCount</strong>
                <small>سجل حضور</small>
            </div>

            <div class="employee360-kpi warning">
                <span>متأخر</span>
                <strong>@Model.LateCount</strong>
                <small>سجل تأخير</small>
            </div>

            <div class="employee360-kpi danger">
                <span>غياب</span>
                <strong>@Model.AbsentCount</strong>
                <small>سجل غياب</small>
            </div>

            <div class="employee360-kpi warning">
                <span>بصمات ناقصة</span>
                <strong>@Model.MissingCheckoutCount</strong>
                <small>خروج مفقود</small>
            </div>

            <div class="employee360-kpi">
                <span>ساعات العمل</span>
                <strong>@Model.TotalWorkingHours</strong>
                <small>ساعة محسوبة</small>
            </div>
        </section>

        <section class="employee360-grid">
            <div class="employee360-card">
                <h3>البيانات الأساسية</h3>

                <div class="employee360-info-list">
                    <div><span>كود الموظف</span><strong>@Model.Employee.EmployeeNo</strong></div>
                    <div><span>الاسم</span><strong>@Model.Employee.FullName</strong></div>
                    <div><span>الرقم الوطني</span><strong>@Model.Display(Model.Employee.NationalId)</strong></div>
                    <div><span>الهاتف</span><strong>@Model.Display(Model.Employee.Phone)</strong></div>
                    <div><span>الإيميل</span><strong>@Model.Display(Model.Employee.Email)</strong></div>
                    <div><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(Model.Employee.BirthDate)</strong></div>
                    <div><span>الجنس</span><strong>@Model.Display(Model.Employee.Gender)</strong></div>
                    <div><span>الجنسية</span><strong>@Model.Display(Model.Employee.Nationality)</strong></div>
                    <div><span>البلد</span><strong>@Model.Display(Model.Employee.Country)</strong></div>
                </div>
            </div>

            <div class="employee360-card">
                <h3>البيانات الوظيفية</h3>

                <div class="employee360-info-list">
                    <div><span>الشركة</span><strong>@Model.Display(Model.Employee.CompanyName)</strong></div>
                    <div><span>الفرع</span><strong>@Model.Display(Model.Employee.BranchName)</strong></div>
                    <div><span>القسم</span><strong>@Model.Display(Model.Employee.DepartmentName)</strong></div>
                    <div><span>المنصب</span><strong>@Model.Display(Model.Employee.Position)</strong></div>
                    <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(Model.Employee.HireDate)</strong></div>
                    <div><span>نوع العقد</span><strong>@Model.Display(Model.Employee.ContractType)</strong></div>
                    <div><span>نهاية العقد</span><strong>@Model.DisplayDate(Model.Employee.ContractEndDate)</strong></div>
                    <div><span>الحالة الوظيفية</span><strong>@Model.Display(Model.Employee.EmploymentStatus)</strong></div>
                    <div><span>المدير المباشر</span><strong>@Model.Display(Model.Employee.DirectManager)</strong></div>
                </div>
            </div>
        </section>

        <section class="employee360-card">
            <div class="employee360-section-head">
                <div>
                    <h3>الحضور والانصراف</h3>
                    <p>آخر السجلات حسب الفترة المحددة.</p>
                </div>

                <form method="get" class="employee360-filter">
                    <input type="hidden" name="Id" value="@Model.Employee.Id" />
                    <label>
                        من
                        <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                    </label>
                    <label>
                        إلى
                        <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                    </label>
                    <button type="submit" class="hrms-btn-primary">تحديث</button>
                </form>
            </div>

            <div class="employee360-table-wrap">
                <table class="employee360-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الدخول</th>
                            <th>الخروج</th>
                            <th>الحالة</th>
                            <th>المصدر</th>
                            <th>الجهاز</th>
                            <th>الملاحظة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.AttendanceRows)
                        {
                            <tr>
                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                <td><span class="employee360-badge">@Model.StatusText(row.Status)</span></td>
                                <td>@Model.SourceText(row.Source)</td>
                                <td>@Model.Display(row.DeviceName)</td>
                                <td>@Model.Display(row.Notes)</td>
                            </tr>
                        }

                        @if (!Model.AttendanceRows.Any())
                        {
                            <tr>
                                <td colspan="7" class="employee360-empty">لا توجد سجلات حضور ضمن الفترة المحددة.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="employee360-two-columns">
            <div class="employee360-card">
                <h3>الشفتات الحالية والسابقة</h3>

                <div class="employee360-table-wrap">
                    <table class="employee360-table compact">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th>الشفت</th>
                                <th>الوقت</th>
                                <th>من</th>
                                <th>إلى</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ShiftRows)
                            {
                                <tr>
                                    <td>@row.Code</td>
                                    <td>@row.Name</td>
                                    <td>@row.StartTime - @row.EndTime</td>
                                    <td>@Model.DisplayDate(row.EffectiveFrom)</td>
                                    <td>@Model.DisplayDate(row.EffectiveTo)</td>
                                    <td>@(row.IsCurrent ? "حالي" : "سابق")</td>
                                </tr>
                            }

                            @if (!Model.ShiftRows.Any())
                            {
                                <tr>
                                    <td colspan="6" class="employee360-empty">لا توجد شفتات مسجلة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="employee360-card">
                <h3>طلبات الخدمات الذاتية</h3>

                <div class="employee360-request-kpis">
                    <div><span>معلق</span><strong>@Model.PendingRequests</strong></div>
                    <div><span>مقبول</span><strong>@Model.ApprovedRequests</strong></div>
                    <div><span>مرفوض</span><strong>@Model.RejectedRequests</strong></div>
                </div>

                <div class="employee360-table-wrap">
                    <table class="employee360-table compact">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>النوع</th>
                                <th>الحالة</th>
                                <th>المرحلة</th>
                                <th>التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.RequestRows)
                            {
                                <tr>
                                    <td>@row.Id</td>
                                    <td>@row.RequestType</td>
                                    <td>@Model.RequestStatusText(row.Status)</td>
                                    <td>@Model.Display(row.CurrentStep)</td>
                                    <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                </tr>
                            }

                            @if (!Model.RequestRows.Any())
                            {
                                <tr>
                                    <td colspan="5" class="employee360-empty">لا توجد طلبات مسجلة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="employee360-two-columns">
            <div class="employee360-card">
                <h3>المستندات</h3>

                <div class="employee360-table-wrap">
                    <table class="employee360-table compact">
                        <thead>
                            <tr>
                                <th>النوع</th>
                                <th>الملف</th>
                                <th>تاريخ الانتهاء</th>
                                <th>تاريخ الرفع</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.DocumentRows)
                            {
                                <tr>
                                    <td>@row.DocumentType</td>
                                    <td>@row.FileName</td>
                                    <td>@Model.DisplayDate(row.ExpiryDate)</td>
                                    <td>@Model.DisplayDateTime(row.UploadedAt)</td>
                                </tr>
                            }

                            @if (!Model.DocumentRows.Any())
                            {
                                <tr>
                                    <td colspan="4" class="employee360-empty">لا توجد مستندات مرفوعة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="employee360-card">
                <h3>سجل التعديلات</h3>

                <div class="employee360-table-wrap">
                    <table class="employee360-table compact">
                        <thead>
                            <tr>
                                <th>الإجراء</th>
                                <th>المستخدم</th>
                                <th>التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.AuditRows)
                            {
                                <tr>
                                    <td>@row.Action</td>
                                    <td>@Model.Display(row.UserName)</td>
                                    <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                </tr>
                            }

                            @if (!Model.AuditRows.Any())
                            {
                                <tr>
                                    <td colspan="3" class="employee360-empty">لا يوجد سجل تعديلات لهذا الموظف.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
</div>

@page "/ShiftTypes"
@model SmartAttendance.Web.Pages.ShiftTypes.IndexModel
@using SmartAttendance.Web.Infrastructure.Hrms
@using System.Text.Json

@*
    أنواع المناوبات — المرحلة 1 من مودل الحضور الجديد (نمط كيان):
    قائمة + سلايد بناء بمصفوفة الأيام السبعة. التعديل يتعبأ من JSON مضمّن.
*@

@{
    ViewData["Title"] = "أنواع المناوبات";
    var shiftsJson = JsonSerializer.Serialize(Model.Shifts.Select(s => new
    {
        s.Id, s.Name, s.NameEn, s.ColorHex, s.IsFlexible, s.FlexDailyHours, s.MultiPeriod, s.IsActive,
        s.FillMissingCheckIn, s.FillMissingCheckOut, s.StripSemantics, s.ConsiderPermissionsOutsideShift,
        s.ExcludePermsOutsideStartFromLate, s.TotalDurationMode, s.AvailableInRoster, s.RequestableFromEss,
        s.LatenessGraceMinutes, s.EarlyLeaveGraceMinutes, s.TimeLimitFrom, s.TimeLimitFromDayBefore,
        s.TimeLimitTo, s.TimeLimitToDayAfter, s.MidShiftTime,
        Days = s.Days.Select(d => new { d.DayIndex, d.DayKind, d.StartTime, d.EndTime }),
        Periods = s.Periods.Select(p => new { p.StartTime, p.EndTime })
    }));
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .sht-page { display: flex; flex-direction: column; gap: 14px; color: var(--sa-text, #DCEAF4); }
    .sht-head {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
        padding: 16px 20px; border: 1px solid rgba(73,111,151,.22); border-radius: 20px;
        background: radial-gradient(circle at 90% 10%, rgba(18,217,227,.12), transparent 36%),
                    linear-gradient(135deg, rgba(9,31,52,.95), rgba(5,16,29,.95));
    }
    html[data-theme="light"] .sht-head { background: linear-gradient(135deg, #fff, #f2f7fb); }
    .sht-head h1 { margin: 0; font-size: 20px; font-weight: 1000; }
    .sht-head p { margin: 2px 0 0; font-size: 12px; color: var(--sa-muted, #8FA8BC); font-weight: 800; }
    .sht-btn { min-height: 38px; padding: 8px 18px; border-radius: 12px; border: 0; font-size: 13px; font-weight: 900; cursor: pointer; background: linear-gradient(135deg, #12D9E3, #0ea5b5); color: #04141d; }
    .sht-btn.ghost { background: transparent; border: 1px solid rgba(73,111,151,.3); color: inherit; }

    .sht-table-card { border: 1px solid rgba(73,111,151,.22); border-radius: 18px; overflow: hidden; background: var(--sa-surface, rgba(8,25,43,.9)); }
    .sht-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .sht-table th { text-align: start; padding: 12px 14px; font-size: 11px; font-weight: 1000; color: var(--sa-muted, #8FA8BC); border-bottom: 1px solid rgba(73,111,151,.22); background: rgba(0,0,0,.12); }
    html[data-theme="light"] .sht-table th { background: #f2f7fb; }
    .sht-table td { padding: 11px 14px; border-bottom: 1px solid rgba(143,168,188,.08); vertical-align: middle; }
    .sht-table tr:hover td { background: rgba(18,217,227,.04); }
    .sht-color { display: inline-block; width: 14px; height: 14px; border-radius: 4px; vertical-align: -2px; margin-inline-end: 8px; }
    .sht-chip { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 900; background: rgba(18,217,227,.1); color: #12D9E3; }
    .sht-chip.flex { background: rgba(167,139,250,.14); color: #a78bfa; }
    .sht-chip.off { background: rgba(248,113,113,.12); color: #f87171; }
    .sht-empty { padding: 28px; text-align: center; color: var(--sa-muted, #8FA8BC); font-weight: 800; }

    /* مصفوفة الأيام بالسلايد */
    .sht-daygrid { display: flex; flex-direction: column; gap: 6px; }
    .sht-dayrow { display: grid; grid-template-columns: 72px 120px 1fr 1fr 70px; gap: 8px; align-items: center; padding: 6px 8px; border: 1px solid rgba(73,111,151,.16); border-radius: 10px; font-size: 12px; }
    .sht-dayrow b { font-weight: 900; }
    .sht-dayrow select, .sht-dayrow input { min-height: 32px; border-radius: 8px; border: 1px solid rgba(73,111,151,.25); background: rgba(0,0,0,.16); color: inherit; padding: 4px 8px; font-size: 12px; width: 100%; }
    html[data-theme="light"] .sht-dayrow select, html[data-theme="light"] .sht-dayrow input { background: #fff; }
    .sht-dayrow .hours { text-align: center; font-weight: 900; color: #12D9E3; direction: ltr; }
    .sht-dayrow.is-off { opacity: .55; }
    .sht-form { display: flex; flex-direction: column; gap: 10px; }
    .sht-form label { font-size: 12px; font-weight: 900; display: flex; flex-direction: column; gap: 4px; }
    .sht-form input[type=text], .sht-form input[type=number] { min-height: 36px; border-radius: 10px; border: 1px solid rgba(73,111,151,.25); background: rgba(0,0,0,.16); color: inherit; padding: 6px 10px; }
    html[data-theme="light"] .sht-form input[type=text], html[data-theme="light"] .sht-form input[type=number] { background: #fff; }
    .sht-colors { display: flex; gap: 8px; flex-wrap: wrap; }
    .sht-colors label { flex-direction: row; cursor: pointer; }
    .sht-colors input { display: none; }
    .sht-colors span { width: 26px; height: 26px; border-radius: 8px; display: inline-block; border: 2px solid transparent; }
    .sht-colors input:checked + span { border-color: #fff; box-shadow: 0 0 0 2px #12D9E3; }
    .sht-mode { display: flex; gap: 14px; font-size: 13px; font-weight: 900; flex-wrap: wrap; }
    .sht-alert { padding: 10px 14px; border-radius: 12px; font-size: 13px; font-weight: 800; border: 1px solid rgba(74,222,128,.35); background: rgba(74,222,128,.08); }
    /* الفترات المتعددة (سبليت شفت) */
    .sht-periods { display: flex; flex-direction: column; gap: 6px; }
    .sht-period-row { display: grid; grid-template-columns: 30px 1fr 1fr 56px 34px; gap: 8px; align-items: center; padding: 6px 8px; border: 1px solid rgba(73,111,151,.16); border-radius: 10px; font-size: 12px; }
    .sht-period-row b { font-weight: 900; text-align: center; color: var(--sa-muted,#8FA8BC); }
    .sht-period-row input { min-height: 32px; border-radius: 8px; border: 1px solid rgba(73,111,151,.25); background: rgba(0,0,0,.16); color: inherit; padding: 4px 8px; width: 100%; }
    html[data-theme="light"] .sht-period-row input { background: #fff; }
    .sht-period-row .hours { text-align: center; font-weight: 900; color: #12D9E3; direction: ltr; }
    .sht-period-row .rm { background: rgba(248,113,113,.14); border: 1px solid rgba(248,113,113,.4); color: #f87171; border-radius: 8px; min-height: 32px; cursor: pointer; font-weight: 900; }
    .sht-hint { font-size: 12px; font-weight: 800; color: var(--sa-muted,#8FA8BC); }
    .sht-chip.multi { background: rgba(96,165,250,.14); color: #60a5fa; }
</style>

<section class="sht-page" dir="rtl">
    <header class="sht-head">
        <div>
            <h1>أنواع المناوبات</h1>
            <p>تعريف المناوبات يوماً-بيوم (ثابتة بأوقات أو مرنة بساعات) — أساس محرك الحضور الجديد.</p>
        </div>
        <button type="button" class="sht-btn" onclick="shtOpen(0)">+ مناوبة جديدة</button>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sht-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="sht-table-card">
        @if (Model.Shifts.Count == 0)
        {
            <div class="sht-empty">لا مناوبات معرفة بعد — ابدأ بـ«مناوبة جديدة».</div>
        }
        else
        {
            <table class="sht-table">
                <thead>
                    <tr><th>المناوبة</th><th>النوع</th><th>أيام العطل/الراحة</th><th>ساعات الأسبوع</th><th>الحالة</th><th style="text-align:end">إجراءات</th></tr>
                </thead>
                <tbody>
                    @foreach (var shift in Model.Shifts)
                    {
                        <tr>
                            <td><span class="sht-color" style="background:@shift.ColorHex"></span><b>@shift.Name</b>@(string.IsNullOrWhiteSpace(shift.NameEn) ? "" : $" · {shift.NameEn}")</td>
                            <td>
                                <span class="sht-chip @(shift.IsFlexible ? "flex" : "")">@(shift.IsFlexible ? $"مرنة · {shift.FlexDailyHours:0.##} س/يوم" : "ثابتة")</span>
                                @if (shift.MultiPeriod)
                                { <span class="sht-chip multi">@shift.Periods.Count فترات</span> }
                            </td>
                            <td>@shift.OffDaysText</td>
                            <td style="direction:ltr">@shift.Days.Sum(d => d.WorkHours).ToString("0.##") س</td>
                            <td><span class="sht-chip @(shift.IsActive ? "" : "off")">@(shift.IsActive ? "نشطة" : "متوقفة")</span></td>
                            <td style="text-align:end;white-space:nowrap">
                                <button type="button" class="sht-btn ghost" onclick="shtOpen(@shift.Id)">تعديل</button>
                                <form method="post" asp-page-handler="Delete" style="display:inline">
                                    <input type="hidden" name="id" value="@shift.Id" />
                                    <button type="submit" class="sht-btn ghost" style="color:#f87171" data-zyconfirm="تأكيد الحذف؟">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ---------- سلايد بناء المناوبة ---------- *@
    <div class="hrms-slideover-backdrop" id="sht-backdrop" onclick="shtClose()"></div>
    <aside class="hrms-slideover wide" id="sht-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2 id="sht-title">مناوبة جديدة</h2>
            <button type="button" class="hrms-slideover-close" onclick="shtClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="Save" class="sht-form" id="sht-form">
                <input type="hidden" name="Id" id="sht-Id" value="0" />

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    <label>اسم المناوبة (عربي) *
                        <input type="text" name="Name" id="sht-Name" required />
                    </label>
                    <label>Shift Name (EN)
                        <input type="text" name="NameEn" id="sht-NameEn" dir="ltr" />
                    </label>
                </div>

                <label>لون المناوبة (للمستعرض)</label>
                <div class="sht-colors">
                    @foreach (var color in ShiftTypeStore.Colors)
                    {
                        <label><input type="radio" name="ColorHex" value="@color" @(color == ShiftTypeStore.Colors[0] ? "checked" : "") /><span style="background:@color"></span></label>
                    }
                </div>

                <div class="sht-mode">
                    <label style="flex-direction:row;align-items:center;gap:6px"><input type="radio" name="ShiftMode" value="fixed" checked onchange="shtModeChanged()" /> ثابتة (أوقات لكل يوم)</label>
                    <label style="flex-direction:row;align-items:center;gap:6px"><input type="radio" name="ShiftMode" value="flex" onchange="shtModeChanged()" /> مرنة (ساعات مطلوبة)</label>
                </div>

                <label id="sht-flex-wrap" hidden>الساعات المطلوبة يومياً
                    <input type="number" name="FlexDailyHours" id="sht-FlexHours" step="0.25" min="0" max="24" value="8" style="max-width:140px" />
                </label>

                @* نوع الفترات: واحدة / متعددة (سبليت شفت) — للثابتة فقط *@
                <div class="sht-mode" id="sht-period-mode">
                    <label style="flex-direction:row;align-items:center;gap:6px"><input type="radio" name="PeriodMode" value="single" checked onchange="shtPeriodModeChanged()" /> فترة واحدة</label>
                    <label style="flex-direction:row;align-items:center;gap:6px"><input type="radio" name="PeriodMode" value="multi" onchange="shtPeriodModeChanged()" /> فترات متعددة (سبليت شفت)</label>
                </div>

                <div id="sht-periods-wrap" hidden style="display:flex;flex-direction:column;gap:8px">
                    <label style="margin:0">الفترات <span class="sht-hint">— تنطبق على كل أيام العمل؛ ساعات اليوم = مجموع الفترات</span></label>
                    <div id="sht-periods" class="sht-periods"></div>
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <button type="button" class="sht-btn ghost" onclick="shtAddPeriod()">+ فترة</button>
                        <span class="sht-hint">إجمالي ساعات الفترات: <b id="sht-periods-total" style="color:#12D9E3">0</b></span>
                    </div>
                </div>

                <label>مصفوفة الأسبوع</label>
                <div class="sht-daygrid">
                    <div class="sht-dayrow" style="opacity:.7;border:0;padding:2px 8px">
                        <b>اليوم</b><b>النوع</b><b>الدخول</b><b>الخروج</b><b style="text-align:center">ساعات</b>
                    </div>
                    @for (var dayIndex = 0; dayIndex < 7; dayIndex++)
                    {
                        <div class="sht-dayrow" data-day="@dayIndex">
                            <b>@ShiftTypeStore.DayNames[dayIndex]</b>
                            <select name="day_kind_@dayIndex" onchange="shtDayChanged(@dayIndex)">
                                <option value="Work">يوم عمل</option>
                                <option value="Weekend">يوم عطلة</option>
                                <option value="Rest">يوم راحة</option>
                            </select>
                            <input type="time" name="day_start_@dayIndex" value="09:00" onchange="shtDayChanged(@dayIndex)" />
                            <input type="time" name="day_end_@dayIndex" value="17:00" onchange="shtDayChanged(@dayIndex)" />
                            <span class="hours" data-hours="@dayIndex">8</span>
                        </div>
                    }
                </div>

                @* ===== السماحيات والحدود (فترة السماح + نافذة البصم + منتصف المناوبة) ===== *@
                <label style="margin-top:6px">السماحيات والحدود <span class="sht-hint">— فترة السماح، نافذة البصم الصالحة، منتصف المناوبة</span></label>
                <div style="display:flex;flex-direction:column;gap:10px;border:1px solid rgba(73,111,151,.18);border-radius:12px;padding:12px">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                        <label>فترة السماح للتأخير (دقائق)<input type="number" name="LatenessGraceMinutes" id="sht-LGM" min="0" max="600" value="0" /></label>
                        <label>فترة السماح للخروج المبكر (دقائق)<input type="number" name="EarlyLeaveGraceMinutes" id="sht-ELG" min="0" max="600" value="0" /></label>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                        <label>حد وقت بدء المناوبة (أبكر بصمة صالحة)
                            <span style="display:flex;gap:6px;align-items:center">
                                <input type="time" name="TimeLimitFrom" id="sht-TLF" style="flex:1" />
                                <select name="TimeLimitFromAnchor" id="sht-TLFA" style="min-height:36px;border-radius:8px;border:1px solid rgba(73,111,151,.25);background:rgba(0,0,0,.16);color:inherit;padding:4px 6px">
                                    <option value="same">نفس اليوم</option>
                                    <option value="before">اليوم السابق</option>
                                </select>
                            </span>
                        </label>
                        <label>حد وقت انتهاء المناوبة (أحدث بصمة صالحة)
                            <span style="display:flex;gap:6px;align-items:center">
                                <input type="time" name="TimeLimitTo" id="sht-TLT" style="flex:1" />
                                <select name="TimeLimitToAnchor" id="sht-TLTA" style="min-height:36px;border-radius:8px;border:1px solid rgba(73,111,151,.25);background:rgba(0,0,0,.16);color:inherit;padding:4px 6px">
                                    <option value="same">نفس اليوم</option>
                                    <option value="after">اليوم التالي</option>
                                </select>
                            </span>
                        </label>
                    </div>
                    <label style="max-width:280px">وقت منتصف المناوبة <span class="sht-hint">(لتقسيم بصمات المناوبة العابرة لمنتصف الليل)</span>
                        <input type="time" name="MidShiftTime" id="sht-MST" style="max-width:160px" />
                    </label>
                </div>

                @* ===== قواعد سلوك المناوبة (أسفل اختيار الأيام — نمط كيان) ===== *@
                <label style="margin-top:6px">قواعد المناوبة <span class="sht-hint">— كيف يعامل محرك الحضور بصمات هذه المناوبة</span></label>
                <div style="display:flex;flex-direction:column;gap:8px;border:1px solid rgba(73,111,151,.18);border-radius:12px;padding:12px">
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="FillMissingCheckIn" value="true" id="sht-FMI" /> تعبئة وقت بدء المناوبة تلقائياً لأي بصمة دخول مفقودة</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="FillMissingCheckOut" value="true" id="sht-FMO" /> تعبئة وقت انتهاء المناوبة تلقائياً لأي بصمة خروج مفقودة</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="StripSemantics" value="true" id="sht-STS" /> تجريد فترة الدلالات (استراحة/صلاة…) من مدة الحضور</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="ConsiderPermissionsOutsideShift" value="true" id="sht-CPO" /> احتساب ساعات المغادرة الواقعة خارج المناوبة</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="ExcludePermsOutsideStartFromLate" value="true" id="sht-EPL" /> استثناء المغادرات خارج بداية المناوبة من التأخير</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="AvailableInRoster" value="true" id="sht-AIR" checked /> متاحة في جدول الحضور (الروستر)</label>
                    <label style="flex-direction:row;align-items:center;gap:8px"><input type="checkbox" name="RequestableFromEss" value="true" id="sht-RFE" /> قابلة للطلب من الخدمة الذاتية</label>
                    <label style="max-width:260px">عند احتساب المدة الإجمالية
                        <select name="TotalDurationMode" id="sht-TDM" style="min-height:34px;border-radius:8px;border:1px solid rgba(73,111,151,.25);background:rgba(0,0,0,.16);color:inherit;padding:4px 8px">
                            <option value="WorkOnly">أيام العمل فقط</option>
                            <option value="IncludeOff">اشمل أيام العطل</option>
                            <option value="Both">كلاهما</option>
                        </select>
                    </label>
                </div>

                <label style="flex-direction:row;align-items:center;gap:8px">
                    <input type="checkbox" name="IsActive" value="true" id="sht-Active" checked /> المناوبة نشطة
                </label>

                <button type="submit" class="sht-btn">حفظ المناوبة</button>
            </form>
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        var SHT_DATA = @Html.Raw(shiftsJson);

        function shtEls(d) {
            return {
                kind: document.querySelector('[name="day_kind_' + d + '"]'),
                start: document.querySelector('[name="day_start_' + d + '"]'),
                end: document.querySelector('[name="day_end_' + d + '"]'),
                hours: document.querySelector('[data-hours="' + d + '"]'),
                row: document.querySelector('.sht-dayrow[data-day="' + d + '"]')
            };
        }

        // حساب ساعات اليوم محلياً (يدعم عبور منتصف الليل — مثل السيرفر)
        function shtComputeHours(start, end) {
            if (!start || !end) return 0;
            var s = start.split(':'), e = end.split(':');
            var mins = (parseInt(e[0]) * 60 + parseInt(e[1])) - (parseInt(s[0]) * 60 + parseInt(s[1]));
            if (mins < 0) mins += 1440;
            return Math.round(mins / 60 * 100) / 100;
        }

        function shtIsFlex() { return document.querySelector('[name="ShiftMode"]:checked').value === 'flex'; }
        function shtIsMulti() { var r = document.querySelector('[name="PeriodMode"]:checked'); return !!r && r.value === 'multi' && !shtIsFlex(); }

        function shtDayChanged(d) {
            var el = shtEls(d);
            var isWork = el.kind.value === 'Work';
            var flex = shtIsFlex();
            var multi = shtIsMulti();
            var lockTimes = !isWork || flex || multi;   // بالمرنة/المتعددة لا أوقات لكل يوم
            el.start.disabled = lockTimes;
            el.end.disabled = lockTimes;
            el.row.classList.toggle('is-off', !isWork);
            el.hours.textContent = !isWork ? '0'
                : flex ? (document.getElementById('sht-FlexHours').value || 0)
                : multi ? (document.getElementById('sht-periods-total').textContent || 0)
                : shtComputeHours(el.start.value, el.end.value);
        }

        function shtModeChanged() {
            var flex = shtIsFlex();
            document.getElementById('sht-flex-wrap').hidden = !flex;
            document.getElementById('sht-period-mode').hidden = flex;   // الفترات للثابتة فقط
            if (flex) { var single = document.querySelector('[name="PeriodMode"][value="single"]'); if (single) single.checked = true; }
            shtPeriodModeChanged();
        }
        document.getElementById('sht-FlexHours').addEventListener('input', shtModeChanged);

        // ===== الفترات المتعددة (سبليت شفت) =====
        function shtReindexPeriods() {
            document.querySelectorAll('#sht-periods .sht-period-row').forEach(function (row, i) {
                row.querySelector('.p-start').name = 'period_start_' + i;
                row.querySelector('.p-end').name = 'period_end_' + i;
                row.querySelector('b').textContent = (i + 1);
            });
        }
        function shtAddPeriod(start, end) {
            var wrap = document.getElementById('sht-periods');
            var row = document.createElement('div');
            row.className = 'sht-period-row';
            row.innerHTML = '<b></b>'
                + '<input type="time" class="p-start" value="' + (start || '09:00') + '" onchange="shtPeriodsRecalc()" />'
                + '<input type="time" class="p-end" value="' + (end || '13:00') + '" onchange="shtPeriodsRecalc()" />'
                + '<span class="hours">0</span>'
                + '<button type="button" class="rm" onclick="shtRemovePeriod(this)">×</button>';
            wrap.appendChild(row);
            shtReindexPeriods(); shtPeriodsRecalc();
        }
        function shtRemovePeriod(btn) { var row = btn.closest('.sht-period-row'); row.parentNode.removeChild(row); shtReindexPeriods(); shtPeriodsRecalc(); }
        function shtPeriodsRecalc() {
            var total = 0;
            document.querySelectorAll('#sht-periods .sht-period-row').forEach(function (row) {
                var h = shtComputeHours(row.querySelector('.p-start').value, row.querySelector('.p-end').value);
                row.querySelector('.hours').textContent = h;
                total += h;
            });
            total = Math.round(total * 100) / 100;
            document.getElementById('sht-periods-total').textContent = total;
            if (shtIsMulti()) { for (var d = 0; d < 7; d++) { var el = shtEls(d); if (el.kind.value === 'Work') el.hours.textContent = total; } }
        }
        function shtPeriodModeChanged() {
            var multi = shtIsMulti();
            document.getElementById('sht-periods-wrap').hidden = !multi;
            if (multi && document.querySelectorAll('#sht-periods .sht-period-row').length === 0) {
                shtAddPeriod('09:00', '13:00'); shtAddPeriod('16:00', '20:00');
            }
            for (var d = 0; d < 7; d++) shtDayChanged(d);
            shtPeriodsRecalc();
        }

        function shtOpen(id) {
            var form = document.getElementById('sht-form');
            form.reset();
            document.getElementById('sht-Id').value = id || 0;
            document.getElementById('sht-title').textContent = id ? 'تعديل المناوبة' : 'مناوبة جديدة';
            document.getElementById('sht-periods').innerHTML = '';
            document.querySelector('[name="PeriodMode"][value="single"]').checked = true;

            if (id) {
                var s = SHT_DATA.find(function (x) { return x.Id === id; });
                if (s) {
                    document.getElementById('sht-Name').value = s.Name || '';
                    document.getElementById('sht-NameEn').value = s.NameEn || '';
                    document.getElementById('sht-Active').checked = !!s.IsActive;
                    var colorInput = document.querySelector('[name="ColorHex"][value="' + s.ColorHex + '"]');
                    if (colorInput) colorInput.checked = true;
                    document.querySelector('[name="ShiftMode"][value="' + (s.IsFlexible ? 'flex' : 'fixed') + '"]').checked = true;
                    document.getElementById('sht-FlexHours').value = s.FlexDailyHours || 8;
                    var multi = !s.IsFlexible && !!s.MultiPeriod;
                    document.querySelector('[name="PeriodMode"][value="' + (multi ? 'multi' : 'single') + '"]').checked = true;
                    if (multi) (s.Periods || []).forEach(function (p) { shtAddPeriod(p.StartTime, p.EndTime); });
                    document.getElementById('sht-FMI').checked = !!s.FillMissingCheckIn;
                    document.getElementById('sht-FMO').checked = !!s.FillMissingCheckOut;
                    document.getElementById('sht-STS').checked = !!s.StripSemantics;
                    document.getElementById('sht-CPO').checked = !!s.ConsiderPermissionsOutsideShift;
                    document.getElementById('sht-EPL').checked = !!s.ExcludePermsOutsideStartFromLate;
                    document.getElementById('sht-AIR').checked = !!s.AvailableInRoster;
                    document.getElementById('sht-RFE').checked = !!s.RequestableFromEss;
                    document.getElementById('sht-TDM').value = s.TotalDurationMode || 'WorkOnly';
                    document.getElementById('sht-LGM').value = s.LatenessGraceMinutes || 0;
                    document.getElementById('sht-ELG').value = s.EarlyLeaveGraceMinutes || 0;
                    document.getElementById('sht-TLF').value = s.TimeLimitFrom || '';
                    document.getElementById('sht-TLFA').value = s.TimeLimitFromDayBefore ? 'before' : 'same';
                    document.getElementById('sht-TLT').value = s.TimeLimitTo || '';
                    document.getElementById('sht-TLTA').value = s.TimeLimitToDayAfter ? 'after' : 'same';
                    document.getElementById('sht-MST').value = s.MidShiftTime || '';
                    (s.Days || []).forEach(function (day) {
                        var el = shtEls(day.DayIndex);
                        el.kind.value = day.DayKind || 'Work';
                        if (day.StartTime) el.start.value = day.StartTime;
                        if (day.EndTime) el.end.value = day.EndTime;
                    });
                }
            }
            shtModeChanged();
            document.getElementById('sht-slide').classList.add('open');
            document.getElementById('sht-backdrop').classList.add('open');
        }

        function shtClose() {
            document.getElementById('sht-slide').classList.remove('open');
            document.getElementById('sht-backdrop').classList.remove('open');
        }
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') shtClose(); });
    </script>
}

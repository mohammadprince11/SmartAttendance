@page
@model SmartAttendance.Web.Pages.Approvals.IndexModel

@{
    ViewData["Title"] = "الموافقات";
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .apv-chain { display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
    .apv-step { font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(157,184,204,.25); opacity: .65; }
    .apv-step.done { border-color: rgba(34,197,94,.5); color: #4ade80; opacity: 1; }
    .apv-step.current { border-color: rgba(18,217,227,.6); color: #12D9E3; opacity: 1; box-shadow: 0 0 0 1px rgba(18,217,227,.25); }
    .apv-step.rejected { border-color: rgba(248,113,113,.6); color: #f87171; opacity: 1; }
    .apv-template { font-size: 11px; opacity: .7; display: block; margin-top: 2px; }
    .apv-diff { display: flex; flex-direction: column; gap: 3px; text-align: start; }
    .apv-diff-row { font-size: 11px; font-weight: 700; }
    .apv-diff-row b { color: #12D9E3; }
    .apv-diff-old { color: #f87171; text-decoration: line-through; opacity: .8; }
    .apv-diff-new { color: #4ade80; }
</style>

<div class="hrms-page">
    <div class="page-header">
        <div>
            <h1>الموافقات</h1>
            <p>لجان الموافقة تُبنى من «قوالب الموافقات» — الموافقة تقدّم الخطوة التالية حتى الاعتماد النهائي.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="hrms-alert @(Model.MessageIsError ? "danger" : "success")">@Model.Message</div>
    }

    <form method="get" class="hrms-filter-card">
        <div class="hrms-grid-3">
            <div class="hrms-field">
                <label>الحالة</label>
                <select asp-for="Status">
                    <option value="Pending">قيد الموافقة</option>
                    <option value="Approved">معتمدة</option>
                    <option value="Rejected">مرفوضة</option>
                    <option value="All">الكل</option>
                </select>
            </div>

            <div class="hrms-actions" style="align-self:end;">
                <button class="hrms-btn-primary">تطبيق</button>
            </div>
        </div>
    </form>

    <div class="hrms-table-card">
        <div class="hrms-table-wrap">
            <table class="hrms-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>رقم الموظف</th>
                        <th class="text-start">الاسم</th>
                        <th>نوع الطلب</th>
                        <th>الفترة</th>
                        <th>الحالة</th>
                        <th class="text-start">لجنة الموافقة</th>
                        <th>السبب</th>
                        <th>قرار الخطوة الحالية</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.Requests)
                    {
                        Model.Flows.TryGetValue(request.Id, out var flow);
                        <tr>
                            <td>@request.Id</td>
                            <td>@request.EmployeeNo</td>
                            <td class="text-start">@request.EmployeeName</td>
                            <td>@request.RequestType</td>
                            <td>
                                @if (Model.DataChanges.TryGetValue(request.Id, out var diffs))
                                {
                                    <div class="apv-diff">
                                        @foreach (var d in diffs)
                                        {
                                            <div class="apv-diff-row">
                                                <b>@d.Label:</b>
                                                <span class="apv-diff-old">@(string.IsNullOrWhiteSpace(d.OldValue) ? "—" : d.OldValue)</span>
                                                →
                                                <span class="apv-diff-new">@(string.IsNullOrWhiteSpace(d.NewValue) ? "—" : d.NewValue)</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    @(request.FromDate?.ToString("yyyy-MM-dd"))<text> - </text>@(request.ToDate?.ToString("yyyy-MM-dd"))
                                }
                            </td>
                            <td><span class="hrms-badge @request.Status.ToLower()">@request.Status</span></td>
                            <td class="text-start">
                                @if (flow != null)
                                {
                                    <span class="apv-chain">
                                        @foreach (var step in flow.Steps)
                                        {
                                            var css = step.Status switch
                                            {
                                                "Approved" => "done",
                                                "Current" => "current",
                                                "Rejected" => "rejected",
                                                _ => ""
                                            };
                                            <span class="apv-step @css">@step.DisplayName</span>
                                        }
                                    </span>
                                    <span class="apv-template">قالب: @flow.TemplateName</span>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td class="text-start">@request.Reason</td>
                            <td>
                                @if (request.Status == "Pending" && flow?.Current != null)
                                {
                                    <form method="post" class="hrms-actions" style="justify-content:center;">
                                        <input asp-for="Note" placeholder="ملاحظة@(flow.CommentRequiredOnReject ? " (إلزامية عند الرفض)" : "")" style="min-height:34px;border-radius:10px;border:1px solid var(--sa-border);background:var(--sa-input);color:var(--sa-text);" />
                                        <button asp-page-handler="Approve" asp-route-id="@request.Id" class="hrms-btn-success">موافقة</button>
                                        <button asp-page-handler="Reject" asp-route-id="@request.Id" class="hrms-btn-danger">رفض</button>
                                    </form>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }

                    @if (!Model.Requests.Any())
                    {
                        <tr>
                            <td colspan="9" class="hrms-empty">لا توجد طلبات حسب الفلاتر.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

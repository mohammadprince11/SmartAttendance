@page "{id:int}"
@model SmartAttendance.Web.Pages.Companies.DeleteModel
@{
    ViewData["Title"] = "Delete Company";
}

<div class="delete-page">
    <div class="delete-card">
        <div class="delete-icon">!</div>

        <h1>Delete Company</h1>

        <p class="delete-message">
            Are you sure you want to delete this company?
            <br />
            This action will hide the company from the system.
        </p>

        <div class="delete-details">
            <div>
                <span>Code</span>
                <strong>@Model.Company.Code</strong>
            </div>

            <div>
                <span>Company Name</span>
                <strong>@Model.Company.Name</strong>
            </div>

            <div>
                <span>Email</span>
                <strong>@Model.Company.Email</strong>
            </div>

            <div>
                <span>Phone</span>
                <strong>@Model.Company.Phone</strong>
            </div>
        </div>

        <form method="post" class="delete-actions">
            <input type="hidden" asp-for="Company.Id" />

            <a asp-page="/Companies/Index" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-danger">Delete Company</button>
        </form>
    </div>
</div>
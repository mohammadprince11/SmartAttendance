@page
@model SmartAttendance.Web.Pages.Companies.CreateModel

@{
    ViewData["Title"] = "إضافة شركة";
}

<div class="nexora-setup-page nx-setup-form-page">
    <section class="nexora-setup-hero">
        <div>
            <span class="nexora-setup-kicker">إعداد الشركة</span>
            <h1>إضافة شركة</h1>
            <p>هذه الصفحة احتياطية، ويمكنك الإضافة مباشرة من النافذة المنبثقة في صفحة الشركات.</p>
        </div>
        <a asp-page="./Index" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">الرجوع للقائمة</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-danger nx-setup-alert-danger">@Model.ErrorMessage</div>
    }

    <section class="nexora-setup-card">
        <form method="post" class="nx-setup-modal-form">
            <div class="nx-setup-form-grid">
                <label class="nx-setup-field">
                    <span>اسم الشركة</span>
                    <input asp-for="Company.Name" placeholder="مثال: نيكسورا" />
                    <span asp-validation-for="Company.Name" class="text-danger"></span>
                </label>

                <label class="nx-setup-field">
                    <span>البريد الإلكتروني</span>
                    <input asp-for="Company.Email" placeholder="company@example.com" />
                    <span asp-validation-for="Company.Email" class="text-danger"></span>
                </label>

                <label class="nx-setup-field">
                    <span>رقم الهاتف</span>
                    <input asp-for="Company.Phone" placeholder="07xx xxx xxxx" />
                    <span asp-validation-for="Company.Phone" class="text-danger"></span>
                </label>
            </div>

            <div class="nx-setup-modal__actions">
                <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">إلغاء</a>
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">حفظ الشركة</button>
            </div>
        </form>
    </section>
</div>

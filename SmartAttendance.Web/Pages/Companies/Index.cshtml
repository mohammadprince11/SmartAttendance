@page
@model SmartAttendance.Web.Pages.Companies.IndexModel

@{
    ViewData["Title"] = "Companies";
}

<div class="page-header">
    <div>
        <h1>Companies</h1>
        <p>Manage companies</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">Import Excel</a>
        <a asp-page="./Create" class="btn-primary">+ Add Company</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="Search by company name or code..." />

        <button type="submit" class="btn-primary">Search</button>
        <a asp-page="./Index" class="btn-secondary">Clear</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Company Name</th>
                <th>Active</th>
                <th style="width: 160px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Companies.Any())
            {
                foreach (var company in Model.Companies)
                {
                    <tr>
                        <td>@company.Code</td>
                        <td>@company.Name</td>
                        <td>@(company.IsActive ? "Yes" : "No")</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@company.Id" class="btn-table btn-edit">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@company.Id" class="btn-table btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" style="text-align:center;">No companies found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@page
@model SmartAttendance.Web.Pages.Companies.IndexModel

@{
    ViewData["Title"] = "إعداد الشركة";
}

<div class="nexora-setup-page" data-setup-page="companies">
    <section class="nexora-setup-hero">
        <div>
            <span class="nexora-setup-kicker">الخطوة الأولى</span>
            <h1>إعداد الشركة</h1>
            <p>ابدأ بتسجيل بيانات الشركة الأساسية قبل إنشاء الفروع والأقسام والموظفين.</p>
        </div>

        <div class="nexora-setup-actions">
            <a asp-page="./Import" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">استيراد Excel</a>
            <button type="button" class="btn-primary nx-setup-btn nx-setup-btn-primary" data-nx-setup-open="company-create-modal">+ إضافة شركة</button>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success nx-setup-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    <section class="table-card nexora-setup-card">
        <div class="nexora-setup-card-head">
            <div>
                <span>سجل الشركات</span>
                <strong>الشركات المعرفة داخل النظام</strong>
            </div>
            <small>هذه البيانات تعتبر الأساس لباقي صفحات التهيئة.</small>
        </div>

        <form method="get" class="search-form nexora-setup-search">
            <input type="search"
                   name="SearchTerm"
                   value="@Model.SearchTerm"
                   placeholder="ابحث عن اسم الشركة أو الكود..." />

            <button type="submit" class="btn-primary nx-setup-btn nx-setup-btn-primary">بحث</button>
            <a asp-page="./Index" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">مسح</a>
        </form>

        <div class="nexora-setup-table-wrap">
            <table class="data-table nexora-setup-table">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>اسم الشركة</th>
                        <th>الحالة</th>
                        <th style="width: 170px;">الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Companies.Any())
                    {
                        foreach (var company in Model.Companies)
                        {
                            <tr>
                                <td>
                                    <span class="nx-setup-code">@company.Code</span>
                                </td>
                                <td>
                                    <strong class="nx-setup-title">@company.Name</strong>
                                </td>
                                <td>
                                    <span class="nx-setup-status @(company.IsActive ? "is-active" : "is-inactive")">
                                        @(company.IsActive ? "فعال" : "غير فعال")
                                    </span>
                                </td>
                                <td>
                                    <div class="nx-setup-row-actions">
                                        <a asp-page="./Edit" asp-route-id="@company.Id" class="btn-table btn-edit">تعديل</a>
                                        <a asp-page="./Delete" asp-route-id="@company.Id" class="btn-table btn-delete">حذف</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="nx-setup-empty">لا توجد شركات مسجلة حالياً.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<div class="nx-setup-modal" id="company-create-modal" aria-hidden="true">
    <div class="nx-setup-modal__panel" role="dialog" aria-modal="true" aria-labelledby="company-create-title">
        <button type="button" class="nx-setup-modal__close" data-nx-setup-close aria-label="إغلاق">×</button>

        <div class="nx-setup-modal__head">
            <span>إعداد الشركة</span>
            <h2 id="company-create-title">إضافة شركة جديدة</h2>
            <p>أدخل بيانات الشركة الأساسية ليتم استخدامها في باقي خطوات التهيئة.</p>
        </div>

        <form method="post" asp-page="./Create" class="nx-setup-modal-form">
            <div class="nx-setup-form-grid">
                <label class="nx-setup-field">
                    <span>كود الشركة</span>
                    <input name="Company.Code" autocomplete="off" placeholder="مثال: HQ" required />
                </label>

                <label class="nx-setup-field">
                    <span>اسم الشركة</span>
                    <input name="Company.Name" autocomplete="off" placeholder="مثال: شركة الرغد" required />
                </label>

                <label class="nx-setup-field">
                    <span>البريد الإلكتروني</span>
                    <input name="Company.Email" type="email" autocomplete="off" placeholder="company@example.com" />
                </label>

                <label class="nx-setup-field">
                    <span>رقم الهاتف</span>
                    <input name="Company.Phone" autocomplete="off" placeholder="07xx xxx xxxx" />
                </label>
            </div>

            <div class="nx-setup-modal__actions">
                <button type="button" class="nx-setup-btn nx-setup-btn-secondary" data-nx-setup-close>إلغاء</button>
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">حفظ الشركة</button>
            </div>
        </form>
    </div>
</div>

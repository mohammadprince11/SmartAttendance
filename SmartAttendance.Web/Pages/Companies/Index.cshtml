@page "/Companies"
@model SmartAttendance.Web.Pages.Companies.IndexModel
@{
    ViewData["Title"] = "Companies";
}

<div class="page-header">
    <div>
        <h1>Companies</h1>
        <p>Manage all companies in the system</p>
    </div>

    <a asp-page="/Companies/Create" class="btn-primary">+ Add Company</a>
</div>

<form method="get" class="search-box">
    <input type="text"
           name="SearchTerm"
           value="@Model.SearchTerm"
           placeholder="Search by name or code..."
           class="form-control" />

    <button type="submit" class="btn-primary">Search</button>

    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <a asp-page="/Companies/Index" class="btn-secondary">Clear</a>
    }
</form>

<div class="table-card">
    <div class="table-card-header">
        <h2>Companies List</h2>
    </div>

    <div class="table-wrapper">
        <table class="app-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Company Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Companies.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-row">No companies found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var company in Model.Companies)
                    {
                        <tr>
                            <td>@company.Code</td>
                            <td>@company.Name</td>
                            <td>@company.Email</td>
                            <td>@company.Phone</td>
                            <td>
                                @if (company.IsActive)
                                {
                                    <span class="badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge-muted">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/Companies/Edit" asp-route-id="@company.Id" class="btn-table btn-edit">Edit</a>
                                <a asp-page="/Companies/Delete" asp-route-id="@company.Id" class="btn-table btn-delete">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

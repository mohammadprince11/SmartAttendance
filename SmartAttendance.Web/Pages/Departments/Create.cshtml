@page
@model SmartAttendance.Web.Pages.Departments.CreateModel

@{
    ViewData["Title"] = "إضافة قسم";
}

<div class="nexora-setup-page nx-setup-form-page">
    <section class="nexora-setup-hero">
        <div>
            <span class="nexora-setup-kicker">الأقسام</span>
            <h1>إضافة قسم</h1>
            <p>هذه الصفحة احتياطية، ويمكنك الإضافة مباشرة من النافذة المنبثقة في صفحة الأقسام.</p>
        </div>
        <a asp-page="./Index" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">الرجوع للقائمة</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-danger nx-setup-alert-danger">@Model.ErrorMessage</div>
    }

    <section class="nexora-setup-card">
        <form method="post" class="nx-setup-modal-form">
            <div class="nx-setup-form-grid">
                <label class="nx-setup-field">
                    <span>موقع العمل</span>
                    <select asp-for="Department.BranchId">
                        <option value="">اختر موقع العمل</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.Id">@branch.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Department.BranchId" class="text-danger"></span>
                </label>

                <label class="nx-setup-field">
                    <span>كود القسم</span>
                    <input asp-for="Department.Code" placeholder="مثال: HR" />
                    <span asp-validation-for="Department.Code" class="text-danger"></span>
                </label>

                <label class="nx-setup-field nx-setup-field-wide">
                    <span>اسم القسم</span>
                    <input asp-for="Department.Name" placeholder="مثال: الموارد البشرية" />
                    <span asp-validation-for="Department.Name" class="text-danger"></span>
                </label>
            </div>

            <div class="nx-setup-modal__actions">
                <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">إلغاء</a>
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">حفظ القسم</button>
            </div>
        </form>
    </section>
</div>

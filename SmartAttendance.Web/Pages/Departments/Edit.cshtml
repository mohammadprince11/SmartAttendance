@page
@model SmartAttendance.Web.Pages.Departments.EditModel

@{
    ViewData["Title"] = "Edit Department";
}

<div class="nexora-setup-page nx-setup-form-page">
    <section class="nexora-setup-hero">
        <div>
            <span class="nexora-setup-kicker">&#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645;</span>
            <h1>&#x062A;&#x0639;&#x062F;&#x064A;&#x0644; &#x0642;&#x0633;&#x0645;</h1>
            <p>&#x062A;&#x062D;&#x062F;&#x064A;&#x062B; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645; &#x0627;&#x0644;&#x0645;&#x0633;&#x062A;&#x0642;&#x0644;.</p>
        </div>
        <a asp-page="./Index" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">&#x0627;&#x0644;&#x0631;&#x062C;&#x0648;&#x0639;</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-danger nx-setup-alert-danger">@Model.ErrorMessage</div>
    }

    <section class="nexora-setup-card">
        <form method="post" class="nx-setup-modal-form">
            <input type="hidden" asp-for="Department.Id" />

            <div class="nx-setup-form-grid">
                <label class="nx-setup-field nx-setup-field-wide">
                    <span>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</span>
                    <input asp-for="Department.Name" />
                    <span asp-validation-for="Department.Name" class="text-danger"></span>
                </label>

                <label class="nx-setup-check">
                    <input asp-for="Department.IsActive" />
                    <span>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645; &#x0641;&#x0639;&#x0627;&#x0644;</span>
                </label>
            </div>

            <div class="nx-setup-modal__actions">
                <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">&#x0625;&#x0644;&#x063A;&#x0627;&#x0621;</a>
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">&#x062D;&#x0641;&#x0638;</button>
            </div>
        </form>
    </section>
</div>
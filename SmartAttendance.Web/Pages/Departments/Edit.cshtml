@page
@model SmartAttendance.Web.Pages.Departments.EditModel

@{
    ViewData["Title"] = "Edit Department";
}

<div class="page-header">
    <div>
        <h1>Edit Department</h1>
        <p>Update department information</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <input type="hidden" asp-for="Department.Id" />

        <div class="form-group">
            <label asp-for="Department.BranchId">Branch</label>
            <select asp-for="Department.BranchId" class="form-control">
                <option value="">-- Select Branch --</option>

                @foreach (var branch in Model.Branches)
                {
                    <option value="@branch.Id">@branch.Name</option>
                }
            </select>
            <span asp-validation-for="Department.BranchId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Department.Code">Department Code</label>
            <input asp-for="Department.Code" class="form-control" />
            <span asp-validation-for="Department.Code" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Department.Name">Department Name</label>
            <input asp-for="Department.Name" class="form-control" />
            <span asp-validation-for="Department.Name" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="Department.IsActive" />
                Active
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Update</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
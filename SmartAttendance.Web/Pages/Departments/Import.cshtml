@page
@model SmartAttendance.Web.Pages.Departments.ImportModel

@{
    ViewData["Title"] = "استيراد الأقسام";
}

<div class="nexora-import-page" data-import-page="departments">
    <section class="nexora-import-hero">
        <div>
            <span class="nexora-setup-kicker">استيراد البيانات</span>
            <h1>استيراد الأقسام</h1>
            <p>ارفع الأقسام وربطها بمواقع العمل حتى تصبح جاهزة للمناصب والموظفين.</p>
        </div>

        <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">العودة إلى الأقسام</a>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="nx-setup-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nexora-import-alert is-error">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.ImportResult != null)
    {
        <section class="nexora-import-card">
            <div class="nexora-import-card-head">
                <div>
                    <span>نتيجة الاستيراد</span>
                    <strong>ملخص العملية بعد الحفظ</strong>
                </div>
            </div>

            <div class="nexora-import-summary">
                <div class="nexora-import-summary-card">
                    <span>تمت الإضافة</span>
                    <strong>@Model.ImportResult.CreatedCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>تم التحديث</span>
                    <strong>@Model.ImportResult.UpdatedCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>تم التخطي</span>
                    <strong>@Model.ImportResult.SkippedCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>الأخطاء</span>
                    <strong>@Model.ImportResult.ErrorCount</strong>
                </div>
            </div>
        </section>
    }

    <section class="nexora-import-card">
        <div class="nexora-import-card-head">
            <div>
                <span>مصدر البيانات</span>
                <strong>اختر ملف Excel أو الصق البيانات مباشرة</strong>
            </div>
            <small>استخدم نفس أسماء الأعمدة المطلوبة حتى تتم قراءة الملف بشكل صحيح.</small>
        </div>

        <form method="post" enctype="multipart/form-data" asp-page-handler="Preview">
            <div class="nexora-import-two">
                <div class="nexora-import-box">
                    <div class="nexora-import-box-title">
                        <span class="nexora-import-step">1</span>
                        رفع ملف Excel / CSV
                    </div>

                    <p class="nexora-import-help">
                        اختر ملفاً جاهزاً بصيغة .xlsx أو .csv يحتوي على أعمدة الأقسام.
                    </p>

                    <input asp-for="ImportFile" type="file" accept=".xlsx,.csv" class="nexora-import-file" />

                    <div class="nexora-import-note">
                        إذا قمت برفع ملف ولصق بيانات في نفس الوقت، سيتم اعتماد الملف المرفوع.
                    </div>
                </div>

                <div class="nexora-import-box">
                    <div class="nexora-import-box-title">
                        <span class="nexora-import-step">2</span>
                        لصق من Excel
                    </div>

                    <p class="nexora-import-help">
                        حدد الصفوف من Excel ثم اضغط Ctrl + C، وبعدها الصقها هنا باستخدام Ctrl + V.
                    </p>

                    <textarea asp-for="PastedData"
                              class="nexora-import-paste"
                              placeholder="Code    Name    BranchCode&#10;HR    الموارد البشرية    HQ"></textarea>
                </div>
            </div>

            <div class="nexora-import-required">
                <div>
                    <span>الأعمدة المطلوبة</span>
                    <strong>يجب أن يحتوي الملف على هذه الأعمدة</strong>
                </div>

                <div class="nexora-import-badges">
                    @foreach (var column in Model.RequiredColumns)
                    {
                        <span class="nexora-import-badge">@column</span>
                    }
                </div>
            </div>

            <div class="nexora-import-actions">
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">معاينة البيانات</button>
                <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">إلغاء</a>
            </div>
        </form>
    </section>

    @if (Model.Preview != null)
    {
        <section class="nexora-import-card">
            <div class="nexora-import-card-head">
                <div>
                    <span>معاينة البيانات</span>
                    <strong>@Model.Preview.FileName</strong>
                </div>
                <small>يتم عرض أول @Model.Preview.PreviewLimit صف فقط، لكن الاستيراد سيعالج كل الصفوف الصالحة.</small>
            </div>

            <div class="nexora-import-summary">
                <div class="nexora-import-summary-card">
                    <span>إجمالي الصفوف</span>
                    <strong>@Model.Preview.TotalRows</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>جاهزة</span>
                    <strong>@Model.Preview.ReadyCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>إضافة</span>
                    <strong>@Model.Preview.CreateCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>تحديث</span>
                    <strong>@Model.Preview.UpdateCount</strong>
                </div>

                <div class="nexora-import-summary-card">
                    <span>أخطاء</span>
                    <strong>@Model.Preview.ErrorCount</strong>
                </div>
            </div>

            @if (Model.Preview.ReadyCount > 0)
            {
                <form method="post" asp-page-handler="Import" class="nexora-import-confirm">
                    <input type="hidden" name="token" value="@Model.Preview.Token" />
                    <button type="submit" class="nx-setup-btn nx-setup-btn-primary">استيراد الصفوف الصالحة</button>
                </form>
            }
        </section>

        <section class="table-card nexora-setup-card">
            <div class="nexora-setup-card-head">
                <div>
                    <span>تفاصيل المعاينة</span>
                    <strong>حالة كل صف قبل الاستيراد</strong>
                </div>
            </div>

            <div class="nexora-setup-table-wrap">
                <table class="data-table nexora-setup-table">
                    <thead>
                        <tr>
                            <th>الصف</th>
                            <th>الحالة</th>
                            <th>الإجراء</th>
                            <th>المفتاح</th>
                            <th>الرسالة</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Preview.Rows.Any())
                        {
                            foreach (var row in Model.Preview.Rows)
                            {
                                var statusClass = row.Status == "Ready" ? "status-ready" : "status-error";
                                var statusText = row.Status == "Ready" ? "جاهز" : "خطأ";
                                var actionText = row.Action == "Create"
                                    ? "إضافة"
                                    : row.Action == "Update"
                                        ? "تحديث"
                                        : row.Action == "Skip"
                                            ? "تخطي"
                                            : row.Action;

                                <tr>
                                    <td>@row.RowNumber</td>
                                    <td class="@statusClass">@statusText</td>
                                    <td>@actionText</td>
                                    <td>@row.Key</td>
                                    <td>@row.Message</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="nx-setup-empty">لا توجد صفوف للمعاينة.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

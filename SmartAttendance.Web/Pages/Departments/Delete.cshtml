@page
@model SmartAttendance.Web.Pages.Departments.DeleteModel

@{
    ViewData["Title"] = "Delete Department";
}

<div class="page-header">
    <div>
        <h1>Delete Department</h1>
        <p>Confirm department deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this department?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Branch</label>
            <div class="form-control">@Model.Department.BranchName</div>
        </div>

        <div class="form-group">
            <label>Department Code</label>
            <div class="form-control">@Model.Department.Code</div>
        </div>

        <div class="form-group">
            <label>Department Name</label>
            <div class="form-control">@Model.Department.Name</div>
        </div>

        <div class="form-group">
            <label>Status</label>
            <div class="form-control">
                @(Model.Department.IsActive ? "Active" : "Inactive")
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Department.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@page
@model SmartAttendance.Web.Pages.LeaveRequests.DeleteModel

@{
    ViewData["Title"] = "حذف طلب إجازة";
}

<div class="page-header">
    <div>
        <h1>حذف طلب إجازة</h1>
        <p>تأكيد حذف طلب الإجازة</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this leave request?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>رقم الموظف</label>
            <div class="form-control">@Model.LeaveRequest.EmployeeNo</div>
        </div>

        <div class="form-group">
            <label>اسم الموظف</label>
            <div class="form-control">@Model.LeaveRequest.EmployeeName</div>
        </div>

        <div class="form-group">
            <label>نوع الإجازة</label>
            <div class="form-control">@Model.LeaveRequest.LeaveType</div>
        </div>

        <div class="form-group">
            <label>الحالة</label>
            <div class="form-control">@Model.LeaveRequest.Status</div>
        </div>

        <div class="form-group">
            <label>من تاريخ</label>
            <div class="form-control">@Model.LeaveRequest.FromDate</div>
        </div>

        <div class="form-group">
            <label>إلى تاريخ</label>
            <div class="form-control">@Model.LeaveRequest.ToDate</div>
        </div>

        <div class="form-group">
            <label>إجمالي الأيام</label>
            <div class="form-control">@Model.LeaveRequest.TotalDays</div>
        </div>

        <div class="form-group">
            <label>السبب</label>
            <div class="form-control">@Model.LeaveRequest.Reason</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.LeaveRequest.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

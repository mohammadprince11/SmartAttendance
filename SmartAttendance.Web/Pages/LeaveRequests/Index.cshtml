@page
@model SmartAttendance.Web.Pages.LeaveRequests.IndexModel

@{
    ViewData["Title"] = "طلبات الإجازات";
}

<div class="page-header">
    <div>
        <h1>طلبات الإجازات</h1>
        <p>إدارة إجازات الموظفين المعتمدة</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">استيراد إكسل</a>
        <a asp-page="./Create" class="btn-primary">+ إضافة إجازة</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث بالموظف أو نوع الإجازة أو الحالة أو السبب..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>رقم الموظف</th>
                <th>اسم الموظف</th>
                <th>نوع الإجازة</th>
                <th>الحالة</th>
                <th>من</th>
                <th>إلى</th>
                <th>إجمالي الأيام</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.LeaveRequests.Any())
            {
                foreach (var leave in Model.LeaveRequests)
                {
                    <tr>
                        <td>@leave.EmployeeNo</td>
                        <td>@leave.EmployeeName</td>
                        <td>@leave.LeaveType</td>
                        <td>@leave.Status</td>
                        <td>@leave.FromDate</td>
                        <td>@leave.ToDate</td>
                        <td>@leave.TotalDays</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@leave.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@leave.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="text-align:center;">لا توجد طلبات إجازات.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

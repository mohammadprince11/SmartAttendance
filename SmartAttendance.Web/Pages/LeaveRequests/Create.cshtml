@page
@model SmartAttendance.Web.Pages.LeaveRequests.CreateModel

@{
    ViewData["Title"] = "Add Approved Leave";
}

<div class="page-header">
    <div>
        <h1>Add Approved Leave</h1>
        <p>Register an approved employee leave directly</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label asp-for="LeaveRequest.EmployeeId">Employee</label>
            <select asp-for="LeaveRequest.EmployeeId" class="form-control">
                <option value="">-- Select Employee --</option>

                @foreach (var employee in Model.Employees)
                {
                    <option value="@employee.Id">@employee.EmployeeNo - @employee.FullName</option>
                }
            </select>
            <span asp-validation-for="LeaveRequest.EmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LeaveRequest.LeaveType">Leave Type</label>
            <select asp-for="LeaveRequest.LeaveType" asp-items="Model.LeaveTypes" class="form-control"></select>
            <span asp-validation-for="LeaveRequest.LeaveType" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LeaveRequest.FromDate">From Date</label>
            <input asp-for="LeaveRequest.FromDate" type="date" class="form-control" />
            <span asp-validation-for="LeaveRequest.FromDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LeaveRequest.ToDate">To Date</label>
            <input asp-for="LeaveRequest.ToDate" type="date" class="form-control" />
            <span asp-validation-for="LeaveRequest.ToDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LeaveRequest.Reason">Reason</label>
            <input asp-for="LeaveRequest.Reason" class="form-control" />
            <span asp-validation-for="LeaveRequest.Reason" class="text-danger"></span>
        </div>

        <div class="alert-success">
            Status will be saved automatically as Approved.
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

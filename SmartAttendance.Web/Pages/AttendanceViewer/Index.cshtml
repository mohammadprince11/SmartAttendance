@page "/AttendanceViewer"
@model SmartAttendance.Web.Pages.AttendanceViewer.IndexModel
@using SmartAttendance.Web.Infrastructure.Hrms

@*
    مستعرض الحضور (نمط كيان): مصفوفة موظف × أيام الشهر بـ8 حالات ملونة + شرائح
    فلترة قابلة للتبديل + رؤوس أيام بأسماء الأسبوع + بطاقة موظف + عمود المجموع.
*@

@{
    ViewData["Title"] = "مستعرض الحضور";
    var (year, month) = Model.MonthPair;
    var statusKeys = new (string Key, string Label, string Color)[]
    {
        ("Present", "حاضر", "#4ade80"),
        ("Late", "متأخر", "#facc15"),
        ("Incomplete", "بصمة ناقصة", "#f97316"),
        ("Absent", "غائب", "#f87171"),
        ("Weekend", "عطلة أسبوعية", "#60a5fa"),
        ("Rest", "يوم راحة", "#8FA8BC"),
        ("Holiday", "عطلة رسمية", "#a78bfa"),
        ("Leave", "إجازة", "#12D9E3")
    };
    var colorMap = statusKeys.ToDictionary(s => s.Key, s => s.Color);
    var dayShort = new[] { "سبت", "أحد", "إثن", "ثلا", "أرب", "خمي", "جمع" };
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .avw-page { display: flex; flex-direction: column; gap: 14px; color: var(--sa-text, #DCEAF4); }
    .avw-head {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
        padding: 16px 20px; border: 1px solid rgba(73,111,151,.22); border-radius: 20px;
        background: radial-gradient(circle at 90% 10%, rgba(18,217,227,.12), transparent 36%),
                    linear-gradient(135deg, rgba(9,31,52,.95), rgba(5,16,29,.95));
    }
    html[data-theme="light"] .avw-head { background: linear-gradient(135deg, #fff, #f2f7fb); }
    .avw-head h1 { margin: 0; font-size: 20px; font-weight: 1000; }
    .avw-head p { margin: 2px 0 0; font-size: 12px; color: var(--sa-muted, #8FA8BC); font-weight: 800; }
    .avw-btn { min-height: 38px; padding: 8px 18px; border-radius: 12px; border: 0; font-size: 13px; font-weight: 900; cursor: pointer; background: linear-gradient(135deg, #12D9E3, #0ea5b5); color: #04141d; }
    .avw-btn.ghost { background: transparent; border: 1px solid rgba(73,111,151,.3); color: inherit; }

    .avw-bar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding: 10px 14px; border: 1px solid rgba(73,111,151,.22); border-radius: 16px; background: var(--sa-surface, rgba(8,25,43,.9)); }
    .avw-bar input { min-height: 36px; border-radius: 10px; border: 1px solid rgba(73,111,151,.25); background: rgba(0,0,0,.16); color: var(--sa-text, #DCEAF4); padding: 6px 10px; font-size: 13px; }
    html[data-theme="light"] .avw-bar input { background: #fff; color: inherit; }

    /* شرائح فلترة الحالات (قابلة للتبديل) */
    .avw-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .avw-chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 900; cursor: pointer; border: 1px solid transparent; user-select: none; transition: opacity .15s; }
    .avw-chip i { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
    .avw-chip.off { opacity: .38; filter: grayscale(.6); }
    .avw-chip .cnt { direction: ltr; font-size: 11px; opacity: .85; }

    .avw-matrix-card { border: 1px solid rgba(73,111,151,.22); border-radius: 18px; overflow: auto; background: var(--sa-surface, rgba(8,25,43,.9)); max-height: 68vh; }
    .avw-matrix { border-collapse: separate; border-spacing: 0; font-size: 11px; }
    .avw-matrix th { padding: 6px 6px; font-size: 10px; font-weight: 1000; color: var(--sa-muted, #8FA8BC); border-bottom: 1px solid rgba(73,111,151,.22); background: #0a1f33; text-align: center; position: sticky; top: 0; z-index: 3; }
    html[data-theme="light"] .avw-matrix th { background: #eef4f9; }
    .avw-matrix th.dcol .dn { font-size: 9px; opacity: .75; font-weight: 800; }
    .avw-matrix th.dcol.fri, .avw-matrix td.fri { color: #f87171; background: rgba(248,113,113,.06); }
    .avw-matrix th.emp, .avw-matrix td.emp { text-align: start; min-width: 210px; position: sticky; inset-inline-start: 0; background: var(--sa-surface, #0b2135); z-index: 2; padding: 5px 10px; }
    .avw-matrix thead th.emp { z-index: 4; }
    html[data-theme="light"] .avw-matrix th.emp, html[data-theme="light"] .avw-matrix td.emp { background: #fff; }
    .avw-matrix td { padding: 3px; border-bottom: 1px solid rgba(143,168,188,.06); border-inline-start: 1px solid rgba(143,168,188,.05); text-align: center; }
    .avw-emp { display: flex; align-items: center; gap: 8px; }
    .avw-badge { width: 30px; height: 30px; border-radius: 9px; display: inline-flex; align-items: center; justify-content: center; font-weight: 1000; font-size: 11px; color: #04141d; flex: none; }
    .avw-emp .nm { font-weight: 900; line-height: 1.15; }
    .avw-emp .sub { font-size: 10px; color: var(--sa-muted, #8FA8BC); font-weight: 800; }
    .avw-cell { width: 20px; height: 20px; border-radius: 50%; display: inline-block; opacity: .95; transition: opacity .15s; }
    .avw-cell.empty { background: rgba(143,168,188,.12); }
    .avw-cell.dim { opacity: .08; }
    .avw-total { font-weight: 1000; color: #12D9E3; direction: ltr; white-space: nowrap; }
    .avw-empty { padding: 28px; text-align: center; color: var(--sa-muted, #8FA8BC); font-weight: 800; }
    .avw-pager { display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 12px; font-weight: 900; }
</style>

<section class="avw-page" dir="rtl">
    <header class="avw-head">
        <div>
            <h1>مستعرض الحضور</h1>
            <p>مصفوفة موظف × أيام الشهر بـ8 حالات ملونة — انقر الشرائح لتصفية الحالات المعروضة.</p>
        </div>
    </header>

    <form method="get" class="avw-bar">
        <input type="month" name="Month" value="@Model.Month" onchange="this.form.submit()" />
        <input type="text" name="Search" value="@Model.Search" placeholder="بحث رمز/اسم..." />
        <button type="submit" class="avw-btn ghost">عرض</button>
    </form>

    <div class="avw-bar avw-chips" id="avw-chips">
        @foreach (var (key, label, color) in statusKeys)
        {
            <span class="avw-chip" data-status="@key" style="background:@(color)22;color:@color" onclick="avwToggle(this)">
                <i style="background:@color"></i>@label <span class="cnt" data-cnt="@key">0</span>
            </span>
        }
    </div>

    <div class="avw-matrix-card">
        @if (Model.Rows.Count == 0)
        {
            <div class="avw-empty">لا يوميات لهذا الشهر — شغّل «تحديث الحضور» من شاشة الحضور اليومي.</div>
        }
        else
        {
            <table class="avw-matrix">
                <thead>
                    <tr>
                        <th class="emp">الموظف</th>
                        @for (var day = 1; day <= Model.DaysInMonth; day++)
                        {
                            var date = new DateOnly(year, month, day);
                            var dow = DayAttendanceStore.ToDayIndex(date);
                            var isFri = date.DayOfWeek == DayOfWeek.Friday;
                            <th class="dcol @(isFri ? "fri" : "")">@day<div class="dn">@dayShort[dow]</div></th>
                        }
                        <th>المجموع</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td class="emp">
                                <div class="avw-emp">
                                    <span class="avw-badge" style="background:@row.BadgeColor">@row.Initials</span>
                                    <div>
                                        <div class="nm">@row.EmployeeName</div>
                                        <div class="sub" style="direction:ltr">@row.EmployeeNo@(string.IsNullOrWhiteSpace(row.Position) ? "" : $" · {row.Position}")</div>
                                    </div>
                                </div>
                            </td>
                            @for (var day = 1; day <= Model.DaysInMonth; day++)
                            {
                                var date = new DateOnly(year, month, day);
                                var isFri = date.DayOfWeek == DayOfWeek.Friday;
                                @if (row.Days.TryGetValue(day, out var cell))
                                {
                                    var color = colorMap.TryGetValue(cell.Status, out var c) ? c : "#8FA8BC";
                                    var tip = $"{cell.WorkDate:yyyy-MM-dd} — {DayAttendanceStore.StatusLabel(cell.Status)}"
                                        + (cell.CheckIn != null ? $" · دخول {cell.CheckIn:HH:mm}" : "")
                                        + (cell.CheckOut != null ? $" · خروج {cell.CheckOut:HH:mm}" : "")
                                        + (cell.LateHours > 0 ? $" · تأخير {cell.LateHours:0.##}س" : "");
                                    <td class="@(isFri ? "fri" : "")"><span class="avw-cell" data-status="@cell.Status" style="background:@color" title="@tip"></span></td>
                                }
                                else
                                {
                                    <td class="@(isFri ? "fri" : "")"><span class="avw-cell empty" title="لم يُحلل"></span></td>
                                }
                            }
                            <td class="avw-total">@row.PresentDays/@row.WorkDays</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="avw-pager">
            @if (Model.PageNumber > 1)
            {
                <a class="avw-btn ghost" href="?Month=@Model.Month&Search=@Model.Search&PageNumber=@(Model.PageNumber - 1)">السابق</a>
            }
            <span>صفحة @Model.PageNumber من @Model.TotalPages (@Model.TotalRows موظف)</span>
            @if (Model.PageNumber < Model.TotalPages)
            {
                <a class="avw-btn ghost" href="?Month=@Model.Month&Search=@Model.Search&PageNumber=@(Model.PageNumber + 1)">التالي</a>
            }
        </div>
    }
</section>

@section Scripts {
    <script>
        // عدّ كل حالة + تصفية بالنقر على الشريحة (إخفاء/تعتيم خلايا الحالة)
        var avwHidden = new Set();

        function avwCounts() {
            var counts = {};
            document.querySelectorAll('.avw-cell[data-status]').forEach(function (el) {
                var s = el.getAttribute('data-status');
                counts[s] = (counts[s] || 0) + 1;
            });
            document.querySelectorAll('[data-cnt]').forEach(function (el) {
                el.textContent = counts[el.getAttribute('data-cnt')] || 0;
            });
        }
        function avwToggle(chip) {
            var s = chip.getAttribute('data-status');
            if (avwHidden.has(s)) { avwHidden.delete(s); chip.classList.remove('off'); }
            else { avwHidden.add(s); chip.classList.add('off'); }
            document.querySelectorAll('.avw-cell[data-status="' + s + '"]').forEach(function (el) {
                el.classList.toggle('dim', avwHidden.has(s));
            });
        }
        avwCounts();
    </script>
}

@page
@model SmartAttendance.Web.Pages.Employees.IndexModel

@{
    ViewData["Title"] = "الموظفون";
}

<link rel="stylesheet" href="~/css/employees-nexora-clean.css" asp-append-version="true" />

<div class="nx-employees-page">
    <div class="nx-page-head">
        <div>
            <div class="nx-eyebrow">NEXORA HR Affairs</div>
            <h1>الموظفون</h1>
            <p>إدارة بيانات الموظفين والوصول السريع إلى ملف الموظف الشامل.</p>
        </div>

        <div class="nx-head-actions">
            <a asp-page="./EndServiceList" class="hrms-btn-secondary">منتهية خدماتهم</a>
            <a asp-page="./Import" class="hrms-btn-secondary">استيراد Excel</a>
            <a asp-page="./Create" class="hrms-btn-primary">إضافة موظف +</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="nx-alert success">@TempData["SuccessMessage"]</div>
    }

    <div class="nx-card">
        <form method="get" class="nx-search-form">
            <div class="nx-search-box">
                <span>بحث</span>
                <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="ابحث بالكود، الاسم، القسم، المنصب، الفرع، الهاتف أو الإيميل..." />
            </div>
            <div class="nx-search-actions">
                <button type="submit" class="hrms-btn-primary">بحث</button>
                <a asp-page="./Index" class="hrms-btn-secondary">مسح</a>
            </div>
        </form>

        <div class="nx-table-toolbar"><div class="nx-count">عدد النتائج: <strong>@Model.Employees.Count()</strong></div></div>

        <div class="nx-table-wrap">
            <table class="nx-employees-table">
                <thead>
                    <tr>
                        <th class="col-code">كود الموظف</th><th class="col-name">اسم الموظف</th><th>القسم</th><th>المنصب</th><th>الفرع</th><th>الهاتف</th><th>الإيميل</th><th>تاريخ التعيين</th><th>الحالة</th><th class="col-actions">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Employees.Any())
                    {
                        foreach (var employee in Model.Employees)
                        {
                            <tr>
                                <td class="col-code"><span class="nx-code">@employee.EmployeeNo</span></td>
                                <td class="col-name"><div class="nx-employee-name">@employee.FullName</div></td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.DepartmentName) ? employee.DepartmentName : "-")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.Position) ? employee.Position : "-")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.BranchName) ? employee.BranchName : "-")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.Phone) ? employee.Phone : "-")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.Email) ? employee.Email : "-")</td>
                                <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>
                                <td><span class="nx-status @(employee.IsActive ? "active" : "inactive")">@(employee.IsActive ? "فعال" : "غير فعال")</span></td>
                                <td class="col-actions"><div class="nx-row-actions"><a asp-page="./Profile" asp-route-id="@employee.Id" class="nx-action primary">ملف</a></div></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="10" class="nx-empty">لا توجد بيانات موظفين حالياً.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

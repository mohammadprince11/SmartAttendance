@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel

@{
    ViewData["Title"] = "ملف الموظف الشامل";

    string StatusClass(int status)
    {
        return status switch
        {
            1 => "ok",
            2 => "warn",
            3 => "danger",
            4 => "info",
            5 => "warn",
            _ => "warn"
        };
    }

    string RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "ok",
            "Rejected" => "danger",
            "Pending" => "warn",
            _ => "warn"
        };
    }

    var employee = Model.Employee;
    var initial = employee == null || string.IsNullOrWhiteSpace(employee.FullName) ? "N" : employee.FullName.Trim()[0].ToString();

    var documentCount = Model.DocumentRows.Count;
    var requestCount = Model.RequestRows.Count;
    var payrollScore = Model.AbsentCount == 0 && Model.MissingCheckoutCount == 0 && Model.PendingRequests == 0 ? 94 : 72;
    var healthScore = Math.Max(0, 100 - (Model.AbsentCount * 8) - (Model.MissingCheckoutCount * 7) - (Model.PendingRequests * 5));
    var healthText = healthScore >= 85 ? "مرتفع" : healthScore >= 60 ? "يحتاج متابعة" : "خطر";
}

<link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />

<div class="nxr-page">
    <section class="nxr-topline">
        <div class="nxr-title">
            <div class="nxr-brand-mini">NEXORA Employee 360</div>
            <h1>ملف الموظف الشامل</h1>
            <p>شؤون الموظفين › ملفات الموظفين › ملف الموظف الشامل</p>
        </div>

        <div class="nxr-actions">
            <a asp-page="./Index" class="nxr-btn">رجوع</a>
            @if (employee != null)
            {
                <a asp-page="./Edit" asp-route-id="@employee.Id" class="nxr-btn primary">تعديل البيانات</a>
                <a asp-page="./Lifecycle" asp-route-id="@employee.Id" class="nxr-btn">السجل الوظيفي</a>
                @if (employee.IsActive)
                {
                    <a asp-page="./EndService" asp-route-id="@employee.Id" class="nxr-btn danger">إنهاء خدمة</a>
                }
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nxr-error">@Model.ErrorMessage</div>
    }
    else if (employee != null)
    {
        <section class="nxr-card nxr-profile-hero">
            <div class="nxr-profile-main">
                <div class="nxr-avatar-xl">@initial</div>

                <div class="nxr-profile-name">
                    <h2>@employee.FullName</h2>
                    <div class="nxr-chips">
                        <span class="nxr-chip">@employee.EmployeeNo</span>
                        <span class="nxr-chip">@(Model.Display(employee.BranchName))</span>
                        <span class="nxr-chip">@(Model.Display(employee.DepartmentName))</span>
                        <span class="nxr-chip gold">@(employee.IsActive ? "فعال" : "غير فعال")</span>
                    </div>
                </div>
            </div>

            <div class="nxr-identity-meta">
                <div class="nxr-meta-item"><span>تاريخ التعيين</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                <div class="nxr-meta-item"><span>الحالة الوظيفية</span><strong>@Model.Display(employee.EmploymentStatus)</strong></div>
                <div class="nxr-meta-item"><span>نوع التوظيف</span><strong>@Model.Display(employee.ContractType)</strong></div>
            </div>
        </section>

        <section class="nxr-insights">
            <div class="nxr-card nxr-score-card">
                <div class="nxr-score-ring"><strong>@payrollScore%</strong></div>
                <div>
                    <span class="nxr-chip">Payroll Readiness</span>
                    <h3>جاهز مبدئياً لإطلاق الراتب</h3>
                    <p>يتم احتساب المؤشر من الحضور، الطلبات، المستندات، والبصمات الناقصة.</p>
                </div>
            </div>

            <div class="nxr-card nxr-score-card">
                <div>
                    <span class="nxr-chip">Employee Health Score</span>
                    <h3>مؤشر استقرار الموظف: @healthText</h3>
                    <p>أداء تشغيلي يعتمد على انتظام الحضور واكتمال البيانات والطلبات.</p>
                </div>
                <div class="nxr-wave"></div>
            </div>
        </section>

        <section class="nxr-grid-4">
            <div class="nxr-kpi"><div class="nxr-kpi-icon">☑</div><span>سجلات الحضور</span><strong>@Model.AttendanceCount</strong><small>ضمن الفترة</small></div>
            <div class="nxr-kpi ok"><div class="nxr-kpi-icon">✓</div><span>الحضور</span><strong>@Model.PresentCount</strong><small>سجل حضور</small></div>
            <div class="nxr-kpi warn"><div class="nxr-kpi-icon">⏱</div><span>المتأخر</span><strong>@Model.LateCount</strong><small>مرة</small></div>
            <div class="nxr-kpi danger"><div class="nxr-kpi-icon">!</div><span>الغياب</span><strong>@Model.AbsentCount</strong><small>يوم</small></div>
            <div class="nxr-kpi warn"><div class="nxr-kpi-icon">⌾</div><span>البصمات الناقصة</span><strong>@Model.MissingCheckoutCount</strong><small>مرة</small></div>
            <div class="nxr-kpi"><div class="nxr-kpi-icon">◷</div><span>ساعات العمل</span><strong>@Model.TotalWorkingHours</strong><small>ساعة</small></div>
            <div class="nxr-kpi"><div class="nxr-kpi-icon">▣</div><span>المستندات</span><strong>@documentCount</strong><small>مستند</small></div>
            <div class="nxr-kpi"><div class="nxr-kpi-icon">□</div><span>الطلبات</span><strong>@requestCount</strong><small>طلب</small></div>
        </section>

        <nav class="nxr-card nxr-tabs">
            <a href="#data" class="nxr-tab active">البيانات</a>
            <a href="#attendance" class="nxr-tab">الحضور</a>
            <a href="#requests" class="nxr-tab">الطلبات</a>
            <a href="#documents" class="nxr-tab">المستندات</a>
            <a href="#audit" class="nxr-tab">السجل</a>
        </nav>

        <section id="data" class="nxr-grid-3">
            <div class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>البيانات الأساسية</h3></div>
                <div class="nxr-info-list">
                    <div class="nxr-info-row"><span>الاسم الكامل</span><strong>@employee.FullName</strong></div>
                    <div class="nxr-info-row"><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
                    <div class="nxr-info-row"><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                    <div class="nxr-info-row"><span>الهوية</span><strong>@Model.Display(employee.NationalId)</strong></div>
                    <div class="nxr-info-row"><span>الهاتف</span><strong>@Model.Display(employee.Phone)</strong></div>
                    <div class="nxr-info-row"><span>الإيميل</span><strong>@Model.Display(employee.Email)</strong></div>
                </div>
            </div>

            <div class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>البيانات الوظيفية</h3></div>
                <div class="nxr-info-list">
                    <div class="nxr-info-row"><span>الفرع</span><strong>@Model.Display(employee.BranchName)</strong></div>
                    <div class="nxr-info-row"><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                    <div class="nxr-info-row"><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                    <div class="nxr-info-row"><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                    <div class="nxr-info-row"><span>المدير المباشر</span><strong>@Model.Display(employee.DirectManager)</strong></div>
                    <div class="nxr-info-row"><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>
                </div>
            </div>

            <div id="attendance" class="nxr-card nxr-panel">
                <div class="nxr-panel-title">
                    <div>
                        <h3>الحضور والانصراف</h3>
                        <p>آخر سجلات الحضور ضمن الفترة المحددة.</p>
                    </div>
                </div>
                <div class="nxr-table-wrap">
                    <table class="nxr-table" style="min-width:620px">
                        <thead><tr><th>التاريخ</th><th>الدخول</th><th>الخروج</th><th>الحالة</th></tr></thead>
                        <tbody>
                        @if (Model.AttendanceRows.Any())
                        {
                            foreach (var row in Model.AttendanceRows.Take(7))
                            {
                                <tr>
                                    <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                    <td>@Model.DisplayTime(row.CheckIn)</td>
                                    <td>@Model.DisplayTime(row.CheckOut)</td>
                                    <td><span class="nxr-status @StatusClass(row.Status)">@Model.StatusText(row.Status)</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="nxr-empty">لا توجد سجلات حضور.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="nxr-grid-4">
            <div id="requests" class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>الطلبات</h3></div>
                <div class="nxr-info-list">
                @if (Model.RequestRows.Any())
                {
                    foreach (var row in Model.RequestRows.Take(4))
                    {
                        <div class="nxr-info-row">
                            <span>@row.RequestType</span>
                            <strong><span class="nxr-status @RequestClass(row.Status)">@Model.RequestStatusText(row.Status)</span></strong>
                        </div>
                    }
                }
                else
                {
                    <p style="color:var(--nxr-muted)">لا توجد طلبات.</p>
                }
                </div>
            </div>

            <div class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>الشفتات</h3></div>
                <div class="nxr-info-list">
                @if (Model.ShiftRows.Any())
                {
                    foreach (var row in Model.ShiftRows.Take(4))
                    {
                        <div class="nxr-info-row"><span>@row.Name</span><strong>@row.StartTime - @row.EndTime</strong></div>
                    }
                }
                else
                {
                    <p style="color:var(--nxr-muted)">لا توجد شفتات.</p>
                }
                </div>
            </div>

            <div id="documents" class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>المستندات</h3></div>
                <div class="nxr-info-list">
                @if (Model.DocumentRows.Any())
                {
                    foreach (var row in Model.DocumentRows.Take(4))
                    {
                        <div class="nxr-info-row"><span>@row.DocumentType</span><strong>@row.FileName</strong></div>
                    }
                }
                else
                {
                    <p style="color:var(--nxr-muted)">لا توجد مستندات.</p>
                }
                </div>
            </div>

            <div id="audit" class="nxr-card nxr-panel">
                <div class="nxr-panel-title"><h3>سجل التعديلات</h3></div>
                <div class="nxr-info-list">
                @if (Model.AuditRows.Any())
                {
                    foreach (var row in Model.AuditRows.Take(4))
                    {
                        <div class="nxr-info-row"><span>@row.Action</span><strong>@Model.DisplayDateTime(row.CreatedAt)</strong></div>
                    }
                }
                else
                {
                    <p style="color:var(--nxr-muted)">لا توجد تعديلات.</p>
                }
                </div>
            </div>
        </section>
    }
</div>

@page
@model SmartAttendance.Web.Pages.Employees.EditModel
@{
    ViewData["Title"] = "تعديل بيانات الموظف";

    var employeePhotoFallback = Url.Content("~/brand/employee-photo-placeholder.svg");
    var employeePhotoSrc = string.IsNullOrWhiteSpace(Model.CurrentPhotoPath)
        ? employeePhotoFallback
        : Model.CurrentPhotoPath;
}

<link rel="stylesheet" href="~/css/nexora-edit-custom-datepicker.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-photo-upload.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-edit-clean-layout.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-profile-dynamic-fields.css" asp-append-version="true" />

<style>
    /* توحيد الستايل مع النظام */
    input[data-nexora-date-field="true"] { background-color: #0f172a !important; color: #e2e8f0 !important; border: 1px solid #334155 !important; border-radius: 8px !important; padding: 10px 16px !important; }
    input[data-nexora-date-field="true"]:focus { border-color: #0ea5e9 !important; box-shadow: 0 0 0 2px rgba(14, 165, 233, 0.2) !important; }

    /* ستايل قائمة البحث الذكية */
    .nxr-searchable-wrapper { position: relative; width: 100%; }
    .nxr-search-input { width: 100%; background-color: #0f172a !important; color: #e2e8f0 !important; border: 1px solid #334155 !important; border-radius: 8px !important; padding: 10px 16px !important; transition: border-color 0.2s; cursor: pointer; }
    .nxr-search-input:focus { outline: none; border-color: #0ea5e9 !important; box-shadow: 0 0 0 2px rgba(14, 165, 233, 0.2) !important; }
    .nxr-search-dropdown { display: none; position: absolute; top: 100%; left: 0; right: 0; background-color: #1e293b; border: 1px solid #334155; border-radius: 8px; margin-top: 4px; max-height: 250px; overflow-y: auto; z-index: 9999; box-shadow: 0 10px 25px rgba(0,0,0,0.5); }
    .nxr-option { padding: 10px 16px; cursor: pointer; color: #cbd5e1; border-bottom: 1px solid #334155; font-size: 0.95rem; }
    .nxr-option:last-child { border-bottom: none; }
    .nxr-option:hover { background-color: #334155; color: #fff; }
    .nxr-option-code { font-size: 0.8rem; background: #0f172a; padding: 2px 6px; border-radius: 4px; margin-left: 8px; color: #0ea5e9; }
</style>

<div class="nxr-edit-final-page" dir="rtl">
    <section class="nxr-edit-final-hero">
        <div>
            <span>Employee Data</span>
            <h1>تعديل بيانات الموظف</h1>
            <p>ترتيب الحقول حسب الأهمية ببلوك واحد.</p>
        </div>
        <div class="nxr-edit-final-hero-actions">
            <a asp-page="./Profile" asp-route-id="@Model.Employee.Id" class="nxr-edit-btn secondary">العودة للملف</a>
            <a asp-page="./Index" class="nxr-edit-btn ghost">قائمة الموظفين</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nxr-edit-alert danger">@Model.ErrorMessage</div>
    }

    <section class="nxr-edit-final-summary">
        <img src="@employeePhotoSrc" alt="Employee photo" onerror="this.onerror=null;this.src='@employeePhotoFallback';" />
        <div>
            <h2>@Model.Employee.FullName</h2>
            <p>
                <span>الكود: <strong>@Model.Employee.EmployeeNo</strong></span>
                <span>المنصب: <strong>@(string.IsNullOrWhiteSpace(Model.Employee.Position) ? "-" : Model.Employee.Position)</strong></span>
                <span>الحالة: <strong>@(Model.Employee.IsActive ? "فعال" : "غير فعال")</strong></span>
            </p>
        </div>
    </section>

    <form method="post" enctype="multipart/form-data" class="nxr-edit-final-form">
        <input type="hidden" asp-for="Employee.Id" />

        <section class="nxr-edit-final-card">
            <div class="nxr-edit-final-card-head">
                <div>
                    <span>Employee Data</span>
                    <h2>بيانات الموظف</h2>
                    <p>كل الحقول مرتبة حسب الأهمية.</p>
                </div>
            </div>

            <div class="nxr-edit-photo-status-row">
                <label class="nxr-edit-photo-box" data-employee-photo-drop>
                    <input asp-for="EmployeePhoto" type="file" accept="image/png,image/jpeg,image/webp" />
                    <img data-employee-photo-preview data-placeholder-src="@employeePhotoFallback" src="@employeePhotoSrc" alt="Employee photo" onerror="this.onerror=null;this.src='@employeePhotoFallback';" />
                </label>
                <div class="nxr-edit-photo-info">
                    <strong>صورة الموظف</strong>
                    <span>اختر صورة PNG أو JPG أو WEBP.</span>
                    <small>Max 5MB</small>
                </div>
                <div class="nxr-edit-status-near-photo">
                    <label>حالة الموظف</label>
                    <label class="nxr-edit-status-switch">
                        <input asp-for="Employee.IsActive" />
                        <span>فعال داخل النظام</span>
                    </label>
                </div>
            </div>

            <div class="nxr-edit-final-grid">
                <div class="nxr-edit-field">
                    <label asp-for="Employee.EmployeeNo">كود الموظف</label>
                    <input asp-for="Employee.EmployeeNo" />
                    <span asp-validation-for="Employee.EmployeeNo"></span>
                </div>
                @* اسم الموظف الكامل يتولّد تلقائياً من الاسم الرباعي — لا يُدخل مرتين *@
                <input type="hidden" asp-for="Employee.FullName" />
                <div class="nxr-edit-field">
                    <label asp-for="Employee.FirstName">الاسم الأول (عربي)</label>
                    <input asp-for="Employee.FirstName" data-quad-name />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.SecondName">الاسم الثاني (عربي)</label>
                    <input asp-for="Employee.SecondName" data-quad-name />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.ThirdName">الاسم الثالث (عربي)</label>
                    <input asp-for="Employee.ThirdName" data-quad-name />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.LastName">اللقب (عربي)</label>
                    <input asp-for="Employee.LastName" data-quad-name />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.FirstNameEn">First Name</label>
                    <input asp-for="Employee.FirstNameEn" dir="ltr" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.SecondNameEn">Second Name</label>
                    <input asp-for="Employee.SecondNameEn" dir="ltr" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.ThirdNameEn">Third Name</label>
                    <input asp-for="Employee.ThirdNameEn" dir="ltr" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.LastNameEn">Last Name</label>
                    <input asp-for="Employee.LastNameEn" dir="ltr" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.NationalId">الرقم الوطني / البطاقة</label>
                    <input asp-for="Employee.NationalId" />
                    <span asp-validation-for="Employee.NationalId"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Phone">الهاتف</label>
                    <input asp-for="Employee.Phone" />
                    <span asp-validation-for="Employee.Phone"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Email">البريد الإلكتروني (العمل)</label>
                    <input asp-for="Employee.Email" />
                    <span asp-validation-for="Employee.Email"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.BranchId">موقع العمل</label>
                    <select asp-for="Employee.BranchId" class="nxr-native-select" id="Employee_BranchId">
                        <option value="">اختر موقع العمل</option>
                        @foreach (var branch in Model.Branches.OrderBy(x => x.Name)) { <option value="@branch.Id" data-company-id="@branch.CompanyId" selected="@(branch.Id == Model.Employee.BranchId ? "selected" : null)">@branch.Name</option> }
                    </select>
                    <span asp-validation-for="Employee.BranchId"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.DepartmentId">القسم</label>
                    <select asp-for="Employee.DepartmentId" class="nxr-native-select" id="Employee_DepartmentId">
                        <option value="">اختر القسم</option>
                        @foreach (var department in Model.Departments.OrderBy(x => x.CompanyName).ThenBy(x => x.Name)) { <option value="@department.Id" data-company-id="@department.CompanyId" selected="@(department.Id == Model.Employee.DepartmentId ? "selected" : null)">@department.Name</option> }
                    </select>
                    <span asp-validation-for="Employee.DepartmentId"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.PositionId">المنصب</label>
                    <select asp-for="Employee.PositionId" class="nxr-native-select" id="Employee_PositionId">
                        <option value="">اختر المنصب</option>
                        @foreach (var position in Model.PositionOptions.OrderBy(x => x.Name)) { <option value="@position.Id" data-company-id="@position.CompanyId" selected="@(position.Id == Model.Employee.PositionId ? "selected" : null)">@position.Name</option> }
                    </select>
                    <span asp-validation-for="Employee.PositionId"></span>
                </div>

                <!-- --- القائمة الذكية للمدير (بالبحث) --- -->
                <div class="nxr-edit-field">
                    <label asp-for="DirectManagerId">المدير المباشر</label>
                    <div class="nxr-searchable-wrapper" id="managerSearchWrapper">
                        <input type="hidden" asp-for="DirectManagerId" id="managerHiddenId" />
                        <input type="text" class="nxr-search-input" id="managerSearchInput" placeholder="بحث بالاسم أو الكود..." autocomplete="off" />
                        <div class="nxr-search-dropdown" id="managerDropdown">
                            <div class="nxr-option" data-value="" data-text="-- بدون مدير --">-- بدون مدير --</div>
                            @foreach (var manager in Model.Managers)
                            {
                                <div class="nxr-option" data-value="@manager.Id" data-text="@manager.FullName @manager.EmployeeNo">
                                    <span class="nxr-option-code">@manager.EmployeeNo</span> @manager.FullName
                                </div>
                            }
                        </div>
                    </div>
                    <span asp-validation-for="DirectManagerId"></span>
                </div>
                <!-- --------------------------------------- -->

                <div class="nxr-edit-field">
                    <label asp-for="Employee.HireDate">تاريخ التعيين (العقد)</label>
                    <input name="Employee.HireDate" id="Employee_HireDate" value="@Model.Employee.HireDate.ToString("yyyy-MM-dd")" type="text" data-nexora-date-field="true" inputmode="numeric" autocomplete="off" placeholder="yyyy-mm-dd" />
                    <span asp-validation-for="Employee.HireDate"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.JoiningDate">تاريخ المباشرة الفعلية (إن اختلفت)</label>
                    <input name="Employee.JoiningDate" id="Employee_JoiningDate" value="@(Model.Employee.JoiningDate?.ToString("yyyy-MM-dd"))" type="text" data-nexora-date-field="true" inputmode="numeric" autocomplete="off" placeholder="yyyy-mm-dd" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.BirthDate">تاريخ الميلاد</label>
                    <input name="Employee.BirthDate" id="Employee_BirthDate" value="@(Model.Employee.BirthDate?.ToString("yyyy-MM-dd"))" type="text" data-nexora-date-field="true" inputmode="numeric" autocomplete="off" placeholder="yyyy-mm-dd" />
                    <span asp-validation-for="Employee.BirthDate"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Gender">الجنس</label>
                    <select asp-for="Employee.Gender" class="nxr-native-select">
                        <option value="">اختر...</option><option value="Male">ذكر</option><option value="Female">أنثى</option>
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.MaritalStatus">الحالة الاجتماعية</label>
                    <select asp-for="Employee.MaritalStatus" class="nxr-native-select">
                        <option value="">اختر...</option><option value="Single">أعزب</option><option value="Married">متزوج</option><option value="Divorced">مطلق</option><option value="Widowed">أرمل</option><option value="Separated">منفصل</option>
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Country">البلد</label>
                    <select asp-for="Employee.Country" class="nxr-native-select">
                        <option value="">اختر البلد</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.Country) && !SmartAttendance.Web.Infrastructure.Ui.NexoraEmployeeLookups.IsKnownCountry(Model.Employee.Country)) { <option value="@Model.Employee.Country">@Model.Employee.Country</option> }
                        <option value="Iraq">العراق</option><option value="Syria">سوريا</option><option value="Jordan">الأردن</option><option value="Lebanon">لبنان</option><option value="Saudi Arabia">السعودية</option><option value="United Arab Emirates">الإمارات</option><option value="Qatar">قطر</option><option value="Kuwait">الكويت</option><option value="Bahrain">البحرين</option><option value="Oman">عمان</option><option value="Egypt">مصر</option><option value="Turkey">تركيا</option><option value="Iran">إيران</option><option value="India">الهند</option><option value="Pakistan">باكستان</option><option value="Bangladesh">بنغلادش</option><option value="Philippines">الفلبين</option><option value="Nepal">نيبال</option><option value="Other">أخرى</option>
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Nationality">الجنسية</label>
                    <select asp-for="Employee.Nationality" class="nxr-native-select">
                        <option value="">اختر الجنسية</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.Nationality) && !SmartAttendance.Web.Infrastructure.Ui.NexoraEmployeeLookups.IsKnownNationality(Model.Employee.Nationality)) { <option value="@Model.Employee.Nationality">@Model.Employee.Nationality</option> }
                        <option value="Iraqi">عراقي</option><option value="Syrian">سوري</option><option value="Jordanian">أردني</option><option value="Lebanese">لبناني</option><option value="Saudi">سعودي</option><option value="Emirati">إماراتي</option><option value="Qatari">قطري</option><option value="Kuwaiti">كويتي</option><option value="Bahraini">بحريني</option><option value="Omani">عماني</option><option value="Egyptian">مصري</option><option value="Turkish">تركي</option><option value="Iranian">إيراني</option><option value="Indian">هندي</option><option value="Pakistani">باكستاني</option><option value="Bangladeshi">بنغلادشي</option><option value="Filipino">فلبيني</option><option value="Nepali">نيبالي</option><option value="Other">أخرى</option>
                    </select>
                </div>

                @* ---------- الجنسية والإقامة ---------- *@
                <div class="nxr-edit-field">
                    <label asp-for="Employee.IsCitizen">مواطن</label>
                    <select asp-for="Employee.IsCitizen" class="nxr-native-select">
                        <option value="true">مواطن</option>
                        <option value="false">غير مواطن (وافد)</option>
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.PassportNo">رقم جواز السفر</label>
                    <input asp-for="Employee.PassportNo" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.SponsorName">الكفيل</label>
                    <select asp-for="Employee.SponsorName" class="nxr-native-select">
                        <option value="">بدون كفيل</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.SponsorName) && !Model.SponsorOptions.Contains(Model.Employee.SponsorName)) { <option value="@Model.Employee.SponsorName">@Model.Employee.SponsorName</option> }
                        @foreach (var sponsor in Model.SponsorOptions) { <option value="@sponsor">@sponsor</option> }
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.Religion">الديانة</label>
                    <select asp-for="Employee.Religion" class="nxr-native-select">
                        <option value="">اختر...</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.Religion) && !Model.ReligionOptions.Contains(Model.Employee.Religion)) { <option value="@Model.Employee.Religion">@Model.Employee.Religion</option> }
                        @foreach (var religion in Model.ReligionOptions) { <option value="@religion">@religion</option> }
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.MotherCountry">البلد الأم</label>
                    <input asp-for="Employee.MotherCountry" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.MotherCity">المدينة الأم</label>
                    <input asp-for="Employee.MotherCity" />
                </div>

                @* ---------- الاتصال والتوظيف ---------- *@
                <div class="nxr-edit-field">
                    <label asp-for="Employee.PersonalEmail">البريد الشخصي</label>
                    <input asp-for="Employee.PersonalEmail" dir="ltr" />
                    <span asp-validation-for="Employee.PersonalEmail"></span>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.PhoneExtension">امتداد الهاتف</label>
                    <input asp-for="Employee.PhoneExtension" />
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.WorkType">نوع الدوام</label>
                    <select asp-for="Employee.WorkType" class="nxr-native-select">
                        <option value="">اختر...</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.WorkType) && !Model.WorkTypeOptions.Contains(Model.Employee.WorkType)) { <option value="@Model.Employee.WorkType">@Model.Employee.WorkType</option> }
                        @foreach (var workType in Model.WorkTypeOptions) { <option value="@workType">@workType</option> }
                    </select>
                </div>
                <div class="nxr-edit-field">
                    <label asp-for="Employee.JobGrade">الدرجة الوظيفية</label>
                    <select asp-for="Employee.JobGrade" class="nxr-native-select">
                        <option value="">اختر...</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Employee.JobGrade) && !Model.GradeOptions.Contains(Model.Employee.JobGrade)) { <option value="@Model.Employee.JobGrade">@Model.Employee.JobGrade</option> }
                        @foreach (var grade in Model.GradeOptions) { <option value="@grade">@grade</option> }
                    </select>
                </div>
            </div>

        @if (Model.ProfileDynamicSections.Any(profileSection => profileSection.Fields.Count > 0))
        {
            <section class="nxr-edit-final-card nxr-profile-dynamic-edit-card">
                <div class="nxr-edit-final-card-head">
                    <div>
                        <span>Dynamic Profile Fields</span>
                        <h2>حقول ملف الموظف</h2>
                    </div>
                </div>
                <div class="nxr-profile-dynamic-sections">
                    @foreach (var profileSection in Model.ProfileDynamicSections.Where(item => item.Fields.Count > 0))
                    {
                        <article class="nxr-profile-dynamic-edit-section">
                            <div class="nxr-profile-dynamic-section-head">
                                <h3>@profileSection.Label</h3>
                                <span>@profileSection.Fields.Count حقل</span>
                            </div>
                            <div class="nxr-edit-final-grid">
                                @foreach (var field in profileSection.Fields)
                                {
                                    var inputId = $"ProfileCustomValues_{field.FieldKey}";
                                    var requiredValue = field.IsRequired ? "required" : null;
                                    <div class="nxr-edit-field @(field.IsTextArea ? "nxr-span-2" : "")">
                                        <label for="@inputId">@field.FieldLabel @if (field.IsRequired){<span>*</span>}</label>
                                        @if (field.IsTextArea) { <textarea id="@inputId" name="ProfileCustomValues[@field.FieldKey]" required="@requiredValue" rows="3">@field.FieldValue</textarea> }
                                        else if (field.IsSelect)
                                        {
                                            <select id="@inputId" name="ProfileCustomValues[@field.FieldKey]" required="@requiredValue">
                                                <option value="">اختر</option>
                                                @foreach (var option in field.Options)
                                                {
                                                    <option value="@option" selected="@(option == field.FieldValue ? "selected" : null)">@option</option>
                                                }
                                            </select>
                                        }
                                        else if (field.IsCheckbox)
                                        {
                                            <input id="@inputId" name="ProfileCustomValues[@field.FieldKey]" type="checkbox" value="true" checked="@(field.IsCheckedValue ? "checked" : null)" />
                                        }
                                        else { <input id="@inputId" name="ProfileCustomValues[@field.FieldKey]" type="@field.InputType" value="@field.FieldValue" required="@requiredValue" /> }
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
        <div class="nxr-edit-final-actions">
                <button type="submit" class="nxr-edit-btn primary">حفظ التعديل</button>
                <a asp-page="./Profile" asp-route-id="@Model.Employee.Id" class="nxr-edit-btn secondary">إلغاء والعودة للملف</a>
            </div>
        </section>
    </form>
</div>

@section Scripts {
    <script src="~/js/nexora-edit-custom-datepicker.js" asp-append-version="true" defer></script>
    <script src="~/js/nexora-employee-photo-upload.js" asp-append-version="true"></script>

    <!-- سكربت القائمة الذكية للمدير المباشر -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const wrapper = document.getElementById('managerSearchWrapper');
            const input = document.getElementById('managerSearchInput');
            const hidden = document.getElementById('managerHiddenId');
            const dropdown = document.getElementById('managerDropdown');
            const options = dropdown.querySelectorAll('.nxr-option');

            if(!wrapper || !input || !hidden || !dropdown) return;

            // جلب النص الحالي بناءً على القيمة المخفية
            let selectedText = "";
            if(hidden.value) {
                const selectedOpt = dropdown.querySelector('.nxr-option[data-value="' + hidden.value + '"]');
                if(selectedOpt) {
                    selectedText = selectedOpt.textContent.trim();
                    input.value = selectedText;
                }
            } else {
                input.value = "-- بدون مدير --";
            }

            input.addEventListener('focus', function() {
                input.value = '';
                filterOptions('');
                dropdown.style.display = 'block';
            });

            input.addEventListener('input', function(e) {
                filterOptions(e.target.value.toLowerCase());
            });

            function filterOptions(term) {
                options.forEach(opt => {
                    const textToSearch = opt.getAttribute('data-text').toLowerCase();
                    if(textToSearch.includes(term)) {
                        opt.style.display = 'block';
                    } else {
                        opt.style.display = 'none';
                    }
                });
            }

            options.forEach(opt => {
                opt.addEventListener('click', function() {
                    hidden.value = this.getAttribute('data-value');
                    selectedText = this.textContent.trim();
                    input.value = selectedText;
                    dropdown.style.display = 'none';
                });
            });

            document.addEventListener('click', function(e) {
                if(!wrapper.contains(e.target)) {
                    dropdown.style.display = 'none';
                    if(input.value !== selectedText) {
                        input.value = selectedText; // إعادة النص في حال لم يتم اختيار شيء
                    }
                }
            });
        });
    </script>
    <!-- نهاية سكربت القائمة الذكية -->

    <script>
        (() => {
            const workLocation = document.getElementById("Employee_BranchId");
            const department = document.getElementById("Employee_DepartmentId");
            const position = document.getElementById("Employee_PositionId");
            if (!workLocation || !department || !position) return;
            function refreshSelect(select) { if (window.NexoraSelect && typeof window.NexoraSelect.refresh === "function") { window.NexoraSelect.refresh(select); } select.dispatchEvent(new Event("change", { bubbles: true })); }
            function filterByCompany(select, companyId) {
                let currentIsValid = false;
                Array.from(select.options).forEach(option => {
                    if (!option.value) { option.hidden = false; option.disabled = false; return; }
                    const belongsToCompany = companyId && option.dataset.companyId === companyId;
                    option.hidden = !belongsToCompany; option.disabled = !belongsToCompany;
                    if (belongsToCompany && option.value === select.value) { currentIsValid = true; }
                });
                if (!currentIsValid) { select.value = ""; }
                refreshSelect(select);
            }
            function filterOrganization() {
                const selectedOption = workLocation.options[workLocation.selectedIndex];
                const companyId = selectedOption?.dataset.companyId || "";
                filterByCompany(department, companyId);
                filterByCompany(position, companyId);
            }
            workLocation.addEventListener("change", filterOrganization);
            filterOrganization();
            window.NexoraEditFilterOrganization = filterOrganization;
        })();
    </script>

    <script>
        (() => {
            const labels = { Male: { Single: "أعزب", Married: "متزوج", Divorced: "مطلق", Widowed: "أرمل", Separated: "منفصل" }, Female: { Single: "عزباء", Married: "متزوجة", Divorced: "مطلقة", Widowed: "أرملة", Separated: "منفصلة" } };
            const placeholder = "اختر...";
            function getGenderGroup(genderValue) { const value = (genderValue || "").trim(); if (value === "Female" || value === "أنثى" || value === "انثى") { return labels.Female; } return labels.Male; }
            function applyMaritalLabels() {
                const gender = document.getElementById("Employee_Gender"); const marital = document.getElementById("Employee_MaritalStatus");
                if (!gender || !marital) return;
                const group = getGenderGroup(gender.value);
                Array.from(marital.options).forEach(option => {
                    if (!option.value) { option.textContent = placeholder; return; }
                    if (group[option.value]) { option.textContent = group[option.value]; }
                });
                if (window.NexoraSelect && typeof window.NexoraSelect.refresh === "function") { window.NexoraSelect.refresh(marital); } else { marital.dispatchEvent(new Event("change", { bubbles: true })); }
            }
            function bind() {
                const gender = document.getElementById("Employee_Gender");
                if (gender && !gender.dataset.maritalGenderBound) { gender.dataset.maritalGenderBound = "1"; gender.addEventListener("change", applyMaritalLabels); gender.addEventListener("input", applyMaritalLabels); }
                applyMaritalLabels();
            }
            if (document.readyState === "loading") { document.addEventListener("DOMContentLoaded", bind); } else { bind(); }
            setTimeout(bind, 100); setTimeout(bind, 400); setTimeout(bind, 900);
        })();
    </script>
    <script>
        // الاسم الرباعي → يبني "اسم الموظف" تلقائياً أثناء الكتابة (يبقى قابلاً للتعديل اليدوي).
        (function () {
            var full = document.getElementById("Employee_FullName");
            var parts = Array.prototype.slice.call(document.querySelectorAll("[data-quad-name]"));
            if (!full || !parts.length) return;
            function compose() {
                var first = document.getElementById("Employee_FirstName");
                var last = document.getElementById("Employee_LastName");
                if (!first || !last || !first.value.trim() || !last.value.trim()) return;
                var values = parts.map(function (p) { return p.value.trim(); }).filter(Boolean);
                full.value = values.join(" ");
            }
            parts.forEach(function (p) { p.addEventListener("input", compose); });
        })();
    </script>
    <script>
        // التحكم بالحقول: علامة * و required على الحقول الإلزامية المعرّفة مركزياً.
        (function () {
            var keys = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RequiredFieldKeys));
            keys.forEach(function (key) {
                var input = document.querySelector('[name="Employee.' + key + '"]');
                if (!input || input.type === "hidden") return;
                input.setAttribute("required", "required");
                var label = (input.id && document.querySelector('label[for="' + input.id + '"]')) ||
                    (input.closest(".nxr-field") || input.parentElement).querySelector("label");
                if (label && !label.querySelector(".nx-req-star")) {
                    var star = document.createElement("span");
                    star.className = "nx-req-star";
                    star.textContent = " *";
                    star.style.cssText = "color:#f87171;font-weight:900";
                    label.appendChild(star);
                }
            });
        })();
    </script>
    <partial name="_ValidationScriptsPartial" />

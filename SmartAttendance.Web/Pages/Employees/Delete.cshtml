@page
@model SmartAttendance.Web.Pages.Employees.DeleteModel

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="page-header">
    <div>
        <h1>Delete Employee</h1>
        <p>Confirm employee deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this employee?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Employee No</label>
            <div class="form-control">@Model.Employee.EmployeeNo</div>
        </div>

        <div class="form-group">
            <label>Full Name</label>
            <div class="form-control">@Model.Employee.FullName</div>
        </div>

        <div class="form-group">
            <label>Department</label>
            <div class="form-control">@Model.Employee.DepartmentName</div>
        </div>

        <div class="form-group">
            <label>Branch</label>
            <div class="form-control">@Model.Employee.BranchName</div>
        </div>

        <div class="form-group">
            <label>Phone</label>
            <div class="form-control">@Model.Employee.Phone</div>
        </div>

        <div class="form-group">
            <label>Status</label>
            <div class="form-control">
                @(Model.Employee.IsActive ? "Active" : "Inactive")
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Employee.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

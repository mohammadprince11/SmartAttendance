                        <small>Documents Risk</small>
                    </div>
                }

                @if (Model.ExpiringDocumentsCount > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>مستندات قرب الانتهاء</strong>
                        <span>يوجد @Model.ExpiringDocumentsCount مستند قريب الانتهاء.</span>
                        <small>Documents Follow-up</small>
                    </div>
                }

                @if (contractNeedsReview)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>العقد يحتاج متابعة</strong>
                        <span>نهاية العقد: @Model.DisplayDate(employee.ContractEndDate)</span>
                        <small>Contract Follow-up</small>
                    </div>
                }

                @if (!hasEmployeeRequirements)
                {
                    <div class="nxr-requirement-item ok">
                        <strong>الملف مكتمل حالياً</strong>
                        <span>لا توجد متطلبات ظاهرة حسب البيانات الحالية.</span>
                        <small>HR Status</small>
                    </div>
                }
            </div>

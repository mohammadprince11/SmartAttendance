@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel

@{
    ViewData["Title"] = "ملف الموظف";

    var employee = Model.Employee;
    var today = DateOnly.FromDateTime(DateTime.Today);
    var initial = employee == null || string.IsNullOrWhiteSpace(employee.FullName) ? "N" : employee.FullName.Trim()[0].ToString();

    string StatusClass(int status)
    {
        return status switch
        {
            1 => "ok",
            2 => "warn",
            3 => "danger",
            4 => "info",
            5 => "muted",
            _ => "muted"
        };
    }

    string RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "ok",
            "Rejected" => "danger",
            "Pending" => "warn",
            _ => "muted"
        };
    }

    string DocumentClass(DateOnly? expiryDate)
    {
        if (!expiryDate.HasValue)
        {
            return "muted";
        }

        if (expiryDate.Value < today)
        {
            return "danger";
        }

        if (expiryDate.Value <= today.AddDays(30))
        {
            return "warn";
        }

        return "ok";
    }

    string DocumentText(DateOnly? expiryDate)
    {
        if (!expiryDate.HasValue)
        {
            return "بدون تاريخ انتهاء";
        }

        if (expiryDate.Value < today)
        {
            return $"منتهي: {expiryDate.Value:yyyy-MM-dd}";
        }

        if (expiryDate.Value <= today.AddDays(30))
        {
            return $"قريب الانتهاء: {expiryDate.Value:yyyy-MM-dd}";
        }

        return $"صالح إلى: {expiryDate.Value:yyyy-MM-dd}";
    }

    var readinessClass = Model.PayrollRiskItems == 0 ? "ok" : "warn";
    var readinessText = Model.PayrollRiskItems == 0 ? "جاهز مبدئياً" : "يحتاج مراجعة";
    var employeeStatusText = employee?.IsActive == true ? "فعال" : "غير فعال";
}

<link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-profile-pro.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-profile-kayan-style.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-profile-polish-requirements.css" asp-append-version="true" />

<div class="nxr-page nxr-profile-pro-page">
    <section class="nxr-profile-pro-topline">
        <div>
            <div class="nxr-brand-mini">NEXORA Employee Profile</div>
            <h1>ملف الموظف</h1>
            <p>مركز مختصر لبيانات الموظف، الحضور، الطلبات، المستندات، والشفتات.</p>
        </div>

        <div class="nxr-actions nxr-profile-pro-actions nxr-kayan-top-actions">
            <a asp-page="./Index" class="nxr-btn">رجوع للقائمة</a>
            @if (employee != null)
            {
                <div class="nxr-action-menu" data-nxr-action-menu>
                    <button type="button" class="nxr-btn primary nxr-action-menu-button" data-nxr-action-toggle>
                        إجراءات الموظف
                    </button>

                    <div class="nxr-action-menu-panel" data-nxr-action-panel>
                        <div class="nxr-action-menu-head">
                            <strong>مركز إجراءات الموظف</strong>
                            <span>أوامر شؤون الموظفين</span>
                        </div>

                        <a asp-page="./Edit" asp-route-id="@employee.Id" class="nxr-action-item">
                            <span>تعديل البيانات</span>
                            <small>تحديث المعلومات الشخصية والوظيفية</small>
                        </a>

                        <a asp-page="/EmployeeDocuments/Index" asp-route-employeeId="@employee.Id" class="nxr-action-item">
                            <span>رفع مستند</span>
                            <small>إضافة مستمسك أو ملف جديد</small>
                        </a>

                        <a asp-page="./Lifecycle" asp-route-id="@employee.Id" class="nxr-action-item">
                            <span>السجل الوظيفي</span>
                            <small>الحركات والتغييرات الوظيفية</small>
                        </a>

                        <button type="button" class="nxr-action-item is-disabled">
                            <span>إضافة عقد / تجديد عقد</span>
                            <small>قريباً ضمن مركز العقود</small>
                        </button>

                        <button type="button" class="nxr-action-item is-disabled">
                            <span>حركة وظيفية</span>
                            <small>نقل فرع، قسم، منصب أو مدير مباشر</small>
                        </button>

                        <button type="button" class="nxr-action-item is-disabled">
                            <span>إضافة عهدة</span>
                            <small>ربط جهاز، بطاقة، زي أو عهدة بالموظف</small>
                        </button>

                        <button type="button" class="nxr-action-item is-disabled">
                            <span>مخالفة / كتاب HR</span>
                            <small>إنذار، عقوبة، شكر، أو كتاب إداري</small>
                        </button>

                        @if (employee.IsActive)
                        {
                            <a asp-page="./EndService" asp-route-id="@employee.Id" class="nxr-action-item danger">
                                <span>إنهاء خدمة</span>
                                <small>إجراء رسمي لإنهاء خدمة الموظف</small>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="nxr-success">@TempData["SuccessMessage"]</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nxr-error">@Model.ErrorMessage</div>
    }
    else if (employee != null)
    {
        <section class="nxr-kayan-profile-card nxr-card">
            <div class="nxr-kayan-identity">
                <div class="nxr-kayan-avatar">@initial</div>

                <div class="nxr-kayan-main">
                    <div class="nxr-kayan-code">@Model.Display(employee.EmployeeNo)</div>
                    <h2>@employee.FullName</h2>
                    <p>@Model.Display(employee.Position)</p>

                    <div class="nxr-kayan-status-row">
                        <span class="nxr-profile-pro-badge @(employee.IsActive ? "ok" : "danger")">@employeeStatusText</span>
                        <span class="nxr-profile-pro-badge muted">@Model.Display(employee.BranchName)</span>
                        <span class="nxr-profile-pro-badge muted">@Model.Display(employee.DepartmentName)</span>
                    </div>

                    <div class="nxr-kayan-contact">
                        <div>
                            <span>البريد الإلكتروني</span>
                            <strong>@Model.Display(employee.Email)</strong>
                        </div>
                        <div>
                            <span>الهاتف</span>
                            <strong>@Model.Display(employee.Phone)</strong>
                        </div>
                        <div>
                            <span>المدير المباشر</span>
                            <strong>@Model.Display(employee.DirectManager)</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="nxr-kayan-section">
                <div class="nxr-kayan-section-head">
                    <h3>المعلومات الشخصية</h3>
                    <a asp-page="./Edit" asp-route-id="@employee.Id" class="nxr-kayan-edit" title="تعديل">✎</a>
                </div>

                <div class="nxr-kayan-info-grid">
                    <div><span>رقم الهوية</span><strong>@Model.Display(employee.NationalId)</strong></div>
                    <div><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
                    <div><span>الجنس</span><strong>@Model.Display(employee.Gender)</strong></div>
                    <div><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                    <div><span>البلد</span><strong>@Model.Display(employee.Country)</strong></div>
                    <div><span>الحالة</span><strong>@employeeStatusText</strong></div>
                </div>
            </div>

            <div class="nxr-kayan-section">
                <div class="nxr-kayan-section-head">
                    <h3>المعلومات الوظيفية</h3>
                    <a asp-page="./Lifecycle" asp-route-id="@employee.Id" class="nxr-kayan-edit" title="السجل الوظيفي">↗</a>
                </div>

                <div class="nxr-kayan-info-grid">
                    <div><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                    <div><span>الفرع</span><strong>@Model.Display(employee.BranchName)</strong></div>
                    <div><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                    <div><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                    <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                    <div><span>مدة الخدمة</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                    <div><span>نوع العقد</span><strong>@Model.Display(employee.ContractType)</strong></div>
                    <div><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>
                </div>
            </div>

            <div class="nxr-kayan-section nxr-kayan-financial">
                <div class="nxr-kayan-section-head">
                    <h3>المعلومات المالية</h3>
                    <button type="button" class="nxr-kayan-edit" title="مخفي حسب الصلاحية">◎</button>
                </div>

                <div class="nxr-kayan-info-grid">
                    <div><span>الراتب الأساسي</span><strong>مخفي حسب الصلاحية</strong></div>
                    <div><span>الراتب الكلي</span><strong>مخفي حسب الصلاحية</strong></div>
                    <div><span>العملة</span><strong>IQD / USD لاحقاً</strong></div>
                    <div><span>طريقة الدفع</span><strong>قريباً</strong></div>
                    <div><span>القروض والسلف</span><strong>قريباً</strong></div>
                    <div><span>جاهزية الراتب</span><strong>@readinessText</strong></div>
                </div>
            </div>
        </section>

        var contractNeedsReview = employee.ContractEndDate.HasValue && employee.ContractEndDate.Value <= today.AddDays(30);
        var hasEmployeeRequirements =
            Model.PayrollRiskItems > 0 ||
            Model.AttendanceExceptionsCount > 0 ||
            Model.PendingRequests > 0 ||
            Model.ExpiredDocumentsCount > 0 ||
            Model.ExpiringDocumentsCount > 0 ||
            contractNeedsReview;


        <section class="nxr-employee-requirements @(hasEmployeeRequirements ? "" : "is-clear")">
            <div class="nxr-requirements-head">
                <div class="nxr-requirements-title">
                    <h3>متطلبات الموظف</h3>
                    <p>الملاحظات التي تحتاج متابعة من شؤون الموظفين قبل اعتماد الملف أو جاهزية الراتب.</p>
                </div>

                <span class="nxr-requirements-badge">
                    @(hasEmployeeRequirements ? "توجد متطلبات تحتاج متابعة" : "لا توجد متطلبات حالياً")
                </span>
            </div>

            <div class="nxr-requirements-grid">
                @if (Model.PayrollRiskItems > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>جاهزية الراتب</strong>
                        <span>يوجد @Model.PayrollRiskItems ملاحظة تحتاج مراجعة قبل إغلاق الراتب.</span>
                        <small>Payroll Readiness</small>
                    </div>
                }

                @if (Model.AttendanceExceptionsCount > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>استثناءات الحضور</strong>
                        <span>يوجد @Model.AttendanceExceptionsCount حالة حضور تحتاج تدقيق أو معالجة.</span>
                        <small>Attendance Exceptions</small>
                    </div>
                }

                @if (Model.PendingRequests > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>طلبات معلقة</strong>
                        <span>يوجد @Model.PendingRequests طلب بانتظار الموافقة أو الإغلاق.</span>
                        <small>Pending Requests</small>
                    </div>
                }

                @if (Model.ExpiredDocumentsCount > 0)
                {
                    <div class="nxr-requirement-item danger">
                        <strong>مستندات منتهية</strong>
                        <span>يوجد @Model.ExpiredDocumentsCount مستند منتهي يحتاج تحديث.</span>
                        <small>Documents Risk</small>
                    </div>
                }

                @if (Model.ExpiringDocumentsCount > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>مستندات قرب الانتهاء</strong>
                        <span>يوجد @Model.ExpiringDocumentsCount مستند قريب الانتهاء.</span>
                        <small>Documents Follow-up</small>
                    </div>
                }

                @if (contractNeedsReview)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>العقد يحتاج متابعة</strong>
                        <span>نهاية العقد: @Model.DisplayDate(employee.ContractEndDate)</span>
                        <small>Contract Follow-up</small>
                    </div>
                }

                @if (!hasEmployeeRequirements)
                {
                    <div class="nxr-requirement-item ok">
                        <strong>الملف مكتمل حالياً</strong>
                        <span>لا توجد متطلبات ظاهرة حسب البيانات الحالية.</span>
                        <small>HR Status</small>
                    </div>
                }
            </div>
        </section>
        <section class="nxr-profile-pro-nav nxr-card">
            <a href="#overview">الملخص</a>
            <a href="#data">البيانات</a>
            <a href="#attendance">الحضور</a>
            <a href="#requests">الطلبات</a>
            <a href="#documents">المستندات</a>
            <a href="#shifts">الشفتات</a>
            <a href="#audit">السجل</a>
        </section>

        <section id="overview" class="nxr-profile-pro-status-grid nxr-kayan-risk-grid">
            <div class="nxr-card nxr-profile-pro-status @readinessClass">
                <span>جاهزية الراتب</span>
                <strong>@readinessText</strong>
                <small>@Model.PayrollRiskItems ملاحظة تحتاج مراجعة</small>
            </div>
            <div class="nxr-card nxr-profile-pro-status @Model.AttendanceExceptionClass">
                <span>استثناءات الحضور</span>
                <strong>@Model.AttendanceExceptionsCount</strong>
                <small>تأخير، غياب، بصمة ناقصة أو ملاحظة</small>
            </div>
            <div class="nxr-card nxr-profile-pro-status @(Model.ExpiredDocumentsCount > 0 ? "danger" : Model.ExpiringDocumentsCount > 0 ? "warn" : "ok")">
                <span>حالة المستندات</span>
                <strong>@Model.DocumentRows.Count</strong>
                <small>@Model.ExpiredDocumentsCount منتهي، @Model.ExpiringDocumentsCount قريب الانتهاء</small>
            </div>
            <div class="nxr-card nxr-profile-pro-status @(Model.PendingRequests > 0 ? "warn" : "ok")">
                <span>طلبات معلقة</span>
                <strong>@Model.PendingRequests</strong>
                <small>@Model.ApprovedRequests مقبول، @Model.RejectedRequests مرفوض</small>
            </div>
        </section>

        <section class="nxr-profile-pro-filter nxr-card">
            <form method="get">
                <input type="hidden" name="Id" value="@employee.Id" />
                <div>
                    <label>من تاريخ</label>
                    <input type="date" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div>
                    <label>إلى تاريخ</label>
                    <input type="date" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <button type="submit" class="nxr-btn primary">تحديث الفترة</button>
                <a asp-page="./Profile" asp-route-id="@employee.Id" class="nxr-btn">آخر 30 يوم</a>
            </form>
        </section>

        <section class="nxr-profile-pro-kpis">
            <div class="nxr-kpi"><span>سجلات الحضور</span><strong>@Model.AttendanceCount</strong><small>ضمن الفترة</small></div>
            <div class="nxr-kpi ok"><span>حضور</span><strong>@Model.PresentCount</strong><small>سجل</small></div>
            <div class="nxr-kpi warn"><span>تأخير</span><strong>@Model.LateCount</strong><small>مرة</small></div>
            <div class="nxr-kpi danger"><span>غياب</span><strong>@Model.AbsentCount</strong><small>يوم</small></div>
            <div class="nxr-kpi warn"><span>بصمات ناقصة</span><strong>@Model.MissingCheckoutCount</strong><small>مرة</small></div>
            <div class="nxr-kpi"><span>ساعات العمل</span><strong>@Model.TotalWorkingHours</strong><small>ساعة</small></div>
        </section>

        <section id="data" class="nxr-profile-pro-two-col nxr-kayan-details-section">
            <div class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>البيانات الشخصية</h3>
                </div>
                <div class="nxr-profile-pro-info">
                    <div><span>الاسم الكامل</span><strong>@employee.FullName</strong></div>
                    <div><span>رقم الموظف</span><strong>@Model.Display(employee.EmployeeNo)</strong></div>
                    <div><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
                    <div><span>الجنس</span><strong>@Model.Display(employee.Gender)</strong></div>
                    <div><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                    <div><span>البلد</span><strong>@Model.Display(employee.Country)</strong></div>
                    <div><span>رقم الهوية</span><strong>@Model.Display(employee.NationalId)</strong></div>
                    <div><span>الهاتف</span><strong>@Model.Display(employee.Phone)</strong></div>
                    <div><span>الإيميل</span><strong>@Model.Display(employee.Email)</strong></div>
                </div>
            </div>

            <div class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>البيانات الوظيفية</h3>
                </div>
                <div class="nxr-profile-pro-info">
                    <div><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                    <div><span>الفرع</span><strong>@Model.Display(employee.BranchName)</strong></div>
                    <div><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                    <div><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                    <div><span>الحالة الوظيفية</span><strong>@Model.Display(employee.EmploymentStatus)</strong></div>
                    <div><span>نوع التوظيف</span><strong>@Model.Display(employee.ContractType)</strong></div>
                    <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                    <div><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>
                    <div><span>المدير المباشر</span><strong>@Model.Display(employee.DirectManager)</strong></div>
                </div>
            </div>
        </section>

        <section id="attendance" class="nxr-card nxr-profile-pro-panel">
            <div class="nxr-profile-pro-panel-title with-action">
                <div>
                    <h3>الحضور والانصراف</h3>
                    <p>آخر السجلات ضمن الفترة المحددة.</p>
                </div>
                <a asp-page="/AttendanceRecords/Index" class="nxr-mini-link">فتح سجلات الحضور</a>
            </div>

            <div class="nxr-profile-pro-table-wrap">
                <table class="nxr-profile-pro-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الدخول</th>
                            <th>الخروج</th>
                            <th>الجهاز</th>
                            <th>الحالة</th>
                            <th>الملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.AttendanceRows.Any())
                    {
                        foreach (var row in Model.AttendanceRows.Take(10))
                        {
                            <tr>
                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                <td>@Model.Display(row.DeviceName)</td>
                                <td><span class="nxr-profile-pro-badge @StatusClass(row.Status)">@Model.StatusText(row.Status)</span></td>
                                <td>@Model.Display(row.Notes)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="nxr-profile-pro-empty">لا توجد سجلات حضور ضمن هذه الفترة.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="nxr-profile-pro-two-col">
            <div id="requests" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>الطلبات</h3>
                        <p>آخر طلبات الخدمة الذاتية والإجازات.</p>
                    </div>
                    <a asp-page="/SelfServices/Index" class="nxr-mini-link">فتح الطلبات</a>
                </div>

                <div class="nxr-profile-pro-list">
                @if (Model.RequestRows.Any())
                {
                    foreach (var row in Model.RequestRows.Take(8))
                    {
                        <div class="nxr-profile-pro-list-item">
                            <div>
                                <strong>@Model.Display(row.RequestType)</strong>
                                <span>@Model.DisplayDate(row.RequestDate) · @Model.Display(row.CurrentStep)</span>
                            </div>
                            <span class="nxr-profile-pro-badge @RequestClass(row.Status)">@Model.RequestStatusText(row.Status)</span>
                        </div>
                    }
                }
                else
                {
                    <div class="nxr-profile-pro-empty">لا توجد طلبات محفوظة.</div>
                }
                </div>
            </div>

            <div id="documents" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>المستندات</h3>
                        <p>آخر المستندات المرتبطة بالموظف.</p>
                    </div>
                    <a asp-page="/EmployeeDocuments/Index" asp-route-employeeId="@employee.Id" class="nxr-mini-link">+ رفع مستند</a>
                </div>

                <div class="nxr-profile-pro-docs">
                @if (Model.DocumentRows.Any())
                {
                    foreach (var row in Model.DocumentRows.Take(8))
                    {
                        <div class="nxr-profile-pro-doc">
                            <div>
                                <strong>@Model.Display(row.DocumentType)</strong>
                                <span>@Model.Display(row.FileName)</span>
                                <small class="@DocumentClass(row.ExpiryDate)">@DocumentText(row.ExpiryDate)</small>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(row.StoredPath))
                            {
                                <a href="@row.StoredPath" target="_blank" class="nxr-btn">فتح</a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="nxr-profile-pro-empty">لا توجد مستندات محفوظة لهذا الموظف.</div>
                }
                </div>
            </div>
        </section>

        <section class="nxr-profile-pro-three-col nxr-kayan-future-modules">
            <div id="assets" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>العهد</h3>
                        <p>الأجهزة والبطاقات والمعدات المسلّمة للموظف.</p>
                    </div>
                    <button type="button" class="nxr-mini-link disabled">قريباً</button>
                </div>
                <div class="nxr-kayan-coming-soon">
                    <strong>مركز العهد</strong>
                    <span>لابتوب، موبايل، سيم كارد، زي عمل، بطاقة دخول، أو أي عهدة أخرى.</span>
                </div>
            </div>

            <div id="discipline" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>المخالفات</h3>
                        <p>المخالفات والإجراءات التأديبية حسب سياسة الشركة.</p>
                    </div>
                    <button type="button" class="nxr-mini-link disabled">قريباً</button>
                </div>
                <div class="nxr-kayan-coming-soon">
                    <strong>المخالفات والعقوبات</strong>
                    <span>لفت نظر، إنذار، إنذار بالفصل، عقوبة، أو إيقاف تكليف.</span>
                </div>
            </div>

            <div id="letters" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>كتب HR</h3>
                        <p>قوالب الكتب الرسمية المرتبطة بملف الموظف.</p>
                    </div>
                    <button type="button" class="nxr-mini-link disabled">قريباً</button>
                </div>
                <div class="nxr-kayan-coming-soon">
                    <strong>رسائل وقوالب HR</strong>
                    <span>مباشرة، شكر، إنذار، عدم تجديد عقد، إنهاء خدمة، أو طلب صرف.</span>
                </div>
            </div>
        </section>

        <section class="nxr-profile-pro-two-col">
            <div id="shifts" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>الشفتات</h3>
                    <p>الشفتات الحالية والسابقة للموظف.</p>
                </div>

                <div class="nxr-profile-pro-list">
                @if (Model.ShiftRows.Any())
                {
                    foreach (var row in Model.ShiftRows.Take(8))
                    {
                        <div class="nxr-profile-pro-list-item">
                            <div>
                                <strong>@Model.Display(row.Name)</strong>
                                <span>@row.StartTime - @row.EndTime · @Model.Display(row.WorkingHours)</span>
                                <small>@Model.DisplayDate(row.EffectiveFrom) إلى @Model.DisplayDate(row.EffectiveTo)</small>
                            </div>
                            <span class="nxr-profile-pro-badge @(row.IsCurrent ? "ok" : "muted")">@(row.IsCurrent ? "حالي" : "سابق")</span>
                        </div>
                    }
                }
                else
                {
                    <div class="nxr-profile-pro-empty">لا توجد شفتات مرتبطة.</div>
                }
                </div>
            </div>

            <div id="audit" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>سجل التعديلات</h3>
                    <p>آخر الحركات المسجلة على ملف الموظف.</p>
                </div>

                <div class="nxr-profile-pro-list">
                @if (Model.AuditRows.Any())
                {
                    foreach (var row in Model.AuditRows.Take(8))
                    {
                        <div class="nxr-profile-pro-list-item">
                            <div>
                                <strong>@Model.Display(row.Action)</strong>
                                <span>@Model.Display(row.UserName) · @Model.Display(row.IpAddress)</span>
                            </div>
                            <small>@Model.DisplayDateTime(row.CreatedAt)</small>
                        </div>
                    }
                }
                else
                {
                    <div class="nxr-profile-pro-empty">لا توجد تعديلات مسجلة.</div>
                }
                </div>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script src="~/js/nexora-employee-profile-kayan-style.js" asp-append-version="true"></script>
}

@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel
@using SmartAttendance.Domain.Enums

@functions {
    private static string Z360Age(DateOnly? birthDate)
    {
        if (!birthDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - birthDate.Value.Year;

        if (birthDate.Value > today.AddYears(-age))
        {
            age--;
        }

        return age < 0 ? "-" : age.ToString();
    }

    private static string Z360WorkDuration(DateOnly? hireDate)
    {
        if (!hireDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var start = hireDate.Value;

        if (start > today)
        {
            return "-";
        }

        var years = today.Year - start.Year;
        var months = today.Month - start.Month;

        if (today.Day < start.Day)
        {
            months--;
        }

        if (months < 0)
        {
            years--;
            months += 12;
        }

        if (years <= 0 && months <= 0)
        {
            return "أقل من شهر";
        }

        if (years <= 0)
        {
            return $"{months} شهر";
        }

        if (months <= 0)
        {
            return $"{years} سنة";
        }

        return $"{years} سنة و {months} شهر";
    }

    private static string Z360Gender(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Trim() switch
        {
            "Male" => "ذكر",
            "Female" => "أنثى",
            _ => value.Trim()
        };
    }

    private static string Z360MaritalStatus(string? value, string? gender)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var normalized = value.Trim();
        var genderValue = (gender ?? string.Empty).Trim();
        var isFemale =
            string.Equals(genderValue, "Female", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(genderValue, "أنثى", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(genderValue, "انثى", StringComparison.OrdinalIgnoreCase);

        return normalized switch
        {
            "Single" => isFemale ? "عزباء" : "أعزب",
            "Married" => isFemale ? "متزوجة" : "متزوج",
            "Divorced" => isFemale ? "مطلقة" : "مطلق",
            "Widowed" => isFemale ? "أرملة" : "أرمل",
            "Separated" => isFemale ? "منفصلة" : "منفصل",
            _ => normalized
        };
    }

    private static string Z360AttendanceClass(int status)
    {
        return status switch
        {
            1 => "z360-badge-ok",
            2 => "z360-badge-warn",
            3 => "z360-badge-danger",
            _ => string.Empty
        };
    }

    private static string Z360RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "z360-badge-ok",
            "Rejected" => "z360-badge-danger",
            "Pending" => "z360-badge-warn",
            _ => string.Empty
        };
    }
}

@{
    ViewData["Title"] = "ملف الموظف";

    var employee = Model.Employee;
    var today = DateOnly.FromDateTime(DateTime.Today);
    var photoFallback = Url.Content("~/brand/zynora-symbol.svg");
    var readinessClass = Model.PayrollRiskItems == 0 ? "z360-kpi-ok" : "z360-kpi-warn";
    var healthClass = Model.Employee360HealthScore >= 85
        ? "z360-kpi-ok"
        : Model.Employee360HealthScore >= 65
            ? "z360-kpi-warn"
            : "z360-kpi-danger";
    var readinessText = Model.PayrollRiskItems == 0 ? "جاهز" : "مراجعة";

    var basicDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "basic");
    var personalDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "personal");
    var jobDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "job");
    // "additional" plus any admin-created custom sections (keys outside the four fixed ones).
    var additionalDynamicSections = Model.ProfileDynamicSections
        .Where(item => item.Key != "basic" && item.Key != "personal" && item.Key != "job" && item.Key != "financial")
        .ToList();

    var documentHasId = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "ID", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("هوية", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("بطاقة", StringComparison.OrdinalIgnoreCase));

    var documentHasContract = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Contract", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Contract", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("عقد", StringComparison.OrdinalIgnoreCase));

    var documentHasPassport = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Passport", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Passport", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("جواز", StringComparison.OrdinalIgnoreCase));

    var documentHasVisa = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Visa", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Visa", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("إقامة", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("اقامة", StringComparison.OrdinalIgnoreCase));

    var employeeGeo = employee == null
        ? string.Empty
        : $"{employee.Nationality} {employee.Country}".ToLowerInvariant();

    var isExpat =
        !string.IsNullOrWhiteSpace(employeeGeo) &&
        !(employeeGeo.Contains("iraq") ||
          employeeGeo.Contains("iraqi") ||
          employeeGeo.Contains("العراق") ||
          employeeGeo.Contains("عراقي") ||
          employeeGeo.Contains("عراقية"));

    var contractNeedsReview =
        employee != null &&
        employee.ContractEndDate.HasValue &&
        employee.ContractEndDate.Value <= today.AddDays(30);

    var hasRequirements =
        Model.PayrollRiskItems > 0 ||
        Model.AttendanceExceptionsCount > 0 ||
        Model.PendingRequests > 0 ||
        Model.ExpiredDocumentsCount > 0 ||
        Model.ExpiringDocumentsCount > 0 ||
        !documentHasId ||
        !documentHasContract ||
        (isExpat && (!documentHasPassport || !documentHasVisa)) ||
        contractNeedsReview;

    var profileFileCards = new[]
    {
        new { Category = "Experience", Title = "الخبرات" },
        new { Category = "Certificates", Title = "الشهادات" },
        new { Category = "Medical", Title = "الملفات الطبية" },
        new { Category = "Training", Title = "الدورات التدريبية" },
        new { Category = "Education", Title = "التعليم" }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/z360-profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
}

<div class="z360-page" dir="rtl">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="z360-alert z360-alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="z360-alert z360-alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="z360-alert z360-alert-danger">@Model.ErrorMessage</div>
    }

    @if (employee != null)
    {
        <div class="z360-stack">
            <section class="z360-hero" aria-label="هوية الموظف">
                <div class="z360-identity">
                    @if (Model.CanEditEmployee)
                    {
                        <form method="post"
                              asp-page-handler="UploadProfilePhoto"
                              asp-route-id="@employee.Id"
                              enctype="multipart/form-data"
                              class="z360-photo-form"
                              data-employee-photo-form
                              data-auto-submit-photo>
                            <label class="z360-avatar" data-employee-photo-drop>
                                <input type="file"
                                       name="EmployeePhoto"
                                       accept=".png,.jpg,.jpeg,.webp"
                                       aria-label="تغيير صورة الموظف" />
                                <img src="@(string.IsNullOrWhiteSpace(employee.PhotoPath) ? photoFallback : employee.PhotoPath)"
                                     alt="صورة @employee.FullName"
                                     data-employee-photo-preview
                                     onerror="this.onerror=null;this.src='@photoFallback';" />
                                <span class="z360-avatar-overlay">تغيير الصورة</span>
                            </label>
                        </form>
                    }
                    else
                    {
                        <div class="z360-avatar">
                            <img src="@(string.IsNullOrWhiteSpace(employee.PhotoPath) ? photoFallback : employee.PhotoPath)"
                                 alt="صورة @employee.FullName"
                                 onerror="this.onerror=null;this.src='@photoFallback';" />
                        </div>
                    }

                    <div class="z360-identity-copy">
                        <span class="z360-employee-code">@Model.Display(employee.EmployeeNo)</span>
                        <h1>@employee.FullName</h1>
                        <p class="z360-position">
                            @Model.Display(employee.Position)
                            @if (!string.IsNullOrWhiteSpace(employee.DepartmentName))
                            {
                                <span> | @employee.DepartmentName</span>
                            }
                        </p>
                        <div class="z360-tags">
                            <span class="z360-tag @(employee.IsActive ? "z360-tag-success" : "z360-tag-danger")">
                                @(employee.IsActive ? "فعال" : "غير فعال")
                            </span>
                            <span class="z360-tag">@Model.Display(employee.BranchName)</span>
                            <span class="z360-tag">@Model.Display(employee.CompanyName)</span>
                        </div>
                    </div>
                </div>

                <div class="z360-contact">
                    <div class="z360-contact-row">
                        <span>البريد الإلكتروني</span>
                        <strong>@Model.Display(employee.Email)</strong>
                    </div>
                    <div class="z360-contact-row">
                        <span>الهاتف</span>
                        <strong>@Model.Display(employee.Phone)</strong>
                    </div>
                    <div class="z360-contact-row">
                        <span>المدير المباشر</span>
                        <strong>@Model.Display(employee.DirectManager)</strong>
                    </div>

                    @if (basicDynamicSection != null)
                    {
                        foreach (var field in basicDynamicSection.Fields
                            .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue))
                            .Take(3))
                        {
                            <div class="z360-contact-row">
                                <span>@field.FieldLabel</span>
                                <strong>@(field.IsCheckbox ? (field.IsCheckedValue ? "نعم" : "لا") : field.FieldValue)</strong>
                            </div>
                        }
                    }
                </div>

            </section>

            <section class="z360-command" aria-label="مركز التحكم والعمليات">
                <div class="z360-command-title">
                    <h2>مركز التحكم والعمليات (360)</h2>
                    <p>إجراءات ملف الموظف حسب الصلاحيات الممنوحة</p>
                </div>

                <div class="z360-actions">
                    @if (Model.CanEditEmployee)
                    {
                        <a asp-page="./Edit"
                           asp-route-id="@employee.Id"
                           class="z360-action z360-action-primary">
                            تعديل البيانات
                        </a>
                    }

                    @if (Model.CanOpenEmployeeDocuments)
                    {
                        <a asp-page="/EmployeeDocuments/Index"
                           asp-route-employeeId="@employee.Id"
                           class="z360-action">
                            إضافة مستند
                        </a>
                    }
                    else if (Model.CanUploadDocument)
                    {
                        <a href="#profile-files" class="z360-action">إضافة مستند</a>
                    }

                    @if (employee.IsActive && Model.CanEndService)
                    {
                        <a asp-page="./EndService"
                           asp-route-id="@employee.Id"
                           class="z360-action z360-action-danger">
                            إنهاء الخدمة
                        </a>
                    }
                    else if (!employee.IsActive && Model.CanRehire)
                    {
                        <button type="button"
                                class="z360-action z360-action-success"
                                data-nxr-reassign-open>
                            إعادة تعيين
                        </button>
                    }

                    @if (Model.CanViewDirectory)
                    {
                        <a asp-page="./Index" class="z360-action">رجوع للقائمة</a>
                    }
                </div>
            </section>

            @if (!employee.IsActive && Model.CanRehire)
            {
                <div class="z360-modal"
                     data-nxr-reassign-modal
                     hidden>
                    <div class="z360-modal-dialog"
                         role="dialog"
                         aria-modal="true"
                         aria-labelledby="z360-reassign-title">
                        <div class="z360-modal-head">
                            <div>
                                <strong id="z360-reassign-title">إعادة تعيين الموظف</strong>
                                <span>راجع البيانات السابقة وحدد موقع العمل الجديد قبل الحفظ.</span>
                            </div>
                            <button type="button"
                                    class="z360-modal-close"
                                    data-nxr-reassign-close
                                    aria-label="إغلاق">&times;</button>
                        </div>

                        <form method="post"
                              asp-page-handler="ReassignFromModalV2"
                              asp-route-id="@employee.Id">
                            <div class="z360-modal-body">
                                <section class="z360-modal-section">
                                    <h4>البيانات السابقة</h4>
                                    <div class="z360-old-grid">
                                        <div><span>الكود</span><strong>@Model.Display(employee.EmployeeNo)</strong></div>
                                        <div><span>الاسم</span><strong>@Model.Display(employee.FullName)</strong></div>
                                        <div><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                                        <div><span>موقع العمل</span><strong>@Model.Display(employee.BranchName)</strong></div>
                                        <div><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                                        <div><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                                        <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                                        <div><span>الحالة السابقة</span><strong>@Model.Display(employee.EmploymentStatus)</strong></div>
                                    </div>
                                </section>

                                <section class="z360-modal-section">
                                    <h4>التعديل قبل الحفظ</h4>
                                    <div class="z360-edit-grid">
                                        <label>
                                            <span>الشركة</span>
                                            <select name="ReassignCompanyId" data-nxr-reassign-company>
                                                @foreach (var company in Model.ReassignCompanies)
                                                {
                                                    <option value="@company.Id"
                                                            selected="@(company.Id == Model.CurrentReassignCompanyId ? "selected" : null)">
                                                        @Model.Display(company.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>موقع العمل</span>
                                            <select name="ReassignBranchId" data-nxr-reassign-branch>
                                                @foreach (var branch in Model.ReassignBranches)
                                                {
                                                    <option value="@branch.Id"
                                                            data-company-id="@branch.CompanyId"
                                                            selected="@(branch.Id == Model.CurrentReassignBranchId ? "selected" : null)">
                                                        @Model.Display(branch.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>القسم</span>
                                            <select name="ReassignDepartmentId" data-nxr-reassign-department>
                                                @foreach (var department in Model.ReassignDepartments)
                                                {
                                                    <option value="@department.Id"
                                                            data-company-id="@department.CompanyId"
                                                            selected="@(department.Id == Model.CurrentReassignDepartmentId ? "selected" : null)">
                                                        @Model.Display(department.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>تاريخ المباشرة الجديد</span>
                                            <input type="date"
                                                   name="ReassignDate"
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                   required />
                                        </label>

                                        <label>
                                            <span>المنصب بعد إعادة التعيين</span>
                                            <input type="text"
                                                   name="ReassignPosition"
                                                   value="@employee.Position" />
                                        </label>

                                        <label class="z360-wide">
                                            <span>سبب إعادة التعيين</span>
                                            <textarea name="ReassignReason"
                                                      rows="3"
                                                      required></textarea>
                                        </label>

                                        <label class="z360-wide">
                                            <span>ملاحظات الموارد البشرية</span>
                                            <textarea name="ReassignNotes"
                                                      rows="3"></textarea>
                                        </label>
                                    </div>
                                </section>

                                <label class="z360-confirm">
                                    <input type="checkbox"
                                           name="ConfirmReassign"
                                           value="true"
                                           required />
                                    <span>أؤكد إعادة تفعيل الموظف وحفظ الحركة في السجل الوظيفي.</span>
                                </label>
                            </div>

                            <div class="z360-modal-actions">
                                <button type="button"
                                        class="z360-action"
                                        data-nxr-reassign-close>
                                    إلغاء
                                </button>
                                <button type="submit"
                                        class="z360-action z360-action-success">
                                    حفظ وإعادة التعيين
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <section class="z360-kpis" aria-label="مؤشرات الموظف">
                <div class="z360-kpi @healthClass">
                    <span class="z360-kpi-label">مؤشر الصحة الوظيفية</span>
                    <strong class="z360-kpi-value">@Model.Employee360HealthScore%</strong>
                    <small class="z360-kpi-note">@Model.Employee360HealthText</small>
                </div>
                <div class="z360-kpi @readinessClass">
                    <span class="z360-kpi-label">جاهزية الراتب</span>
                    <strong class="z360-kpi-value">@readinessText</strong>
                    <small class="z360-kpi-note">@Model.PayrollRiskItems ملاحظة</small>
                </div>
                <div class="z360-kpi">
                    <span class="z360-kpi-label">رصيد الإجازات</span>
                    <strong class="z360-kpi-value">—</strong>
                    <small class="z360-kpi-note">غير مربوط حالياً</small>
                </div>
                <div class="z360-kpi">
                    <span class="z360-kpi-label">العهد المسجلة</span>
                    <strong class="z360-kpi-value">—</strong>
                    <small class="z360-kpi-note">وحدة العهد غير مفعلة</small>
                </div>
            </section>

            <section class="z360-summary-grid" aria-label="ملخص بيانات الموظف">
                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>المعلومات الشخصية</h3>
                        @if (Model.CanEditEmployee)
                        {
                            <a asp-page="./Edit"
                               asp-route-id="@employee.Id"
                               class="z360-card-tool"
                               title="تعديل">✎</a>
                        }
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الرقم الوطني</span><strong>@Model.Display(employee.NationalId)</strong></div>
                        <div class="z360-field"><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
                        <div class="z360-field"><span>العمر</span><strong>@Z360Age(employee.BirthDate)</strong></div>
                        <div class="z360-field"><span>الحالة الاجتماعية</span><strong>@Z360MaritalStatus(employee.MaritalStatus, employee.Gender)</strong></div>
                        <div class="z360-field"><span>الجنس</span><strong>@Z360Gender(employee.Gender)</strong></div>
                        <div class="z360-field"><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                        <div class="z360-field"><span>البلد</span><strong>@Model.Display(employee.Country)</strong></div>
                        <div class="z360-field"><span>مواطن</span><strong>@(employee.IsCitizen ? "مواطن" : "وافد")</strong></div>
                        @if (!employee.IsCitizen || !string.IsNullOrWhiteSpace(employee.PassportNo))
                        {
                            <div class="z360-field"><span>رقم جواز السفر</span><strong>@Model.Display(employee.PassportNo)</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.SponsorName))
                        {
                            <div class="z360-field"><span>الكفيل</span><strong>@employee.SponsorName</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.Religion))
                        {
                            <div class="z360-field"><span>الديانة</span><strong>@employee.Religion</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.PersonalEmail))
                        {
                            <div class="z360-field"><span>البريد الشخصي</span><strong dir="ltr">@employee.PersonalEmail</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.PhoneExtension))
                        {
                            <div class="z360-field"><span>امتداد الهاتف</span><strong>@employee.PhoneExtension</strong></div>
                        }

                        @if (personalDynamicSection != null)
                        {
                            foreach (var field in personalDynamicSection.Fields
                                .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                            {
                                <div class="z360-field">
                                    <span>@field.FieldLabel</span>
                                    <strong>@(field.IsCheckbox ? (field.IsCheckedValue ? "نعم" : "لا") : field.FieldValue)</strong>
                                </div>
                            }
                        }
                    </div>
                </article>

                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>المعلومات الوظيفية</h3>
                        @if (Model.CanViewLifecycle)
                        {
                            <a asp-page="./Lifecycle"
                               asp-route-id="@employee.Id"
                               class="z360-card-tool"
                               title="السجل الوظيفي">↗</a>
                        }
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                        <div class="z360-field"><span>موقع العمل</span><strong>@Model.Display(employee.BranchName)</strong></div>
                        <div class="z360-field"><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                        <div class="z360-field"><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                        <div class="z360-field"><span>مدة العمل</span><strong>@Z360WorkDuration(employee.HireDate)</strong></div>
                        <div class="z360-field"><span>نوع العقد</span><strong>@Model.Display(employee.ContractType)</strong></div>
                        <div class="z360-field"><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>
                        @if (employee.JoiningDate.HasValue)
                        {
                            <div class="z360-field"><span>تاريخ المباشرة الفعلية</span><strong>@Model.DisplayDate(employee.JoiningDate)</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.WorkType))
                        {
                            <div class="z360-field"><span>نوع الدوام</span><strong>@employee.WorkType</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(employee.JobGrade))
                        {
                            <div class="z360-field"><span>الدرجة الوظيفية</span><strong>@employee.JobGrade</strong></div>
                        }

                        @if (jobDynamicSection != null)
                        {
                            foreach (var field in jobDynamicSection.Fields
                                .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                            {
                                <div class="z360-field">
                                    <span>@field.FieldLabel</span>
                                    <strong>@(field.IsCheckbox ? (field.IsCheckedValue ? "نعم" : "لا") : field.FieldValue)</strong>
                                </div>
                            }
                        }
                    </div>
                </article>

                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>تنبيهات ومخالفات</h3>
                        <span class="z360-card-tool" aria-hidden="true">!</span>
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field">
                            <span>الغيابات والتأخير</span>
                            <strong class="@(Model.AttendanceExceptionsCount > 0 ? "z360-value-danger" : "")">
                                @Model.AttendanceExceptionsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>بصمات ناقصة</span>
                            <strong class="@(Model.MissingCheckoutCount > 0 ? "z360-value-warning" : "")">
                                @Model.MissingCheckoutCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>طلبات معلقة</span>
                            <strong class="@(Model.PendingRequests > 0 ? "z360-value-warning" : "")">
                                @Model.PendingRequests
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>مستندات منتهية</span>
                            <strong class="@(Model.ExpiredDocumentsCount > 0 ? "z360-value-danger" : "")">
                                @Model.ExpiredDocumentsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>مستندات قرب الانتهاء</span>
                            <strong class="@(Model.ExpiringDocumentsCount > 0 ? "z360-value-warning" : "")">
                                @Model.ExpiringDocumentsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>حالة الملف</span>
                            <strong class="@(hasRequirements ? "z360-value-warning" : "z360-value-success")">
                                @(hasRequirements ? "يحتاج متابعة" : "مكتمل حالياً")
                            </strong>
                        </div>
                    </div>
                </article>

                @{
                    var fin = Model.FinancialInfo;
                    string finText(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v!;
                    string finMoney(decimal? v) => v.HasValue ? $"{v.Value:#,0.####} {fin?.Currency}".Trim() : "—";
                    var payText = fin?.PaymentMethod switch
                    {
                        "Cash" or "نقدا" => "نقداً",
                        "Cheque" or "شيك" => "شيك",
                        "Bank" or "البنك" => "تحويل بنكي",
                        _ => finText(fin?.PaymentMethod)
                    };
                }
                @* الحقول الحساسة: بطاقة الرواتب تظهر فقط للأدوار المخوّلة (Sensitive.SalaryRoles) *@
                <article class="z360-card" hidden="@(!Model.CanViewSalary)">
                    <div class="z360-card-head">
                        <h3>المعلومات المالية</h3>
                        <a class="z360-card-tool" asp-page="./FinancialInfo" asp-route-id="@Model.Id" title="تعديل المعلومات المالية">✎</a>
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الراتب الأساسي</span><strong>@finMoney(fin?.BasicSalary)</strong></div>
                        <div class="z360-field"><span>الراتب الكلي</span><strong>@finMoney((fin?.BasicSalary ?? 0) + Model.ActiveAllowancesTotal)</strong></div>
                        <div class="z360-field"><span>العملة</span><strong>@finText(fin?.Currency)</strong></div>
                        <div class="z360-field"><span>سلم الرواتب</span><strong>@finText(fin?.SalaryScale)</strong></div>
                        <div class="z360-field"><span>طريقة الدفع</span><strong>@payText</strong></div>
                        @if (payText == "تحويل بنكي")
                        {
                            @* بيانات البنك تعني شيئاً فقط عند الدفع بالتحويل البنكي *@
                            <div class="z360-field"><span>البنك</span><strong>@finText(fin?.BankName)</strong></div>
                            <div class="z360-field"><span>IBAN</span><strong>@finText(fin?.Iban)</strong></div>
                        }
                        <div class="z360-field"><span>الضمان الاجتماعي</span><strong>@finText(fin?.SocialSecurityType)</strong></div>
                        <div class="z360-field"><span>ملف الضريبة</span><strong>@finText(fin?.TaxFile)</strong></div>
                        <div class="z360-field"><span>احتساب الراتب</span><strong>@(fin?.StopSalaryCalc == true ? "موقوف" : "مُفعّل")</strong></div>
                        <div class="z360-field"><span>جاهزية الراتب</span><strong>@readinessText</strong></div>
                    </div>
                </article>

            </section>

            @* قسم «معلومات إضافية» مخفي مؤقتاً بطلب المستخدم (2026-07-21) — أزل `false &&` لإرجاعه *@
            @if (false && additionalDynamicSections.Count > 0)
            {
                <section class="z360-module-grid" aria-label="معلومات إضافية">
                    @foreach (var profileSection in additionalDynamicSections)
                    {
                        <article class="z360-module">
                            <div class="z360-module-head">
                                <div>
                                    <h3>@profileSection.Label</h3>
                                    <p>بيانات إضافية مرتبطة بملف الموظف.</p>
                                </div>
                            </div>
                            <div class="z360-fields">
                                @foreach (var field in profileSection.Fields
                                    .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                                {
                                    <div class="z360-field">
                                        <span>@field.FieldLabel</span>
                                        <strong>@(field.IsCheckbox ? (field.IsCheckedValue ? "نعم" : "لا") : field.FieldValue)</strong>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </section>
            }

            @if (hasRequirements)
            {
                <section class="z360-requirements">
                    <div class="z360-section-head">
                        <div>
                            <h3>متطلبات الموظف</h3>
                            <p>الملاحظات التي تحتاج متابعة قبل اعتماد الملف أو إغلاق الراتب.</p>
                        </div>
                        <span class="z360-status-pill">توجد متطلبات تحتاج متابعة</span>
                    </div>

                    <div class="z360-requirement-grid">
                        @if (!documentHasId)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>هوية / بطاقة وطنية مفقودة</strong>
                                <span>هذا المستند مطلوب لكل موظف.</span>
                            </div>
                        }
                        @if (!documentHasContract)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>عقد العمل مفقود</strong>
                                <span>العقد مطلوب لاكتمال ملف الموظف.</span>
                            </div>
                        }
                        @if (isExpat && !documentHasPassport)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>جواز السفر مفقود</strong>
                                <span>مطلوب للموظفين الوافدين.</span>
                            </div>
                        }
                        @if (isExpat && !documentHasVisa)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>الإقامة / الفيزا مفقودة</strong>
                                <span>مطلوبة للموظفين الوافدين.</span>
                            </div>
                        }
                        @if (Model.PayrollRiskItems > 0)
                        {
                            <div class="z360-requirement">
                                <strong>جاهزية الراتب</strong>
                                <span>يوجد @Model.PayrollRiskItems ملاحظة تحتاج مراجعة.</span>
                            </div>
                        }
                        @if (Model.AttendanceExceptionsCount > 0)
                        {
                            <div class="z360-requirement">
                                <strong>استثناءات الحضور</strong>
                                <span>يوجد @Model.AttendanceExceptionsCount حالة تحتاج تدقيق.</span>
                            </div>
                        }
                        @if (Model.PendingRequests > 0)
                        {
                            <div class="z360-requirement">
                                <strong>طلبات معلقة</strong>
                                <span>يوجد @Model.PendingRequests طلب بانتظار الإجراء.</span>
                            </div>
                        }
                        @if (Model.ExpiredDocumentsCount > 0)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>مستندات منتهية</strong>
                                <span>يوجد @Model.ExpiredDocumentsCount مستند منتهي.</span>
                            </div>
                        }
                        @if (Model.ExpiringDocumentsCount > 0)
                        {
                            <div class="z360-requirement">
                                <strong>مستندات قرب الانتهاء</strong>
                                <span>يوجد @Model.ExpiringDocumentsCount مستند يحتاج متابعة.</span>
                            </div>
                        }
                        @if (contractNeedsReview)
                        {
                            <div class="z360-requirement">
                                <strong>العقد يحتاج متابعة</strong>
                                <span>نهاية العقد: @Model.DisplayDate(employee.ContractEndDate)</span>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (!string.IsNullOrEmpty(Model.PanelSuccess))
            {
                <div class="hrms-badge approved" style="padding:10px 14px;margin-bottom:10px">@Model.PanelSuccess</div>
            }
            @if (!string.IsNullOrEmpty(Model.PanelError))
            {
                <div class="hrms-badge rejected" style="padding:10px 14px;margin-bottom:10px">@Model.PanelError</div>
            }

            <section class="z360-details">
                <nav class="z360-detail-nav" aria-label="أقسام ملف الموظف" data-z360-tabs>
                    <a href="#attendance" data-z360-tab="attendance" class="is-active">الحضور</a>
                    <a href="#requests" data-z360-tab="requests">الطلبات</a>
                    <a href="#documents" data-z360-tab="documents">المستندات</a>
                    <a href="#profile-files" data-z360-tab="profile-files">ملفات الموظف</a>
                    <a href="#shifts" data-z360-tab="shifts">الشفتات</a>
                    <a href="#timeline" data-z360-tab="timeline">الخط الزمني</a>
                    @if (Model.CanViewHistory)
                    {
                        <a href="#audit" data-z360-tab="audit">سجل التعديلات</a>
                    }
                </nav>

                <div class="z360-module-grid">
                    <article id="attendance" class="z360-module z360-module-wide">
                        <div class="z360-module-head">
                            <div>
                                <h3>الحضور والانصراف</h3>
                                <p>السجلات والاستثناءات ضمن الفترة المحددة.</p>
                            </div>
                        </div>

                        <form method="get" class="z360-filter">
                            <input type="hidden" name="Id" value="@employee.Id" />
                            <label>
                                <span>من تاريخ</span>
                                <input type="date"
                                       name="FromDate"
                                       value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                            </label>
                            <label>
                                <span>إلى تاريخ</span>
                                <input type="date"
                                       name="ToDate"
                                       value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                            </label>
                            <button type="submit" class="z360-action z360-action-primary">تحديث الفترة</button>
                            <a asp-page="./Profile"
                               asp-route-id="@employee.Id"
                               class="z360-action">آخر 30 يوم</a>
                        </form>

                        <div class="z360-mini-kpis">
                            <div class="z360-mini-kpi"><span>السجلات</span><strong>@Model.AttendanceCount</strong></div>
                            <div class="z360-mini-kpi"><span>الحضور</span><strong>@Model.PresentCount</strong></div>
                            <div class="z360-mini-kpi"><span>التأخير</span><strong>@Model.LateCount</strong></div>
                            <div class="z360-mini-kpi"><span>الغياب</span><strong>@Model.AbsentCount</strong></div>
                            <div class="z360-mini-kpi"><span>بصمات ناقصة</span><strong>@Model.MissingCheckoutCount</strong></div>
                            <div class="z360-mini-kpi"><span>ساعات العمل</span><strong>@Model.TotalWorkingHours</strong></div>
                        </div>

                        <div class="z360-table-wrap">
                            <table class="z360-table">
                                <thead>
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>الدخول</th>
                                        <th>الخروج</th>
                                        <th>الجهاز</th>
                                        <th>الحالة</th>
                                        <th>الملاحظات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.AttendanceRows.Any())
                                    {
                                        foreach (var row in Model.AttendanceRows.Take(15))
                                        {
                                            <tr>
                                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                                <td>@Model.Display(row.DeviceName)</td>
                                                <td>
                                                    <span class="z360-badge @Z360AttendanceClass(row.Status)">
                                                        @Model.StatusText(row.Status)
                                                    </span>
                                                </td>
                                                <td>@Model.DisplayAttendanceNote(row.Notes)</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6">
                                                <div class="z360-empty">لا توجد سجلات حضور ضمن هذه الفترة.</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <article id="requests" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>الطلبات</h3>
                                <p>آخر طلبات الموظف والخدمة الذاتية.</p>
                            </div>
                            <span class="z360-badge z360-badge-warn">@Model.PendingRequests معلق</span>
                        </div>

                        @if (Model.RequestRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.RequestRows.Take(8))
                                {
                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.RequestType)</strong>
                                            <span>@Model.DisplayDate(row.RequestDate) · @Model.Display(row.CurrentStep)</span>
                                        </div>
                                        <span class="z360-badge @Z360RequestClass(row.Status)">
                                            @Model.RequestStatusText(row.Status)
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد طلبات محفوظة.</div>
                        }
                    </article>

                    <article id="documents" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>المستندات</h3>
                                <p>آخر المستندات الرسمية المرتبطة بالموظف.</p>
                            </div>
                            @if (Model.CanOpenEmployeeDocuments)
                            {
                                <a asp-page="/EmployeeDocuments/Index"
                                   asp-route-employeeId="@employee.Id"
                                   class="z360-action">فتح المركز</a>
                            }
                        </div>

                        @if (Model.DocumentRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.DocumentRows.Take(8))
                                {
                                    var documentClass =
                                        !row.ExpiryDate.HasValue ? string.Empty :
                                        row.ExpiryDate.Value < today ? "z360-badge-danger" :
                                        row.ExpiryDate.Value <= today.AddDays(30) ? "z360-badge-warn" :
                                        "z360-badge-ok";

                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.DocumentType)</strong>
                                            <span>@Model.Display(row.FileName)</span>
                                            <small>@(row.ExpiryDate.HasValue ? $"ينتهي: {row.ExpiryDate:yyyy-MM-dd}" : "بدون تاريخ انتهاء")</small>
                                        </div>
                                        <div class="z360-file-actions">
                                            <span class="z360-badge @documentClass">
                                                @(row.ExpiryDate.HasValue ? Model.DisplayDate(row.ExpiryDate) : "مفتوح")
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(row.StoredPath))
                                            {
                                                <a href="@row.StoredPath" target="_blank">فتح</a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد مستندات محفوظة لهذا الموظف.</div>
                        }
                    </article>

                    <article id="profile-files" class="z360-module z360-module-wide">
                        <div class="z360-module-head">
                            <div>
                                <h3>ملفات الموظف</h3>
                                <p>الخبرات والشهادات والملفات الطبية والتدريب والتعليم.</p>
                            </div>
                        </div>

                        <div class="z360-files-grid">
                            @{
                                var recordCards = new[]
                                {
                                    new { Type = EmployeeRecordType.Experience, Title = "الخبرات", TitleLabel = "اسم الشركة", SubLabel = "المسمى الوظيفي", RefLabel = "رقم مرجعي", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Certificate, Title = "الشهادات", TitleLabel = "اسم الشهادة", SubLabel = "جهة الإصدار", RefLabel = "رقم المرجع", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Medical, Title = "الملفات الطبية", TitleLabel = "الحالة الطبية", SubLabel = "تفاصيل", RefLabel = "رقم مرجعي", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Training, Title = "الدورات التدريبية", TitleLabel = "اسم الدورة", SubLabel = "الجهة", RefLabel = "رقم مرجعي", ShowAmount = true, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Education, Title = "التعليم", TitleLabel = "الجامعة / المؤسسة", SubLabel = "الدرجة والتخصص", RefLabel = "رقم مرجعي", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Asset, Title = "العهد", TitleLabel = "اسم العهدة", SubLabel = "النوع", RefLabel = "رقم مرجعي", ShowAmount = true, ShowCurrent = true, CurrentLabel = "بحوزة الموظف" },
                                    new { Type = EmployeeRecordType.Address, Title = "العنوان", TitleLabel = "العنوان", SubLabel = "المنطقة", RefLabel = "رقم مرجعي", ShowAmount = false, ShowCurrent = true, CurrentLabel = "العنوان الحالي" },
                                    new { Type = EmployeeRecordType.EmergencyContact, Title = "جهات الطوارئ", TitleLabel = "الاسم", SubLabel = "صلة القرابة", RefLabel = "رقم الهاتف", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" },
                                    new { Type = EmployeeRecordType.Residency, Title = "الإقامة", TitleLabel = "نوع الإقامة", SubLabel = "الحالة", RefLabel = "رقم الإقامة", ShowAmount = false, ShowCurrent = false, CurrentLabel = "" }
                                };
                            }
                            @foreach (var card in recordCards)
                            {
                                var records = Model.RecordsOf(card.Type).ToList();
                                <section class="z360-file-card">
                                    <div class="z360-file-card-head">
                                        <h4>@card.Title</h4>
                                        <button type="button" class="z360-upload-label" title="إضافة"
                                                data-hrms-open="rec-form"
                                                onclick="hrmsOpenRecord('@card.Type', '@card.Title', '@card.TitleLabel', '@card.SubLabel', '@card.RefLabel', @card.ShowAmount.ToString().ToLowerInvariant(), @card.ShowCurrent.ToString().ToLowerInvariant(), '@card.CurrentLabel')">+</button>
                                    </div>

                                    @if (records.Any())
                                    {
                                        <div class="z360-file-items">
                                            @foreach (var r in records)
                                            {
                                                <div class="z360-file-item">
                                                    <div class="z360-file-item-main">
                                                        <strong>@r.Title@(r.IsCurrent ? " ✓" : "")</strong>
                                                        <span>@r.Subtitle@(r.Amount.HasValue ? " · " + r.Amount.Value.ToString("0.##") : "")@(r.ToDate.HasValue ? " · " + r.ToDate.Value.ToString("yyyy") : "")@(string.IsNullOrWhiteSpace(r.Country) ? "" : " · " + r.Country)</span>
                                                        @* القيم المخصصة (حقول الكيانات) تظهر على البطاقة نفسها لا بالسلايد فقط *@
                                                        @{
                                                            var typeKey = r.RecordType.ToString();
                                                            var cfDefs = Model.CustomFieldsOf(typeKey);
                                                            var cfVals = Model.CustomFieldValues.TryGetValue(typeKey, out var byRec) && byRec.TryGetValue(r.Id, out var vals) ? vals : null;
                                                        }
                                                        @if (cfVals != null && cfDefs.Count > 0)
                                                        {
                                                            var cfParts = cfDefs
                                                                .Where(f => cfVals.TryGetValue(f.FieldKey, out var v) && !string.IsNullOrWhiteSpace(v))
                                                                .Select(f => f.FieldLabel + ": " + (f.IsCheckbox ? "نعم" : cfVals[f.FieldKey]))
                                                                .ToList();
                                                            @if (cfParts.Count > 0)
                                                            {
                                                                <span style="color:#67e8f9;font-size:11px;font-weight:800">@string.Join(" · ", cfParts)</span>
                                                            }
                                                        }
                                                    </div>
                                                    <div class="z360-file-actions">
                                                        @if (!string.IsNullOrWhiteSpace(r.AttachmentPath))
                                                        {
                                                            <a href="@r.AttachmentPath" target="_blank">الملف</a>
                                                        }
                                                        <button type="button" class="rec-open"
                                                                data-type="@r.RecordType" data-card-title="@card.Title" data-title-label="@card.TitleLabel" data-sub-label="@card.SubLabel"
                                                                data-ref-label="@card.RefLabel" data-show-amount="@card.ShowAmount.ToString().ToLowerInvariant()" data-show-current="@card.ShowCurrent.ToString().ToLowerInvariant()" data-current-label="@card.CurrentLabel"
                                                                data-id="@r.Id" data-title="@r.Title" data-subtitle="@r.Subtitle" data-country="@r.Country" data-refno="@r.RefNo"
                                                                data-fromdate="@(r.FromDate?.ToString("yyyy-MM-dd"))" data-todate="@(r.ToDate?.ToString("yyyy-MM-dd"))" data-amount="@(r.Amount?.ToString("0.##"))" data-iscurrent="@r.IsCurrent.ToString().ToLowerInvariant()" data-note="@r.Note"
                                                                data-gpa="@r.Gpa" data-returndate="@(r.ReturnDate?.ToString("yyyy-MM-dd"))" data-isreturned="@r.IsReturned.ToString().ToLowerInvariant()"
                                                                data-refcontactname="@r.RefContactName" data-refcontactposition="@r.RefContactPosition" data-refcontactphone="@r.RefContactPhone" data-refcontactnote="@r.RefContactNote"
                                                                data-hrms-open="rec-form">تعديل</button>
                                                        <form method="post" asp-page-handler="DeleteRecord" asp-route-id="@Model.Id" onsubmit="return confirm('هل تريد الحذف؟');">
                                                            <input type="hidden" name="recordId" value="@r.Id" />
                                                            <button type="submit">حذف</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="z360-empty">لا توجد سجلات.</div>
                                    }
                                </section>
                            }

                            <section class="z360-file-card">
                                <div class="z360-file-card-head">
                                    <h4>العائلة والمعالون</h4>
                                    <button type="button" class="z360-upload-label" data-hrms-open="dep-form" onclick="hrmsResetForm('dep')" title="إضافة معال">+</button>
                                </div>
                                @if (Model.Dependents.Any())
                                {
                                    <div class="z360-file-items">
                                        @foreach (var d in Model.Dependents)
                                        {
                                            <div class="z360-file-item">
                                                <div class="z360-file-item-main">
                                                    <strong>@d.Name</strong>
                                                    <span>@Model.RelationText(d.Relation)@(d.IsDependent ? " · معال" : "")@(d.IsEmergencyContact ? " · طوارئ" : "")</span>
                                                    @{
                                                        var depDefs = Model.CustomFieldsOf("Dependent");
                                                        var depVals = Model.CustomFieldValues.TryGetValue("Dependent", out var depByRec) && depByRec.TryGetValue(d.Id, out var dv) ? dv : null;
                                                    }
                                                    @if (depVals != null && depDefs.Count > 0)
                                                    {
                                                        var depParts = depDefs
                                                            .Where(f => depVals.TryGetValue(f.FieldKey, out var v) && !string.IsNullOrWhiteSpace(v))
                                                            .Select(f => f.FieldLabel + ": " + (f.IsCheckbox ? "نعم" : depVals[f.FieldKey]))
                                                            .ToList();
                                                        @if (depParts.Count > 0)
                                                        {
                                                            <span style="color:#67e8f9;font-size:11px;font-weight:800">@string.Join(" · ", depParts)</span>
                                                        }
                                                    }
                                                </div>
                                                <div class="z360-file-actions">
                                                    <button type="button" class="rec-edit" data-form="dep"
                                                            data-id="@d.Id" data-relation="@d.Relation" data-name="@d.Name" data-nameother="@d.NameOther"
                                                            data-birthdate="@(d.BirthDate?.ToString("yyyy-MM-dd"))" data-marriagedate="@(d.MarriageDate?.ToString("yyyy-MM-dd"))"
                                                            data-religion="@d.Religion" data-nationality="@d.Nationality" data-nationalid="@d.NationalId" data-passportno="@d.PassportNo"
                                                            data-iscitizen="@d.IsCitizen.ToString().ToLowerInvariant()" data-maritalstatus="@d.MaritalStatus"
                                                            data-residencyno="@d.ResidencyNo" data-gender="@d.Gender" data-isstudent="@d.IsStudent.ToString().ToLowerInvariant()"
                                                            data-isemergencycontact="@d.IsEmergencyContact.ToString().ToLowerInvariant()" data-isspecialneeds="@d.IsSpecialNeeds.ToString().ToLowerInvariant()"
                                                            data-isworking="@d.IsWorking.ToString().ToLowerInvariant()" data-isdependent="@d.IsDependent.ToString().ToLowerInvariant()"
                                                            data-mobilephone="@d.MobilePhone" data-companyname="@d.CompanyName" data-note="@d.Note"
                                                            data-hrms-open="dep-form">تعديل</button>
                                                    <form method="post" asp-page-handler="DeleteDependent" asp-route-id="@Model.Id" onsubmit="return confirm('هل تريد الحذف؟');">
                                                        <input type="hidden" name="recordId" value="@d.Id" />
                                                        <button type="submit">حذف</button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="z360-empty">لا يوجد معالون.</div>
                                }
                            </section>

                            @* ---------- العلاوات (نمط كيان) — حساسة: للأدوار المخوّلة فقط ---------- *@
                            <section class="z360-file-card" hidden="@(!Model.CanViewSalary)">
                                <div class="z360-file-card-head">
                                    <h4>العلاوات</h4>
                                    <button type="button" class="z360-upload-label" title="إضافة علاوة"
                                            onclick="allowanceOpen(0,'','',this)" data-hrms-open="allowance-form">+</button>
                                </div>
                                @if (Model.Allowances.Any())
                                {
                                    var todayAllow = DateOnly.FromDateTime(DateTime.Today);
                                    <div class="z360-fields" style="margin-bottom:8px">
                                        <div class="z360-field"><span>إجمالي العلاوات النشطة</span><strong>@Model.ActiveAllowancesTotal.ToString("#,0.##") @(Model.FinancialInfo?.Currency)</strong></div>
                                    </div>
                                    <div class="z360-table-wrap">
                                        <table class="z360-table">
                                            <thead><tr><th>الاسم</th><th>المبلغ</th><th>من – إلى</th><th>الحالة</th><th></th></tr></thead>
                                            <tbody>
                                                @foreach (var allowance in Model.Allowances)
                                                {
                                                    var isActive = allowance.IsActiveOn(todayAllow);
                                                    <tr>
                                                        <td>@allowance.ItemName</td>
                                                        <td>@allowance.Amount.ToString("#,0.##")</td>
                                                        <td>@allowance.FromDate.ToString("yyyy-MM-dd") @(allowance.ToDate.HasValue ? "– " + allowance.ToDate.Value.ToString("yyyy-MM-dd") : "(مفتوحة)")</td>
                                                        <td><span class="z360-badge @(isActive ? "z360-badge-ok" : "z360-badge-warn")">@(isActive ? "نشطة" : "توقفت")</span></td>
                                                        <td style="white-space:nowrap">
                                                            <button type="button" class="z360-card-tool" title="تعديل" data-hrms-open="allowance-form"
                                                                    onclick="allowanceOpen(@allowance.Id,'@Html.Raw(allowance.ItemName.Replace("'", "\\'"))',@allowance.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture),this,'@allowance.FromDate.ToString("yyyy-MM-dd")','@(allowance.ToDate?.ToString("yyyy-MM-dd") ?? "")',@(allowance.EndAfterDate ? "true" : "false"),'@Html.Raw((allowance.Note ?? "").Replace("'", "\\'"))')">✎</button>
                                                            <form method="post" asp-page-handler="DeleteAllowance" asp-route-id="@Model.Id" style="display:inline" onsubmit="return confirm('حذف العلاوة؟');">
                                                                <input type="hidden" name="recordId" value="@allowance.Id" />
                                                                <button type="submit" class="z360-card-tool" title="حذف">🗑</button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="z360-empty">لا توجد علاوات — أضف أول علاوة من زر +.</div>
                                }
                            </section>

                            @* ---------- العقود (نمط كيان: متعددة، التجديد صف جديد) ---------- *@
                            <section class="z360-file-card">
                                <div class="z360-file-card-head">
                                    <h4>العقود</h4>
                                    <button type="button" class="z360-upload-label" title="إضافة عقد"
                                            onclick="contractOpen(0)" data-hrms-open="contract-form">+</button>
                                </div>
                                @if (Model.Contracts.Any())
                                {
                                    var todayContract = DateOnly.FromDateTime(DateTime.Today);
                                    <div class="z360-table-wrap">
                                        <table class="z360-table">
                                            <thead><tr><th>رقم العقد</th><th>النوع</th><th>من – إلى</th><th>الأيام المتبقية</th><th>الحالي</th><th></th></tr></thead>
                                            <tbody>
                                                @foreach (var contract in Model.Contracts)
                                                {
                                                    var remaining = contract.RemainingDays(todayContract);
                                                    <tr>
                                                        <td>@(string.IsNullOrWhiteSpace(contract.ContractNo) ? "—" : contract.ContractNo)</td>
                                                        <td>@contract.ContractType</td>
                                                        <td>@contract.FromDate.ToString("yyyy-MM-dd") @(contract.ToDate.HasValue ? "– " + contract.ToDate.Value.ToString("yyyy-MM-dd") : "– غير محدود")</td>
                                                        <td>@(remaining.HasValue ? $"{remaining} يوم" : "—")</td>
                                                        <td>@(contract.IsCurrent ? "✔" : "")</td>
                                                        <td style="white-space:nowrap">
                                                            @if (!string.IsNullOrWhiteSpace(contract.AttachmentPath))
                                                            {
                                                                <a class="z360-card-tool" href="@contract.AttachmentPath" target="_blank" title="العقد الموقع">📄</a>
                                                            }
                                                            <button type="button" class="z360-card-tool" title="تعديل" data-hrms-open="contract-form"
                                                                    onclick="contractOpen(@contract.Id,'@Html.Raw((contract.ContractNo ?? "").Replace("'", "\\'"))','@Html.Raw(contract.ContractType.Replace("'", "\\'"))','@contract.FromDate.ToString("yyyy-MM-dd")','@(contract.ToDate?.ToString("yyyy-MM-dd") ?? "")',@(contract.IsCurrent ? "true" : "false"),'@Html.Raw((contract.Note ?? "").Replace("'", "\\'"))')">✎</button>
                                                            <form method="post" asp-page-handler="DeleteContract" asp-route-id="@Model.Id" style="display:inline" onsubmit="return confirm('حذف العقد؟');">
                                                                <input type="hidden" name="recordId" value="@contract.Id" />
                                                                <button type="submit" class="z360-card-tool" title="حذف">🗑</button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="z360-empty">لا توجد عقود — أضف أول عقد من زر +.</div>
                                }
                            </section>

                            @* ---------- الإجازات (دفتر استحقاقات بنمط كيان) ---------- *@
                            <section class="z360-file-card">
                                <div class="z360-file-card-head">
                                    <h4>الإجازات — سنة @Model.LeaveLedgerYear</h4>
                                    <a class="z360-upload-label" href="/LeaveBalances/Adjust?employeeId=@Model.Id&year=@Model.LeaveLedgerYear" title="ضبط الأرصدة">✎</a>
                                </div>
                                <div class="z360-table-wrap">
                                    <table class="z360-table">
                                        <thead><tr><th>النوع</th><th>الرصيد السابق</th><th>الاستحقاق</th><th>المستخدم</th><th>الرصيد الحالي</th></tr></thead>
                                        <tbody>
                                            @foreach (var ledger in Model.LeaveLedger)
                                            {
                                                <tr>
                                                    <td>@Model.LeaveTypeText(ledger.Type)</td>
                                                    <td>@ledger.CarriedOver.ToString("0.#") يوم</td>
                                                    <td>@ledger.Entitled.ToString("0.#") يوم</td>
                                                    <td>@ledger.Used.ToString("0.#") يوم</td>
                                                    <td><strong style="@(ledger.Current < 0 ? "color:#f87171" : "")">@ledger.Current.ToString("0.#") يوم</strong></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        </div>
                    </article>

                    <article id="shifts" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>الشفتات</h3>
                                <p>الشفتات الحالية والسابقة.</p>
                            </div>
                        </div>

                        @if (Model.ShiftRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.ShiftRows.Take(8))
                                {
                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.Name)</strong>
                                            <span>@row.StartTime - @row.EndTime · @Model.Display(row.WorkingHours)</span>
                                            <small>@Model.DisplayDate(row.EffectiveFrom) إلى @Model.DisplayDate(row.EffectiveTo)</small>
                                        </div>
                                        <span class="z360-badge @(row.IsCurrent ? "z360-badge-ok" : "")">
                                            @(row.IsCurrent ? "حالي" : "سابق")
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد شفتات مرتبطة.</div>
                        }
                    </article>

                    @* الخط الزمني الموحّد: كل أحداث الموظف من كل المصادر بترتيب زمني *@
                    <article id="timeline" class="z360-module" hidden>
                        <div class="z360-module-head">
                            <div>
                                <h3>الخط الزمني</h3>
                                <p>رحلة الموظف كاملة: تعيين، عقود، حركات، مخالفات، طلبات، وملفات.</p>
                            </div>
                        </div>
                        @if (Model.TimelineEvents.Count == 0)
                        {
                            <p style="color:var(--sa-muted,#8FA8BC);font-weight:800;padding:12px">لا أحداث مسجلة بعد.</p>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:0;position:relative;padding-inline-start:6px">
                                @foreach (var ev in Model.TimelineEvents)
                                {
                                    <div style="display:grid;grid-template-columns:34px 110px 1fr;gap:10px;align-items:start;padding:9px 0;border-bottom:1px solid rgba(143,168,188,.08)">
                                        <span style="font-size:16px;text-align:center">@ev.Icon</span>
                                        <span style="font-size:11px;color:var(--sa-muted,#8FA8BC);font-weight:800;direction:ltr;text-align:end">@ev.EventDate.ToString("yyyy-MM-dd")</span>
                                        <span style="font-size:13px">
                                            <b style="font-weight:900">@ev.Title</b>
                                            @if (!string.IsNullOrWhiteSpace(ev.Detail))
                                            {
                                                <small style="display:block;color:var(--sa-muted,#8FA8BC);font-weight:700">@ev.Detail</small>
                                            }
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                    </article>

                    @if (Model.CanViewHistory)
                    {
                        <article id="audit" class="z360-module">
                            <div class="z360-module-head">
                                <div>
                                    <h3>سجل التعديلات</h3>
                                    <p>آخر الحركات المسجلة على ملف الموظف.</p>
                                </div>
                            </div>

                            @if (Model.AuditRows.Any())
                            {
                                <div class="z360-list">
                                    @foreach (var row in Model.AuditRows.Take(8))
                                    {
                                        <div class="z360-list-row">
                                            <div class="z360-list-main">
                                                <strong>@Model.Display(row.Action)</strong>
                                                <span>@Model.Display(row.UserName) · @Model.Display(row.IpAddress)</span>
                                            </div>
                                            <small>@Model.DisplayDateTime(row.CreatedAt)</small>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="z360-empty">لا توجد تعديلات مسجلة.</div>
                            }
                        </article>
                    }
                </div>
            </section>
        </div>
    }
</div>

@* ---------- Slide-over: dependent ---------- *@
<aside class="hrms-slideover wide" id="dep-form" aria-hidden="true">
    <div class="hrms-slideover-head"><h2 id="dep-form-title">إضافة معال</h2><button type="button" class="hrms-slideover-close" data-hrms-close>×</button></div>
    <div class="hrms-slideover-body">
        <form method="post" asp-page-handler="SaveDependent" asp-route-id="@Model.Id" class="hrms-page">
            <input type="hidden" name="Dependent.Id" id="dep-Id" value="0" />
            <div class="hrms-grid-2">
                <div class="hrms-field"><label>صلة القرابة</label>
                    <select name="Dependent.Relation" id="dep-Relation">
                        <option value="Spouse">شريك</option>
                        <option value="Son">إبن</option>
                        <option value="Daughter">بنت</option>
                        <option value="Relative">قريب</option>
                    </select>
                </div>
                <div class="hrms-field"><label>الاسم</label><input name="Dependent.Name" id="dep-Name" required /></div>
                <div class="hrms-field"><label>الاسم (لغة أخرى)</label><input name="Dependent.NameOther" id="dep-NameOther" /></div>
                <div class="hrms-field"><label>تاريخ الميلاد</label><input type="date" name="Dependent.BirthDate" id="dep-BirthDate" /></div>
                <div class="hrms-field"><label>تاريخ الزواج</label><input type="date" name="Dependent.MarriageDate" id="dep-MarriageDate" /></div>
                <div class="hrms-field"><label>الديانة</label><input name="Dependent.Religion" id="dep-Religion" /></div>
                <div class="hrms-field"><label>الجنسية</label><input name="Dependent.Nationality" id="dep-Nationality" /></div>
                <div class="hrms-field"><label>رقم الهوية</label><input name="Dependent.NationalId" id="dep-NationalId" /></div>
                <div class="hrms-field"><label>رقم الجواز</label><input name="Dependent.PassportNo" id="dep-PassportNo" /></div>
                <div class="hrms-field"><label>رقم الإقامة</label><input name="Dependent.ResidencyNo" id="dep-ResidencyNo" /></div>
                <div class="hrms-field"><label>الجنس</label>
                    <select name="Dependent.Gender" id="dep-Gender">
                        <option value="">اختر</option>
                        <option value="Male">ذكر</option>
                        <option value="Female">أنثى</option>
                    </select>
                </div>
                <div class="hrms-field"><label>الحالة الاجتماعية</label><input name="Dependent.MaritalStatus" id="dep-MaritalStatus" /></div>
                <div class="hrms-field"><label>هاتف محمول</label><input name="Dependent.MobilePhone" id="dep-MobilePhone" /></div>
                <div class="hrms-field"><label>اسم الشركة</label><input name="Dependent.CompanyName" id="dep-CompanyName" /></div>
            </div>
            <div class="hrms-inline-form" style="flex-wrap:wrap;gap:14px;margin:8px 0">
                <label><input type="checkbox" name="Dependent.IsDependent" id="dep-IsDependent" value="true" /> معال</label>
                <label><input type="checkbox" name="Dependent.IsEmergencyContact" id="dep-IsEmergencyContact" value="true" /> جهة طوارئ</label>
                <label><input type="checkbox" name="Dependent.IsSpecialNeeds" id="dep-IsSpecialNeeds" value="true" /> احتياجات خاصة</label>
                <label><input type="checkbox" name="Dependent.IsWorking" id="dep-IsWorking" value="true" /> عامل</label>
                <label><input type="checkbox" name="Dependent.IsStudent" id="dep-IsStudent" value="true" /> طالب</label>
                <label><input type="checkbox" name="Dependent.IsCitizen" id="dep-IsCitizen" value="true" /> مواطن</label>
            </div>
            <div class="hrms-field"><label>ملاحظة</label><input name="Dependent.Note" id="dep-Note" /></div>
            <partial name="_EntityCustomFields" model='new EntityCustomFieldsPartialModel { EntityKey = "Dependent", Fields = Model.CustomFieldsOf("Dependent") }' />
            <button type="submit" class="hrms-btn-primary">حفظ</button>
        </form>
    </div>
</aside>

@* ---------- Slide-over: allowance (علاوة) ---------- *@
<aside class="hrms-slideover" id="allowance-form" aria-hidden="true">
    <div class="hrms-slideover-head"><h2 id="allowance-form-title">إضافة علاوة</h2><button type="button" class="hrms-slideover-close" data-hrms-close>×</button></div>
    <div class="hrms-slideover-body">
        <form method="post" asp-page-handler="SaveAllowance" asp-route-id="@Model.Id" enctype="multipart/form-data" class="hrms-page">
            <input type="hidden" name="Allowance.Id" id="alw-Id" value="0" />
            <div class="hrms-field"><label>عنصر الراتب</label>
                <select name="Allowance.ItemName" id="alw-ItemName" required>
                    <option value="">اختر</option>
                    @foreach (var item in Model.SalaryItemOptions)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div class="hrms-field"><label>المبلغ</label><input type="number" step="0.0001" min="0" name="Allowance.Amount" id="alw-Amount" required /></div>
            <div class="hrms-field"><label>من تاريخ</label><input type="date" name="Allowance.FromDate" id="alw-FromDate" required /></div>
            <div class="hrms-field"><label>إلى تاريخ (اختياري — فارغ = مفتوحة)</label><input type="date" name="Allowance.ToDate" id="alw-ToDate" /></div>
            <label class="hrms-toggle"><input type="checkbox" name="Allowance.EndAfterDate" id="alw-EndAfterDate" value="true" /> إنهاء تلقائي بعد التاريخ</label>
            <div class="hrms-field"><label>ملاحظة</label><input name="Allowance.Note" id="alw-Note" /></div>
            <div class="hrms-field"><label>ملف مرفق (اختياري)</label><input type="file" name="AllowanceAttachment" accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx,.xls,.xlsx" /></div>
            <partial name="_EntityCustomFields" model='new EntityCustomFieldsPartialModel { EntityKey = "Allowance", Fields = Model.CustomFieldsOf("Allowance") }' />
            <button type="submit" class="hrms-btn-primary">حفظ العلاوة</button>
        </form>
    </div>
</aside>

<script>
    // تعبئة درج العلاوة للإضافة (id=0) أو التعديل (قيم الصف).
    function allowanceOpen(id, itemName, amount, btn, fromDate, toDate, endAfter, note) {
        document.getElementById('alw-Id').value = id || 0;
        document.getElementById('allowance-form-title').textContent = id ? 'تعديل العلاوة' : 'إضافة علاوة';
        var sel = document.getElementById('alw-ItemName');
        sel.value = itemName || '';
        if (itemName && sel.value !== itemName) { // قيمة قديمة مو بالقائمة
            var opt = document.createElement('option'); opt.value = itemName; opt.textContent = itemName; sel.appendChild(opt); sel.value = itemName;
        }
        document.getElementById('alw-Amount').value = amount || '';
        document.getElementById('alw-FromDate').value = fromDate || '';
        document.getElementById('alw-ToDate').value = toDate || '';
        document.getElementById('alw-EndAfterDate').checked = endAfter === true || endAfter === 'true';
        document.getElementById('alw-Note').value = note || '';
        if (window.hrmsCfFill) hrmsCfFill('Allowance', 'allowance-form', id || 0);
    }
</script>

@* ---------- Slide-over: contract (عقد) ---------- *@
<aside class="hrms-slideover" id="contract-form" aria-hidden="true">
    <div class="hrms-slideover-head"><h2 id="contract-form-title">إضافة عقد</h2><button type="button" class="hrms-slideover-close" data-hrms-close>×</button></div>
    <div class="hrms-slideover-body">
        <form method="post" asp-page-handler="SaveContract" asp-route-id="@Model.Id" enctype="multipart/form-data" class="hrms-page">
            <input type="hidden" name="Contract.Id" id="ctr-Id" value="0" />
            <div class="hrms-field"><label>رقم العقد</label><input name="Contract.ContractNo" id="ctr-ContractNo" /></div>
            <div class="hrms-field"><label>نوع العقد</label>
                <select name="Contract.ContractType" id="ctr-ContractType" required>
                    <option value="">اختر</option>
                    @foreach (var contractType in Model.ContractTypeOptions)
                    {
                        <option value="@contractType">@contractType</option>
                    }
                </select>
            </div>
            <div class="hrms-field"><label>من تاريخ</label><input type="date" name="Contract.FromDate" id="ctr-FromDate" required /></div>
            <div class="hrms-field"><label>إلى تاريخ (فارغ = غير محدود)</label><input type="date" name="Contract.ToDate" id="ctr-ToDate" /></div>
            <label class="hrms-toggle"><input type="checkbox" name="Contract.IsCurrent" id="ctr-IsCurrent" value="true" /> العقد الحالي (يحدّث نوع العقد وانتهاءه ببيانات الموظف)</label>
            <div class="hrms-field"><label>ملاحظات العقد</label><input name="Contract.Note" id="ctr-Note" /></div>
            <div class="hrms-field"><label>العقد الموقّع (اختياري)</label><input type="file" name="ContractAttachment" accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx" /></div>
            <partial name="_EntityCustomFields" model='new EntityCustomFieldsPartialModel { EntityKey = "Contract", Fields = Model.CustomFieldsOf("Contract") }' />
            <button type="submit" class="hrms-btn-primary">حفظ العقد</button>
        </form>
    </div>
</aside>

<script>
    // تعبئة درج العقد للإضافة (id=0) أو التعديل.
    function contractOpen(id, contractNo, contractType, fromDate, toDate, isCurrent, note) {
        document.getElementById('ctr-Id').value = id || 0;
        document.getElementById('contract-form-title').textContent = id ? 'تعديل العقد' : 'إضافة عقد';
        document.getElementById('ctr-ContractNo').value = contractNo || '';
        var sel = document.getElementById('ctr-ContractType');
        sel.value = contractType || '';
        if (contractType && sel.value !== contractType) {
            var opt = document.createElement('option'); opt.value = contractType; opt.textContent = contractType; sel.appendChild(opt); sel.value = contractType;
        }
        document.getElementById('ctr-FromDate').value = fromDate || '';
        document.getElementById('ctr-ToDate').value = toDate || '';
        document.getElementById('ctr-IsCurrent').checked = isCurrent === true || isCurrent === 'true';
        document.getElementById('ctr-Note').value = note || '';
        if (window.hrmsCfFill) hrmsCfFill('Contract', 'contract-form', id || 0);
    }
</script>

@* ---------- Slide-over: structured file record (education/experience/…) ---------- *@
<aside class="hrms-slideover wide" id="rec-form" aria-hidden="true">
    <div class="hrms-slideover-head"><h2 id="rec-form-title">إضافة سجل</h2><button type="button" class="hrms-slideover-close" data-hrms-close>×</button></div>
    <div class="hrms-slideover-body">
        <form method="post" asp-page-handler="SaveRecord" asp-route-id="@Model.Id" enctype="multipart/form-data" class="hrms-page">
            <input type="hidden" name="RecordInput.Id" id="rec-Id" value="0" />
            <input type="hidden" name="RecordInput.RecordType" id="rec-RecordType" value="Education" />
            <div class="hrms-grid-2">
                <div class="hrms-field"><label id="rec-Title-label">العنوان</label><input name="RecordInput.Title" id="rec-Title" required /></div>
                <div class="hrms-field"><label id="rec-Subtitle-label">تفاصيل</label><input name="RecordInput.Subtitle" id="rec-Subtitle" /></div>
                <div class="hrms-field"><label>البلد</label><input name="RecordInput.Country" id="rec-Country" /></div>
                <div class="hrms-field"><label id="rec-RefNo-label">رقم مرجعي</label><input name="RecordInput.RefNo" id="rec-RefNo" /></div>
                <div class="hrms-field"><label>من تاريخ</label><input type="date" name="RecordInput.FromDate" id="rec-FromDate" /></div>
                <div class="hrms-field"><label>إلى تاريخ</label><input type="date" name="RecordInput.ToDate" id="rec-ToDate" /></div>
                <div class="hrms-field" id="rec-Amount-field" hidden><label>المبلغ</label><input type="number" step="0.01" min="0" name="RecordInput.Amount" id="rec-Amount" /></div>
                <div class="hrms-field" id="rec-Gpa-field" hidden><label>المعدل التراكمي</label><input name="RecordInput.Gpa" id="rec-Gpa" /></div>
                <div class="hrms-field" id="rec-ReturnDate-field" hidden><label>تاريخ الإرجاع</label><input type="date" name="RecordInput.ReturnDate" id="rec-ReturnDate" /></div>
            </div>
            <label id="rec-Current-field" class="hrms-toggle" hidden style="margin-bottom:6px"><input type="checkbox" name="RecordInput.IsCurrent" id="rec-IsCurrent" value="true" /> <span id="rec-Current-label">الحالي</span></label>
            <label id="rec-Returned-field" class="hrms-toggle" hidden style="margin-bottom:6px"><input type="checkbox" name="RecordInput.IsReturned" id="rec-IsReturned" value="true" /> تم إرجاع العهدة</label>
            <div id="rec-Reference-block" hidden>
                <div class="hrms-tile-sub" style="margin:6px 0 4px">مرجع من جهة العمل السابقة (اختياري)</div>
                <div class="hrms-grid-2">
                    <div class="hrms-field"><label>اسم المرجع</label><input name="RecordInput.RefContactName" id="rec-RefContactName" /></div>
                    <div class="hrms-field"><label>الموقع الوظيفي للمرجع</label><input name="RecordInput.RefContactPosition" id="rec-RefContactPosition" /></div>
                    <div class="hrms-field"><label>هاتف المرجع</label><input name="RecordInput.RefContactPhone" id="rec-RefContactPhone" /></div>
                    <div class="hrms-field"><label>ملاحظات المرجع</label><input name="RecordInput.RefContactNote" id="rec-RefContactNote" /></div>
                </div>
            </div>
            <div class="hrms-field"><label>ملاحظة</label><input name="RecordInput.Note" id="rec-Note" /></div>
            <div class="hrms-field"><label>ملف مرفق (اختياري)</label><input type="file" name="RecordAttachment" accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx,.xls,.xlsx" /></div>
            @* الحقول المخصصة لكل نوع سجل — السلايد مشترك فتظهر مجموعة النوع الفعال فقط (JS) *@
            @foreach (var recordTypeKey in new[] { "Education", "Experience", "Certificate", "Training", "Medical", "Asset", "Address", "EmergencyContact", "Residency" })
            {
                <partial name="_EntityCustomFields" model='new EntityCustomFieldsPartialModel { EntityKey = recordTypeKey, Fields = Model.CustomFieldsOf(recordTypeKey), ApplyRequired = false, StartHidden = true }' />
            }
            <button type="submit" class="hrms-btn-primary">حفظ</button>
        </form>
    </div>
</aside>

@section Scripts {
    <script src="~/js/nexora-employee-photo-upload.js" asp-append-version="true"></script>
    <script src="~/js/nexora-profile-reassign-modal.js" asp-append-version="true"></script>

    <script>
        // الحقول المخصصة (الداينمك مرحلة 2): قيم كل السجلات + تعبئة/تفريغ بالسلايدات.
        var HRMS_CF = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CustomFieldValues));
        function hrmsCfFill(entity, slideId, recordId) {
            var values = (HRMS_CF[entity] || {})[recordId] || {};
            document.querySelectorAll('#' + slideId + ' [data-cf-entity="' + entity + '"]').forEach(function (el) {
                var v = values[el.dataset.cfInput] || '';
                if (el.type === 'checkbox') el.checked = v === 'true'; else el.value = v;
            });
        }
        function hrmsCfToggleRecordGroups(type) {
            document.querySelectorAll('#rec-form [data-cf-group]').forEach(function (group) {
                group.hidden = group.dataset.cfGroup !== type;
            });
        }
    </script>

    <script>
        var HRMS_FORM_TITLE = { dep: 'معال', ed: 'مؤهل', ex: 'خبرة', ce: 'شهادة' };
        function hrmsResetForm(kind) {
            var slide = document.getElementById(kind + '-form');
            var f = slide.querySelector('form'); f.reset();
            slide.querySelector('input[type=hidden]').value = '0';
            document.getElementById(kind + '-form-title').textContent = 'إضافة ' + HRMS_FORM_TITLE[kind];
        }
        (function () {
            document.querySelectorAll('.rec-edit').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var kind = btn.dataset.form, p = kind;
                    var form = document.getElementById(kind + '-form');
                    document.getElementById(kind + '-form-title').textContent = 'تعديل ' + HRMS_FORM_TITLE[kind];
                    var byId = {}; form.querySelectorAll('[id]').forEach(function (e) { byId[e.id.toLowerCase()] = e; });
                    Object.keys(btn.dataset).forEach(function (key) {
                        if (key === 'form' || key === 'hrmsOpen') return;
                        var el = byId[(p + '-' + key).toLowerCase()];
                        if (!el) return;
                        if (el.type === 'checkbox') el.checked = btn.dataset[key] === 'true';
                        else el.value = btn.dataset[key] || '';
                    });
                    // الحقول المخصصة للمعال
                    if (kind === 'dep') hrmsCfFill('Dependent', 'dep-form', btn.dataset.id);
                });
            });
        })();

        // Structured file records: shared slide-over for all categories.
        function hrmsSetRecordLabels(type, cardTitle, titleLabel, subLabel, refLabel, showAmount, showCurrent, currentLabel) {
            document.getElementById('rec-RecordType').value = type;
            document.getElementById('rec-form-title').textContent = cardTitle;
            document.getElementById('rec-Title-label').textContent = titleLabel;
            document.getElementById('rec-Subtitle-label').textContent = subLabel;
            document.getElementById('rec-RefNo-label').textContent = refLabel || 'رقم مرجعي';
            document.getElementById('rec-Amount-field').hidden = !showAmount;
            var cur = document.getElementById('rec-Current-field');
            cur.hidden = !showCurrent;
            document.getElementById('rec-Current-label').textContent = currentLabel || 'الحالي';
            // حقول نوعية (نمط كيان): معدل للتعليم، إرجاع للعهد، مرجع للخبرات.
            document.getElementById('rec-Gpa-field').hidden = type !== 'Education';
            document.getElementById('rec-ReturnDate-field').hidden = type !== 'Asset';
            document.getElementById('rec-Returned-field').hidden = type !== 'Asset';
            document.getElementById('rec-Reference-block').hidden = type !== 'Experience';
            hrmsCfToggleRecordGroups(type);
        }
        function hrmsOpenRecord(type, cardTitle, titleLabel, subLabel, refLabel, showAmount, showCurrent, currentLabel) {
            var f = document.querySelector('#rec-form form'); f.reset();
            document.getElementById('rec-Id').value = '0';
            hrmsSetRecordLabels(type, cardTitle, titleLabel, subLabel, refLabel, showAmount, showCurrent, currentLabel);
        }
        (function () {
            document.querySelectorAll('.rec-open').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var d = btn.dataset;
                    hrmsSetRecordLabels(d.type, d.cardTitle, d.titleLabel, d.subLabel, d.refLabel,
                        d.showAmount === 'true', d.showCurrent === 'true', d.currentLabel);
                    var byId = {};
                    document.querySelectorAll('#rec-form [id]').forEach(function (e) { byId[e.id.toLowerCase()] = e; });
                    ['id', 'title', 'subtitle', 'country', 'refno', 'fromdate', 'todate', 'amount', 'note',
                     'gpa', 'returndate', 'refcontactname', 'refcontactposition', 'refcontactphone', 'refcontactnote'].forEach(function (k) {
                        var el = byId['rec-' + k];
                        if (el) el.value = d[k] || '';
                    });
                    var curCb = document.getElementById('rec-IsCurrent');
                    if (curCb) curCb.checked = d.iscurrent === 'true';
                    var retCb = document.getElementById('rec-IsReturned');
                    if (retCb) retCb.checked = d.isreturned === 'true';
                    hrmsCfFill(d.type, 'rec-form', d.id);
                });
            });
        })();
    </script>

    <script>
        // تبويبات أقسام الملف: يظهر قسم واحد فقط حسب التبويب المختار
        (function () {
            var nav = document.querySelector("[data-z360-tabs]");
            if (!nav) return;

            var tabs = Array.prototype.slice.call(nav.querySelectorAll("[data-z360-tab]"));
            var sectionIds = tabs.map(function (tab) { return tab.getAttribute("data-z360-tab"); });

            function activate(targetId) {
                if (sectionIds.indexOf(targetId) === -1) return;

                sectionIds.forEach(function (id) {
                    var section = document.getElementById(id);
                    if (section) section.hidden = (id !== targetId);
                });

                tabs.forEach(function (tab) {
                    tab.classList.toggle("is-active", tab.getAttribute("data-z360-tab") === targetId);
                });
            }

            tabs.forEach(function (tab) {
                tab.addEventListener("click", function (event) {
                    event.preventDefault();
                    activate(tab.getAttribute("data-z360-tab"));
                });
            });

            // روابط داخلية تشير لقسم (مثل زر "إضافة مستند" → #profile-files)
            document.querySelectorAll('a[href^="#"]').forEach(function (link) {
                var targetId = link.getAttribute("href").slice(1);
                if (sectionIds.indexOf(targetId) === -1 || link.hasAttribute("data-z360-tab")) return;

                link.addEventListener("click", function () {
                    activate(targetId);
                });
            });

            // القسم الأول فعال والباقي مخفي عند التحميل — أو القسم المحدد في الرابط (#section)
            var fromHash = (location.hash || "").slice(1);
            activate(sectionIds.indexOf(fromHash) !== -1 ? fromHash : sectionIds[0]);
        })();
    </script>
}

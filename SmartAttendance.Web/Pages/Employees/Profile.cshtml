@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel

@functions {
    private static string Z360Age(DateOnly? birthDate)
    {
        if (!birthDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - birthDate.Value.Year;

        if (birthDate.Value > today.AddYears(-age))
        {
            age--;
        }

        return age < 0 ? "-" : age.ToString();
    }

    private static string Z360WorkDuration(DateOnly? hireDate)
    {
        if (!hireDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var start = hireDate.Value;

        if (start > today)
        {
            return "-";
        }

        var years = today.Year - start.Year;
        var months = today.Month - start.Month;

        if (today.Day < start.Day)
        {
            months--;
        }

        if (months < 0)
        {
            years--;
            months += 12;
        }

        if (years <= 0 && months <= 0)
        {
            return "أقل من شهر";
        }

        if (years <= 0)
        {
            return $"{months} شهر";
        }

        if (months <= 0)
        {
            return $"{years} سنة";
        }

        return $"{years} سنة و {months} شهر";
    }

    private static string Z360Gender(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Trim() switch
        {
            "Male" => "ذكر",
            "Female" => "أنثى",
            _ => value.Trim()
        };
    }

    private static string Z360MaritalStatus(string? value, string? gender)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var normalized = value.Trim();
        var genderValue = (gender ?? string.Empty).Trim();
        var isFemale =
            string.Equals(genderValue, "Female", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(genderValue, "أنثى", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(genderValue, "انثى", StringComparison.OrdinalIgnoreCase);

        return normalized switch
        {
            "Single" => isFemale ? "عزباء" : "أعزب",
            "Married" => isFemale ? "متزوجة" : "متزوج",
            "Divorced" => isFemale ? "مطلقة" : "مطلق",
            "Widowed" => isFemale ? "أرملة" : "أرمل",
            "Separated" => isFemale ? "منفصلة" : "منفصل",
            _ => normalized
        };
    }

    private static string Z360AttendanceClass(int status)
    {
        return status switch
        {
            1 => "z360-badge-ok",
            2 => "z360-badge-warn",
            3 => "z360-badge-danger",
            _ => string.Empty
        };
    }

    private static string Z360RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "z360-badge-ok",
            "Rejected" => "z360-badge-danger",
            "Pending" => "z360-badge-warn",
            _ => string.Empty
        };
    }
}

@{
    ViewData["Title"] = "ملف الموظف";

    var employee = Model.Employee;
    var today = DateOnly.FromDateTime(DateTime.Today);
    var photoFallback = Url.Content("~/brand/zynora-symbol.svg");
    var readinessClass = Model.PayrollRiskItems == 0 ? "z360-kpi-ok" : "z360-kpi-warn";
    var healthClass = Model.Employee360HealthScore >= 85
        ? "z360-kpi-ok"
        : Model.Employee360HealthScore >= 65
            ? "z360-kpi-warn"
            : "z360-kpi-danger";
    var readinessText = Model.PayrollRiskItems == 0 ? "جاهز" : "مراجعة";

    var basicDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "basic");
    var personalDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "personal");
    var jobDynamicSection = Model.ProfileDynamicSections.FirstOrDefault(item => item.Key == "job");
    var additionalDynamicSections = Model.ProfileDynamicSections
        .Where(item => item.Key == "additional")
        .ToList();

    var documentHasId = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "ID", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("هوية", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("بطاقة", StringComparison.OrdinalIgnoreCase));

    var documentHasContract = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Contract", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Contract", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("عقد", StringComparison.OrdinalIgnoreCase));

    var documentHasPassport = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Passport", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Passport", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("جواز", StringComparison.OrdinalIgnoreCase));

    var documentHasVisa = Model.DocumentRows.Any(d =>
        string.Equals(d.DocumentType, "Visa", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("Visa", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("إقامة", StringComparison.OrdinalIgnoreCase) ||
        (d.DocumentType ?? string.Empty).Contains("اقامة", StringComparison.OrdinalIgnoreCase));

    var employeeGeo = employee == null
        ? string.Empty
        : $"{employee.Nationality} {employee.Country}".ToLowerInvariant();

    var isExpat =
        !string.IsNullOrWhiteSpace(employeeGeo) &&
        !(employeeGeo.Contains("iraq") ||
          employeeGeo.Contains("iraqi") ||
          employeeGeo.Contains("العراق") ||
          employeeGeo.Contains("عراقي") ||
          employeeGeo.Contains("عراقية"));

    var contractNeedsReview =
        employee != null &&
        employee.ContractEndDate.HasValue &&
        employee.ContractEndDate.Value <= today.AddDays(30);

    var hasRequirements =
        Model.PayrollRiskItems > 0 ||
        Model.AttendanceExceptionsCount > 0 ||
        Model.PendingRequests > 0 ||
        Model.ExpiredDocumentsCount > 0 ||
        Model.ExpiringDocumentsCount > 0 ||
        !documentHasId ||
        !documentHasContract ||
        (isExpat && (!documentHasPassport || !documentHasVisa)) ||
        contractNeedsReview;

    var profileFileCards = new[]
    {
        new { Category = "Experience", Title = "الخبرات" },
        new { Category = "Certificates", Title = "الشهادات" },
        new { Category = "Medical", Title = "الملفات الطبية" },
        new { Category = "Training", Title = "الدورات التدريبية" },
        new { Category = "Education", Title = "التعليم" }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/z360-profile.css" asp-append-version="true" />
}

<div class="z360-page" dir="rtl">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="z360-alert z360-alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="z360-alert z360-alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="z360-alert z360-alert-danger">@Model.ErrorMessage</div>
    }

    @if (employee != null)
    {
        <div class="z360-stack">
            <section class="z360-hero" aria-label="هوية الموظف">
                <div class="z360-identity">
                    @if (Model.CanEditEmployee)
                    {
                        <form method="post"
                              asp-page-handler="UploadProfilePhoto"
                              asp-route-id="@employee.Id"
                              enctype="multipart/form-data"
                              class="z360-photo-form"
                              data-employee-photo-form
                              data-auto-submit-photo>
                            <label class="z360-avatar" data-employee-photo-drop>
                                <input type="file"
                                       name="EmployeePhoto"
                                       accept=".png,.jpg,.jpeg,.webp"
                                       aria-label="تغيير صورة الموظف" />
                                <img src="@(string.IsNullOrWhiteSpace(employee.PhotoPath) ? photoFallback : employee.PhotoPath)"
                                     alt="صورة @employee.FullName"
                                     data-employee-photo-preview
                                     onerror="this.onerror=null;this.src='@photoFallback';" />
                                <span class="z360-avatar-overlay">تغيير الصورة</span>
                            </label>
                        </form>
                    }
                    else
                    {
                        <div class="z360-avatar">
                            <img src="@(string.IsNullOrWhiteSpace(employee.PhotoPath) ? photoFallback : employee.PhotoPath)"
                                 alt="صورة @employee.FullName"
                                 onerror="this.onerror=null;this.src='@photoFallback';" />
                        </div>
                    }

                    <div class="z360-identity-copy">
                        <span class="z360-employee-code">@Model.Display(employee.EmployeeNo)</span>
                        <h1>@employee.FullName</h1>
                        <p class="z360-position">
                            @Model.Display(employee.Position)
                            @if (!string.IsNullOrWhiteSpace(employee.DepartmentName))
                            {
                                <span> | @employee.DepartmentName</span>
                            }
                        </p>
                        <div class="z360-tags">
                            <span class="z360-tag @(employee.IsActive ? "z360-tag-success" : "z360-tag-danger")">
                                @(employee.IsActive ? "فعال" : "غير فعال")
                            </span>
                            <span class="z360-tag">@Model.Display(employee.BranchName)</span>
                            <span class="z360-tag">@Model.Display(employee.CompanyName)</span>
                        </div>
                    </div>
                </div>

                <div class="z360-contact">
                    <div class="z360-contact-row">
                        <span>البريد الإلكتروني</span>
                        <strong>@Model.Display(employee.Email)</strong>
                    </div>
                    <div class="z360-contact-row">
                        <span>الهاتف</span>
                        <strong>@Model.Display(employee.Phone)</strong>
                    </div>
                    <div class="z360-contact-row">
                        <span>المدير المباشر</span>
                        <strong>@Model.Display(employee.DirectManager)</strong>
                    </div>

                    @if (basicDynamicSection != null)
                    {
                        foreach (var field in basicDynamicSection.Fields
                            .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue))
                            .Take(3))
                        {
                            <div class="z360-contact-row">
                                <span>@field.FieldLabel</span>
                                <strong>@field.FieldValue</strong>
                            </div>
                        }
                    }
                </div>

            </section>

            <section class="z360-command" aria-label="مركز التحكم والعمليات">
                <div class="z360-command-title">
                    <h2>مركز التحكم والعمليات (360)</h2>
                    <p>إجراءات ملف الموظف حسب الصلاحيات الممنوحة</p>
                </div>

                <div class="z360-actions">
                    @if (Model.CanEditEmployee)
                    {
                        <a asp-page="./Edit"
                           asp-route-id="@employee.Id"
                           class="z360-action z360-action-primary">
                            تعديل البيانات
                        </a>
                    }

                    @if (Model.CanOpenEmployeeDocuments)
                    {
                        <a asp-page="/EmployeeDocuments/Index"
                           asp-route-employeeId="@employee.Id"
                           class="z360-action">
                            إضافة مستند
                        </a>
                    }
                    else if (Model.CanUploadDocument)
                    {
                        <a href="#profile-files" class="z360-action">إضافة مستند</a>
                    }

                    @if (employee.IsActive && Model.CanEndService)
                    {
                        <a asp-page="./EndService"
                           asp-route-id="@employee.Id"
                           class="z360-action z360-action-danger">
                            إنهاء الخدمة
                        </a>
                    }
                    else if (!employee.IsActive && Model.CanRehire)
                    {
                        <button type="button"
                                class="z360-action z360-action-success"
                                data-nxr-reassign-open>
                            إعادة تعيين
                        </button>
                    }

                    @if (Model.CanViewDirectory)
                    {
                        <a asp-page="./Index" class="z360-action">رجوع للقائمة</a>
                    }
                </div>
            </section>

            @if (!employee.IsActive && Model.CanRehire)
            {
                <div class="z360-modal"
                     data-nxr-reassign-modal
                     hidden>
                    <div class="z360-modal-dialog"
                         role="dialog"
                         aria-modal="true"
                         aria-labelledby="z360-reassign-title">
                        <div class="z360-modal-head">
                            <div>
                                <strong id="z360-reassign-title">إعادة تعيين الموظف</strong>
                                <span>راجع البيانات السابقة وحدد موقع العمل الجديد قبل الحفظ.</span>
                            </div>
                            <button type="button"
                                    class="z360-modal-close"
                                    data-nxr-reassign-close
                                    aria-label="إغلاق">&times;</button>
                        </div>

                        <form method="post"
                              asp-page-handler="ReassignFromModalV2"
                              asp-route-id="@employee.Id">
                            <div class="z360-modal-body">
                                <section class="z360-modal-section">
                                    <h4>البيانات السابقة</h4>
                                    <div class="z360-old-grid">
                                        <div><span>الكود</span><strong>@Model.Display(employee.EmployeeNo)</strong></div>
                                        <div><span>الاسم</span><strong>@Model.Display(employee.FullName)</strong></div>
                                        <div><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                                        <div><span>موقع العمل</span><strong>@Model.Display(employee.BranchName)</strong></div>
                                        <div><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                                        <div><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                                        <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(employee.HireDate)</strong></div>
                                        <div><span>الحالة السابقة</span><strong>@Model.Display(employee.EmploymentStatus)</strong></div>
                                    </div>
                                </section>

                                <section class="z360-modal-section">
                                    <h4>التعديل قبل الحفظ</h4>
                                    <div class="z360-edit-grid">
                                        <label>
                                            <span>الشركة</span>
                                            <select name="ReassignCompanyId" data-nxr-reassign-company>
                                                @foreach (var company in Model.ReassignCompanies)
                                                {
                                                    <option value="@company.Id"
                                                            selected="@(company.Id == Model.CurrentReassignCompanyId ? "selected" : null)">
                                                        @Model.Display(company.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>موقع العمل</span>
                                            <select name="ReassignBranchId" data-nxr-reassign-branch>
                                                @foreach (var branch in Model.ReassignBranches)
                                                {
                                                    <option value="@branch.Id"
                                                            data-company-id="@branch.CompanyId"
                                                            selected="@(branch.Id == Model.CurrentReassignBranchId ? "selected" : null)">
                                                        @Model.Display(branch.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>القسم</span>
                                            <select name="ReassignDepartmentId" data-nxr-reassign-department>
                                                @foreach (var department in Model.ReassignDepartments)
                                                {
                                                    <option value="@department.Id"
                                                            data-company-id="@department.CompanyId"
                                                            selected="@(department.Id == Model.CurrentReassignDepartmentId ? "selected" : null)">
                                                        @Model.Display(department.Name)
                                                    </option>
                                                }
                                            </select>
                                        </label>

                                        <label>
                                            <span>تاريخ المباشرة الجديد</span>
                                            <input type="date"
                                                   name="ReassignDate"
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                   required />
                                        </label>

                                        <label>
                                            <span>المنصب بعد إعادة التعيين</span>
                                            <input type="text"
                                                   name="ReassignPosition"
                                                   value="@employee.Position" />
                                        </label>

                                        <label class="z360-wide">
                                            <span>سبب إعادة التعيين</span>
                                            <textarea name="ReassignReason"
                                                      rows="3"
                                                      required></textarea>
                                        </label>

                                        <label class="z360-wide">
                                            <span>ملاحظات الموارد البشرية</span>
                                            <textarea name="ReassignNotes"
                                                      rows="3"></textarea>
                                        </label>
                                    </div>
                                </section>

                                <label class="z360-confirm">
                                    <input type="checkbox"
                                           name="ConfirmReassign"
                                           value="true"
                                           required />
                                    <span>أؤكد إعادة تفعيل الموظف وحفظ الحركة في السجل الوظيفي.</span>
                                </label>
                            </div>

                            <div class="z360-modal-actions">
                                <button type="button"
                                        class="z360-action"
                                        data-nxr-reassign-close>
                                    إلغاء
                                </button>
                                <button type="submit"
                                        class="z360-action z360-action-success">
                                    حفظ وإعادة التعيين
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <section class="z360-kpis" aria-label="مؤشرات الموظف">
                <div class="z360-kpi @healthClass">
                    <span class="z360-kpi-label">مؤشر الصحة الوظيفية</span>
                    <strong class="z360-kpi-value">@Model.Employee360HealthScore%</strong>
                    <small class="z360-kpi-note">@Model.Employee360HealthText</small>
                </div>
                <div class="z360-kpi @readinessClass">
                    <span class="z360-kpi-label">جاهزية الراتب</span>
                    <strong class="z360-kpi-value">@readinessText</strong>
                    <small class="z360-kpi-note">@Model.PayrollRiskItems ملاحظة</small>
                </div>
                <div class="z360-kpi">
                    <span class="z360-kpi-label">رصيد الإجازات</span>
                    <strong class="z360-kpi-value">—</strong>
                    <small class="z360-kpi-note">غير مربوط حالياً</small>
                </div>
                <div class="z360-kpi">
                    <span class="z360-kpi-label">العهد المسجلة</span>
                    <strong class="z360-kpi-value">—</strong>
                    <small class="z360-kpi-note">وحدة العهد غير مفعلة</small>
                </div>
            </section>

            <section class="z360-summary-grid" aria-label="ملخص بيانات الموظف">
                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>المعلومات الشخصية</h3>
                        @if (Model.CanEditEmployee)
                        {
                            <a asp-page="./Edit"
                               asp-route-id="@employee.Id"
                               class="z360-card-tool"
                               title="تعديل">✎</a>
                        }
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الرقم الوطني</span><strong>@Model.Display(employee.NationalId)</strong></div>
                        <div class="z360-field"><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
                        <div class="z360-field"><span>العمر</span><strong>@Z360Age(employee.BirthDate)</strong></div>
                        <div class="z360-field"><span>الحالة الاجتماعية</span><strong>@Z360MaritalStatus(employee.MaritalStatus, employee.Gender)</strong></div>
                        <div class="z360-field"><span>الجنس</span><strong>@Z360Gender(employee.Gender)</strong></div>
                        <div class="z360-field"><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                        <div class="z360-field"><span>البلد</span><strong>@Model.Display(employee.Country)</strong></div>

                        @if (personalDynamicSection != null)
                        {
                            foreach (var field in personalDynamicSection.Fields
                                .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                            {
                                <div class="z360-field">
                                    <span>@field.FieldLabel</span>
                                    <strong>@field.FieldValue</strong>
                                </div>
                            }
                        }
                    </div>
                </article>

                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>المعلومات الوظيفية</h3>
                        @if (Model.CanViewLifecycle)
                        {
                            <a asp-page="./Lifecycle"
                               asp-route-id="@employee.Id"
                               class="z360-card-tool"
                               title="السجل الوظيفي">↗</a>
                        }
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                        <div class="z360-field"><span>موقع العمل</span><strong>@Model.Display(employee.BranchName)</strong></div>
                        <div class="z360-field"><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                        <div class="z360-field"><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                        <div class="z360-field"><span>مدة العمل</span><strong>@Z360WorkDuration(employee.HireDate)</strong></div>
                        <div class="z360-field"><span>نوع العقد</span><strong>@Model.Display(employee.ContractType)</strong></div>
                        <div class="z360-field"><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>

                        @if (jobDynamicSection != null)
                        {
                            foreach (var field in jobDynamicSection.Fields
                                .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                            {
                                <div class="z360-field">
                                    <span>@field.FieldLabel</span>
                                    <strong>@field.FieldValue</strong>
                                </div>
                            }
                        }
                    </div>
                </article>

                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>تنبيهات ومخالفات</h3>
                        <span class="z360-card-tool" aria-hidden="true">!</span>
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field">
                            <span>الغيابات والتأخير</span>
                            <strong class="@(Model.AttendanceExceptionsCount > 0 ? "z360-value-danger" : "")">
                                @Model.AttendanceExceptionsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>بصمات ناقصة</span>
                            <strong class="@(Model.MissingCheckoutCount > 0 ? "z360-value-warning" : "")">
                                @Model.MissingCheckoutCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>طلبات معلقة</span>
                            <strong class="@(Model.PendingRequests > 0 ? "z360-value-warning" : "")">
                                @Model.PendingRequests
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>مستندات منتهية</span>
                            <strong class="@(Model.ExpiredDocumentsCount > 0 ? "z360-value-danger" : "")">
                                @Model.ExpiredDocumentsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>مستندات قرب الانتهاء</span>
                            <strong class="@(Model.ExpiringDocumentsCount > 0 ? "z360-value-warning" : "")">
                                @Model.ExpiringDocumentsCount
                            </strong>
                        </div>
                        <div class="z360-field">
                            <span>حالة الملف</span>
                            <strong class="@(hasRequirements ? "z360-value-warning" : "z360-value-success")">
                                @(hasRequirements ? "يحتاج متابعة" : "مكتمل حالياً")
                            </strong>
                        </div>
                    </div>
                </article>

                <article class="z360-card">
                    <div class="z360-card-head">
                        <h3>المعلومات المالية</h3>
                        <span class="z360-card-tool" title="بيانات حساسة">◎</span>
                    </div>
                    <div class="z360-fields">
                        <div class="z360-field"><span>الراتب الأساسي</span><strong class="z360-financial-mask">مخفي حسب الصلاحية</strong></div>
                        <div class="z360-field"><span>الراتب الكلي</span><strong class="z360-financial-mask">مخفي حسب الصلاحية</strong></div>
                        <div class="z360-field"><span>العملة</span><strong>غير مربوطة حالياً</strong></div>
                        <div class="z360-field"><span>طريقة الدفع</span><strong>غير مربوطة حالياً</strong></div>
                        <div class="z360-field"><span>القروض والسلف</span><strong>غير مربوطة حالياً</strong></div>
                        <div class="z360-field"><span>جاهزية الراتب</span><strong>@readinessText</strong></div>
                    </div>
                </article>
            </section>

            @if (additionalDynamicSections.Count > 0)
            {
                <section class="z360-module-grid" aria-label="معلومات إضافية">
                    @foreach (var profileSection in additionalDynamicSections)
                    {
                        <article class="z360-module">
                            <div class="z360-module-head">
                                <div>
                                    <h3>@profileSection.Label</h3>
                                    <p>بيانات إضافية مرتبطة بملف الموظف.</p>
                                </div>
                            </div>
                            <div class="z360-fields">
                                @foreach (var field in profileSection.Fields
                                    .Where(item => !string.IsNullOrWhiteSpace(item.FieldValue)))
                                {
                                    <div class="z360-field">
                                        <span>@field.FieldLabel</span>
                                        <strong>@field.FieldValue</strong>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </section>
            }

            @if (hasRequirements)
            {
                <section class="z360-requirements">
                    <div class="z360-section-head">
                        <div>
                            <h3>متطلبات الموظف</h3>
                            <p>الملاحظات التي تحتاج متابعة قبل اعتماد الملف أو إغلاق الراتب.</p>
                        </div>
                        <span class="z360-status-pill">توجد متطلبات تحتاج متابعة</span>
                    </div>

                    <div class="z360-requirement-grid">
                        @if (!documentHasId)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>هوية / بطاقة وطنية مفقودة</strong>
                                <span>هذا المستند مطلوب لكل موظف.</span>
                            </div>
                        }
                        @if (!documentHasContract)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>عقد العمل مفقود</strong>
                                <span>العقد مطلوب لاكتمال ملف الموظف.</span>
                            </div>
                        }
                        @if (isExpat && !documentHasPassport)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>جواز السفر مفقود</strong>
                                <span>مطلوب للموظفين الوافدين.</span>
                            </div>
                        }
                        @if (isExpat && !documentHasVisa)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>الإقامة / الفيزا مفقودة</strong>
                                <span>مطلوبة للموظفين الوافدين.</span>
                            </div>
                        }
                        @if (Model.PayrollRiskItems > 0)
                        {
                            <div class="z360-requirement">
                                <strong>جاهزية الراتب</strong>
                                <span>يوجد @Model.PayrollRiskItems ملاحظة تحتاج مراجعة.</span>
                            </div>
                        }
                        @if (Model.AttendanceExceptionsCount > 0)
                        {
                            <div class="z360-requirement">
                                <strong>استثناءات الحضور</strong>
                                <span>يوجد @Model.AttendanceExceptionsCount حالة تحتاج تدقيق.</span>
                            </div>
                        }
                        @if (Model.PendingRequests > 0)
                        {
                            <div class="z360-requirement">
                                <strong>طلبات معلقة</strong>
                                <span>يوجد @Model.PendingRequests طلب بانتظار الإجراء.</span>
                            </div>
                        }
                        @if (Model.ExpiredDocumentsCount > 0)
                        {
                            <div class="z360-requirement z360-requirement-danger">
                                <strong>مستندات منتهية</strong>
                                <span>يوجد @Model.ExpiredDocumentsCount مستند منتهي.</span>
                            </div>
                        }
                        @if (Model.ExpiringDocumentsCount > 0)
                        {
                            <div class="z360-requirement">
                                <strong>مستندات قرب الانتهاء</strong>
                                <span>يوجد @Model.ExpiringDocumentsCount مستند يحتاج متابعة.</span>
                            </div>
                        }
                        @if (contractNeedsReview)
                        {
                            <div class="z360-requirement">
                                <strong>العقد يحتاج متابعة</strong>
                                <span>نهاية العقد: @Model.DisplayDate(employee.ContractEndDate)</span>
                            </div>
                        }
                    </div>
                </section>
            }

            <section class="z360-details">
                <nav class="z360-detail-nav" aria-label="أقسام ملف الموظف" data-z360-tabs>
                    <a href="#attendance" data-z360-tab="attendance" class="is-active">الحضور</a>
                    <a href="#requests" data-z360-tab="requests">الطلبات</a>
                    <a href="#documents" data-z360-tab="documents">المستندات</a>
                    <a href="#profile-files" data-z360-tab="profile-files">ملفات الموظف</a>
                    <a href="#shifts" data-z360-tab="shifts">الشفتات</a>
                    @if (Model.CanViewHistory)
                    {
                        <a href="#audit" data-z360-tab="audit">سجل التعديلات</a>
                    }
                </nav>

                <div class="z360-module-grid">
                    <article id="attendance" class="z360-module z360-module-wide">
                        <div class="z360-module-head">
                            <div>
                                <h3>الحضور والانصراف</h3>
                                <p>السجلات والاستثناءات ضمن الفترة المحددة.</p>
                            </div>
                        </div>

                        <form method="get" class="z360-filter">
                            <input type="hidden" name="Id" value="@employee.Id" />
                            <label>
                                <span>من تاريخ</span>
                                <input type="date"
                                       name="FromDate"
                                       value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                            </label>
                            <label>
                                <span>إلى تاريخ</span>
                                <input type="date"
                                       name="ToDate"
                                       value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                            </label>
                            <button type="submit" class="z360-action z360-action-primary">تحديث الفترة</button>
                            <a asp-page="./Profile"
                               asp-route-id="@employee.Id"
                               class="z360-action">آخر 30 يوم</a>
                        </form>

                        <div class="z360-mini-kpis">
                            <div class="z360-mini-kpi"><span>السجلات</span><strong>@Model.AttendanceCount</strong></div>
                            <div class="z360-mini-kpi"><span>الحضور</span><strong>@Model.PresentCount</strong></div>
                            <div class="z360-mini-kpi"><span>التأخير</span><strong>@Model.LateCount</strong></div>
                            <div class="z360-mini-kpi"><span>الغياب</span><strong>@Model.AbsentCount</strong></div>
                            <div class="z360-mini-kpi"><span>بصمات ناقصة</span><strong>@Model.MissingCheckoutCount</strong></div>
                            <div class="z360-mini-kpi"><span>ساعات العمل</span><strong>@Model.TotalWorkingHours</strong></div>
                        </div>

                        <div class="z360-table-wrap">
                            <table class="z360-table">
                                <thead>
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>الدخول</th>
                                        <th>الخروج</th>
                                        <th>الجهاز</th>
                                        <th>الحالة</th>
                                        <th>الملاحظات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.AttendanceRows.Any())
                                    {
                                        foreach (var row in Model.AttendanceRows.Take(15))
                                        {
                                            <tr>
                                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                                <td>@Model.Display(row.DeviceName)</td>
                                                <td>
                                                    <span class="z360-badge @Z360AttendanceClass(row.Status)">
                                                        @Model.StatusText(row.Status)
                                                    </span>
                                                </td>
                                                <td>@Model.Display(row.Notes)</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6">
                                                <div class="z360-empty">لا توجد سجلات حضور ضمن هذه الفترة.</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <article id="requests" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>الطلبات</h3>
                                <p>آخر طلبات الموظف والخدمة الذاتية.</p>
                            </div>
                            <span class="z360-badge z360-badge-warn">@Model.PendingRequests معلق</span>
                        </div>

                        @if (Model.RequestRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.RequestRows.Take(8))
                                {
                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.RequestType)</strong>
                                            <span>@Model.DisplayDate(row.RequestDate) · @Model.Display(row.CurrentStep)</span>
                                        </div>
                                        <span class="z360-badge @Z360RequestClass(row.Status)">
                                            @Model.RequestStatusText(row.Status)
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد طلبات محفوظة.</div>
                        }
                    </article>

                    <article id="documents" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>المستندات</h3>
                                <p>آخر المستندات الرسمية المرتبطة بالموظف.</p>
                            </div>
                            @if (Model.CanOpenEmployeeDocuments)
                            {
                                <a asp-page="/EmployeeDocuments/Index"
                                   asp-route-employeeId="@employee.Id"
                                   class="z360-action">فتح المركز</a>
                            }
                        </div>

                        @if (Model.DocumentRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.DocumentRows.Take(8))
                                {
                                    var documentClass =
                                        !row.ExpiryDate.HasValue ? string.Empty :
                                        row.ExpiryDate.Value < today ? "z360-badge-danger" :
                                        row.ExpiryDate.Value <= today.AddDays(30) ? "z360-badge-warn" :
                                        "z360-badge-ok";

                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.DocumentType)</strong>
                                            <span>@Model.Display(row.FileName)</span>
                                            <small>@(row.ExpiryDate.HasValue ? $"ينتهي: {row.ExpiryDate:yyyy-MM-dd}" : "بدون تاريخ انتهاء")</small>
                                        </div>
                                        <div class="z360-file-actions">
                                            <span class="z360-badge @documentClass">
                                                @(row.ExpiryDate.HasValue ? Model.DisplayDate(row.ExpiryDate) : "مفتوح")
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(row.StoredPath))
                                            {
                                                <a href="@row.StoredPath" target="_blank">فتح</a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد مستندات محفوظة لهذا الموظف.</div>
                        }
                    </article>

                    <article id="profile-files" class="z360-module z360-module-wide">
                        <div class="z360-module-head">
                            <div>
                                <h3>ملفات الموظف</h3>
                                <p>الخبرات والشهادات والملفات الطبية والتدريب والتعليم.</p>
                            </div>
                        </div>

                        <div class="z360-files-grid">
                            @foreach (var fileCard in profileFileCards)
                            {
                                var cardFiles = Model.ProfileFilesByCategory(fileCard.Category);
                                var inputId = $"z360Upload_{fileCard.Category}_{employee.Id}";

                                <section class="z360-file-card">
                                    <div class="z360-file-card-head">
                                        <h4>@fileCard.Title</h4>
                                        @if (Model.CanUploadDocument)
                                        {
                                            <label for="@inputId"
                                                   class="z360-upload-label"
                                                   title="رفع ملف">+</label>
                                        }
                                    </div>

                                    @if (Model.CanUploadDocument)
                                    {
                                        <form method="post"
                                              enctype="multipart/form-data"
                                              asp-page-handler="UploadProfileAreaFile"
                                              asp-route-id="@employee.Id">
                                            <input type="hidden"
                                                   name="ProfileAreaCategory"
                                                   value="@fileCard.Category" />
                                            <input id="@inputId"
                                                   class="z360-hidden-input"
                                                   type="file"
                                                   name="ProfileAreaFile"
                                                   accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx,.xls,.xlsx"
                                                   onchange="this.form.submit()" />
                                        </form>
                                    }

                                    @if (cardFiles.Any())
                                    {
                                        <div class="z360-file-items">
                                            @foreach (var file in cardFiles.Take(5))
                                            {
                                                <div class="z360-file-item">
                                                    <div class="z360-file-item-main">
                                                        <strong>@Model.Display(file.FileName)</strong>
                                                        <span>@(file.UploadedAt.HasValue ? file.UploadedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")</span>
                                                    </div>
                                                    <div class="z360-file-actions">
                                                        <a href="@file.StoredPath" target="_blank">فتح</a>
                                                        @if (Model.CanDeleteDocument)
                                                        {
                                                            <form method="post"
                                                                  asp-page-handler="DeleteProfileAreaFile"
                                                                  asp-route-id="@employee.Id"
                                                                  asp-route-fileId="@file.Id"
                                                                  onsubmit="return confirm('هل تريد حذف الملف؟');">
                                                                <button type="submit">حذف</button>
                                                            </form>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="z360-empty">لا توجد ملفات.</div>
                                    }
                                </section>
                            }
                        </div>
                    </article>

                    <article id="shifts" class="z360-module">
                        <div class="z360-module-head">
                            <div>
                                <h3>الشفتات</h3>
                                <p>الشفتات الحالية والسابقة.</p>
                            </div>
                        </div>

                        @if (Model.ShiftRows.Any())
                        {
                            <div class="z360-list">
                                @foreach (var row in Model.ShiftRows.Take(8))
                                {
                                    <div class="z360-list-row">
                                        <div class="z360-list-main">
                                            <strong>@Model.Display(row.Name)</strong>
                                            <span>@row.StartTime - @row.EndTime · @Model.Display(row.WorkingHours)</span>
                                            <small>@Model.DisplayDate(row.EffectiveFrom) إلى @Model.DisplayDate(row.EffectiveTo)</small>
                                        </div>
                                        <span class="z360-badge @(row.IsCurrent ? "z360-badge-ok" : "")">
                                            @(row.IsCurrent ? "حالي" : "سابق")
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="z360-empty">لا توجد شفتات مرتبطة.</div>
                        }
                    </article>

                    @if (Model.CanViewHistory)
                    {
                        <article id="audit" class="z360-module">
                            <div class="z360-module-head">
                                <div>
                                    <h3>سجل التعديلات</h3>
                                    <p>آخر الحركات المسجلة على ملف الموظف.</p>
                                </div>
                            </div>

                            @if (Model.AuditRows.Any())
                            {
                                <div class="z360-list">
                                    @foreach (var row in Model.AuditRows.Take(8))
                                    {
                                        <div class="z360-list-row">
                                            <div class="z360-list-main">
                                                <strong>@Model.Display(row.Action)</strong>
                                                <span>@Model.Display(row.UserName) · @Model.Display(row.IpAddress)</span>
                                            </div>
                                            <small>@Model.DisplayDateTime(row.CreatedAt)</small>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="z360-empty">لا توجد تعديلات مسجلة.</div>
                            }
                        </article>
                    }
                </div>
            </section>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/nexora-employee-photo-upload.js" asp-append-version="true"></script>
    <script src="~/js/nexora-profile-reassign-modal.js" asp-append-version="true"></script>

    <script>
        // تبويبات أقسام الملف: يظهر قسم واحد فقط حسب التبويب المختار
        (function () {
            var nav = document.querySelector("[data-z360-tabs]");
            if (!nav) return;

            var tabs = Array.prototype.slice.call(nav.querySelectorAll("[data-z360-tab]"));
            var sectionIds = tabs.map(function (tab) { return tab.getAttribute("data-z360-tab"); });

            function activate(targetId) {
                if (sectionIds.indexOf(targetId) === -1) return;

                sectionIds.forEach(function (id) {
                    var section = document.getElementById(id);
                    if (section) section.hidden = (id !== targetId);
                });

                tabs.forEach(function (tab) {
                    tab.classList.toggle("is-active", tab.getAttribute("data-z360-tab") === targetId);
                });
            }

            tabs.forEach(function (tab) {
                tab.addEventListener("click", function (event) {
                    event.preventDefault();
                    activate(tab.getAttribute("data-z360-tab"));
                });
            });

            // روابط داخلية تشير لقسم (مثل زر "إضافة مستند" → #profile-files)
            document.querySelectorAll('a[href^="#"]').forEach(function (link) {
                var targetId = link.getAttribute("href").slice(1);
                if (sectionIds.indexOf(targetId) === -1 || link.hasAttribute("data-z360-tab")) return;

                link.addEventListener("click", function () {
                    activate(targetId);
                });
            });

            // القسم الأول فعال والباقي مخفي عند التحميل
            activate(sectionIds[0]);
        })();
    </script>
}

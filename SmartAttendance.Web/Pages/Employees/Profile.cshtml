                <div class="nxr-profile-kayan-pane" data-nxr-profile-pane="activity">
                    <div class="nxr-profile-kayan-activity-head">
                        <div>
                            <h3>الأنشطة الأخيرة</h3>
                            <p>آخر الحركات المسجلة على ملف الموظف، ويمكن لاحقاً ربطها بكل أوامر شؤون الموظفين.</p>
                        </div>
                        <span class="nxr-profile-kayan-chip">@Model.AuditRows.Count حركة</span>
                    </div>

                    <div class="nxr-profile-kayan-activity-table-wrap">
                        <table class="nxr-profile-kayan-activity-table">
                            <thead>
                                <tr>
                                    <th>اسم المستخدم</th>
                                    <th>الإجراء</th>
                                    <th>تاريخ الحركة</th>
                                    <th>تفاصيل</th>
                                </tr>
                            </thead>
                            <tbody>
                            @if (Model.AuditRows.Any())
                            {
                                foreach (var row in Model.AuditRows.Take(40))
                                {
                                    var userInitial = string.IsNullOrWhiteSpace(row.UserName) ? "N" : row.UserName.Trim()[0].ToString();

                                    <tr>
                                        <td>
                                            <span class="nxr-profile-kayan-user">
                                                <span class="nxr-profile-kayan-user-avatar">@userInitial</span>
                                                @Model.Display(row.UserName)
                                            </span>
                                        </td>
                                        <td>@Model.Display(row.Action)</td>
                                        <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                        <td><span class="nxr-profile-kayan-chip">عرض</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">
                                        <div class="nxr-profile-kayan-empty">
                                            <div>
                                                <span class="icon">◷</span>
                                                <strong>لا توجد أنشطة مسجلة</strong>
                                                <small>ستظهر هنا الحركات مثل تعديل البيانات، رفع مستند، تغيير قسم، أو إنهاء خدمة.</small>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
        <!-- NEXORA_PROFILE_KAYAN_PAGES_END -->
<section class="nxr-profile-pro-filter nxr-card">
            <form method="get">
                <input type="hidden" name="Id" value="@employee.Id" />
                <div>
                    <label>من تاريخ</label>
                    <input type="date" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div>
                    <label>إلى تاريخ</label>
                    <input type="date" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <button type="submit" class="nxr-btn primary">تحديث الفترة</button>
                <a asp-page="./Profile" asp-route-id="@employee.Id" class="nxr-btn">آخر 30 يوم</a>
            </form>
        </section>

        <section class="nxr-profile-pro-kpis">
            <div class="nxr-kpi"><span>سجلات الحضور</span><strong>@Model.AttendanceCount</strong><small>ضمن الفترة</small></div>
            <div class="nxr-kpi ok"><span>حضور</span><strong>@Model.PresentCount</strong><small>سجل</small></div>
            <div class="nxr-kpi warn"><span>تأخير</span><strong>@Model.LateCount</strong><small>مرة</small></div>
            <div class="nxr-kpi danger"><span>غياب</span><strong>@Model.AbsentCount</strong><small>يوم</small></div>
            <div class="nxr-kpi warn"><span>بصمات ناقصة</span><strong>@Model.MissingCheckoutCount</strong><small>مرة</small></div>
            <div class="nxr-kpi"><span>ساعات العمل</span><strong>@Model.TotalWorkingHours</strong><small>ساعة</small></div>
        </section>

        <section id="data" class="nxr-profile-pro-two-col nxr-kayan-details-section">
            <div class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>البيانات الشخصية</h3>
                </div>
                <div class="nxr-profile-pro-info">
                    <div><span>الاسم الكامل</span><strong>@employee.FullName</strong></div>
                    <div><span>رقم الموظف</span><strong>@Model.Display(employee.EmployeeNo)</strong></div>
                    <div><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(employee.BirthDate)</strong></div>
@* NEXORA_PROFILE_PERSONAL_STATIC_EXTRA_START *@
<div><span>&#x0627;&#x0644;&#x0639;&#x0645;&#x0631;</span><strong>@NxrDisplayAge(employee.BirthDate)</strong></div>
<div><span>&#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x0629; &#x0627;&#x0644;&#x0627;&#x062C;&#x062A;&#x0645;&#x0627;&#x0639;&#x064A;&#x0629;</span><strong>@NxrDisplayMaritalStatusByGender(employee.MaritalStatus, employee.Gender)</strong></div>
@* NEXORA_PROFILE_PERSONAL_STATIC_EXTRA_END *@
                    <div><span>الجنس</span><strong>@NxrDisplayGender(employee.Gender)</strong></div>
                    <div><span>الجنسية</span><strong>@Model.Display(employee.Nationality)</strong></div>
                    <div><span>البلد</span><strong>@Model.Display(employee.Country)</strong></div>
                    <div><span>رقم الهوية</span><strong>@Model.Display(employee.NationalId)</strong></div>
                    <div><span>الهاتف</span><strong>@Model.Display(employee.Phone)</strong></div>
                    <div><span>الإيميل</span><strong>@Model.Display(employee.Email)</strong></div>
                </div>
            </div>

            <div class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title">
                    <h3>البيانات الوظيفية</h3>
                </div>
                <div class="nxr-profile-pro-info">
                    <div><span>الشركة</span><strong>@Model.Display(employee.CompanyName)</strong></div>
                    <div><span>موقع العمل</span><strong>@Model.Display(employee.BranchName)</strong></div>
                    <div><span>القسم</span><strong>@Model.Display(employee.DepartmentName)</strong></div>
                    <div><span>المنصب</span><strong>@Model.Display(employee.Position)</strong></div>
                    <div><span>الحالة الوظيفية</span><strong>@Model.Display(employee.EmploymentStatus)</strong></div>
                    <div><span>نوع التوظيف</span><strong>@Model.Display(employee.ContractType)</strong></div>
                    <div><span>&#x0645;&#x062F;&#x0629; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</span><strong>@NxrDisplayWorkDuration(employee.HireDate)</strong></div>
                    <div><span>نهاية العقد</span><strong>@Model.DisplayDate(employee.ContractEndDate)</strong></div>
                    <div><span>المدير المباشر</span><strong>@Model.Display(employee.DirectManager)</strong></div>
                </div>
            </div>
        </section>

        <section id="attendance" class="nxr-card nxr-profile-pro-panel">
            <div class="nxr-profile-pro-panel-title with-action">
                <div>
                    <h3>الحضور والانصراف</h3>
                    <p>آخر السجلات ضمن الفترة المحددة.</p>
                </div></div>

            <div class="nxr-profile-pro-table-wrap">
                <table class="nxr-profile-pro-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الدخول</th>
                            <th>الخروج</th>
                            <th>الجهاز</th>
                            <th>الحالة</th>
                            <th>الملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.AttendanceRows.Any())
                    {
                        foreach (var row in Model.AttendanceRows.Take(10))
                        {
                            <tr>
                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                <td>@Model.Display(row.DeviceName)</td>
                                <td><span class="nxr-profile-pro-badge @StatusClass(row.Status)">@Model.StatusText(row.Status)</span></td>
                                <td>@Model.Display(row.Notes)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="nxr-profile-pro-empty">لا توجد سجلات حضور ضمن هذه الفترة.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="nxr-profile-pro-two-col">
            <div id="requests" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">
                    <div>
                        <h3>الطلبات</h3>

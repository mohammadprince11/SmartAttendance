                        <span>العقد مطلوب لاكتمال ملف الموظف.</span>
                        <small>Document Rules</small>
                    </div>
                }

                @if (documentIsExpat && !documentHasPassport)
                {
                    <div class="nxr-requirement-item danger">
                        <strong>مستند ناقص: جواز سفر</strong>
                        <span>مطلوب للموظفين الوافدين.</span>
                        <small>Expats Documents</small>
                    </div>
                }

                @if (documentIsExpat && !documentHasVisa)
                {
                    <div class="nxr-requirement-item danger">
                        <strong>مستند ناقص: إقامة / فيزا</strong>
                        <span>مطلوب للموظفين الوافدين.</span>
                        <small>Expats Documents</small>
                    </div>
                }

                @if (documentNeedsHealthCard && !documentHasHealthCard)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>مستند ناقص: بطاقة صحية</strong>
                        <span>مطلوبة للمطاعم، الكافيهات، الفنادق، والمواقع الغذائية.</span>
                        <small>Health Compliance</small>
                    </div>
                }

                @if (Model.PayrollRiskItems > 0)
                {
                    <div class="nxr-requirement-item warn">
                        <strong>جاهزية الراتب</strong>
                        <span>يوجد @Model.PayrollRiskItems ملاحظة تحتاج مراجعة قبل إغلاق الراتب.</span>
                        <small>Payroll Readiness</small>
                    </div>
                }

                @if (Model.AttendanceExceptionsCount > 0)
                {
                    <div class="nxr-requirement-item warn">

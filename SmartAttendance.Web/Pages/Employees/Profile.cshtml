@* NEXORA_PROFILE_STATIC_FUNCTIONS_START *@
@functions {
    private static string NxrDisplayAge(DateOnly? birthDate)
    {
        if (!birthDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - birthDate.Value.Year;

        if (birthDate.Value > today.AddYears(-age))
        {
            age--;
        }

        return age < 0 ? "-" : age.ToString();
    }

    private static string NxrDisplayWorkDuration(DateOnly? hireDate)
    {
        if (!hireDate.HasValue)
        {
            return "-";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var start = hireDate.Value;

        if (start > today)
        {
            return "-";
        }

        var years = today.Year - start.Year;
        var months = today.Month - start.Month;

        if (today.Day < start.Day)
        {
            months--;
        }

        if (months < 0)
        {
            years--;
            months += 12;
        }

        if (years <= 0 && months <= 0)
        {
            return "\u0623\u0642\u0644 \u0645\u0646 \u0634\u0647\u0631";
        }

        if (years <= 0)
        {
            return months.ToString() + " \u0634\u0647\u0631";
        }

        if (months <= 0)
        {
            return years.ToString() + " \u0633\u0646\u0629";
        }

        return years.ToString() + " \u0633\u0646\u0629 \u0648 " + months.ToString() + " \u0634\u0647\u0631";
    }

    private static string NxrDisplayMaritalStatus(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var normalized = value.Trim();

        return normalized switch
        {
            "Single" => "\u0623\u0639\u0632\u0628",
            "Married" => "\u0645\u062A\u0632\u0648\u062C",
            "Divorced" => "\u0645\u0637\u0644\u0642",
            "Widowed" => "\u0623\u0631\u0645\u0644",
            "Separated" => "\u0645\u0646\u0641\u0635\u0644",
            _ => normalized
        };
    }

    private static string NxrDisplayGender(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var normalized = value.Trim();

        return normalized switch
        {
            "Male" => "\u0630\u0643\u0631",
            "Female" => "\u0623\u0646\u062B\u0649",
            _ => normalized
        };
    }
}
@* NEXORA_PROFILE_STATIC_FUNCTIONS_END *@





@{
    ViewData["Title"] = "ملف الموظف";

    var employee = Model.Employee;
    var today = DateOnly.FromDateTime(DateTime.Today);
    var initial = employee == null || string.IsNullOrWhiteSpace(employee.FullName) ? "N" : employee.FullName.Trim()[0].ToString();

    var employeePhotoFallback = Url.Content("~/brand/employee-photo-placeholder.svg");
    string StatusClass(int status)
    {
        return status switch
        {
            1 => "ok",
            2 => "warn",
            3 => "danger",
            4 => "info",
            5 => "muted",
            _ => "muted"
        };
    }

    string RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "ok",
            "Rejected" => "danger",
            "Pending" => "warn",
            _ => "muted"
        };
    }

    string DocumentClass(DateOnly? expiryDate)
    {
        if (!expiryDate.HasValue)
        {
            return "muted";
        }

        if (expiryDate.Value < today)
        {
            return "danger";
        }

        if (expiryDate.Value <= today.AddDays(30))
        {
            return "warn";
        }

        return "ok";
    }

    string DocumentText(DateOnly? expiryDate)
    {
        if (!expiryDate.HasValue)
        {
            return "بدون تاريخ انتهاء";
        }

        if (expiryDate.Value < today)
        {
            return $"منتهي: {expiryDate.Value:yyyy-MM-dd}";
        }

        if (expiryDate.Value <= today.AddDays(30))
        {
            return $"قريب الانتهاء: {expiryDate.Value:yyyy-MM-dd}";
        }

        return $"صالح إلى: {expiryDate.Value:yyyy-MM-dd}";
    }

    var readinessClass = Model.PayrollRiskItems == 0 ? "ok" : "warn";
    var readinessText = Model.PayrollRiskItems == 0 ? "جاهز مبدئياً" : "يحتاج مراجعة";
    var employeeStatusText = employee?.IsActive == true ? "فعال" : "غير فعال";
}


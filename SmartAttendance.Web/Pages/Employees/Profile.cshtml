        var documentHasId = Model.DocumentRows.Any(d =>
            string.Equals(d.DocumentType, "ID", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("هوية", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("بطاقة", StringComparison.OrdinalIgnoreCase));

        var documentHasContract = Model.DocumentRows.Any(d =>
            string.Equals(d.DocumentType, "Contract", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("Contract", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("عقد", StringComparison.OrdinalIgnoreCase));

        var documentHasPassport = Model.DocumentRows.Any(d =>
            string.Equals(d.DocumentType, "Passport", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("Passport", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("جواز", StringComparison.OrdinalIgnoreCase));

        var documentHasVisa = Model.DocumentRows.Any(d =>
            string.Equals(d.DocumentType, "Visa", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("Visa", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("إقامة", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("اقامة", StringComparison.OrdinalIgnoreCase));

        var documentHasHealthCard = Model.DocumentRows.Any(d =>
            string.Equals(d.DocumentType, "Health Card", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("Health", StringComparison.OrdinalIgnoreCase) ||
            (d.DocumentType ?? "").Contains("صحية", StringComparison.OrdinalIgnoreCase));

        var documentEmployeeGeo = $"{employee.Nationality} {employee.Country}".ToLowerInvariant();
        var documentIsExpat =
            !string.IsNullOrWhiteSpace(documentEmployeeGeo) &&
            !(documentEmployeeGeo.Contains("iraq") || documentEmployeeGeo.Contains("iraqi") || documentEmployeeGeo.Contains("العراق") || documentEmployeeGeo.Contains("عراقي") || documentEmployeeGeo.Contains("عراقية"));

        var documentWorkContext = $"{employee.CompanyName} {employee.BranchName} {employee.DepartmentName} {employee.Position}".ToLowerInvariant();
        var documentNeedsHealthCard =
            documentWorkContext.Contains("food") ||
            documentWorkContext.Contains("restaurant") ||
            documentWorkContext.Contains("cafe") ||
            documentWorkContext.Contains("coffee") ||
            documentWorkContext.Contains("kitchen") ||
            documentWorkContext.Contains("hotel") ||
            documentWorkContext.Contains("patchi") ||
            documentWorkContext.Contains("rixos") ||
            documentWorkContext.Contains("movenpick") ||
            documentWorkContext.Contains("مطعم") ||
            documentWorkContext.Contains("كافيه") ||
            documentWorkContext.Contains("مطبخ") ||
            documentWorkContext.Contains("فندق") ||
            documentWorkContext.Contains("اغذية") ||
            documentWorkContext.Contains("أغذية");

        var documentMissingRequiredCount = 0;
        if (!documentHasId) { documentMissingRequiredCount++; }
        if (!documentHasContract) { documentMissingRequiredCount++; }
        if (documentIsExpat && !documentHasPassport) { documentMissingRequiredCount++; }
        if (documentIsExpat && !documentHasVisa) { documentMissingRequiredCount++; }
        if (documentNeedsHealthCard && !documentHasHealthCard) { documentMissingRequiredCount++; }

        var contractNeedsReview = employee.ContractEndDate.HasValue && employee.ContractEndDate.Value <= today.AddDays(30);
        var hasEmployeeRequirements =
            Model.PayrollRiskItems > 0 ||
            Model.AttendanceExceptionsCount > 0 ||
            Model.PendingRequests > 0 ||
            Model.ExpiredDocumentsCount > 0 ||
            Model.ExpiringDocumentsCount > 0 ||
            documentMissingRequiredCount > 0 ||
            contractNeedsReview;


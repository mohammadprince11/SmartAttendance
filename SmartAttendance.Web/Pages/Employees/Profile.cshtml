                    foreach (var row in Model.RequestRows.Take(8))
                    {
                        <div class="nxr-profile-pro-list-item">
                            <div>
                                <strong>@Model.Display(row.RequestType)</strong>
                                <span>@Model.DisplayDate(row.RequestDate) · @Model.Display(row.CurrentStep)</span>
                            </div>
                            <span class="nxr-profile-pro-badge @RequestClass(row.Status)">@Model.RequestStatusText(row.Status)</span>
                        </div>
                    }
                }
                else
                {
                    <div class="nxr-profile-pro-empty">لا توجد طلبات محفوظة.</div>
                }
                </div>
            </div>

            <div id="documents" class="nxr-card nxr-profile-pro-panel">
                <div class="nxr-profile-pro-panel-title with-action">

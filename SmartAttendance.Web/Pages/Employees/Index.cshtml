@page
@model SmartAttendance.Web.Pages.Employees.IndexModel

@{
    ViewData["Title"] = "قائمة الموظفين";

    var employees = Model.Employees;
    var hasFilters = !string.IsNullOrWhiteSpace(Model.SearchTerm)
        || !string.IsNullOrWhiteSpace(Model.BranchFilter)
        || !string.IsNullOrWhiteSpace(Model.DepartmentFilter)
        || !string.IsNullOrWhiteSpace(Model.StatusFilter)
        || !string.IsNullOrWhiteSpace(Model.SortBy);
}

<link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employees-index-pro.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employees-master-filter.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employees-table-modern-rebuild.css" asp-append-version="true" />
<script src="~/js/nexora-employee-row-click.js" asp-append-version="true" defer></script>

<div class="nxr-page nxr-emp-page">
    <section class="nxr-topline nxr-emp-hero">
        <div class="nxr-title">
            <div class="nxr-brand-mini">NEXORA HR PLATFORM</div>
            <h1>قائمة الموظفين</h1>
          @*   <p>بحث وفلترة الموظفين حسب موقع العمل والقسم والحالة مع إبقاء الإجراء الأساسي داخل القائمة: ملف الموظف.</p> *@
        </div>

        <div class="nxr-actions nxr-emp-actions">
            <a asp-page="./Create" class="nxr-btn primary">إضافة موظف</a>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="nxr-success">@TempData["SuccessMessage"]</div>
    }

    <section class="nxr-emp-kpis">
        <div class="nxr-emp-kpi">
            <span>إجمالي الموظفين</span>
            <strong>@Model.TotalEmployees</strong>
            <small>كل السجلات</small>
        </div>

        <div class="nxr-emp-kpi ok">
            <span>فعال</span>
            <strong>@Model.ActiveEmployees</strong>
            <small>موظفون نشطون</small>
        </div>

        <div class="nxr-emp-kpi warn">
            <span>غير فعال</span>
            <strong>@Model.InactiveEmployees</strong>
            <small>قيد المراجعة</small>
        </div>

        <div class="nxr-emp-kpi info">
            <span>تعيينات السنة</span>
            <strong>@Model.NewThisYear</strong>
            <small>@DateTime.Today.Year</small>
        </div>

        <div class="nxr-emp-kpi filter">
            <span>النتائج الحالية</span>
            <strong>@Model.FilteredEmployees</strong>
            <small>حسب البحث والفلترة</small>
        </div>
    </section>

    <section class="nxr-card nxr-emp-filter-card">
        <form method="get" class="nxr-emp-filter nxr-live-filter" data-nxr-live-filter autocomplete="off">
            <div class="nxr-emp-field search">
                <label>بحث سريع</label>
                <input class="nxr-input"
                       type="text"
                       name="SearchTerm"
                       value="@Model.SearchTerm"
                       placeholder="الكود، الاسم، الهاتف، المنصب، موقع العمل أو القسم..."
                       data-nxr-live-search />
            </div>

            <div class="nxr-emp-field">
                <label>موقع العمل</label>
                <select data-nexora-select="true" name="BranchFilter" class="nxr-input" data-nxr-live-select>
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.BranchFilter) ? "selected" : null)">كل مواقع العمل</option>
                    @foreach (var branch in Model.BranchOptions)
                    {
                        <option value="@branch" selected="@(string.Equals(Model.BranchFilter, branch, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                            @branch
                        </option>
                    }
                </select>
            </div>

            <div class="nxr-emp-field">
                <label>القسم</label>
                <select data-nexora-select="true" name="DepartmentFilter" class="nxr-input" data-nxr-live-select>
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.DepartmentFilter) ? "selected" : null)">كل الأقسام</option>
                    @foreach (var department in Model.DepartmentOptions)
                    {
                        <option value="@department" selected="@(string.Equals(Model.DepartmentFilter, department, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                            @department
                        </option>
                    }
                </select>
            </div>

            <div class="nxr-emp-field">
                <label>الحالة</label>
                <select data-nexora-select="true" name="StatusFilter" class="nxr-input" data-nxr-live-select>
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.StatusFilter) ? "selected" : null)">كل الحالات</option>
                    <option value="active" selected="@(string.Equals(Model.StatusFilter, "active", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">فعال</option>
                    <option value="inactive" selected="@(string.Equals(Model.StatusFilter, "inactive", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">غير فعال</option>
                </select>
            </div>

            <div class="nxr-emp-field">
                <label>ترتيب</label>
                <select data-nexora-select="true" name="SortBy" class="nxr-input" data-nxr-live-select>
                    <option value="name" selected="@((Model.SortBy ?? "name").Equals("name", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">حسب الاسم</option>
                    <option value="code" selected="@(string.Equals(Model.SortBy, "code", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">حسب الكود</option>
                    <option value="branch" selected="@(string.Equals(Model.SortBy, "branch", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">حسب موقع العمل</option>
                    <option value="department" selected="@(string.Equals(Model.SortBy, "department", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">حسب القسم</option>
                    <option value="hireDate" selected="@(string.Equals(Model.SortBy, "hireDate", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">الأحدث تعييناً</option>
                    <option value="status" selected="@(string.Equals(Model.SortBy, "status", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">حسب الحالة</option>
                </select>
            </div>

            <div class="nxr-emp-filter-actions">
                <button type="submit" class="nxr-btn primary">تطبيق</button>
                <a asp-page="./Index" class="nxr-btn">مسح الفلاتر</a>
            </div>
        </form>
    </section>

    <section class="nxr-card nxr-emp-list-card">
        <div class="nxr-emp-list-head">
            <div>
                <h2>سجل الموظفين</h2>
                <p>
                    @if (hasFilters)
                    {
                        <span>تم عرض @Model.FilteredEmployees من أصل @Model.TotalEmployees موظف.</span>
                    }
                    else
                    {
                        <span>عرض كل الموظفين المسجلين في النظام.</span>
                    }
                </p>
            </div>

            <span class="nxr-emp-count">@Model.FilteredEmployees نتيجة</span>
        </div>

        <div class="nxr-table-wrap nxr-emp-table-wrap">
            <table class="nxr-table nxr-emp-table">
                <colgroup>
                    <col class="nxr-col-employee" />
                    <col class="nxr-col-code" />
                    <col class="nxr-col-branch" />
                    <col class="nxr-col-department" />
                    <col class="nxr-col-position" />
                    <col class="nxr-col-hire" />
                    <col class="nxr-col-status" />
                   @*  <col class="nxr-col-action" /> *@
                </colgroup>

                <thead>
                    <tr>
                        <th>الموظف</th>
                        <th>الكود</th>
                        <th>موقع العمل</th>
                        <th>القسم</th>
                        <th>المنصب</th>
                        <th>تاريخ التعيين</th>
                        <th>الحالة</th>
</tr>
                </thead>

                <tbody>
                    @if (employees.Any())
                    {
                        foreach (var employee in employees)
                        {
                            <tr class="nxr-clickable-employee-row"
                                data-employee-row
                                data-profile-url="@(Url.Page("./Profile", new { id = employee.Id }))"
                                tabindex="0"
                                role="link"
                                aria-label="Open employee profile">
                                <td class="nxr-emp-person-cell">
                                    <div class="nxr-emp-person">
                                        <div>
                                            <strong>@employee.FullName</strong>
                                            <small>
                                                @if (!string.IsNullOrWhiteSpace(employee.Phone))
                                                {
                                                    <span>@employee.Phone</span>
                                                }
                                                else if (!string.IsNullOrWhiteSpace(employee.Email))
                                                {
                                                    <span>@employee.Email</span>
                                                }
                                                else
                                                {
                                                    <span>لا توجد بيانات تواصل</span>
                                                }
                                            </small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="nxr-code">@employee.EmployeeNo</span>
                                </td>

                                <td>@(!string.IsNullOrWhiteSpace(employee.BranchName) ? employee.BranchName : "غير محدد")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.DepartmentName) ? employee.DepartmentName : "غير محدد")</td>
                                <td>@(!string.IsNullOrWhiteSpace(employee.Position) ? employee.Position : "-")</td>
                                <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>

                                <td>
                                    <span class="nxr-status @(employee.IsActive ? "active" : "inactive")">
                                        @(employee.IsActive ? "فعال" : "غير فعال")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="nxr-empty nxr-emp-empty">
                                لا توجد نتائج مطابقة للبحث أو الفلترة الحالية.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/nexora-employees-master-filter.js" asp-append-version="true"></script>
    <script src="~/js/nexora-employees-table-modern-rebuild.js" asp-append-version="true"></script>
}



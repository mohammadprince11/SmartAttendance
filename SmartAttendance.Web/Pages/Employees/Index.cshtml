@page
@model SmartAttendance.Web.Pages.Employees.IndexModel

@{
    ViewData["Title"] = "Employees";
}

<div class="page-header">
    <div>
        <h1>Employees</h1>
        <p>Manage employee master data</p>
    </div>

    <a asp-page="./Create" class="btn-primary">+ Add Employee</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="Search by employee no, name, department, branch, phone..." />

        <button type="submit" class="btn-primary">Search</button>
        <a asp-page="./Index" class="btn-secondary">Clear</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>Employee No</th>
                <th>Full Name</th>
                <th>Department</th>
                <th>Branch</th>
                <th>Phone</th>
                <th>Hire Date</th>
                <th>Status</th>
                <th style="width: 160px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Employees.Any())
            {
                foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>@employee.EmployeeNo</td>
                        <td>@employee.FullName</td>
                        <td>@employee.DepartmentName</td>
                        <td>@employee.BranchName</td>
                        <td>@employee.Phone</td>
                        <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @(employee.IsActive ? "Active" : "Inactive")
                        </td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@employee.Id" class="btn-table btn-edit">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@employee.Id" class="btn-table btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="text-align:center;">
                        No employees found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

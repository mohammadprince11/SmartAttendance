@page
@model SmartAttendance.Web.Pages.Employees.IndexModel
@{ 
    ViewData["Title"] = "قائمة الموظفين"; 
    var employees = Model.Employees; 
    string BuildEmployeePageUrl(int pageNumber) 
    { 
        return Url.Page("./Index", new { Model.CompanyId, Model.SearchTerm, Model.BranchId, Model.DepartmentId, Model.StatusFilter, Model.SortBy, Model.PageSize, PageNumber = pageNumber }) ?? "#"; 
    } 
}
@section Styles { <link rel="stylesheet" href="~/css/zynora-people.css" asp-append-version="true" /> }
<script src="~/js/nexora-employee-row-click.js" asp-append-version="true" defer></script>

<div class="zhr-container">
    <div class="zhr-header">
        <div class="zhr-company-badge">
            <span style="color:var(--zhr-text-secondary); margin-left:8px;">الشركة الحالية:</span>
            <strong style="color:var(--cloud-white);">@Model.SelectedCompanyName</strong>
        </div>
        @if (Model.CanCreateEmployee || Model.CanImportEmployees) 
        { 
            <div style="display:flex; gap:12px;"> 
                @if (Model.CanImportEmployees) { <a asp-page="./Import" class="zhr-btn zhr-btn-secondary">استيراد الموظفين</a> } 
                @if (Model.CanCreateEmployee) { <a asp-page="./Create" class="zhr-btn zhr-btn-primary">إضافة موظف</a> } 
            </div> 
        }
    </div>

    @if (TempData["SuccessMessage"] != null) 
    { 
        <div style="background:rgba(40, 167, 69, 0.1); color:var(--success); border: 1px solid var(--success); padding:12px; border-radius:8px; margin-bottom:20px; font-weight:bold;">
            @TempData["SuccessMessage"]
        </div> 
    }

    <section class="zhr-kpi-grid">
        <div class="zhr-kpi-card"><span class="zhr-kpi-title">إجمالي الموظفين</span><span class="zhr-kpi-value">@Model.TotalEmployees</span></div>
        <div class="zhr-kpi-card active"><span class="zhr-kpi-title">فعال</span><span class="zhr-kpi-value">@Model.ActiveEmployees</span></div>
        <div class="zhr-kpi-card inactive"><span class="zhr-kpi-title">غير فعال</span><span class="zhr-kpi-value">@Model.InactiveEmployees</span></div>
        <div class="zhr-kpi-card new"><span class="zhr-kpi-title">تعيينات السنة</span><span class="zhr-kpi-value">@Model.NewThisYear</span></div>
        <div class="zhr-kpi-card total"><span class="zhr-kpi-title">النتائج الحالية</span><span class="zhr-kpi-value">@Model.FilteredEmployees</span></div>
    </section>

    <section class="zhr-filter-card">
        <form method="get" id="zhr-filter-form" autocomplete="off" style="margin: 0;">
            <input type="hidden" name="PageNumber" value="1" />
            <div class="zhr-filter-grid">
                <div class="zhr-form-group">
                    <label class="zhr-label">الشركة</label>
                    <select name="CompanyId" class="zhr-select" onchange="document.getElementById('zhr-filter-form').submit()">
                        @foreach(var c in Model.CompanyOptions){<option value="@c.Id" selected="@(Model.CompanyId==c.Id ? "selected" : null)">@c.Name</option>}
                    </select>
                </div>
                <div class="zhr-form-group">
                    <label class="zhr-label">بحث سريع</label>
                    <input type="search" name="SearchTerm" class="zhr-input" value="@Model.SearchTerm" placeholder="الكود، الاسم، القسم..." onblur="document.getElementById('zhr-filter-form').submit()" />
                </div>
                <div class="zhr-form-group">
                    <label class="zhr-label">موقع العمل</label>
                    <select name="BranchId" class="zhr-select" onchange="document.getElementById('zhr-filter-form').submit()">
                        <option value="">الكل</option>
                        @foreach(var b in Model.BranchOptions){<option value="@b.Id" selected="@(Model.BranchId==b.Id ? "selected" : null)">@b.Name</option>}
                    </select>
                </div>
                <div class="zhr-form-group">
                    <label class="zhr-label">القسم</label>
                    <select name="DepartmentId" class="zhr-select" onchange="document.getElementById('zhr-filter-form').submit()">
                        <option value="">الكل</option>
                        @foreach(var d in Model.DepartmentOptions){<option value="@d.Id" selected="@(Model.DepartmentId==d.Id ? "selected" : null)">@d.Name</option>}
                    </select>
                </div>
                <div class="zhr-form-group">
                    <label class="zhr-label">الحالة</label>
                    <select name="StatusFilter" class="zhr-select" onchange="document.getElementById('zhr-filter-form').submit()">
                        <option value="all" selected="@(Model.StatusFilter=="all" ? "selected" : null)">الكل</option>
                        <option value="active" selected="@(Model.StatusFilter=="active" ? "selected" : null)">فعال</option>
                        <option value="inactive" selected="@(Model.StatusFilter=="inactive" ? "selected" : null)">غير فعال</option>
                    </select>
                </div>
                <div class="zhr-form-group">
                    <a asp-page="./Index" asp-route-companyId="@Model.CompanyId" class="zhr-btn zhr-btn-secondary" title="مسح الفلاتر">مسح</a>
                </div>
            </div>
        </form>
    </section>

    <section class="zhr-table-card">
        <div class="zhr-toolbar">
            <span class="zhr-toolbar-info">
                @if(Model.FilteredEmployees > 0){<text>عرض @Model.FirstItemNumber إلى @Model.LastItemNumber من أصل @Model.FilteredEmployees</text>}else{<text>لا توجد نتائج</text>}
            </span>
            <div class="zhr-pagesize-wrapper">
                <label class="zhr-label" style="margin:0;">الأسطر:</label>
                <select name="PageSize" form="zhr-filter-form" class="zhr-select" style="padding: 4px 8px; width: auto; height: 32px;" onchange="document.getElementById('zhr-filter-form').submit()">
                    <option value="10" selected="@(Model.PageSize==10 ? "selected" : null)">10</option>
                    <option value="25" selected="@(Model.PageSize==25 ? "selected" : null)">25</option>
                    <option value="50" selected="@(Model.PageSize==50 ? "selected" : null)">50</option>
                    <option value="100" selected="@(Model.PageSize==100 ? "selected" : null)">100</option>
                </select>
            </div>
        </div>
        <div class="zhr-table-responsive">
            <table class="zhr-table">
                <thead><tr><th>الموظف</th><th>الكود</th><th>موقع العمل</th><th>القسم</th><th>المنصب</th><th>تاريخ التعيين</th><th>الحالة</th></tr></thead>
                <tbody>
                    @if(employees.Any())
                    {
                        foreach(var emp in employees)
                        {
                            <tr class="@(emp.CanViewProfile ? "zhr-clickable" : "")" data-employee-row="@(emp.CanViewProfile ? "true" : null)" data-profile-url="@(emp.CanViewProfile ? Url.Page("./Profile", new { id = emp.Id }) : null)">
                                <td class="zhr-emp-meta"><strong>@emp.FullName</strong><small>@(string.IsNullOrWhiteSpace(emp.Phone) ? emp.Email : emp.Phone)</small></td>
                                <td><strong>@emp.EmployeeNo</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(emp.BranchName) ? "-" : emp.BranchName)</td>
                                <td>@(string.IsNullOrWhiteSpace(emp.DepartmentName) ? "-" : emp.DepartmentName)</td>
                                <td>@(string.IsNullOrWhiteSpace(emp.Position) ? "-" : emp.Position)</td>
                                <td>@emp.HireDate.ToString("yyyy-MM-dd")</td>
                                <td><span class="zhr-status-badge @(emp.IsActive ? "zhr-status-active" : "zhr-status-inactive")">@(emp.IsActive ? "فعال" : "غير فعال")</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" style="text-align:center; padding:32px; color:var(--zhr-text-secondary);">لا توجد بيانات مطابقة</td></tr>
                    }
                </tbody>
            </table>
        </div>
        @if(Model.TotalPages > 1)
        {
            <div class="zhr-pagination">
                @if(Model.PageNumber > 1){<a href="@BuildEmployeePageUrl(Model.PageNumber - 1)" class="zhr-page-link">السابق</a>}else{<button class="zhr-page-link" disabled>السابق</button>} 
                @foreach(var p in Model.PaginationPages)
                {
                    if(p.HasValue)
                    {
                        if(p.Value == Model.PageNumber){<button class="zhr-page-link active" disabled>@p.Value</button>}else{<a href="@BuildEmployeePageUrl(p.Value)" class="zhr-page-link">@p.Value</a>}
                    }
                    else{<span style="color:var(--zhr-text-secondary);">...</span>}
                } 
                @if(Model.PageNumber < Model.TotalPages){<a href="@BuildEmployeePageUrl(Model.PageNumber + 1)" class="zhr-page-link">التالي</a>}else{<button class="zhr-page-link" disabled>التالي</button>}
            </div>
        }
    </section>
</div>

@page
@model SmartAttendance.Web.Pages.Employees.ProfileModel

@{
    ViewData["Title"] = "Employee 360";

    var contractClass = "muted";
    var contractText = "لا يوجد تاريخ نهاية عقد مسجل";

    if (Model.Employee?.ContractEndDate != null)
    {
        var days = Model.Employee.ContractEndDate.Value.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;

        if (days < 0)
        {
            contractClass = "danger";
            contractText = "العقد منتهي منذ " + Math.Abs(days) + " يوم";
        }
        else if (days <= 30)
        {
            contractClass = "warn";
            contractText = "العقد ينتهي خلال " + days + " يوم";
        }
        else
        {
            contractClass = "ok";
            contractText = "العقد مستقر";
        }
    }

    string StatusClass(int status)
    {
        return status switch
        {
            1 => "ok",
            2 => "warn",
            3 => "danger",
            4 => "info",
            5 => "gold",
            _ => "muted"
        };
    }

    string RequestClass(string? status)
    {
        return status switch
        {
            "Approved" => "ok",
            "Rejected" => "danger",
            "Pending" => "warn",
            _ => "muted"
        };
    }
}

<link rel="stylesheet" href="~/css/employee-360-profile-v2.css" asp-append-version="true" />

<div class="employee360v2-page">
    <div class="employee360v2-head">
        <div>
            <div class="employee360v2-eyebrow">NEXORA Employee 360 Final</div>
            <h1>ملف الموظف الشامل</h1>
            <p>Employee 360 Final: ملف موحد للبيانات، الحضور، الطلبات، المستندات، وجاهزية الراتب قبل الإغلاق.</p>
        </div>

        <div class="employee360v2-actions">
            <a asp-page="./Index" class="employee360v2-btn ghost">رجوع</a>
            <a href="#readiness" class="employee360v2-btn primary">مراجعة الراتب</a>

            @if (Model.Employee != null)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Employee.Id" class="employee360v2-btn primary">تعديل البيانات</a>
                <a asp-page="./Lifecycle" asp-route-id="@Model.Employee.Id" class="employee360v2-btn ghost">السجل الوظيفي</a>

                @if (!Model.Employee.IsActive)
                {
                    <a asp-page="./Rehire" asp-route-id="@Model.Employee.Id" class="employee360v2-btn primary">إعادة تعيين</a>
                }


                @if (Model.Employee.IsActive)
                {
                    <a asp-page="./EndService" asp-route-id="@Model.Employee.Id" class="employee360v2-btn danger">إنهاء خدمة</a>
                }
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="employee360v2-alert danger">@Model.ErrorMessage</div>
    }

    @if (Model.Employee != null)
    {
        <section class="employee360v2-hero">
            <div class="employee360v2-avatar">
                @(!string.IsNullOrWhiteSpace(Model.Employee.FullName) ? Model.Employee.FullName.Trim()[0] : 'N')
            </div>

            <div class="employee360v2-identity">
                <h2>@Model.Employee.FullName</h2>
                <div class="employee360v2-meta">
                    <span>@Model.Employee.EmployeeNo</span>
                    <span>@Model.Display(Model.Employee.Position)</span>
                    <span>@Model.Display(Model.Employee.DepartmentName)</span>
                    <span>@Model.Display(Model.Employee.BranchName)</span>
                </div>
            </div>

            <div class="employee360v2-state">
                <span class="employee360v2-status @(Model.Employee.IsActive ? "ok" : "danger")">
                    @(Model.Employee.IsActive ? "فعال" : "غير فعال")
                </span>
                <small>@Model.Display(Model.Employee.EmploymentStatus)</small>
            </div>
        </section>

        <section class="employee360v2-alert-strip @contractClass">
            <strong>حالة العقد</strong>
            <span>@contractText</span>
            <small>نهاية العقد: @Model.DisplayDate(Model.Employee.ContractEndDate)</small>
        </section>
        <section class="employee360v2-readiness-card @Model.PayrollReadinessClass">
            <div>
                <span class="employee360v2-mini-label">Payroll Readiness</span>
                <h3>@Model.PayrollReadinessText</h3>
                <p>
                    يتم احتساب المؤشر من الغياب، البصمات الناقصة، الطلبات المعلقة، والمستندات المنتهية أو القريبة من الانتهاء.
                </p>
            </div>
            <div class="employee360v2-readiness-score">
                <strong>@Model.PayrollRiskItems</strong>
                <span>نقاط تحتاج مراجعة</span>
            </div>
        </section>
        <section class="employee360v11-health-card @Model.Employee360HealthClass">
            <div>
                <span class="employee360v2-mini-label">Employee Health Score</span>
                <h3>مؤشر استقرار الموظف: @Model.Employee360HealthText</h3>
                <p>
                    مؤشر تشغيلي سريع يجمع الغياب، البصمات الناقصة، الطلبات المعلقة، والمستندات. الهدف منه مساعدة HR قبل الراتب، وليس اتخاذ قرار نهائي.
                </p>
            </div>

            <div class="employee360v11-score-ring">
                <strong>@Model.Employee360HealthScore</strong>
                <span>من 100</span>
            </div>
        </section>

        <section class="employee360v2-kpis">
            <div class="employee360v2-kpi">
                <span>سجلات الحضور</span>
                <strong>@Model.AttendanceCount</strong>
                <small>ضمن الفترة المحددة</small>
            </div>

            <div class="employee360v2-kpi ok">
                <span>حاضر</span>
                <strong>@Model.PresentCount</strong>
                <small>سجل حضور</small>
            </div>

            <div class="employee360v2-kpi warn">
                <span>متأخر</span>
                <strong>@Model.LateCount</strong>
                <small>سجل تأخير</small>
            </div>

            <div class="employee360v2-kpi danger">
                <span>غياب</span>
                <strong>@Model.AbsentCount</strong>
                <small>سجل غياب</small>
            </div>

            <div class="employee360v2-kpi warn">
                <span>بصمات ناقصة</span>
                <strong>@Model.MissingCheckoutCount</strong>
                <small>خروج مفقود</small>
            </div>

            <div class="employee360v2-kpi">
                <span>ساعات العمل</span>
                <strong>@Model.TotalWorkingHours</strong>
                <small>ساعة محسوبة</small>
            </div>            <div class="employee360v2-kpi @Model.PayrollReadinessClass">
                <span>جاهزية الراتب</span>
                <strong>@Model.PayrollRiskItems</strong>
                <small>@Model.PayrollReadinessText</small>
            </div>

            <div class="employee360v2-kpi @Model.AttendanceRiskClass">
                <span>مخاطر الحضور</span>
                <strong>@Model.AttendanceRiskItems</strong>
                <small>غياب + تأخير + بصمة ناقصة</small>
            </div>

            <div class="employee360v2-kpi warn">
                <span>مستندات تحتاج متابعة</span>
                <strong>@(Model.ExpiredDocumentsCount + Model.ExpiringDocumentsCount)</strong>
                <small>منتهية أو خلال 30 يوم</small>
            </div>            <div class="employee360v2-kpi @Model.AttendanceExceptionClass">
                <span>استثناءات الحضور</span>
                <strong>@Model.AttendanceExceptionsCount</strong>
                <small>تأخير، غياب، بصمة ناقصة أو ملاحظات</small>
            </div>


        </section>

        <section class="employee360v2-tabs">
            <a href="#basic">البيانات</a>
            <a href="#attendance">الحضور</a>
            <a href="#exceptions">استثناءات الحضور</a>
            <a href="#shifts">الشفتات</a>
            <a href="#requests">الطلبات</a>
            <a href="#documents">المستندات</a>
            <a href="#readiness">جاهزية الراتب</a>
            <a href="#audit">السجل</a>
        </section>

        <section id="basic" class="employee360v2-grid">
            <div class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>البيانات الأساسية</h3>
                </div>

                <div class="employee360v2-info">
                    <div><span>كود الموظف</span><strong>@Model.Employee.EmployeeNo</strong></div>
                    <div><span>الاسم</span><strong>@Model.Employee.FullName</strong></div>
                    <div><span>الرقم الوطني</span><strong>@Model.Display(Model.Employee.NationalId)</strong></div>
                    <div><span>الهاتف</span><strong>@Model.Display(Model.Employee.Phone)</strong></div>
                    <div><span>الإيميل</span><strong>@Model.Display(Model.Employee.Email)</strong></div>
                    <div><span>تاريخ الميلاد</span><strong>@Model.DisplayDate(Model.Employee.BirthDate)</strong></div>
                    <div><span>الجنس</span><strong>@Model.Display(Model.Employee.Gender)</strong></div>
                    <div><span>الجنسية</span><strong>@Model.Display(Model.Employee.Nationality)</strong></div>
                    <div><span>البلد</span><strong>@Model.Display(Model.Employee.Country)</strong></div>
                </div>
            </div>

            <div class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>البيانات الوظيفية</h3>
                </div>

                <div class="employee360v2-info">
                    <div><span>الشركة</span><strong>@Model.Display(Model.Employee.CompanyName)</strong></div>
                    <div><span>الفرع</span><strong>@Model.Display(Model.Employee.BranchName)</strong></div>
                    <div><span>القسم</span><strong>@Model.Display(Model.Employee.DepartmentName)</strong></div>
                    <div><span>المنصب</span><strong>@Model.Display(Model.Employee.Position)</strong></div>
                    <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(Model.Employee.HireDate)</strong></div>
                    <div><span>نوع العقد</span><strong>@Model.Display(Model.Employee.ContractType)</strong></div>
                    <div><span>نهاية العقد</span><strong>@Model.DisplayDate(Model.Employee.ContractEndDate)</strong></div>
                    <div><span>الحالة الوظيفية</span><strong>@Model.Display(Model.Employee.EmploymentStatus)</strong></div>
                    <div><span>المدير المباشر</span><strong>@Model.Display(Model.Employee.DirectManager)</strong></div>
                </div>
            </div>
        </section>
        <section id="exceptions" class="employee360v2-card employee360v12-exceptions-panel">
            <div class="employee360v2-card-head">
                <h3>استثناءات الحضور</h3>
                <span class="employee360v2-status @Model.AttendanceExceptionClass">@Model.AttendanceExceptionsCount حالة</span>
            </div>

            <div class="employee360v12-exception-summary">
                <div>
                    <strong>@Model.LateCount</strong>
                    <span>تأخير</span>
                </div>
                <div>
                    <strong>@Model.AbsentCount</strong>
                    <span>غياب</span>
                </div>
                <div>
                    <strong>@Model.MissingCheckoutCount</strong>
                    <span>بصمة ناقصة</span>
                </div>
                <div>
                    <strong>@Model.AttendanceExceptionRows.Count</strong>
                    <span>معروضة الآن</span>
                </div>
            </div>

            <div class="employee360v2-table-wrap">
                <table class="employee360v2-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الدخول</th>
                            <th>الخروج</th>
                            <th>الحالة</th>
                            <th>المصدر</th>
                            <th>الملاحظة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AttendanceExceptionRows.Any())
                        {
                            foreach (var row in Model.AttendanceExceptionRows)
                            {
                                <tr>
                                    <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                    <td>@Model.DisplayTime(row.CheckIn)</td>
                                    <td>@Model.DisplayTime(row.CheckOut)</td>
                                    <td><span class="employee360v2-status @StatusClass(row.Status)">@Model.AttendanceStatusName(row.Status)</span></td>
                                    <td>@Model.AttendanceSourceName(row.Source)</td>
                                    <td>@Model.Display(row.Notes)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">لا توجد استثناءات حضور ضمن الفترة المحددة.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="employee360v2-payroll-note">
                <strong>استخدام عملي:</strong>
                هذه القائمة تساعد HR على معرفة السجلات التي يجب مراجعتها قبل اعتماد الراتب أو إغلاق فترة الحضور.
            </div>
        </section>
        <section id="attendance" class="employee360v2-card">
            <div class="employee360v2-card-head split">
                <div>
                    <h3>الحضور والانصراف</h3>
                    <p>آخر السجلات حسب الفترة المحددة.</p>
                </div>

                <form method="get" class="employee360v2-filter">
                    <input type="hidden" name="Id" value="@Model.Employee.Id" />
                    <label>
                        من
                        <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                    </label>
                    <label>
                        إلى
                        <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                    </label>
                    <button type="submit" class="employee360v2-btn primary">تحديث</button>
                </form>
            </div>

            <div class="employee360v2-table-wrap">
                <table class="employee360v2-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الدخول</th>
                            <th>الخروج</th>
                            <th>الحالة</th>
                            <th>المصدر</th>
                            <th>الجهاز</th>
                            <th>الملاحظة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.AttendanceRows)
                        {
                            <tr>
                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                <td><span class="employee360v2-badge @StatusClass(row.Status)">@Model.StatusText(row.Status)</span></td>
                                <td>@Model.SourceText(row.Source)</td>
                                <td>@Model.Display(row.DeviceName)</td>
                                <td>@Model.Display(row.Notes)</td>
                            </tr>
                        }

                        @if (!Model.AttendanceRows.Any())
                        {
                            <tr>
                                <td colspan="7" class="employee360v2-empty">لا توجد سجلات حضور ضمن الفترة المحددة.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="employee360v2-grid">
            <div id="shifts" class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>الشفتات</h3>
                    <p>الشفت الحالي والسابق للموظف.</p>
                </div>

                <div class="employee360v2-table-wrap">
                    <table class="employee360v2-table compact">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th>الشفت</th>
                                <th>الوقت</th>
                                <th>من</th>
                                <th>إلى</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ShiftRows)
                            {
                                <tr>
                                    <td>@row.Code</td>
                                    <td>@row.Name</td>
                                    <td>@row.StartTime - @row.EndTime</td>
                                    <td>@Model.DisplayDate(row.EffectiveFrom)</td>
                                    <td>@Model.DisplayDate(row.EffectiveTo)</td>
                                    <td>@(row.IsCurrent ? "حالي" : "سابق")</td>
                                </tr>
                            }

                            @if (!Model.ShiftRows.Any())
                            {
                                <tr>
                                    <td colspan="6" class="employee360v2-empty">لا توجد شفتات مسجلة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="requests" class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>الطلبات</h3>
                    <p>آخر طلبات الخدمات الذاتية.</p>
                </div>

                <div class="employee360v2-mini-kpis">
                    <div><span>معلق</span><strong>@Model.PendingRequests</strong></div>
                    <div><span>مقبول</span><strong>@Model.ApprovedRequests</strong></div>
                    <div><span>مرفوض</span><strong>@Model.RejectedRequests</strong></div>
                </div>

                <div class="employee360v2-table-wrap">
                    <table class="employee360v2-table compact">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>النوع</th>
                                <th>الحالة</th>
                                <th>المرحلة</th>
                                <th>التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.RequestRows)
                            {
                                <tr>
                                    <td>@row.Id</td>
                                    <td>@row.RequestType</td>
                                    <td><span class="employee360v2-badge @RequestClass(row.Status)">@Model.RequestStatusText(row.Status)</span></td>
                                    <td>@Model.Display(row.CurrentStep)</td>
                                    <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                </tr>
                            }

                            @if (!Model.RequestRows.Any())
                            {
                                <tr>
                                    <td colspan="5" class="employee360v2-empty">لا توجد طلبات مسجلة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="employee360v2-grid">
            <div id="documents" class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>المستندات</h3>
                    <p>ملفات الموظف المرفوعة.</p>
                </div>

                <div class="employee360v2-table-wrap">
                    <table class="employee360v2-table compact">
                        <thead>
                            <tr>
                                <th>النوع</th>
                                <th>الملف</th>
                                <th>تاريخ الانتهاء</th>
                                <th>تاريخ الرفع</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.DocumentRows)
                            {
                                <tr>
                                    <td>@row.DocumentType</td>
                                    <td>@row.FileName</td>
                                    <td>@Model.DisplayDate(row.ExpiryDate)</td>
                                    <td>@Model.DisplayDateTime(row.UploadedAt)</td>
                                </tr>
                            }

                            @if (!Model.DocumentRows.Any())
                            {
                                <tr>
                                    <td colspan="4" class="employee360v2-empty">لا توجد مستندات مرفوعة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="audit" class="employee360v2-card">
                <div class="employee360v2-card-head">
                    <h3>سجل التعديلات</h3>
                    <p>آخر العمليات المسجلة على الموظف.</p>
                </div>

                <div class="employee360v2-table-wrap">
                    <table class="employee360v2-table compact">
                        <thead>
                            <tr>
                                <th>الإجراء</th>
                                <th>المستخدم</th>
                                <th>التاريخ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.AuditRows)
                            {
                                <tr>
                                    <td>@row.Action</td>
                                    <td>@Model.Display(row.UserName)</td>
                                    <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                </tr>
                            }

                            @if (!Model.AuditRows.Any())
                            {
                                <tr>
                                    <td colspan="3" class="employee360v2-empty">لا يوجد سجل تعديلات لهذا الموظف.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
            <div id="readiness" class="employee360v2-card employee360v2-readiness-panel">
                <div class="employee360v2-card-head">
                    <h3>جاهزية الراتب</h3>
                    <span class="employee360v2-status @Model.PayrollReadinessClass">@Model.PayrollReadinessText</span>
                </div>

                <div class="employee360v2-risk-grid">
                    <div class="employee360v2-risk-item">
                        <span>غياب</span>
                        <strong>@Model.AbsentCount</strong>
                        <small>سجلات غياب ضمن الفترة</small>
                    </div>

                    <div class="employee360v2-risk-item">
                        <span>بصمات ناقصة</span>
                        <strong>@Model.MissingCheckoutCount</strong>
                        <small>تحتاج تصحيح قبل الراتب</small>
                    </div>

                    <div class="employee360v2-risk-item">
                        <span>طلبات معلقة</span>
                        <strong>@Model.PendingRequests</strong>
                        <small>بانتظار موافقة</small>
                    </div>

                    <div class="employee360v2-risk-item">
                        <span>مستندات منتهية</span>
                        <strong>@Model.ExpiredDocumentsCount</strong>
                        <small>تحتاج تحديث</small>
                    </div>

                    <div class="employee360v2-risk-item">
                        <span>مستندات خلال 30 يوم</span>
                        <strong>@Model.ExpiringDocumentsCount</strong>
                        <small>تنبيه مبكر</small>
                    </div>
                </div>
                <div class="employee360v11-closure-checklist">
                    <div class="employee360v11-check @(Model.AbsentCount == 0 ? "ok" : "warn")">
                        <strong>الغياب</strong>
                        <span>@(Model.AbsentCount == 0 ? "لا توجد غيابات ضمن الفترة" : "توجد غيابات تحتاج مراجعة")</span>
                    </div>

                    <div class="employee360v11-check @(Model.MissingCheckoutCount == 0 ? "ok" : "warn")">
                        <strong>البصمات الناقصة</strong>
                        <span>@(Model.MissingCheckoutCount == 0 ? "لا توجد بصمات ناقصة" : "توجد بصمات ناقصة قبل الراتب")</span>
                    </div>

                    <div class="employee360v11-check @(Model.PendingRequests == 0 ? "ok" : "warn")">
                        <strong>الطلبات المعلقة</strong>
                        <span>@(Model.PendingRequests == 0 ? "لا توجد طلبات معلقة" : "توجد طلبات بانتظار الموافقة")</span>
                    </div>

                    <div class="employee360v11-check @(Model.ExpiredDocumentsCount == 0 ? "ok" : "warn")">

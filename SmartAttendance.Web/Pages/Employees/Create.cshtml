@page
@model SmartAttendance.Web.Pages.Employees.CreateModel

<link rel="stylesheet" href="~/css/nexora-edit-custom-datepicker.css" asp-append-version="true" />
@{
    ViewData["Title"] = "إضافة موظف جديد";
    var employeePhotoFallback = Url.Content("~/brand/employee-photo-placeholder.svg");
}

<link rel="stylesheet" href="~/css/nexora-employee-create-documents-final.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-create-clean-fix.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-create-stable.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-photo-upload.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-employee-profile-dynamic-fields.css" asp-append-version="true" />

<div class="nxr-page nxr-create-clean-page" dir="rtl">
    <section class="nxr-topline nxr-create-clean-header">
        <div class="nxr-title">
            <div class="nxr-brand-mini">NEXORA HR</div>
            <h1>إضافة موظف جديد</h1>
            <p>إدخال بيانات الموظف الأساسية والوظيفية مع إمكانية رفع المستمسكات عند الإنشاء.</p>
        </div>

        <div class="nxr-actions">
            <a asp-page="./Index" class="nxr-btn">رجوع للقائمة</a>
            <button form="employee-create-form" type="submit" class="nxr-btn primary">إنشاء الموظف</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="nxr-error">@Model.ErrorMessage</div>
    }

    <form id="employee-create-form" method="post" enctype="multipart/form-data" class="nxr-form nxr-create-clean-form">

        <section class="nxr-card nxr-form-section nxr-create-section nxr-photo-upload-card">
            <div class="nxr-section-title">
                <div>
                    <h2>صورة الموظف</h2>
                    <p>اضغط على مساحة الصورة نفسها أو اسحب الصورة فوقها. لا يوجد زر رفع منفصل.</p>
                </div>
                <span class="nxr-chip">اختياري</span>
            </div>

            <div class="nxr-photo-upload-wrap">
                <label class="nxr-photo-drop has-image has-brand-placeholder" data-employee-photo-drop>
                    <input asp-for="EmployeePhoto" type="file" accept="image/png,image/jpeg,image/webp" />
                    <img class="nxr-photo-preview" src="@employeePhotoFallback" data-employee-photo-preview data-placeholder-src="@employeePhotoFallback" alt="Employee photo preview" onerror="this.onerror=null;this.src='@employeePhotoFallback';" />
                    <span class="nxr-photo-placeholder">
                        <strong>+</strong>
                        <span>اضغط لإضافة صورة</span>
                    </span>
                </label>

                <div class="nxr-photo-hint">
                    <strong>مساحة الصورة هي زر الرفع</strong>
                    <span>ارفع صورة واضحة للموظف بصيغة PNG أو JPG أو WEBP.</span>
                    <small>الحد الأقصى 5MB. سيتم حفظ الصورة داخل ملف الموظف بعد الإنشاء.</small>
                </div>
            </div>
        </section>

        <section class="nxr-card nxr-form-section nxr-create-section">
            <div class="nxr-section-title">
                <div>
                    <h2>البيانات الأساسية</h2>
                    <p>الحقول الرئيسية لتعريف الموظف داخل النظام.</p>
                </div>
                <span class="nxr-chip gold">مطلوب</span>
            </div>

            <div class="nxr-form-grid nxr-create-grid nxr-basic-grid">
                <div class="nxr-field">
                    <label asp-for="Employee.EmployeeNo">كود الموظف</label>
                    <input asp-for="Employee.EmployeeNo" placeholder="مثال: EMP-250601" />
                    <span asp-validation-for="Employee.EmployeeNo" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.FullName">الاسم الكامل</label>
                    <input asp-for="Employee.FullName" placeholder="أدخل الاسم الكامل" />
                    <span asp-validation-for="Employee.FullName" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.NationalId">رقم الهوية</label>
                    <input asp-for="Employee.NationalId" placeholder="أدخل رقم الهوية" />
                    <span asp-validation-for="Employee.NationalId" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.BirthDate">تاريخ الميلاد</label>
                    <input data-nexora-date-field="true" inputmode="numeric" autocomplete="off" placeholder="yyyy-mm-dd" asp-for="Employee.BirthDate" type="text" />
                    <span asp-validation-for="Employee.BirthDate" class="text-danger"></span>
                </div>
@* NEXORA_DEMOGRAPHIC_FIELDS_START *@
                <div class="nxr-field">
                    <label asp-for="Employee.Gender">&#x0627;&#x0644;&#x062C;&#x0646;&#x0633;</label>
                    <select asp-for="Employee.Gender" class="nxr-native-select">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631;...</option>
                        <option value="Male">&#x0630;&#x0643;&#x0631;</option>
                        <option value="Female">&#x0623;&#x0646;&#x062B;&#x0649;</option>
                    </select>
                    <span asp-validation-for="Employee.Gender" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.MaritalStatus">&#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x0629; &#x0627;&#x0644;&#x0627;&#x062C;&#x062A;&#x0645;&#x0627;&#x0639;&#x064A;&#x0629;</label>
                    <select asp-for="Employee.MaritalStatus" class="nxr-native-select">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631;...</option>
                        <option value="Single">&#x0623;&#x0639;&#x0632;&#x0628;</option>
                        <option value="Married">&#x0645;&#x062A;&#x0632;&#x0648;&#x062C;</option>
                        <option value="Divorced">&#x0645;&#x0637;&#x0644;&#x0642;</option>
                        <option value="Widowed">&#x0623;&#x0631;&#x0645;&#x0644;</option>
                        <option value="Separated">&#x0645;&#x0646;&#x0641;&#x0635;&#x0644;</option>
                    </select>
                    <span asp-validation-for="Employee.MaritalStatus" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.Country">&#x0627;&#x0644;&#x0628;&#x0644;&#x062F;</label>
                    <select asp-for="Employee.Country" class="nxr-native-select">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631; &#x0627;&#x0644;&#x0628;&#x0644;&#x062F;</option>
                        <option value="Iraq">&#x0627;&#x0644;&#x0639;&#x0631;&#x0627;&#x0642;</option>
                        <option value="Syria">&#x0633;&#x0648;&#x0631;&#x064A;&#x0627;</option>
                        <option value="Jordan">&#x0627;&#x0644;&#x0623;&#x0631;&#x062F;&#x0646;</option>
                        <option value="Lebanon">&#x0644;&#x0628;&#x0646;&#x0627;&#x0646;</option>
                        <option value="Saudi Arabia">&#x0627;&#x0644;&#x0633;&#x0639;&#x0648;&#x062F;&#x064A;&#x0629;</option>
                        <option value="United Arab Emirates">&#x0627;&#x0644;&#x0625;&#x0645;&#x0627;&#x0631;&#x0627;&#x062A;</option>
                        <option value="Qatar">&#x0642;&#x0637;&#x0631;</option>
                        <option value="Kuwait">&#x0627;&#x0644;&#x0643;&#x0648;&#x064A;&#x062A;</option>
                        <option value="Bahrain">&#x0627;&#x0644;&#x0628;&#x062D;&#x0631;&#x064A;&#x0646;</option>
                        <option value="Oman">&#x0639;&#x0645;&#x0627;&#x0646;</option>
                        <option value="Egypt">&#x0645;&#x0635;&#x0631;</option>
                        <option value="Turkey">&#x062A;&#x0631;&#x0643;&#x064A;&#x0627;</option>
                        <option value="Iran">&#x0625;&#x064A;&#x0631;&#x0627;&#x0646;</option>
                        <option value="India">&#x0627;&#x0644;&#x0647;&#x0646;&#x062F;</option>
                        <option value="Pakistan">&#x0628;&#x0627;&#x0643;&#x0633;&#x062A;&#x0627;&#x0646;</option>
                        <option value="Bangladesh">&#x0628;&#x0646;&#x063A;&#x0644;&#x0627;&#x062F;&#x0634;</option>
                        <option value="Philippines">&#x0627;&#x0644;&#x0641;&#x0644;&#x0628;&#x064A;&#x0646;</option>
                        <option value="Nepal">&#x0646;&#x064A;&#x0628;&#x0627;&#x0644;</option>
                        <option value="Other">&#x0623;&#x062E;&#x0631;&#x0649;</option>
                    </select>
                    <span asp-validation-for="Employee.Country" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.Nationality">&#x0627;&#x0644;&#x062C;&#x0646;&#x0633;&#x064A;&#x0629;</label>
                    <select asp-for="Employee.Nationality" class="nxr-native-select">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631; &#x0627;&#x0644;&#x062C;&#x0646;&#x0633;&#x064A;&#x0629;</option>
                        <option value="Iraqi">&#x0639;&#x0631;&#x0627;&#x0642;&#x064A;</option>
                        <option value="Syrian">&#x0633;&#x0648;&#x0631;&#x064A;</option>
                        <option value="Jordanian">&#x0623;&#x0631;&#x062F;&#x0646;&#x064A;</option>
                        <option value="Lebanese">&#x0644;&#x0628;&#x0646;&#x0627;&#x0646;&#x064A;</option>
                        <option value="Saudi">&#x0633;&#x0639;&#x0648;&#x062F;&#x064A;</option>
                        <option value="Emirati">&#x0625;&#x0645;&#x0627;&#x0631;&#x0627;&#x062A;&#x064A;</option>
                        <option value="Qatari">&#x0642;&#x0637;&#x0631;&#x064A;</option>
                        <option value="Kuwaiti">&#x0643;&#x0648;&#x064A;&#x062A;&#x064A;</option>
                        <option value="Bahraini">&#x0628;&#x062D;&#x0631;&#x064A;&#x0646;&#x064A;</option>
                        <option value="Omani">&#x0639;&#x0645;&#x0627;&#x0646;&#x064A;</option>
                        <option value="Egyptian">&#x0645;&#x0635;&#x0631;&#x064A;</option>
                        <option value="Turkish">&#x062A;&#x0631;&#x0643;&#x064A;</option>
                        <option value="Iranian">&#x0625;&#x064A;&#x0631;&#x0627;&#x0646;&#x064A;</option>
                        <option value="Indian">&#x0647;&#x0646;&#x062F;&#x064A;</option>
                        <option value="Pakistani">&#x0628;&#x0627;&#x0643;&#x0633;&#x062A;&#x0627;&#x0646;&#x064A;</option>
                        <option value="Bangladeshi">&#x0628;&#x0646;&#x063A;&#x0644;&#x0627;&#x062F;&#x0634;&#x064A;</option>
                        <option value="Filipino">&#x0641;&#x0644;&#x0628;&#x064A;&#x0646;&#x064A;</option>
                        <option value="Nepali">&#x0646;&#x064A;&#x0628;&#x0627;&#x0644;&#x064A;</option>
                        <option value="Other">&#x0623;&#x062E;&#x0631;&#x0649;</option>
                    </select>
                    <span asp-validation-for="Employee.Nationality" class="text-danger"></span>
                </div>
@* NEXORA_DEMOGRAPHIC_FIELDS_END *@
@* NEXORA_MARITAL_STATUS_FIELD_END *@
            </div>
        </section>

        <section class="nxr-card nxr-form-section nxr-create-section">
            <div class="nxr-section-title">
                <div>
                    <h2>المعلومات الوظيفية</h2>
                    <p>اختيار القسم وتحديد المنصب وتاريخ التعيين.</p>
                </div>
                <span class="nxr-chip gold">مطلوب</span>
            </div>

            <div class="nxr-form-grid nxr-create-grid nxr-employment-grid">
                <div class="nxr-field">
                    <label asp-for="Employee.BranchId">&#x0645;&#x0648;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</label>
                    <select asp-for="Employee.BranchId" class="nxr-native-select" id="Employee_BranchId">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631; &#x0645;&#x0648;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</option>
                        @foreach (var branch in Model.Branches.OrderBy(x => x.Name))
                        {
                            <option value="@branch.Id"
                                    data-company-id="@branch.CompanyId"
                                    selected="@(branch.Id == Model.Employee.BranchId ? "selected" : null)">
                                @branch.Name
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.BranchId" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.DepartmentId">&#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</label>
                    <select data-nexora-select="true" asp-for="Employee.DepartmentId" class="nxr-native-select" id="Employee_DepartmentId">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</option>
                        @foreach (var department in Model.Departments.OrderBy(x => x.CompanyName).ThenBy(x => x.Name))
                        {
                            <option value="@department.Id"
                                    data-company-id="@department.CompanyId"
                                    selected="@(department.Id == Model.Employee.DepartmentId ? "selected" : null)">
                                @department.Name
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.DepartmentId" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.PositionId">&#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;</label>
                    <select asp-for="Employee.PositionId" class="nxr-native-select" id="Employee_PositionId">
                        <option value="">&#x0627;&#x062E;&#x062A;&#x0631; &#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;</option>
                        @foreach (var position in Model.PositionOptions.OrderBy(x => x.Name))
                        {
                            <option value="@position.Id"
                                    data-company-id="@position.CompanyId"
                                    selected="@(position.Id == Model.Employee.PositionId ? "selected" : null)">
                                @position.Name
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.PositionId" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.HireDate">تاريخ التعيين</label>
                    <input data-nexora-date-field="true" inputmode="numeric" autocomplete="off" placeholder="yyyy-mm-dd" asp-for="Employee.HireDate" type="text" />
                    <span asp-validation-for="Employee.HireDate" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="nxr-card nxr-form-section nxr-create-section">
            <div class="nxr-section-title">
                <div>
                    <h2>بيانات الاتصال</h2>
                    <p>معلومات التواصل الخاصة بالموظف.</p>
                </div>
                <span class="nxr-chip">اختياري</span>
            </div>

            <div class="nxr-form-grid nxr-create-grid two">
                <div class="nxr-field">
                    <label asp-for="Employee.Phone">الهاتف</label>
                    <input asp-for="Employee.Phone" placeholder="07xxxxxxxxx" />
                    <span asp-validation-for="Employee.Phone" class="text-danger"></span>
                </div>

                <div class="nxr-field">
                    <label asp-for="Employee.Email">البريد الإلكتروني</label>
                    <input asp-for="Employee.Email" placeholder="name@example.com" />
                    <span asp-validation-for="Employee.Email" class="text-danger"></span>
                </div>
            </div>
        </section>


        @* NEXORA_CREATE_DYNAMIC_PROFILE_FIELDS_MARKER *@
        @if (Model.ProfileDynamicSections.Any(profileSection => profileSection.Fields.Count > 0))
        {
            <section class="nxr-card nxr-form-section nxr-create-section nxr-create-dynamic-profile-section">
                <div class="nxr-section-title">
                    <div>
                        <h2>&#x062D;&#x0642;&#x0648;&#x0644; &#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;</h2>
                        <p>&#x0627;&#x0644;&#x062D;&#x0642;&#x0648;&#x0644; &#x0627;&#x0644;&#x0625;&#x0636;&#x0627;&#x0641;&#x064A;&#x0629; &#x0627;&#x0644;&#x062A;&#x064A; &#x062A;&#x0645;&#x062A; &#x0625;&#x0636;&#x0627;&#x0641;&#x062A;&#x0647;&#x0627; &#x0645;&#x0646; &#x0625;&#x0639;&#x062F;&#x0627;&#x062F;&#x0627;&#x062A; &#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;.</p>
                    </div>
                    <span class="nxr-chip gold">&#x062A;&#x062D;&#x0641;&#x0638; &#x0639;&#x0646;&#x062F; &#x0627;&#x0644;&#x0625;&#x0646;&#x0634;&#x0627;&#x0621;</span>
                </div>

                <div class="nxr-create-dynamic-profile-groups">
                    @foreach (var profileSection in Model.ProfileDynamicSections.Where(item => item.Fields.Count > 0))
                    {
                        <div class="nxr-create-dynamic-profile-group">
<div class="nxr-form-grid nxr-create-grid">
                                @foreach (var field in profileSection.Fields)
                                {
                                    var inputId = $"CreateProfileCustomValues_{field.FieldKey}";
                                    var requiredAttribute = field.IsRequired ? "required" : null;
                                    var fieldClass = field.IsTextArea ? "nxr-field wide" : "nxr-field";

                                    <div class="@fieldClass">
                                        <label for="@inputId">
                                            @field.FieldLabel
                                            @if (field.IsRequired)
                                            {
                                                <span>*</span>
                                            }
                                        </label>

                                        @if (field.IsTextArea)
                                        {
                                            <textarea id="@inputId"
                                                      name="ProfileCustomValues[@field.FieldKey]"
                                                      required="@requiredAttribute"
                                                      rows="3"
                                                      placeholder="@field.FieldLabel">@field.FieldValue</textarea>
                                        }
                                        else
                                        {
                                            <input id="@inputId"
                                                   name="ProfileCustomValues[@field.FieldKey]"
                                                   type="@field.InputType"
                                                   value="@field.FieldValue"
                                                   required="@requiredAttribute"
                                                   placeholder="@field.FieldLabel" />
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
        <section class="nxr-card nxr-form-section nxr-create-section nxr-documents-section">
            <div class="nxr-section-title">
                <div>
                    <h2>المستمسكات الأولية</h2>
                    <p>يمكن رفع مستمسكات الموظف الآن أو لاحقاً من ملف الموظف.</p>
                </div>
                <span class="nxr-chip gold">تحفظ عند الإنشاء</span>
            </div>

            <div class="nxr-doc-clean-box">
                <div>
                    <strong>الملفات المدعومة</strong>
                    <p>PDF, JPG, PNG, Word, Excel وبحد أقصى 10MB لكل ملف.</p>
                </div>

                <button type="button" class="nxr-btn nxr-documents-modal-open" data-nxr-documents-open>
                    اختيار المستمسكات والملفات
                </button>
            </div>

            <div class="nxr-selected-documents" data-nxr-documents-preview>
                لم يتم اختيار أي مستمسك بعد.
            </div>
        </section>

        <div id="nxrDocumentsModal" class="nxr-documents-modal" data-nxr-documents-modal aria-hidden="true">
            <div class="nxr-documents-modal-panel" role="dialog" aria-modal="true" aria-label="المستمسكات الأولية">
                <div class="nxr-documents-modal-head">
                    <div>
                        <span class="nxr-force-modal-badge">NEXORA Employee Documents</span>
                        <h2>اختيار المستمسكات الأولية</h2>
                        <p>كل صف يحتوي نوع المستمسك، حالة المطلوب، واختيار الملف الذي سيُحفظ عند إنشاء الموظف.</p>
                    </div>

                    <button type="button" class="nxr-documents-modal-close" data-nxr-documents-close aria-label="إغلاق">×</button>
                </div>

                <div class="nxr-documents-modal-body">
                    <div class="nxr-force-modal-note">
                        <strong>ملاحظة:</strong>
                        عند الضغط على إنشاء الموظف سيتم رفع الملفات وربطها بملف الموظف الجديد تلقائياً.
                    </div>

                    <div class="nxr-document-summary">
                        عدد المستمسكات المحددة: <strong data-nxr-documents-count>0</strong>
                    </div>
                    <div class="nxr-documents-validation" data-nxr-documents-validation hidden></div>

                    <div class="nxr-documents-list-modal" data-nxr-documents-list></div>

                    <button type="button" class="nxr-force-btn gold nxr-document-add" data-nxr-document-add>
                        + إضافة مستمسك
                    </button>
                </div>

                <div class="nxr-documents-modal-actions">
                    <button type="button" class="nxr-force-btn gold" data-nxr-documents-close>&#1581;&#1601;&#1592;</button>
                </div>
            </div>
        </div>

        <section class="nxr-create-submit-bar">
            <a asp-page="./Index" class="nxr-btn">إلغاء</a>
            <button type="submit" class="nxr-btn primary">إنشاء الموظف</button>
        </section>
</form>
</div>
<script src="~/js/nexora-edit-custom-datepicker.js" asp-append-version="true" defer></script>
@section Scripts {
    <!-- NEXORA_CREATE_ORGANIZATION_FILTER_START -->
    <script>
        (() => {
            const workLocation = document.getElementById("Employee_BranchId");
            const department = document.getElementById("Employee_DepartmentId");
            const position = document.getElementById("Employee_PositionId");

            if (!workLocation || !department || !position) {
                return;
            }

            function refreshSelect(select) {
                if (window.NexoraSelect && typeof window.NexoraSelect.refresh === "function") {
                    window.NexoraSelect.refresh(select);
                }

                select.dispatchEvent(new Event("change", { bubbles: true }));
            }

            function filterByCompany(select, companyId) {
                let currentIsValid = false;

                Array.from(select.options).forEach(option => {
                    if (!option.value) {
                        option.hidden = false;
                        option.disabled = false;
                        return;
                    }

                    const belongsToCompany =
                        companyId &&
                        option.dataset.companyId === companyId;

                    option.hidden = !belongsToCompany;
                    option.disabled = !belongsToCompany;

                    if (belongsToCompany && option.value === select.value) {
                        currentIsValid = true;
                    }
                });

                if (!currentIsValid) {
                    select.value = "";
                }

                refreshSelect(select);
            }

            function filterOrganization() {
                const selectedOption = workLocation.options[workLocation.selectedIndex];
                const companyId = selectedOption?.dataset.companyId || "";

                filterByCompany(department, companyId);
                filterByCompany(position, companyId);
            }

            workLocation.addEventListener("change", filterOrganization);
            filterOrganization();

            window.NexoraCreateFilterOrganization = filterOrganization;
        })();
    </script>
    <!-- NEXORA_CREATE_ORGANIZATION_FILTER_END -->

    <!-- NEXORA_MARITAL_BY_GENDER_START -->
    <script>
        (() => {
            const labels = {
                Male: {
                    Single: "\u0623\u0639\u0632\u0628",
                    Married: "\u0645\u062A\u0632\u0648\u062C",
                    Divorced: "\u0645\u0637\u0644\u0642",
                    Widowed: "\u0623\u0631\u0645\u0644",
                    Separated: "\u0645\u0646\u0641\u0635\u0644"
                },
                Female: {
                    Single: "\u0639\u0632\u0628\u0627\u0621",
                    Married: "\u0645\u062A\u0632\u0648\u062C\u0629",
                    Divorced: "\u0645\u0637\u0644\u0642\u0629",
                    Widowed: "\u0623\u0631\u0645\u0644\u0629",
                    Separated: "\u0645\u0646\u0641\u0635\u0644\u0629"
                }
            };

            const placeholder = "\u0627\u062E\u062A\u0631...";

            function getGenderGroup(genderValue) {
                const value = (genderValue || "").trim();

                if (value === "Female" || value === "\u0623\u0646\u062B\u0649" || value === "\u0627\u0646\u062B\u0649") {
                    return labels.Female;
                }

                return labels.Male;
            }

            function applyMaritalLabels() {
                const gender = document.getElementById("Employee_Gender");
                const marital = document.getElementById("Employee_MaritalStatus");

                if (!gender || !marital) {
                    return;
                }

                const group = getGenderGroup(gender.value);

                Array.from(marital.options).forEach(option => {
                    if (!option.value) {
                        option.textContent = placeholder;
                        return;
                    }

                    if (group[option.value]) {
                        option.textContent = group[option.value];
                    }
                });

                if (window.NexoraSelect && typeof window.NexoraSelect.refresh === "function") {
                    window.NexoraSelect.refresh(marital);
                } else {
                    marital.dispatchEvent(new Event("change", { bubbles: true }));
                }
            }

            function bind() {
                const gender = document.getElementById("Employee_Gender");

                if (gender && !gender.dataset.maritalGenderBound) {
                    gender.dataset.maritalGenderBound = "1";
                    gender.addEventListener("change", applyMaritalLabels);
                    gender.addEventListener("input", applyMaritalLabels);
                }

                applyMaritalLabels();
            }

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", bind);
            } else {
                bind();
            }

            setTimeout(bind, 100);
            setTimeout(bind, 400);
            setTimeout(bind, 900);
        })();
    </script>
    <!-- NEXORA_MARITAL_BY_GENDER_END -->

<script>
(function () {
    "use strict";

    function txt(element) {
        return (element && element.textContent ? element.textContent : "").replace(/\s+/g, " ").trim();
    }

    function isPreviewTable(table) {
        var text = txt(table);
        return text.indexOf("Message") >= 0 &&
               text.indexOf("Key") >= 0 &&
               text.indexOf("Action") >= 0 &&
               text.indexOf("Status") >= 0 &&
               text.indexOf("Row") >= 0;
    }

    function findHeaderIndex(headers, name) {
        for (var i = 0; i < headers.length; i++) {
            if (txt(headers[i]).toLowerCase() === name.toLowerCase()) {
                return i;
            }
        }

        return -1;
    }

    function wrapTable(table) {
        var parent = table.parentElement;
        if (!parent) return;

        if (!parent.classList.contains("nxr-import-preview-v3-table-shell")) {
            parent.classList.add("nxr-import-preview-v3-table-shell");
        }

        var p = parent;
        var hops = 0;
        while (p && p !== document.body && hops < 4) {
            p.classList.add("nxr-import-preview-v3-card-fix");
            p = p.parentElement;
            hops++;
        }
    }

    function forceCell(cell, css) {
        if (!cell) return;
        cell.setAttribute("style", (cell.getAttribute("style") || "") + ";" + css);
    }

    function applyTable(table) {
        if (!isPreviewTable(table)) return;

        table.classList.add("nxr-import-preview-v3-table");
        wrapTable(table);

        var headers = Array.prototype.slice.call(table.querySelectorAll("thead th"));
        var messageIndex = findHeaderIndex(headers, "Message");
        var keyIndex = findHeaderIndex(headers, "Key");
        var statusIndex = findHeaderIndex(headers, "Status");
        var rowIndex = findHeaderIndex(headers, "Row");

        headers.forEach(function (th) {
            forceCell(th, "background:linear-gradient(135deg,rgba(8,35,56,.98),rgba(9,49,73,.98)) !important;color:#dff8ff !important;border:0 !important;border-bottom:1px solid rgba(34,211,238,.16) !important;padding:16px 14px !important;text-align:right !important;");
        });

        Array.prototype.slice.call(table.querySelectorAll("tbody tr")).forEach(function (tr, rowNumber) {
            tr.style.setProperty("background", rowNumber % 2 === 0 ? "rgba(4,17,29,.92)" : "rgba(7,24,39,.92)", "important");
            tr.style.setProperty("transition", "background .22s ease, box-shadow .22s ease", "important");

            tr.addEventListener("mouseenter", function () {
                tr.style.setProperty("background", "rgba(34,211,238,.13)", "important");
                tr.style.setProperty("box-shadow", "inset 4px 0 0 rgba(34,211,238,.65)", "important");
            });

            tr.addEventListener("mouseleave", function () {
                tr.style.setProperty("background", rowNumber % 2 === 0 ? "rgba(4,17,29,.92)" : "rgba(7,24,39,.92)", "important");
                tr.style.removeProperty("box-shadow");
            });

            Array.prototype.slice.call(tr.children).forEach(function (td, index) {
                forceCell(td, "background:transparent !important;color:#f4fbff !important;border:0 !important;border-bottom:1px solid rgba(157,184,204,.10) !important;padding:16px 14px !important;text-align:right !important;font-weight:850 !important;");

                if (index === messageIndex) {
                    td.classList.add("nxr-import-preview-v3-message");
                }

                if (index === keyIndex) {
                    td.classList.add("nxr-import-preview-v3-key");
                    forceCell(td, "color:#bdf4ff !important;font-weight:1000 !important;");
                }

                if (index === statusIndex && txt(td).toLowerCase() === "error") {
                    td.classList.add("nxr-import-preview-v3-error");
                    forceCell(td, "color:#fecaca !important;font-weight:1000 !important;");
                }

                if (index === rowIndex) {
                    td.classList.add("nxr-import-preview-v3-row-number");
                    forceCell(td, "color:#fde68a !important;font-weight:1000 !important;");
                }
            });
        });
    }

    function apply() {
        Array.prototype.slice.call(document.querySelectorAll("table")).forEach(applyTable);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", apply);
    } else {
        apply();
    }

    window.setTimeout(apply, 150);
    window.setTimeout(apply, 500);
    window.setTimeout(apply, 1200);
})();
</script>

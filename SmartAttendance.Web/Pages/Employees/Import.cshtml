.nexora-dyn-col-chip {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: 28px !important;
    padding: 0 12px !important;
    border-radius: 999px !important;
    border: 1px solid rgba(34, 211, 238, .28) !important;
    background: rgba(34, 211, 238, .08) !important;
    color: #dff8ff !important;
    font-size: 12px !important;
    font-weight: 900 !important;
}

.nexora-dyn-col-chip.is-custom {
    border-color: rgba(251, 191, 36, .38) !important;
    background: rgba(251, 191, 36, .10) !important;
    color: #fde68a !important;
}

.nexora-dyn-col-chip.is-required {
    border-color: rgba(248, 113, 113, .52) !important;
    background: rgba(248, 113, 113, .12) !important;
    color: #fecaca !important;
}

.nexora-dynamic-required-columns {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 8px !important;
    justify-content: flex-end !important;
    margin-top: 12px !important;
}
/* NEXORA_FIX18A_V4_DYNAMIC_PASTE_STYLE_END */
</style>

<script>
(function () {
    var endpoint = window.location.pathname + "?handler=TemplateColumns";

    function normalizeList(value) {
        if (!Array.isArray(value)) {
            return [];
        }

        return value
            .map(function (item) { return String(item || "").trim(); })
            .filter(function (item) { return item.length > 0; });
    }

    function toPayload(payload) {
        payload = payload || {};

        return {
            columns: normalizeList(payload.columns || payload.Columns || payload),
            requiredColumns: normalizeList(payload.requiredColumns || payload.RequiredColumns)
        };
    }

    function sampleFor(column) {
        var c = String(column || "").toLowerCase();

        if (c === "employeeno") return "1001";
        if (c === "fullname") return "Ahmed Ali";
        if (c === "companyname") return "NEXORA Company";
        if (c === "companycode") return "";
        if (c === "worklocationname") return "Head Office";
        if (c === "worklocationcode") return "";
        if (c === "departmentname") return "Human Resources";
        if (c === "departmentcode") return "";
        if (c === "positionname") return "HR Officer";
        if (c === "positioncode") return "";
        if (c === "hiredate") return "2026-01-01";
        if (c === "nationalid") return "123456789012";
        if (c === "phone") return "07700000000";
        if (c === "email") return "employee@example.com";
        if (c === "birthdate") return "1995-01-01";
        if (c === "isactive") return "TRUE";
        if (c === "nationality") return "Iraqi";
        if (c === "country") return "Iraq";
        if (c === "gender") return "Male";
        if (c === "maritalstatus") return "Single";
        if (c === "contracttype") return "Open";
        if (c === "contractenddate") return "";
        if (c === "employmentstatus") return "Active";
        if (c === "directmanageremployeeno") return "1000";
        if (c.indexOf("custom:") === 0) return "";

        return "";
    }

    function makeChip(column, requiredColumns) {
        var required = requiredColumns.some(function (item) {
            return item.toLowerCase() === String(column).toLowerCase();
        });
        var custom = String(column).toLowerCase().indexOf("custom:") === 0;
        var chip = document.createElement("span");

        chip.className =
            "nexora-dyn-col-chip" +
            (custom ? " is-custom" : "") +
            (required ? " is-required" : "");
        chip.textContent = column + (required ? " *" : "");

        return chip;
    }

    function updateTextareas(columns) {
        var headerLine = columns.join("\t");
        var sampleLine = columns.map(sampleFor).join("\t");
        var placeholder = headerLine + "\n" + sampleLine;

        document.querySelectorAll("textarea").forEach(function (textarea) {
            if (!textarea.value || textarea.value.trim().length === 0) {
                textarea.placeholder = placeholder;
            }

            textarea.setAttribute("data-nexora-dynamic-paste", "true");
        });
    }

    function insertDynamicPreview(columns, requiredColumns) {
        var templateCard = document.querySelector("[data-nexora-dynamic-template-card]");
        if (!templateCard) {
            return;
        }

        var panel = document.querySelector("[data-nexora-dynamic-paste-columns]");
        if (!panel) {
            panel = document.createElement("section");
            panel.className = "nexora-dynamic-paste-columns";
            panel.setAttribute("data-nexora-dynamic-paste-columns", "true");
            templateCard.insertAdjacentElement("afterend", panel);
        }

        panel.innerHTML = "";

        var head = document.createElement("div");
        head.className = "nexora-dynamic-paste-columns-head";

        var titleWrap = document.createElement("div");
        var title = document.createElement("strong");
        title.textContent = "\u0623\u0639\u0645\u062F\u0629 \u0627\u0644\u0646\u0633\u062E \u0648\u0627\u0644\u0644\u0635\u0642 \u0645\u0646 Excel";
        var note = document.createElement("span");
        note.textContent = "\u0627\u0644\u0623\u062D\u0645\u0631 \u0627\u0644\u0641\u0627\u062A\u062D \u0645\u0637\u0644\u0648\u0628\u060C \u0627\u0644\u0630\u0647\u0628\u064A \u062D\u0642\u0644 \u0645\u062E\u0635\u0635\u060C \u0648\u0628\u0627\u0642\u064A \u0627\u0644\u062D\u0642\u0648\u0644 \u0627\u062E\u062A\u064A\u0627\u0631\u064A\u0629.";

        titleWrap.appendChild(title);
        titleWrap.appendChild(document.createElement("br"));
        titleWrap.appendChild(note);

        var count = document.createElement("span");
        count.textContent = columns.length + " columns";

        head.appendChild(titleWrap);
        head.appendChild(count);

        var wrap = document.createElement("div");
        wrap.className = "nexora-dynamic-paste-chip-wrap";

        columns.forEach(function (column) {
            wrap.appendChild(makeChip(column, requiredColumns));
        });

        panel.appendChild(head);
        panel.appendChild(wrap);
    }

    function updateRequiredColumns(requiredColumns) {
        var panels = Array.prototype.slice.call(
            document.querySelectorAll(".import-v3-required, .nexora-import-required")
        );
        var panel = panels[0];

        if (!panel) {
            return;
        }

        var badgeWrap = panel.querySelector(".import-v3-badges");
        if (badgeWrap) {
            badgeWrap.innerHTML = "";

            requiredColumns.forEach(function (column) {
                badgeWrap.appendChild(makeChip(column, requiredColumns));
            });
        }
    }

    function apply(payload) {
        if (!payload.columns.length) {
            return;
        }

        updateTextareas(payload.columns);
        insertDynamicPreview(payload.columns, payload.requiredColumns);
        updateRequiredColumns(payload.requiredColumns);
    }

    fetch(endpoint, { headers: { "Accept": "application/json" } })
        .then(function (response) { return response.ok ? response.json() : null; })
        .then(function (payload) { apply(toPayload(payload)); })
        .catch(function () { });
})();
</script>
@* NEXORA_FIX18A_V4_DYNAMIC_PASTE_END *@



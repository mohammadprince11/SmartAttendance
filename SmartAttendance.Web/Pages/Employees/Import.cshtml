<script>
(function () {
    "use strict";

    function textOf(element) {
        return (element && element.textContent ? element.textContent : "").replace(/\s+/g, " ").trim();
    }

    function closestCard(element) {
        var node = element;
        while (node && node !== document.body) {
            if (node.tagName === "SECTION" || String(node.className || "").indexOf("card") >= 0) {
                return node;
            }
            node = node.parentElement;
        }
        return element ? element.parentElement : null;
    }

    function markPreviewCards() {
        Array.prototype.slice.call(document.querySelectorAll("h1,h2,h3,strong")).forEach(function (heading) {
            var text = textOf(heading);
            if (text.indexOf("Preview:") >= 0) {
                var card = closestCard(heading);
                if (card) {
                    card.classList.add("nxr-import-preview-v2-card");
                }
            }
        });

        Array.prototype.slice.call(document.querySelectorAll("table")).forEach(function (table) {
            var text = textOf(table);
            if (text.indexOf("Message") >= 0 && text.indexOf("Status") >= 0 && text.indexOf("Row") >= 0) {
                table.classList.add("nxr-import-preview-v2-table");
                var parent = table.parentElement;
                while (parent && parent !== document.body) {
                    parent.classList.add("nxr-import-preview-v2-card");
                    if (parent.tagName === "SECTION" || String(parent.className || "").indexOf("card") >= 0) {
                        break;
                    }
                    parent = parent.parentElement;
                }

                Array.prototype.slice.call(table.querySelectorAll("td")).forEach(function (td) {
                    if (textOf(td).toLowerCase() === "error") {
                        td.setAttribute("data-nxr-status", "error");
                    }
                });
            }
        });
    }

    function markStats() {
        var labels = ["Total Rows", "Ready", "Create", "Update", "Errors"];
        Array.prototype.slice.call(document.querySelectorAll("div,section,article")).forEach(function (element) {
            var text = textOf(element);
            var matched = labels.some(function (label) { return text.indexOf(label) >= 0; });

            if (!matched) {
                return;
            }

            var directChildren = Array.prototype.slice.call(element.children || []);
            var statChildren = directChildren.filter(function (child) {
                var childText = textOf(child);
                return labels.some(function (label) { return childText.indexOf(label) >= 0; }) && /\d/.test(childText);
            });

            if (statChildren.length >= 3) {
                element.classList.add("nxr-import-preview-v2-card");
                statChildren.forEach(function (child) {
                    child.classList.add("nxr-import-preview-v2-stat");

                    Array.prototype.slice.call(child.querySelectorAll("*")).forEach(function (item) {
                        var itemText = textOf(item);
                        if (labels.indexOf(itemText) >= 0) {
                            item.classList.add("nxr-import-preview-v2-stat-label");
                        }

                        if (/^\d+$/.test(itemText)) {
                            item.classList.add("nxr-import-preview-v2-stat-value");
                        }
                    });
                });
            }
        });
    }

    function markControls() {
        Array.prototype.slice.call(document.querySelectorAll("button,select")).forEach(function (item) {
            var parent = item.parentElement;
            var hops = 0;
            while (parent && parent !== document.body && hops < 4) {
                parent.classList.add("nxr-import-preview-v2-controls");
                parent = parent.parentElement;
                hops++;
            }
        });
    }

    function apply() {
        markPreviewCards();
        markStats();
        markControls();

        Array.prototype.slice.call(document.querySelectorAll("table td")).forEach(function (td) {
            if (textOf(td).toLowerCase() === "error") {
                td.classList.add("nxr-import-error-text");
            }
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", apply);
    } else {
        apply();
    }

    window.setTimeout(apply, 250);
    window.setTimeout(apply, 800);
})();
</script>
@* NEXORA_FIX18C_UI_V2_EMPLOYEE_IMPORT_FORCE_DESIGN_END *@



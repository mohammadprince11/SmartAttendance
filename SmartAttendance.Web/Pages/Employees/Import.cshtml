<style>
/* NEXORA_FIX18A_V4_DYNAMIC_PASTE_STYLE_START */
.nexora-dynamic-paste-columns {
    margin: 0 0 22px !important;
    padding: 20px !important;
    border-radius: 22px !important;
    border: 1px solid rgba(34, 211, 238, .22) !important;
    background: linear-gradient(145deg, rgba(8, 31, 50, .86), rgba(5, 18, 31, .94)) !important;
    color: #e8f3ff !important;
}

.nexora-dynamic-paste-columns-head {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 14px !important;
    margin-bottom: 14px !important;

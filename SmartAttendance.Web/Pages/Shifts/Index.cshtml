@page
@model SmartAttendance.Web.Pages.Shifts.IndexModel

@{
    ViewData["Title"] = "Shifts";
}

<div class="page-header">
    <div>
        <h1>Shifts</h1>
        <p>Manage work shifts</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">Import Excel</a>
        <a asp-page="./Create" class="btn-primary">+ Add Shift</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="Search by shift code or name..." />

        <button type="submit" class="btn-primary">Search</button>
        <a asp-page="./Index" class="btn-secondary">Clear</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Start</th>
                <th>End</th>
                <th>Hours</th>
                <th>Grace In</th>
                <th>Grace Out</th>
                <th>Night</th>
                <th>Active</th>
                <th style="width: 160px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Shifts.Any())
            {
                foreach (var shift in Model.Shifts)
                {
                    <tr>
                        <td>@shift.Code</td>
                        <td>@shift.Name</td>
                        <td>@shift.StartTime</td>
                        <td>@shift.EndTime</td>
                        <td>@shift.WorkingHours</td>
                        <td>@shift.GraceInMinutes</td>
                        <td>@shift.GraceOutMinutes</td>
                        <td>@(shift.IsNightShift ? "Yes" : "No")</td>
                        <td>@(shift.IsActive ? "Yes" : "No")</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@shift.Id" class="btn-table btn-edit">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@shift.Id" class="btn-table btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;">No shifts found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@page
@model SmartAttendance.Web.Pages.Shifts.IndexModel

@{
    ViewData["Title"] = "الشفتات";
}

<div class="page-header">
    <div>
        <h1>الشفتات</h1>
        <p>إدارة مناوبات العمل</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">استيراد إكسل</a>
        <a asp-page="./Create" class="btn-primary">+ إضافة شفت</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث برمز المناوبة أو اسمها..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>الرمز</th>
                <th>الاسم</th>
                <th>البداية</th>
                <th>النهاية</th>
                <th>الساعات</th>
                <th>سماح الدخول</th>
                <th>سماح الخروج</th>
                <th>ليلية</th>
                <th>نشط</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Shifts.Any())
            {
                foreach (var shift in Model.Shifts)
                {
                    <tr>
                        <td>@shift.Code</td>
                        <td>@shift.Name</td>
                        <td>@shift.StartTime</td>
                        <td>@shift.EndTime</td>
                        <td>@shift.WorkingHours</td>
                        <td>@shift.GraceInMinutes</td>
                        <td>@shift.GraceOutMinutes</td>
                        <td>@(shift.IsNightShift ? "نعم" : "لا")</td>
                        <td>@(shift.IsActive ? "نعم" : "لا")</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@shift.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@shift.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;">لا توجد مناوبات.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

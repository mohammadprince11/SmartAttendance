@page
@model SmartAttendance.Web.Pages.Shifts.DeleteModel

@{
    ViewData["Title"] = "حذف شفت";
}

<div class="page-header">
    <div>
        <h1>حذف شفت</h1>
        <p>تأكيد حذف المناوبة</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this shift?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>رمز المناوبة</label>
            <div class="form-control">@Model.Shift.Code</div>
        </div>

        <div class="form-group">
            <label>اسم المناوبة</label>
            <div class="form-control">@Model.Shift.Name</div>
        </div>

        <div class="form-group">
            <label>وقت البداية</label>
            <div class="form-control">@Model.Shift.StartTime.ToString("HH:mm")</div>
        </div>

        <div class="form-group">
            <label>وقت النهاية</label>
            <div class="form-control">@Model.Shift.EndTime.ToString("HH:mm")</div>
        </div>

        <div class="form-group">
            <label>ساعات العمل</label>
            <div class="form-control">@Model.Shift.WorkingHours</div>
        </div>

        <div class="form-group">
            <label>سماح الدخول</label>
            <div class="form-control">@Model.Shift.GraceInMinutes min</div>
        </div>

        <div class="form-group">
            <label>سماح الخروج</label>
            <div class="form-control">@Model.Shift.GraceOutMinutes min</div>
        </div>

        <div class="form-group">
            <label>مناوبة ليلية</label>
            <div class="form-control">@(Model.Shift.IsNightShift ? "نعم" : "لا")</div>
        </div>

        <div class="form-group">
            <label>الحالة</label>
            <div class="form-control">@(Model.Shift.IsActive ? "Active" : "Inactive")</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Shift.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

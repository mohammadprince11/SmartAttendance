@page
@model SmartAttendance.Web.Pages.Shifts.DeleteModel

@{
    ViewData["Title"] = "Delete Shift";
}

<div class="page-header">
    <div>
        <h1>Delete Shift</h1>
        <p>Confirm shift deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this shift?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Shift Code</label>
            <div class="form-control">@Model.Shift.Code</div>
        </div>

        <div class="form-group">
            <label>Shift Name</label>
            <div class="form-control">@Model.Shift.Name</div>
        </div>

        <div class="form-group">
            <label>Start Time</label>
            <div class="form-control">@Model.Shift.StartTime.ToString("HH:mm")</div>
        </div>

        <div class="form-group">
            <label>End Time</label>
            <div class="form-control">@Model.Shift.EndTime.ToString("HH:mm")</div>
        </div>

        <div class="form-group">
            <label>Working Hours</label>
            <div class="form-control">@Model.Shift.WorkingHours</div>
        </div>

        <div class="form-group">
            <label>Grace In</label>
            <div class="form-control">@Model.Shift.GraceInMinutes min</div>
        </div>

        <div class="form-group">
            <label>Grace Out</label>
            <div class="form-control">@Model.Shift.GraceOutMinutes min</div>
        </div>

        <div class="form-group">
            <label>Night Shift</label>
            <div class="form-control">@(Model.Shift.IsNightShift ? "Yes" : "No")</div>
        </div>

        <div class="form-group">
            <label>Status</label>
            <div class="form-control">@(Model.Shift.IsActive ? "Active" : "Inactive")</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Shift.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@page
@model SmartAttendance.Web.Pages.OrganizationSettings.IndexModel

@{
    ViewData["Title"] = "Organization Settings";
    var tab = (Model.Tab ?? "companies").ToLowerInvariant();
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/organization-settings.css" asp-append-version="true" />

<div class="org-settings-page">
    <div class="page-header">
        <div>
            <h1>إعدادات الهيكل التنظيمي</h1>
            <p>إدارة الشركات والفروع والأقسام والمناصب من مكان واحد.</p>
        </div>

        <a asp-page="/Organization/Index" class="hrms-btn-secondary">عرض الهيكل</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="hrms-alert success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="hrms-alert error">@Model.ErrorMessage</div>
    }

    <section class="org-settings-tabs">
        <a class="@(tab == "companies" ? "active" : "")" asp-page="./Index" asp-route-Tab="companies">الشركات</a>
        <a class="@(tab == "branches" ? "active" : "")" asp-page="./Index" asp-route-Tab="branches">الفروع</a>
        <a class="@(tab == "departments" ? "active" : "")" asp-page="./Index" asp-route-Tab="departments">الأقسام</a>
        <a class="@(tab == "positions" ? "active" : "")" asp-page="./Index" asp-route-Tab="positions">المناصب</a>
    </section>

    <form method="get" class="hrms-filter-card">
        <input type="hidden" name="Tab" value="@tab" />
        <div class="hrms-grid-2">
            <div class="hrms-field">
                <label>بحث</label>
                <input asp-for="Search" placeholder="بحث..." />
            </div>

            <div class="hrms-actions" style="align-self:end;">
                <button type="submit" class="hrms-btn-primary">بحث</button>
                <a asp-page="./Index" asp-route-Tab="@tab" class="hrms-btn-secondary">مسح</a>
            </div>
        </div>
    </form>

    @if (tab == "companies")
    {
        <section class="org-settings-grid">
            <form method="post" asp-page-handler="SaveCompany" class="hrms-form-card">
                <div class="hrms-section-head">
                    <div>
                        <h2>إضافة / تعديل شركة</h2>
                        <p>بيانات الشركة الأساسية.</p>
                    </div>
                </div>

                <input asp-for="CompanyInput.Id" type="hidden" id="companyId" />

                <div class="hrms-field">
                    <label>اسم الشركة</label>
                    <input asp-for="CompanyInput.Name" id="companyName" required />
                </div>

                <div class="hrms-field">
                    <label>كود الشركة</label>
                    <input asp-for="CompanyInput.Code" id="companyCode" />
                </div>

                <label class="org-settings-check">
                    <input asp-for="CompanyInput.IsActive" id="companyIsActive" checked />
                    <span>فعال</span>
                </label>

                <div class="hrms-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ</button>
                    <button type="button" class="hrms-btn-secondary" data-clear-form="company">جديد</button>
                </div>
            </form>

            <div class="hrms-table-card">
                <div class="hrms-table-wrap">
                    <table class="hrms-table">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th class="text-start">الشركة</th>
                                <th>الفروع</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var company in Model.Companies)
                            {
                                <tr>
                                    <td>@company.Code</td>
                                    <td class="text-start">@company.Name</td>
                                    <td>@company.BranchCount</td>
                                    <td><span class="hrms-badge @(company.IsActive ? "approved" : "rejected")">@(company.IsActive ? "فعال" : "غير فعال")</span></td>
                                    <td>
                                        <button type="button"
                                                class="hrms-btn-secondary"
                                                data-edit-company
                                                data-id="@company.Id"
                                                data-code="@company.Code"
                                                data-name="@company.Name"
                                                data-active="@company.IsActive.ToString().ToLower()">
                                            تعديل
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
    else if (tab == "branches")
    {
        <section class="org-settings-grid">
            <form method="post" asp-page-handler="SaveBranch" class="hrms-form-card">
                <div class="hrms-section-head">
                    <div>
                        <h2>إضافة / تعديل فرع</h2>
                        <p>ربط الفرع بالشركة.</p>
                    </div>
                </div>

                <input asp-for="BranchInput.Id" type="hidden" id="branchId" />

                <div class="hrms-field">
                    <label>الشركة</label>
                    <select asp-for="BranchInput.CompanyId" id="branchCompanyId" required>
                        <option value="">-- اختر الشركة --</option>
                        @foreach (var company in Model.Companies)
                        {
                            <option value="@company.Id">@company.Name</option>
                        }
                    </select>
                </div>

                <div class="hrms-field">
                    <label>اسم الفرع</label>
                    <input asp-for="BranchInput.Name" id="branchName" required />
                </div>

                <div class="hrms-field">
                    <label>كود الفرع</label>
                    <input asp-for="BranchInput.Code" id="branchCode" />
                </div>

                <div class="hrms-field">
                    <label>العنوان</label>
                    <input asp-for="BranchInput.Address" id="branchAddress" />
                </div>

                <label class="org-settings-check">
                    <input asp-for="BranchInput.IsActive" id="branchIsActive" checked />
                    <span>فعال</span>
                </label>

                <div class="hrms-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ</button>
                    <button type="button" class="hrms-btn-secondary" data-clear-form="branch">جديد</button>
                </div>
            </form>

            <div class="hrms-table-card">
                <div class="hrms-table-wrap">
                    <table class="hrms-table">
                        <thead>
                            <tr>
                                <th>الشركة</th>
                                <th>الكود</th>
                                <th class="text-start">الفرع</th>
                                <th>الأقسام</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var branch in Model.Branches)
                            {
                                <tr>
                                    <td>@branch.CompanyName</td>
                                    <td>@branch.Code</td>
                                    <td class="text-start">@branch.Name</td>
                                    <td>@branch.DepartmentCount</td>
                                    <td><span class="hrms-badge @(branch.IsActive ? "approved" : "rejected")">@(branch.IsActive ? "فعال" : "غير فعال")</span></td>
                                    <td>
                                        <button type="button"
                                                class="hrms-btn-secondary"
                                                data-edit-branch
                                                data-id="@branch.Id"
                                                data-company-id="@branch.CompanyId"
                                                data-code="@branch.Code"
                                                data-name="@branch.Name"
                                                data-address="@branch.Address"
                                                data-active="@branch.IsActive.ToString().ToLower()">
                                            تعديل
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
    else if (tab == "departments")
    {
        <section class="org-settings-grid">
            <form method="post" asp-page-handler="SaveDepartment" class="hrms-form-card">
                <div class="hrms-section-head">
                    <div>
                        <h2>إضافة / تعديل قسم</h2>
                        <p>ربط القسم بالفرع.</p>
                    </div>
                </div>

                <input asp-for="DepartmentInput.Id" type="hidden" id="departmentId" />

                <div class="hrms-field">
                    <label>الفرع</label>
                    <select asp-for="DepartmentInput.BranchId" id="departmentBranchId" required>
                        <option value="">-- اختر الفرع --</option>
                        @foreach (var company in Model.Companies)
                        {
                            <optgroup label="@company.Name">
                                @foreach (var branch in Model.Branches.Where(x => x.CompanyId == company.Id))
                                {
                                    <option value="@branch.Id">@branch.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>

                <div class="hrms-field">
                    <label>اسم القسم</label>
                    <input asp-for="DepartmentInput.Name" id="departmentName" required />
                </div>

                <div class="hrms-field">
                    <label>كود القسم</label>
                    <input asp-for="DepartmentInput.Code" id="departmentCode" />
                </div>

                <label class="org-settings-check">
                    <input asp-for="DepartmentInput.IsActive" id="departmentIsActive" checked />
                    <span>فعال</span>
                </label>

                <div class="hrms-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ</button>
                    <button type="button" class="hrms-btn-secondary" data-clear-form="department">جديد</button>
                </div>
            </form>

            <div class="hrms-table-card">
                <div class="hrms-table-wrap">
                    <table class="hrms-table">
                        <thead>
                            <tr>
                                <th>الشركة</th>
                                <th>الفرع</th>
                                <th>الكود</th>
                                <th class="text-start">القسم</th>
                                <th>الموظفين</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var department in Model.Departments)
                            {
                                <tr>
                                    <td>@department.CompanyName</td>
                                    <td>@department.BranchName</td>
                                    <td>@department.Code</td>
                                    <td class="text-start">@department.Name</td>
                                    <td>@department.EmployeeCount</td>
                                    <td><span class="hrms-badge @(department.IsActive ? "approved" : "rejected")">@(department.IsActive ? "فعال" : "غير فعال")</span></td>
                                    <td>
                                        <button type="button"
                                                class="hrms-btn-secondary"
                                                data-edit-department
                                                data-id="@department.Id"
                                                data-branch-id="@department.BranchId"
                                                data-code="@department.Code"
                                                data-name="@department.Name"
                                                data-active="@department.IsActive.ToString().ToLower()">
                                            تعديل
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="org-settings-grid">
            <form method="post" asp-page-handler="SavePosition" class="hrms-form-card">
                <div class="hrms-section-head">
                    <div>
                        <h2>إضافة / تعديل منصب</h2>
                        <p>توحيد المناصب لاستخدامها داخل ملف الموظف.</p>
                    </div>
                </div>

                <input asp-for="PositionInput.Id" type="hidden" id="positionId" />

                <div class="hrms-field">
                    <label>اسم المنصب</label>
                    <input asp-for="PositionInput.Name" id="positionName" required />
                </div>

                <div class="hrms-field">
                    <label>كود المنصب</label>
                    <input asp-for="PositionInput.Code" id="positionCode" />
                </div>

                <div class="hrms-field">
                    <label>الوصف</label>
                    <textarea asp-for="PositionInput.Description" id="positionDescription"></textarea>
                </div>

                <label class="org-settings-check">
                    <input asp-for="PositionInput.IsActive" id="positionIsActive" checked />
                    <span>فعال</span>
                </label>

                <div class="hrms-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ</button>
                    <button type="button" class="hrms-btn-secondary" data-clear-form="position">جديد</button>
                </div>
            </form>

            <div class="hrms-table-card">
                <div class="hrms-table-wrap">
                    <table class="hrms-table">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th class="text-start">المنصب</th>
                                <th class="text-start">الوصف</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var position in Model.Positions)
                            {
                                <tr>
                                    <td>@position.Code</td>
                                    <td class="text-start">@position.Name</td>
                                    <td class="text-start">@position.Description</td>
                                    <td><span class="hrms-badge @(position.IsActive ? "approved" : "rejected")">@(position.IsActive ? "فعال" : "غير فعال")</span></td>
                                    <td>
                                        <button type="button"
                                                class="hrms-btn-secondary"
                                                data-edit-position
                                                data-id="@position.Id"
                                                data-code="@position.Code"
                                                data-name="@position.Name"
                                                data-description="@position.Description"
                                                data-active="@position.IsActive.ToString().ToLower()">
                                            تعديل
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script src="~/js/organization-settings.js" asp-append-version="true"></script>
}

@page
@model SmartAttendance.Web.Pages.UserPermissions.IndexModel

@{
    ViewData["Title"] = "User Permissions";
}

<style>
    .permissions-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
        align-items: start;
    }

    .user-list {
        display: grid;
        gap: 10px;
    }

    .user-card {
        display: block;
        padding: 12px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: #ffffff;
        color: #0f172a;
        text-decoration: none;
    }

    .user-card.active {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .user-card .name {
        font-weight: 700;
        margin-bottom: 4px;
    }

    .user-card .meta {
        color: #64748b;
        font-size: 12px;
    }

    .permission-group {
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 14px;
        background: #ffffff;
    }

    .permission-group h3 {
        margin: 0 0 12px;
        font-size: 16px;
    }

    .permission-check {
        display: grid;
        grid-template-columns: 24px 1fr;
        gap: 10px;
        padding: 9px 0;
        border-top: 1px solid #f1f5f9;
    }

    .permission-check:first-of-type {
        border-top: 0;
    }

    .permission-code {
        font-weight: 700;
        color: #0f172a;
    }

    .permission-desc {
        color: #64748b;
        font-size: 12px;
        margin-top: 3px;
    }

    @@media (max-width: 1000px) {
        .permissions-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <div>
        <h1>User Permissions</h1>
        <p>Grant permissions to each user based on actual need</p>
    </div>

    <a asp-page="/Permissions/Index" class="btn-secondary">Permissions List</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="permissions-layout">
    <div class="table-card">
        <div class="page-header" style="margin-bottom: 12px;">
            <div>
                <h2>Users</h2>
                <p>Select a user</p>
            </div>
        </div>

        <div class="user-list">
            @if (Model.Users.Any())
            {
                foreach (var user in Model.Users)
                {
                    var activeClass = Model.SystemUserId == user.Id ? "active" : "";

                    <a asp-page="./Index"
                       asp-route-SystemUserId="@user.Id"
                       class="user-card @activeClass">
                        <div class="name">@user.FullName</div>
                        <div class="meta">@user.UserName | @user.Role | @(user.IsActive ? "Active" : "Inactive")</div>
                    </a>
                }
            }
            else
            {
                <div style="text-align:center;">No system users found.</div>
            }
        </div>
    </div>

    <div class="table-card">
        @if (Model.Assignment != null)
        {
            <div class="page-header" style="margin-bottom: 12px;">
                <div>
                    <h2>@Model.Assignment.FullName</h2>
                    <p>@Model.Assignment.UserName | @Model.Assignment.Role</p>
                </div>
            </div>

            @if (!Model.Assignment.Groups.Any())
            {
                <div class="alert-danger">
                    No active permissions found. Go to Permissions and click Seed Default Permissions.
                </div>
            }

            <form method="post" asp-route-systemUserId="@Model.Assignment.SystemUserId">
                @foreach (var group in Model.Assignment.Groups)
                {
                    <div class="permission-group">
                        <h3>@group.Module</h3>

                        @foreach (var permission in group.Permissions)
                        {
                            <label class="permission-check">
                                <input type="checkbox"
                                       name="SelectedPermissionIds"
                                       value="@permission.PermissionId"
                                       checked="@permission.IsGranted" />

                                <span>
                                    <span class="permission-code">@permission.Code</span>
                                    <span> - @permission.Name</span>

                                    @if (!string.IsNullOrWhiteSpace(permission.Description))
                                    {
                                        <div class="permission-desc">@permission.Description</div>
                                    }
                                </span>
                            </label>
                        }
                    </div>
                }

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Save Permissions</button>
                    <a asp-page="./Index" asp-route-SystemUserId="@Model.Assignment.SystemUserId" class="btn-secondary">Cancel</a>
                </div>
            </form>
        }
        else
        {
            <div style="text-align:center;">
                Select a user to manage permissions.
            </div>
        }
    </div>
</div>

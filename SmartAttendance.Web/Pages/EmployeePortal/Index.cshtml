@page
@model SmartAttendance.Web.Pages.EmployeePortal.IndexModel
@using SmartAttendance.Web.Infrastructure.Hrms
@{
    Layout = "_EmployeePortalLayout";
    ViewData["Title"] = "بوابة الموظف الذكية";
    var emp = Model.Employee;
    var activeTab = Model.Tab;
}

<section class="nxex-page" dir="rtl" data-nxex-page data-active-tab="@activeTab">
    <header class="nxex-hero">
        <div class="nxex-hero-copy">
            <span>EMPLOYEE EXPERIENCE PORTAL</span>
            <h1>أهلاً @emp.FullName</h1>
            <p>هذه هي صفحة السينك الرسمية: الإعلانات، الاستبيانات، الحضور، الراتب، الطلبات، الشكاوي، والتقييمات تظهر هنا من قاعدة البيانات.</p>
        </div>

        <div class="nxex-identity-card">
            <div class="nxex-avatar">@Model.Initials</div>
            <div>
                <strong>@emp.FullName</strong>
                <span>@Model.DisplayValue(emp.Position)</span>
                <small>@emp.EmployeeNo · @Model.DisplayValue(emp.DepartmentName)</small>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="nxex-alert">@Model.StatusMessage</div>
    }

    @if (Model.IsDemoMode)
    {
        <div class="nxex-warning">
            <strong>وضع تجريبي</strong>
            <span>لم يتم العثور على مستخدم موظف مرتبط بشكل مباشر، لذلك تم عرض أول موظف متوفر للاختبار.</span>
        </div>
    }

    <section class="nxex-command-center">
        <article>
            <span>دوام اليوم</span>
            <strong>@Model.LastAttendanceText</strong>
            <small>@Model.AttendanceTodayStatus</small>
        </article>
        <article>
            <span>إعلانات جديدة</span>
            <strong>@Model.Announcements.Count</strong>
            <small>منشورات موجهة لك</small>
        </article>
        <article>
            <span>استبيانات مطلوبة</span>
            <strong>@Model.OpenPollsCount</strong>
            <small>بانتظار التصويت</small>
        </article>
        <article>
            <span>طلبات قيد المتابعة</span>
            <strong>@Model.PendingRequestsCount</strong>
            <small>خدمة ذاتية</small>
        </article>
        <article>
            <span>شكاوي مفتوحة</span>
            <strong>@Model.OpenFeedbackCount</strong>
            <small>بانتظار الرد</small>
        </article>
    </section>

    <nav class="nxex-tabs">
        <button type="button" data-nxex-tab="home"><span>الرئيسية</span><small>ملخص اليوم</small></button>
        <button type="button" data-nxex-tab="profile"><span>ملفي الشخصي</span><small>بيانات الموظف</small></button>
        <button type="button" data-nxex-tab="attendance"><span>الحضور</span><small>السجل الشهري</small></button>
        <button type="button" data-nxex-tab="compensation"><span>الراتب والتعويضات</span><small>مالي</small></button>
        <button type="button" data-nxex-tab="requests"><span>طلباتي</span><small>الخدمة الذاتية</small></button>
        <button type="button" data-nxex-tab="pulse"><span>الاستبيانات</span><small>نبض الموظفين</small></button>
        <button type="button" data-nxex-tab="feedback"><span>الشكاوي والمقترحات</span><small>إرسال ومتابعة</small></button>
        <button type="button" data-nxex-tab="performance"><span>التقييم والانضباط</span><small>أداء وعقوبات</small></button>
    </nav>

    <main class="nxex-content">
        <section class="nxex-pane" data-nxex-pane="home">
            @* ===== لوحة «إجراءاتي» (موبايل) — بطاقة رصيد إجازات + شبكة إجراءات سريعة ===== *@
            <div class="nxex-mobile-dash">
                <section class="nxex-balance-card">
                    <header>
                        <span>رصيد إجازاتي</span>
                        <small>@DateTime.Now.Year</small>
                    </header>
                    <div class="nxex-balance-row">
                        @if (Model.LeaveBalances.Count == 0)
                        {
                            <div class="nxex-balance-empty">لا يوجد رصيد إجازات مسجّل بعد</div>
                        }
                        else
                        {
                            @foreach (var b in Model.LeaveBalances)
                            {
                                <div class="nxex-balance-item">
                                    <strong>@b.Remaining.ToString("0.#")</strong>
                                    <span>@IndexModel.LeaveTypeArabic(b.Type)</span>
                                    <small>من @b.Entitled.ToString("0.#") يوم</small>
                                </div>
                            }
                        }
                    </div>
                </section>

                <div class="nxex-quick-grid">
                    <button type="button" class="nxex-quick primary" data-open-reqsheet>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
                        <span>طلب جديد</span>
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="requests" data-scroll-target=".nxex-request-list-card">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h12M8 12h12M8 18h12"/><circle cx="4" cy="6" r="1"/><circle cx="4" cy="12" r="1"/><circle cx="4" cy="18" r="1"/></svg>
                        <span>طلباتي</span>
                        @if (Model.PendingRequestsCount > 0){<em class="nxex-quick-badge">@Model.PendingRequestsCount</em>}
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="attendance">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
                        <span>الحضور</span>
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="attendance">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                        <span>بصمة</span>
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="pulse">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2-6 4 12 2-6h6"/></svg>
                        <span>الاستبيانات</span>
                        @if (Model.OpenPollsCount > 0){<em class="nxex-quick-badge">@Model.OpenPollsCount</em>}
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="feedback">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        <span>الشكاوي</span>
                        @if (Model.OpenFeedbackCount > 0){<em class="nxex-quick-badge">@Model.OpenFeedbackCount</em>}
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="profile">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
                        <span>ملفي</span>
                    </button>
                    <button type="button" class="nxex-quick" data-nxex-tab="performance">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="M8 14l-2 7 6-3 6 3-2-7"/></svg>
                        <span>التقييم</span>
                    </button>
                </div>
            </div>

            <div class="nxex-home-grid">
                <section class="nxex-card nxex-wall-card">
                    <header class="nxex-card-head">
                        <div>
                            <h2>حائط الموظف</h2>
                            <p>كل إعلان منشور من الإدارة وموجه لك يظهر هنا.</p>
                        </div>
                        <span class="nxex-chip live">@Model.Announcements.Count منشور</span>
                    </header>

                    @if (Model.Announcements.Count == 0)
                    {
                        <div class="nxex-empty">لا توجد إعلانات منشورة حالياً.</div>
                    }
                    else
                    {
                        <div class="nxex-wall-list">
                            @foreach (var item in Model.Announcements.Take(5))
                            {
                                <article class="nxex-ann-card @Model.AnnouncementTheme(item.Category)">
                                    <div>
                                        <span class="nxex-chip">@item.Category</span>
                                        <small>@Model.DisplayDate(item.PublishDate)</small>
                                    </div>
                                    <h3>@item.Title</h3>
                                    <p>@item.Body</p>
                                    @if (item.IsRead)
                                    {
                                        <div class="nxex-ann-read-state">
                                            <span>تم الاطلاع</span>
                                            <small>@Model.DisplayDate(item.FirstReadAtUtc)</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="ReadAnnouncement" asp-route-id="@item.Id" class="nxex-ann-read">
                                            <input type="hidden" name="returnTab" value="home" />
                                            <button type="submit">عرض وتأكيد القراءة</button>
                                        </form>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>

                <aside class="nxex-smart-rail">
                    <article class="nxex-card">
                        <header class="nxex-card-head compact"><h2>المهام المطلوبة</h2><span class="nxex-chip pending">اليوم</span></header>
                        <div class="nxex-action-list">
                            <button type="button" data-nxex-jump="pulse">التصويت على الاستبيانات</button>
                            <button type="button" data-nxex-jump="attendance">مراجعة الحضور</button>
                            <button type="button" data-nxex-jump="requests">متابعة الطلبات</button>
                            <button type="button" data-nxex-jump="feedback">إرسال مقترح</button>
                        </div>
                    </article>

                    <article class="nxex-card nxex-ai-card">
                        <span>HR INSIGHT</span>
                        <strong>@Model.EmployeeInsight</strong>
                        <p>هذه قراءة مبدئية من بيانات الحضور والطلبات والشكاوي.</p>
                    </article>
                </aside>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="profile">
            <div class="nxex-profile-grid">
                <aside class="nxex-profile-card">
                    <div class="nxex-profile-cover"></div>
                    <div class="nxex-avatar big">@Model.Initials</div>
                    <h2>@emp.FullName</h2>
                    <p>@Model.DisplayValue(emp.Position)</p>
                    <div class="nxex-profile-meta">
                        <div><span>الرقم الوظيفي</span><strong>@emp.EmployeeNo</strong></div>
                        <div><span>القسم</span><strong>@Model.DisplayValue(emp.DepartmentName)</strong></div>
                        <div><span>الفرع</span><strong>@Model.DisplayValue(emp.BranchName)</strong></div>
                        <div><span>الخدمة</span><strong>@Model.ServicePeriodText</strong></div>
                    </div>
                </aside>

                <section class="nxex-card">
                    <header class="nxex-card-head">
                        <div>
                            <h2>بيانات الموظف</h2>
                            <p>مقروءة من جداول الموظفين والفروع والأقسام.</p>
                        </div>
                        <span class="nxex-chip live">DB Linked</span>
                    </header>

                    <div class="nxex-info-grid">
                        <div><span>الاسم</span><strong>@emp.FullName</strong></div>
                        <div><span>الرقم الوظيفي</span><strong>@emp.EmployeeNo</strong></div>
                        <div><span>المنصب</span><strong>@Model.DisplayValue(emp.Position)</strong></div>
                        <div><span>القسم</span><strong>@Model.DisplayValue(emp.DepartmentName)</strong></div>
                        <div><span>الفرع</span><strong>@Model.DisplayValue(emp.BranchName)</strong></div>
                        <div><span>المدير المباشر</span><strong>@Model.DisplayValue(emp.ManagerName)</strong></div>
                        <div><span>تاريخ التعيين</span><strong>@Model.DisplayDate(emp.HireDate)</strong></div>
                        <div><span>الحالة</span><strong>@(emp.IsActive ? "فعال" : "غير فعال")</strong></div>
                        <div><span>الهاتف</span><strong>@Model.DisplayValue(emp.Phone)</strong></div>
                        <div><span>البريد</span><strong>@Model.DisplayValue(emp.Email)</strong></div>
                    </div>
                </section>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="attendance">
            @* ===== بصمة الآن (بصم ذاتي عبر الإنترنت) ===== *@
            <section class="nxex-card" style="margin-bottom:16px">
                <header class="nxex-card-head">
                    <div>
                        <h2>البصمة عبر الإنترنت</h2>
                        <p>سجّل حضورك أو انصرافك مباشرة من المتصفح — تدخل الحضور عند «تحديث الحضور».</p>
                    </div>
                    <span class="nxex-chip live">🌐</span>
                </header>
                <div style="display:flex;gap:10px;flex-wrap:wrap">
                    <form method="post" asp-page-handler="OnlinePunch" style="flex:1;min-width:160px">
                        <input type="hidden" name="returnTab" value="attendance" />
                        <input type="hidden" name="punchType" value="In" />
                        <button type="submit" style="width:100%">🔓 تسجيل حضور الآن</button>
                    </form>
                    <form method="post" asp-page-handler="OnlinePunch" style="flex:1;min-width:160px">
                        <input type="hidden" name="returnTab" value="attendance" />
                        <input type="hidden" name="punchType" value="Out" />
                        <button type="submit" style="width:100%">🚪 تسجيل انصراف الآن</button>
                    </form>
                </div>
                @if (Model.MyOnlinePunches.Any())
                {
                    <div class="nxex-table-wrap" style="margin-top:14px">
                        <table class="nxex-table">
                            <thead><tr><th>النوع</th><th>الوقت</th><th>الدلالة</th></tr></thead>
                            <tbody>
                                @foreach (var p in Model.MyOnlinePunches.Take(8))
                                {
                                    <tr>
                                        <td><span class="nxex-chip @(p.PunchType == "Out" ? "" : "live")">@p.PunchTypeText</span></td>
                                        <td>@p.PunchAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@p.SemanticName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
            <div class="nxex-grid-2">
                <section class="nxex-card">
                    <header class="nxex-card-head">
                        <div><h2>ملخص الحضور</h2><p>قراءة سريعة من سجلات الحضور.</p></div>
                        <span class="nxex-chip">@Model.Attendance.Count سجل</span>
                    </header>
                    <div class="nxex-attendance-summary">
                        <article><strong>@Model.CompletedAttendanceCount</strong><span>بصمة مكتملة</span></article>
                        <article><strong>@Model.MissingCheckoutCount</strong><span>خروج غير مكتمل</span></article>
                        <article><strong>@Model.LastAttendanceText</strong><span>آخر يوم مسجل</span></article>
                    </div>
                </section>

                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>آخر سجلات الحضور</h2></header>
                    <div class="nxex-table-wrap">
                        <table class="nxex-table">
                            <thead><tr><th>التاريخ</th><th>دخول</th><th>خروج</th><th>الحالة</th></tr></thead>
                            <tbody>
                            @if (Model.Attendance.Count == 0)
                            {
                                <tr><td colspan="4">لا توجد سجلات حضور.</td></tr>
                            }
                            @foreach (var row in Model.Attendance.Take(10))
                            {
                                <tr>
                                    <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                    <td>@Model.DisplayTime(row.CheckIn)</td>
                                    <td>@Model.DisplayTime(row.CheckOut)</td>
                                    <td><span class="nxex-chip">@Model.DisplayValue(row.Status)</span></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="compensation">
            <div class="nxex-comp-grid">
                <section class="nxex-card nxex-pay-card">
                    <header class="nxex-card-head">
                        <div><h2>الراتب والتعويضات</h2><p>@Model.CompensationNote</p></div>
                        <span class="nxex-chip pending">خاص بالموظف</span>
                    </header>
                    <div class="nxex-pay-amount">
                        <span>صافي تقديري</span>
                        <strong>@Model.DisplayMoney(Model.Compensation.NetAmount)</strong>
                    </div>
                    <div class="nxex-pay-breakdown">
                        <div><span>الراتب الأساسي</span><strong>@Model.DisplayMoney(Model.Compensation.BasicSalary)</strong></div>
                        <div><span>البدلات / التعويضات</span><strong>@Model.DisplayMoney(Model.Compensation.Allowances)</strong></div>
                        <div><span>الاستقطاعات</span><strong>@Model.DisplayMoney(Model.Compensation.Deductions)</strong></div>
                        <div><span>طريقة الدفع</span><strong>@Model.DisplayValue(Model.Compensation.PaymentMethod)</strong></div>
                    </div>
                </section>

                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>ملاحظة مالية</h2></header>
                    <div class="nxex-note-box">
                        تظهر تفاصيل الراتب بعد اعتماد الكشف من الإدارة المالية والموارد البشرية.
                    </div>
                </section>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="requests">
            <div class="nxex-request-studio">
                <section class="nxex-card nxex-request-create">
                    <header class="nxex-card-head">
                        <div>
                            <h2>إنشاء طلب خدمة ذاتية</h2>
                            <p>أرسل طلبك مباشرة للموارد البشرية، ويظهر في لوحة الإدارة للمتابعة والاعتماد.</p>
                        </div>
                        <span class="nxex-chip live">DB Sync</span>
                    </header>

                    <div class="nxex-request-type-grid" data-request-type-grid>
                        <button type="button" class="active" data-request-type="إجازة">🌴<span>طلب إجازة</span></button>
                        <button type="button" data-request-type="نسيان بصمة">☝️<span>نسيان بصمة</span></button>
                        <button type="button" data-request-type="خروج شخصي">🚶<span>خروج شخصي</span></button>
                        <button type="button" data-request-type="خروج عمل">💼<span>خروج عمل</span></button>
                        <button type="button" data-request-type="أوفر تايم">⏱️<span>أوفر تايم</span></button>
                    </div>

                    <form method="post" asp-page-handler="CreateRequest" class="nxex-form nxex-request-form" data-request-form>
                        <input type="hidden" name="returnTab" value="requests" />
                        <input type="hidden" asp-for="RequestInput.RequestType" value="إجازة" data-request-type-input />

                        <div class="nxex-request-preview">
                            <span>نوع الطلب الحالي</span>
                            <strong data-request-type-title>طلب إجازة</strong>
                            <small data-request-type-help>اختر تاريخ البداية والنهاية وسبب الإجازة.</small>
                        </div>

                        <div class="nxex-form-row">
                            <div>
                                <label>من تاريخ *</label>
                                <input asp-for="RequestInput.FromDate" type="date" />
                            </div>
                            <div>
                                <label>إلى تاريخ</label>
                                <input asp-for="RequestInput.ToDate" type="date" />
                            </div>
                        </div>

                        <label>السبب / الملاحظات *</label>
                        <textarea asp-for="RequestInput.Reason" placeholder="اكتب تفاصيل الطلب هنا..."></textarea>

                        <button type="submit">إرسال الطلب للموارد البشرية</button>
                    </form>
                </section>

                @* ===== طلب بصمة مفقودة مُهيكل (يصل لصفحة إدارة طلبات البصمة) ===== *@
                <section class="nxex-card" id="nxex-missing-punch-card">
                    <header class="nxex-card-head">
                        <div>
                            <h2>طلب بصمة مفقودة</h2>
                            <p>إن نسيت البصمة أو تعطّل الجهاز، وثّق البصمة الغائبة (دخول/خروج) لتعتمدها الموارد البشرية.</p>
                        </div>
                        <span class="nxex-chip live">👆</span>
                    </header>
                    <form method="post" asp-page-handler="SubmitMissingPunch" class="nxex-form">
                        <input type="hidden" name="returnTab" value="requests" />
                        <div class="nxex-form-row">
                            <div>
                                <label>تاريخ البصمة *</label>
                                <input type="date" name="MpDate" required />
                            </div>
                            <div>
                                <label>وقت البصمة *</label>
                                <input type="time" name="MpTime" required />
                            </div>
                        </div>
                        <div class="nxex-form-row">
                            <div>
                                <label>نوع البصمة *</label>
                                <select name="MpType">
                                    <option value="In">ختم دخول</option>
                                    <option value="Out">ختم خروج</option>
                                </select>
                            </div>
                            <div></div>
                        </div>
                        <label>السبب</label>
                        <textarea name="MpReason" placeholder="سبب غياب البصمة (نسيان، عطل جهاز...)"></textarea>
                        <button type="submit">إرسال طلب البصمة</button>
                    </form>
                </section>

                @if (Model.MyMissingPunches.Any())
                {
                    <section class="nxex-card">
                        <header class="nxex-card-head">
                            <div>
                                <h2>طلبات بصمتي</h2>
                                <p>متابعة طلبات البصمة المفقودة التي قدّمتها وحالتها.</p>
                            </div>
                            <span class="nxex-chip pending">@Model.MyMissingPunches.Count</span>
                        </header>
                        <div class="nxex-request-timeline">
                            @foreach (var mp in Model.MyMissingPunches)
                            {
                                <article class="@Model.StatusClass(mp.Status)">
                                    <div class="nxex-request-icon">@(mp.PunchType == "Out" ? "🚪" : "🔓")</div>
                                    <div style="flex:1">
                                        <strong>@mp.PunchTypeText · @mp.PunchAt.ToString("yyyy-MM-dd HH:mm")</strong>
                                        <small style="display:block;opacity:.75">@mp.RefNo@(string.IsNullOrWhiteSpace(mp.Reason) ? "" : " · " + mp.Reason)</small>
                                        @if (!string.IsNullOrWhiteSpace(mp.DecisionNote))
                                        { <small style="display:block;opacity:.6">ملاحظة الإدارة: @mp.DecisionNote</small> }
                                    </div>
                                    <span class="nxex-chip @(mp.Status == MissingPunchRequestStore.Approved ? "live" : "pending")">@mp.StatusText</span>
                                </article>
                            }
                        </div>
                    </section>
                }

                @if (Model.PendingViolationReplies.Any())
                {
                    <section class="nxex-card" style="border:1px solid rgba(250,204,21,.35)">
                        <header class="nxex-card-head">
                            <div>
                                <h2>مخالفات بانتظار ردّك</h2>
                                <p>حق الدفاع: اكتب ردّك على المخالفة ليصل للموارد البشرية قبل اتخاذ الإجراء.</p>
                            </div>
                            <span class="nxex-chip pending">@Model.PendingViolationReplies.Count</span>
                        </header>

                        @foreach (var violation in Model.PendingViolationReplies)
                        {
                            <form method="post" asp-page-handler="ViolationReply" class="nxex-form" style="margin-bottom:12px">
                                <input type="hidden" name="id" value="@violation.Id" />
                                <input type="hidden" name="returnTab" value="requests" />
                                <div class="nxex-request-preview">
                                    <span>@violation.ReferenceNo · @violation.EventDate?.ToString("yyyy-MM-dd")</span>
                                    <strong>@violation.ViolationTitle</strong>
                                </div>
                                <textarea name="reply" required placeholder="اكتب ردّك على هذه المخالفة..."></textarea>
                                <button type="submit">إرسال الرد</button>
                            </form>
                        }
                    </section>
                }

                @if (Model.PendingAssetAcknowledgments.Any())
                {
                    <section class="nxex-card" style="border:1px solid rgba(18,217,227,.35)">
                        <header class="nxex-card-head">
                            <div>
                                <h2>عهد بانتظار إقرارك</h2>
                                <p>أقرّ باستلام العهد المسلّمة إليك — يظهر إقرارك لإدارة الموارد البشرية.</p>
                            </div>
                            <span class="nxex-chip pending">@Model.PendingAssetAcknowledgments.Count</span>
                        </header>

                        @foreach (var asset in Model.PendingAssetAcknowledgments)
                        {
                            <form method="post" asp-page-handler="AcknowledgeAsset" class="nxex-form" style="margin-bottom:10px;display:flex;align-items:center;gap:10px;justify-content:space-between">
                                <input type="hidden" name="id" value="@asset.Id" />
                                <input type="hidden" name="returnTab" value="requests" />
                                <div>
                                    <strong>@asset.Title</strong>
                                    <small style="display:block;opacity:.75">
                                        @(string.IsNullOrWhiteSpace(asset.Subtitle) ? "" : asset.Subtitle + " · ")منذ @(asset.FromDate?.ToString("yyyy-MM-dd") ?? "—")@(asset.Amount.HasValue ? " · بقيمة " + asset.Amount.Value.ToString("#,0.##") : "")
                                    </small>
                                </div>
                                <button type="submit" style="flex:none">أقرّ بالاستلام</button>
                            </form>
                        }
                    </section>
                }

                <section class="nxex-card nxex-request-list-card">
                    <header class="nxex-card-head">
                        <div>
                            <h2>متابعة الطلبات</h2>
                            <p>آخر الطلبات المرسلة من بوابة الموظف.</p>
                        </div>
                        <span class="nxex-chip pending">@Model.Requests.Count طلب</span>
                    </header>

                    <div class="nxex-request-timeline">
                    @if (Model.Requests.Count == 0)
                    {
                        <div class="nxex-empty">لا توجد طلبات حالياً.</div>
                    }
                    @foreach (var row in Model.Requests)
                    {
                        <article class="@Model.StatusClass(row.Status)">
                            <div class="nxex-request-icon">@Model.RequestIcon(row.RequestType)</div>
                            <div>
                                <div class="nxex-request-row-head">
                                    <strong>@row.RequestType</strong>
                                    <span class="nxex-chip @Model.StatusClass(row.Status)">@Model.StatusText(row.Status)</span>
                                </div>
                                <p>@Model.DisplayValue(row.Reason)</p>
                                <small>من @Model.DisplayDate(row.FromDate) إلى @Model.DisplayDate(row.ToDate) · تم الإرسال @Model.DisplayDate(row.CreatedAt)</small>
                            </div>
                        </article>
                    }
                    </div>
                </section>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="pulse">
            <div class="nxex-pulse-grid">
                <section class="nxex-card nxex-pulse-list">
                    <header class="nxex-card-head">
                        <div><h2>الاستبيانات والانتخابات</h2><p>الاستبيانات المنشورة والموجهة لك من Employee Pulse Studio.</p></div>
                        <span class="nxex-chip live">@Model.OpenPollsCount مطلوب</span>
                    </header>

                    @if (Model.Polls.Count == 0)
                    {
                        <div class="nxex-empty">لا توجد استبيانات منشورة حالياً.</div>
                    }

                    @foreach (var poll in Model.Polls)
                    {
                        <article class="nxex-poll-card">
                            <div class="nxex-poll-head">
                                <span class="nxex-chip">@poll.Category</span>
                                <small>@Model.DisplayDate(poll.PublishDate)</small>
                            </div>
                            <h3>@poll.Title</h3>
                            <p>@poll.Question</p>

                            @if (poll.HasVoted)
                            {
                                <div class="nxex-voted">تم تسجيل تصويتك مسبقاً. شكراً لمشاركتك.</div>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="VotePoll" class="nxex-vote-form">
                                    <input type="hidden" name="PollVote.PollId" value="@poll.Id" />
                                    <input type="hidden" name="returnTab" value="pulse" />
                                    <div class="nxex-options">
                                        @foreach (var option in poll.Options)
                                        {
                                            <label>
                                                <input type="radio" name="PollVote.OptionId" value="@option.Id" required />
                                                <span>@option.OptionText</span>
                                            </label>
                                        }
                                    </div>
                                    <button type="submit">إرسال التصويت</button>
                                </form>
                            }
                        </article>
                    }
                </section>

                <aside class="nxex-card nxex-pulse-insight">
                    <header class="nxex-card-head compact"><h2>مؤشر نبضك</h2><span class="nxex-chip">Pulse</span></header>
                    <div class="nxex-ring"><strong>78%</strong><span>نبض عام جيد</span></div>
                    <p>كل مشاركة منك تساعد الموارد البشرية على تحسين بيئة العمل.</p>
                </aside>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="feedback">
            <div class="nxex-feedback-grid">
                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>إرسال شكوى أو مقترح</h2><span class="nxex-chip">موظف</span></header>
                    <form method="post" asp-page-handler="Feedback" class="nxex-form">
                        <input type="hidden" name="returnTab" value="feedback" />
                        <label>النوع</label>
                        <select asp-for="Feedback.Type">
                            <option value="اقتراح">اقتراح</option>
                            <option value="شكوى">شكوى</option>
                            <option value="استفسار">استفسار</option>
                        </select>
                        <label>الأولوية</label>
                        <select asp-for="Feedback.Priority">
                            <option value="منخفض">منخفض</option>
                            <option value="متوسط">متوسط</option>
                            <option value="عالي">عالي</option>
                        </select>
                        <label>العنوان</label>
                        <input asp-for="Feedback.Title" placeholder="اكتب عنوان مختصر" />
                        <label>التفاصيل</label>
                        <textarea asp-for="Feedback.Message" placeholder="اكتب التفاصيل"></textarea>
                        <button type="submit">إرسال</button>
                    </form>
                </section>

                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>متابعة الردود</h2><span class="nxex-chip">@Model.FeedbackItems.Count</span></header>
                    <div class="nxex-feedback-list">
                    @if (Model.FeedbackItems.Count == 0)
                    {
                        <div class="nxex-empty">لا توجد شكاوي أو مقترحات.</div>
                    }
                    @foreach (var item in Model.FeedbackItems)
                    {
                        <article>
                            <div><span class="nxex-chip">@item.Type</span><span class="nxex-chip @Model.StatusClass(item.Status)">@Model.FeedbackStatusText(item.Status)</span></div>
                            <h3>@item.Title</h3>
                            <p>@item.Message</p>
                            @if (!string.IsNullOrWhiteSpace(item.AdminReply))
                            {
                                <div class="nxex-reply"><strong>رد الإدارة - @item.RepliedBy</strong><span>@item.AdminReply</span></div>
                            }
                        </article>
                    }
                    </div>
                </section>
            </div>
        </section>

        <section class="nxex-pane" data-nxex-pane="performance">
            <div class="nxex-grid-2">
                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>التقييم والأداء</h2><span class="nxex-chip pending">قادم</span></header>
                    <div class="nxex-performance">
                        <article><strong>آخر تقييم</strong><span>لم يتم ربط جدول التقييم بعد</span></article>
                        <article><strong>نقاط القوة</strong><span>الالتزام، التعاون، سرعة التعلم</span></article>
                        <article><strong>نقاط التطوير</strong><span>تظهر بعد اعتماد تقييم الإدارة</span></article>
                    </div>
                </section>

                <section class="nxex-card">
                    <header class="nxex-card-head"><h2>الانضباط والعقوبات</h2><span class="nxex-chip">Discipline</span></header>
                    <div class="nxex-note-box">
                        هنا سيتم عرض العقوبات، الإنذارات، والمكافآت بعد ربط جدول الانضباط الرسمي.
                    </div>
                </section>
            </div>
        </section>
    </main>

    @* ===== شاشة طلب الإجازة المنبثقة (منفصلة عن الاستوديو القديم) ===== *@
    @{
        var annualRemaining = Model.LeaveBalances
            .FirstOrDefault(b => b.Type == SmartAttendance.Domain.Enums.LeaveType.Annual)?.Remaining ?? 0m;
        var sickRemaining = Model.LeaveBalances
            .FirstOrDefault(b => b.Type == SmartAttendance.Domain.Enums.LeaveType.Sick)?.Remaining ?? 0m;
    }
    <div class="nxex-modal-backdrop" id="nxex-leave-backdrop" hidden></div>
    <div class="nxex-modal" id="nxex-leave-modal" role="dialog" aria-label="طلب إجازة" hidden>
        <header class="nxex-modal-head">
            <h2>طلب إجازة</h2>
            <button type="button" class="nxex-modal-close" data-close-leave-modal aria-label="إغلاق">✕</button>
        </header>

        @{
            string BalanceSmall(RequestTypeStore.ReqType t)
            {
                if (t.Name == "إجازة سنوية") return annualRemaining <= 0 ? "لا يوجد رصيد" : $"المتبقّي {annualRemaining:0.#} يوم";
                if (t.Name == "إجازة مرضية") return $"المتبقّي {sickRemaining:0.#} يوم";
                return t.AllowedDays.HasValue ? $"حتى {t.AllowedDays} يوم" : string.Empty;
            }
            bool TypeDisabled(RequestTypeStore.ReqType t) => t.Name == "إجازة سنوية" && annualRemaining <= 0;
        }

        <div class="nxex-modal-tabs">
            @{ var firstTab = true; }
            @foreach (var cat in Model.ReqCategories.Where(c => !c.IsPickerEntry))
            {
                <button type="button" class="@(firstTab ? "active" : "")" data-leave-tab="cat-@cat.Id">@cat.Name</button>
                firstTab = false;
            }
        </div>

        <div class="nxex-modal-body">
            @{ var shownDefault = false; }
            @foreach (var cat in Model.ReqCategories)
            {
                var catTypes = Model.ReqTypes.Where(x => x.CategoryId == cat.Id).ToList();
                var isDefault = !cat.IsPickerEntry && !shownDefault;
                if (isDefault) { shownDefault = true; }
                <form method="post" asp-page-handler="CreateLeave" enctype="multipart/form-data"
                      class="nxex-leave-form" data-leave-panel="cat-@cat.Id"
                      data-picker-entry="@cat.IsPickerEntry.ToString().ToLower()" data-cat-name="@cat.Name"
                      hidden="@(isDefault ? null : "hidden")">
                    <div class="nxex-leave-types">
                        @{ var picked = false; }
                        @foreach (var t in catTypes)
                        {
                            var disabled = TypeDisabled(t);
                            var check = !disabled && !picked;
                            if (check) { picked = true; }
                            <label class="nxex-leave-type @(disabled ? "disabled" : (check ? "active" : ""))"
                                   data-needs-time="@t.NeedsTime.ToString().ToLower()"
                                   data-attach-req="@t.AttachmentRequired.ToString().ToLower()"
                                   data-attach-label="@(t.AttachmentLabel ?? "")">
                                <input type="radio" name="reqType" value="@t.Name" checked="@check" disabled="@disabled" />
                                <span>@t.Name</span>
                                @{ var bal = BalanceSmall(t); }
                                @if (!string.IsNullOrEmpty(bal)) { <small>@bal</small> }
                            </label>
                        }
                    </div>

                    <div class="nxex-field">
                        <label>التاريخ</label>
                        <button type="button" class="nxex-date-trigger" data-open-datepicker>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
                            <span data-date-display>اختر التاريخ</span>
                        </button>
                        <input type="hidden" name="from" data-dp-from required />
                        <input type="hidden" name="to" data-dp-to required />
                    </div>

                    <div class="nxex-daycount" data-daycount>عدد الأيام: <strong data-leave-days>—</strong></div>

                    <div class="nxex-cross-note" data-cross-note hidden>
                        ⚠ الحركة عبر يومين — تبدأ في التاريخ المحدَّد وتنتهي في اليوم التالي.
                    </div>

                    <div class="nxex-form-row-2 nxex-time-row" hidden>
                        <div class="nxex-field">
                            <label>من الساعة</label>
                            <button type="button" class="nxex-date-trigger" data-open-timepicker>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                                <span data-time-display>--:--</span>
                            </button>
                            <input type="hidden" name="fromTime" data-tp-input />
                        </div>
                        <div class="nxex-field">
                            <label>إلى الساعة</label>
                            <button type="button" class="nxex-date-trigger" data-open-timepicker>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                                <span data-time-display>--:--</span>
                            </button>
                            <input type="hidden" name="toTime" data-tp-input />
                        </div>
                    </div>

                    <div class="nxex-duration" data-duration hidden>
                        <div>المدة المطلوبة: <strong data-duration-val>—</strong></div>
                        @if (cat.IsPickerEntry)
                        {
                            <div class="nxex-amount-note">المبلغ يُحتسب حسب سياسة الأوفرتايم (تُضبط من الإعدادات لاحقاً).</div>
                        }
                    </div>

                    <div class="nxex-field">
                        <label>السبب (اختياري)</label>
                        <textarea name="reason" rows="2" placeholder="اكتب السبب"></textarea>
                    </div>
                    <div class="nxex-field">
                        <label>إرفاق صورة <span data-attach-star hidden>*</span> <span data-attach-hint style="color:#7f95ab;font-weight:800"></span></label>
                        <input type="file" name="attachment" accept="image/*,.pdf" />
                    </div>

                    <button type="submit" class="nxex-leave-submit">إرسال الطلب</button>
                </form>
            }
        </div>

    </div>

    @* ===== منتقي «طلب جديد» الديناميكي (إجازة + نسيان بصمة + الفئات المستقلة) ===== *@
    <div class="nxex-more-backdrop" id="nxex-req-backdrop" hidden></div>
    <div class="nxex-more-sheet nxex-req-sheet" id="nxex-req-sheet" role="dialog" aria-label="نوع الطلب" hidden>
        <div class="nxex-more-handle"></div>
        <h3>طلب جديد</h3>
        <div class="nxex-more-grid">
            @if (Model.ReqCategories.Any(c => !c.IsPickerEntry))
            {
                <button type="button" class="nxex-more-item" data-open-leave-modal>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M6 21V10l6-4 6 4v11M9 21v-5h6v5"/></svg>
                    <span>إجازة</span>
                </button>
            }
            <button type="button" class="nxex-more-item" data-nxex-tab="requests" data-scroll-target="#nxex-missing-punch-card">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 11v3m0 0 2 2m-2-2-2 2M7 8a5 5 0 0 1 10 0c0 2-1 3-1 5"/><circle cx="12" cy="12" r="9"/></svg>
                <span>نسيان بصمة</span>
            </button>
            @foreach (var cat in Model.ReqCategories.Where(c => c.IsPickerEntry))
            {
                <button type="button" class="nxex-more-item" data-open-cat="cat-@cat.Id">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                    <span>@cat.Name</span>
                </button>
            }
        </div>
    </div>

    @* ===== منتقي التاريخ المخصّص (يوم واحد / أيام متعددة) ===== *@
    <div class="nxex-dp-backdrop" id="nxex-dp-backdrop" hidden></div>
    <div class="nxex-dp-sheet" id="nxex-dp-sheet" role="dialog" aria-label="اختر التاريخ" hidden>
        <div class="nxex-more-handle"></div>
        <h3>اختر التاريخ</h3>
        <div class="nxex-dp-modes">
            <button type="button" class="active" data-dp-mode="single">يوم واحد</button>
            <button type="button" data-dp-mode="range">أيام متعددة</button>
        </div>
        <div class="nxex-dp-fields">
            <div class="nxex-dp-field" data-dp-fieldbox="from" hidden><span>من تاريخ</span><strong data-dp-from-label>—</strong></div>
            <div class="nxex-dp-field" data-dp-fieldbox="to" hidden><span>إلى تاريخ</span><strong data-dp-to-label>—</strong></div>
            <div class="nxex-dp-field" data-dp-fieldbox="single"><span>تاريخ</span><strong data-dp-single-label>—</strong></div>
        </div>
        <div class="nxex-dp-cal">
            <div class="nxex-dp-calhead">
                <button type="button" data-dp-prev aria-label="السابق">‹</button>
                <span data-dp-month></span>
                <button type="button" data-dp-next aria-label="التالي">›</button>
            </div>
            <div class="nxex-dp-week"><span>أحد</span><span>إثنين</span><span>ثلاثاء</span><span>أربعاء</span><span>خميس</span><span>جمعة</span><span>سبت</span></div>
            <div class="nxex-dp-grid" data-dp-grid></div>
        </div>
        <button type="button" class="nxex-dp-apply" data-dp-apply disabled>تطبيق</button>
        <button type="button" class="nxex-dp-cancel" data-dp-cancel>إلغاء</button>
    </div>

    @* ===== منتقي الوقت المخصّص ===== *@
    <div class="nxex-tp-backdrop nxex-dp-backdrop" id="nxex-tp-backdrop" hidden></div>
    <div class="nxex-tp-sheet" id="nxex-tp-sheet" role="dialog" aria-label="اختر الوقت" hidden>
        <div class="nxex-more-handle"></div>
        <h3>اختر الوقت</h3>
        <div class="nxex-tp-preview"><strong data-tp-preview>--:--</strong></div>
        <div class="nxex-tp-cols">
            <div class="nxex-tp-colwrap"><span>ساعة</span><div class="nxex-tp-col" data-tp-hours></div></div>
            <div class="nxex-tp-sep">:</div>
            <div class="nxex-tp-colwrap"><span>دقيقة</span><div class="nxex-tp-col" data-tp-mins></div></div>
        </div>
        <button type="button" class="nxex-dp-apply" data-tp-apply disabled>تطبيق</button>
        <button type="button" class="nxex-dp-cancel" data-tp-cancel>إلغاء</button>
    </div>
</section>

@section Scripts {
    <script src="~/js/nexora-employee-experience.js" asp-append-version="true"></script>
}



<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="dark" data-sidebar="expanded" class="sa-preload">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(ViewData["Title"] ?? "NEXORA") - NEXORA</title>

    <script>
        (function () {
            var theme = localStorage.getItem("SmartAttendance.Theme") || "dark";
            var language = localStorage.getItem("SmartAttendance.Language") || "ar";
            var sidebar = localStorage.getItem("SmartAttendance.Sidebar") || "expanded";

            document.documentElement.setAttribute("data-theme", theme === "light" ? "light" : "dark");
            document.documentElement.setAttribute("data-sidebar", sidebar === "collapsed" ? "collapsed" : "expanded");
            document.documentElement.setAttribute("lang", language === "ar" ? "ar" : "en");
            document.documentElement.setAttribute("dir", language === "ar" ? "rtl" : "ltr");
        })();
    </script>

    <style>
        html[data-theme="dark"], html[data-theme="dark"] body { background:#07121F; color:#E6EAEE; }
        html[data-theme="light"], html[data-theme="light"] body { background:#F4F7FA; color:#07121F; }
        html.sa-preload body { opacity:0; }
        html.sa-ready body { opacity:1; transition:opacity 160ms ease; }
    </style>

    <link rel="icon" type="image/svg+xml" href="~/brand/nexora-symbol.svg" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme-localization.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-brand.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-sidebar-brand-active-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-uiux-v2.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-v3-hotfix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-v3-profile-documents-polish.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-v3-ui-details-hotfix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-documents-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-readiness-modal-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-documents-modal-force-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-documents-dropdown-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-document-file-selector-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-save-documents-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-addemployee-selected-documents-preview.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-remove-duplicate-topbar-toggle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-force-expanded-sidebar-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-proper-sidebar-collapse-fix.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-sidebar-button-force-working-fix.css" asp-append-version="true" />
</head>

<body>
    @{
        var loginUser = Context.Request.Cookies["SA.UserName"];
        var displayNameCookie = Context.Request.Cookies["SA.DisplayName"];
        var loginDisplayName = !string.IsNullOrWhiteSpace(displayNameCookie) ? displayNameCookie : loginUser;
        var loginRole = Context.Request.Cookies["SA.Role"] ?? "";
        var loginEmployeeId = Context.Request.Cookies["SA.EmployeeId"] ?? "";
        var isLoggedIn = !string.IsNullOrWhiteSpace(loginUser);

        var isAdmin = loginRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
        var isHrManager = loginRole.Equals("HR Manager", StringComparison.OrdinalIgnoreCase);
        var isHrOfficer = loginRole.Equals("HR Officer", StringComparison.OrdinalIgnoreCase);
        var isBranchManager = loginRole.Equals("Branch Manager", StringComparison.OrdinalIgnoreCase);
        var isEmployee = loginRole.Equals("Employee", StringComparison.OrdinalIgnoreCase);
        var isFinanceViewer = loginRole.Equals("Finance Viewer", StringComparison.OrdinalIgnoreCase);

        var showOrg = isAdmin || isHrManager || isHrOfficer || isBranchManager || isFinanceViewer;
        var showHr = isAdmin || isHrManager || isHrOfficer || isBranchManager;
        var showAttendance = isAdmin || isHrManager || isHrOfficer;
        var showReports = isAdmin || isHrManager || isHrOfficer || isBranchManager || isFinanceViewer;
        var showSettings = isAdmin || isHrManager;
        var showSelfServices = isAdmin || isHrManager || isHrOfficer || isBranchManager || isEmployee;
        var pageTitle = ViewData["Title"]?.ToString() ?? "NEXORA";
    }

    <div class="nexora-shell">
        <aside class="nexora-sidebar">
            <div class="nexora-brand-card">
                <a asp-page="/Index" class="nexora-brand-link" aria-label="NEXORA Home">
                    <img class="nexora-brand-symbol" src="~/brand/nexora-symbol.svg" alt="NEXORA" />
                    <div class="nexora-brand-copy">
                        <div class="nexora-wordmark">NEXORA</div>
                        <div class="nexora-arabic">نيكسورا</div>
                        <div class="nexora-tagline">Intelligent Solutions. Limitless Impact.</div>
                    </div>
                </a>

                <button type="button"
                        class="nexora-icon-button"
                        data-sidebar-toggle
                        aria-label="Toggle sidebar">
                    <span></span>
                </button>
            </div>

            <nav class="nexora-nav">
                <!-- NEXORA_REFERENCE_V3_START -->
                <a asp-page="/Index" class="nexora-nav-link">
                    <span class="nexora-nav-dot"></span>
                    <span>لوحة التحكم</span>
                </a>

                <details class="nexora-nav-group" open>
                    <summary>
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">شؤون الموظفين</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/Employees/Index" class="nexora-nav-link"><span>إدارة الموظفين</span></a>
<a asp-page="/HRAffairs/PayrollReadiness" class="nexora-nav-link"><span>جاهزية الراتب</span></a>
                        <a asp-page="/HRAffairs/DocumentsRisk" class="nexora-nav-link"><span>العقود والمستندات</span></a>
                        <a asp-page="/EmployeeDocuments/Index" class="nexora-nav-link">
                            <span>رفع المستندات</span>
                        </a>
                    </div>
                </details>

                <details class="nexora-nav-group">
                    <summary>
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">الحضور والانصراف</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/AttendanceOperations/Index" class="nexora-nav-link"><span>مراقبة الحضور</span></a>
                        <a asp-page="/HRAffairs/AttendanceExceptions" class="nexora-nav-link"><span>استثناءات الحضور</span></a>
                        <a asp-page="/Nexora/PayrollClosing" class="nexora-nav-link"><span>إغلاق الراتب</span></a>
                    </div>
                </details>

                <details class="nexora-nav-group">
                    <summary>
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">الخدمات الذاتية</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/Nexora/ApprovalsCenter" class="nexora-nav-link"><span>الموافقات</span></a>
                        <a asp-page="/Nexora/SelfServiceCenter" class="nexora-nav-link"><span>الخدمة الذاتية</span></a>
                        <a asp-page="/Nexora/NotificationsCenter" class="nexora-nav-link"><span>التنبيهات</span></a>
                    </div>
                </details>

                <details class="nexora-nav-group">
                    <summary>
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">الإعدادات</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/Nexora/ReportsCenter" class="nexora-nav-link"><span>التقارير</span></a>
                        <a asp-page="/Nexora/RulesEngine" class="nexora-nav-link"><span>محرك القواعد</span></a>
                        <a asp-page="/Nexora/SettingsCenter" class="nexora-nav-link"><span>الإعدادات</span></a>
                    </div>
                </details>
                <!-- NEXORA_REFERENCE_V3_END -->
            </nav>
        </aside>

        <div class="nexora-main">
            <header class="nexora-topbar">
                <div class="nexora-topbar-left">
                    

                    <div>
                        <div class="nexora-page-title">@pageTitle</div>
                        <div class="nexora-page-subtitle">NEXORA · Intelligent Operations Platform</div>
                    </div>
                </div>

                <div class="nexora-controls">
                    <button type="button" class="nexora-pill-button" data-language-button="ar">AR</button>
                    <button type="button" class="nexora-pill-button" data-language-button="en">EN</button>

                    <button type="button" class="nexora-pill-button" data-theme-button="dark" data-i18n="themeDark">Dark</button>
                    <button type="button" class="nexora-pill-button" data-theme-button="light" data-i18n="themeLight">Light</button>

                    @if (isLoggedIn)
                    {
                        <div class="nexora-user-chip">
                            <span class="nexora-user-avatar">@(string.IsNullOrWhiteSpace(loginDisplayName) ? "N" : loginDisplayName.Trim()[0])</span>
                            <span class="nexora-user-name">@loginDisplayName</span>
                            <span class="nexora-user-role">@loginRole</span>
                        </div>

                        <a asp-page="/Account/Logout" class="nexora-pill-button" data-i18n="logout">Logout</a>
                    }
                    else
                    {
                        <a asp-page="/Account/Login" class="nexora-pill-button" data-i18n="login">Login</a>
                    }
                </div>
            </header>

            <main class="nexora-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        window.SA_AUTH = {
            role: "@loginRole",
            employeeId: "@loginEmployeeId"
        };
    </script>

    <script src="~/js/table-pagination.js" asp-append-version="true"></script>
    <script src="~/js/theme-localization.js" asp-append-version="true"></script>
    <script src="~/js/nexora-brand.js" asp-append-version="true"></script>
    <script src="~/js/nexora-uiux-v2.js" asp-append-version="true"></script>

        <script src="~/js/nexora-reference-redesign-v3.js" asp-append-version="true"></script>
        <script src="~/js/nexora-v3-hotfix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-v3-ui-details-hotfix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-documents-modal.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-readiness-modal-fix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-documents-modal-force-fix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-documents-dropdown-modal.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-document-file-selector-fix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-save-documents-modal.js" asp-append-version="true"></script>
        <script src="~/js/nexora-addemployee-selected-documents-preview.js" asp-append-version="true"></script>
        <script src="~/js/nexora-remove-duplicate-topbar-toggle.js" asp-append-version="true"></script>
        <script src="~/js/nexora-force-expanded-sidebar-fix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-proper-sidebar-collapse-fix.js" asp-append-version="true"></script>
        <script src="~/js/nexora-sidebar-button-force-working-fix.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/nexora-sidebar-brand-active-fix.js" asp-append-version="true"></script>
</body>
</html>















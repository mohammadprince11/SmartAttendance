@{
    var displayName = Context.Request.Cookies["SA.DisplayName"] ?? "موظف";
    var username = Context.Request.Cookies["SA.UserName"] ?? "employee";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NEXORA</title>
    <link rel="stylesheet" href="~/css/nexora-employee-portal-shell.css" asp-append-version="true" />
</head>
<body>
    <div class="nx-emp-shell">
        <aside class="nx-emp-sidebar">
            <div class="nx-emp-brand"><div>N</div><strong>NEXORA</strong><span>Employee Self Service</span></div>
            <div class="nx-emp-user"><span>المستخدم الحالي</span><strong>@username</strong><small>@displayName</small></div>
            <nav>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="home">الصفحة الرئيسية</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="profile">ملفي الشخصي</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="compensation">التعويضات</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="requests">طلباتي</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="team">فريقي</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="attendance">حضوري</a>
                <a asp-page="/EmployeePortal/Index" asp-route-tab="feedback">الشكاوي والمقترحات</a>
            </nav>
            <div class="nx-emp-note">هذه الواجهة مخصصة لحسابات الموظفين فقط.</div>
        </aside>
        <main class="nx-emp-main">
            <header class="nx-emp-top"><strong>بوابة الموظف</strong><div><a href="/">الرئيسية</a><a href="/Account/Logout">خروج</a></div></header>
            @RenderBody()
        </main>
    </div>
</body>
</html>

@{
    Layout = null;
    var userName = Context.User.Identity?.Name ?? "employee";
    var role = Context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Employee";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - NEXORA Employee Experience</title>
    <link rel="stylesheet" href="~/css/nexora-employee-experience.css" asp-append-version="true" />
</head>
<body class="nxex-body">
    <aside class="nxex-shell-sidebar">
        <div class="nxex-brand">
            <div class="nxex-brand-symbol">NX</div>
            <div>
                <strong>NEXORA</strong>
                <span>Employee Experience</span>
            </div>
        </div>

        <div class="nxex-user-mini">
            <span>المستخدم الحالي</span>
            <strong>@userName</strong>
            <small>@role</small>
        </div>

        <nav class="nxex-side-nav">
            <a href="/EmployeePortal?tab=home">الرئيسية</a>
            <a href="/EmployeePortal?tab=profile">ملفي الشخصي</a>
            <a href="/EmployeePortal?tab=attendance">الحضور</a>
            <a href="/EmployeePortal?tab=compensation">الراتب والتعويضات</a>
            <a href="/EmployeePortal?tab=requests">طلباتي</a>
            <a href="/EmployeePortal?tab=pulse">الاستبيانات</a>
            <a href="/EmployeePortal?tab=feedback">الشكاوي والمقترحات</a>
            <a href="/EmployeePortal?tab=performance">التقييم والانضباط</a>
        </nav>

        <div class="nxex-side-note">
            <strong>بوابة الموظف</strong>
            <span>واجهة السينك الرسمية لكل ما ينشر أو يسجل من الإدارة.</span>
        </div>
    </aside>

    <main class="nxex-shell-main">
        <div class="nxex-topbar">
            <div>
                <strong>بوابة الموظف الذكية</strong>
                <span>Employee Experience Portal</span>
            </div>
            <a href="/Account/Logout">خروج</a>
        </div>
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


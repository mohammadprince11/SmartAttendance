<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Attendance</title>

    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>

<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon">SA</div>
                <div>
                    <div class="brand-title">Smart Attendance</div>
                    <div class="brand-subtitle">Enterprise HRMS</div>
                </div>
            </div>

            <nav class="menu">
                <a asp-page="/Index">Dashboard</a>
                <a asp-page="/Companies/Index">Companies</a>
                <a href="/Branches">Branches</a>
                <a href="/Departments">Departments</a>
                <a href="/Employees">Employees</a>
                <a href="/Devices">Devices</a>
                <a href="/Shifts">Shifts</a>
                <a href="#">Attendance</a>
                <a href="#">Reports</a>
                <a href="#">Settings</a>
            </nav>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="page-title">@ViewData["Title"]</div>
                <div class="user-box">Mohammed Ali</div>
            </header>

            <section class="content">
                @RenderBody()
            </section>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
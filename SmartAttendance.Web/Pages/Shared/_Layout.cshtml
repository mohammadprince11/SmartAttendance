@using SmartAttendance.Application.Common.Security
@using SmartAttendance.Web.Infrastructure.Security
@inject IPermissionAuthorizationService PermissionAuthorizationService

<!DOCTYPE html>
<html lang="ar" dir="rtl" data-theme="light" data-sidebar="expanded">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(ViewData["Title"] ?? "ZYNORA HR") - ZYNORA HR</title>

    <script>
        (function () {
            var theme = "light";

            try {
                [
                    "SmartAttendance.Sidebar",
                    "NEXORA.Sidebar.State",
                    "NEXORA.Sidebar.Final.Working",
                    "NEXORA.SidebarMode.Final",
                    "NEXORA.V2.Sidebar",
                    "NEXORA.Sidebar",
                    "SidebarCollapsed",
                    "sidebar"
                ].forEach(function (key) {
                    localStorage.removeItem(key);
                });

                var savedTheme =
                    localStorage.getItem("ZYNORA.Theme");

                if (
                    savedTheme === "light" ||
                    savedTheme === "dark"
                ) {
                    theme = savedTheme;
                }
            } catch (e) { }

            document.documentElement.setAttribute(
                "data-sidebar",
                "expanded"
            );

            document.documentElement.setAttribute(
                "data-theme",
                theme
            );
        })();
    </script>

    <link rel="icon" type="image/svg+xml" href="~/brand/zynora-symbol.svg" />
    <link rel="apple-touch-icon" href="~/brand/zynora-symbol-1024.png" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-ui-stabilization-phase1.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-calendar-v18.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-global-scroll-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-select-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/zynora-design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-brand.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/nexora-button-interactions.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/zynora-checkbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/zynora-file-input.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/zynora-kayan-nav.css" asp-append-version="true" />
</head>

<body dir="rtl">
    @{
        var loginUser = Context.User.Identity?.Name;
        var displayNameCookie = Context.Request.Cookies["SA.DisplayName"] ?? Context.User.FindFirst("DisplayName")?.Value;
        var loginDisplayName = !string.IsNullOrWhiteSpace(displayNameCookie) ? displayNameCookie : loginUser;
        var loginRole = Context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        var loginEmployeeId = Context.User.FindFirst("EmployeeId")?.Value ?? "";
        var isLoggedIn = !string.IsNullOrWhiteSpace(loginUser);
        var systemUserId = PeopleAccessContext.GetSystemUserId(Context) ?? 0;

        var canViewPeopleDirectory = isLoggedIn &&
            await PermissionAuthorizationService.HasPermissionAsync(
                systemUserId,
                PeoplePermissionCodes.ViewDirectory,
                PeopleCompatibilityAccess.IsAllowed(
                    loginRole,
                    PeoplePermissionCodes.ViewDirectory),
                Context.RequestAborted);

        var canImportPeople = isLoggedIn &&
            await PermissionAuthorizationService.HasGlobalPermissionAsync(
                systemUserId,
                PeoplePermissionCodes.Import,
                PeopleCompatibilityAccess.IsAllowed(
                    loginRole,
                    PeoplePermissionCodes.Import),
                Context.RequestAborted);

        var canManagePeoplePermissions = isLoggedIn &&
            await PermissionAuthorizationService.HasGlobalPermissionAsync(
                systemUserId,
                PeoplePermissionCodes.ManagePermissions,
                PeopleCompatibilityAccess.IsAllowed(
                    loginRole,
                    PeoplePermissionCodes.ManagePermissions),
                Context.RequestAborted);

        var isAdminRole = loginRole.Equals(
            "Admin",
            StringComparison.OrdinalIgnoreCase);

        var canViewOrganization = isAdminRole ||
            loginRole.Equals("HR Manager", StringComparison.OrdinalIgnoreCase) ||
            loginRole.Equals("HR Officer", StringComparison.OrdinalIgnoreCase) ||
            loginRole.Equals("Branch Manager", StringComparison.OrdinalIgnoreCase) ||
            loginRole.Equals("Finance Viewer", StringComparison.OrdinalIgnoreCase);

        // These People pages still use the legacy server-side Admin compatibility rule.
        // Keep their navigation visibility aligned with the middleware until each route
        // receives a dedicated dynamic permission code.
        var canUseLegacyPeopleAdministration = isAdminRole;

        var hasVisiblePeopleNavigation =
            canViewPeopleDirectory ||
            canImportPeople ||
            canManagePeoplePermissions ||
            canViewOrganization ||
            canUseLegacyPeopleAdministration;

        var pageTitle = ViewData["Title"]?.ToString() ?? "ZYNORA HR";

        var rawPath = (Context.Request.Path.Value ?? "/").TrimEnd('/');
        if (string.IsNullOrWhiteSpace(rawPath))
        {
            rawPath = "/";
        }

        var currentPath = rawPath.ToLowerInvariant();

        Func<string, string> NormalizePath = path =>
        {
            var value = (path ?? "/").TrimEnd('/').ToLowerInvariant();
            return string.IsNullOrWhiteSpace(value) ? "/" : value;
        };

        Func<string, bool> IsCurrent = path =>
        {
            var normalized = NormalizePath(path);
            if (currentPath == normalized)
            {
                return true;
            }

            if (normalized.EndsWith("/index", StringComparison.OrdinalIgnoreCase))
            {
                var withoutIndex = normalized.Substring(0, normalized.Length - "/index".Length);
                if (string.IsNullOrWhiteSpace(withoutIndex))
                {
                    withoutIndex = "/";
                }

                return currentPath == withoutIndex;
            }

            return false;
        };

        Func<string, bool> IsUnder = path =>
        {
            var normalized = NormalizePath(path);
            if (normalized == "/")
            {
                return currentPath == "/";
            }

            return currentPath == normalized || currentPath.StartsWith(normalized + "/", StringComparison.OrdinalIgnoreCase);
        };

        Func<string, string> ActiveClass = path => IsCurrent(path) ? "active nexora-active" : "";

        var employeesOpen = IsUnder("/Employees") || IsUnder("/EmployeeUpdates") || IsUnder("/DisciplinaryRules") || IsUnder("/EmployeeProfileSettings") || IsUnder("/EmployeeProfiles") || IsUnder("/EmployeeDocuments") || IsUnder("/EmployeePermissions") || IsUnder("/Organization") || IsUnder("/Alerts") || IsUnder("/LeaveBalances") || IsUnder("/PeopleReports") || IsUnder("/EmployeeTasks") || IsUnder("/Engagement");
        var attendanceOpen = IsUnder("/AttendanceOperations") || IsUnder("/AttendanceRecords") || IsUnder("/AttendanceImports") || IsUnder("/AttendanceProcessing") || IsUnder("/AttendanceCorrections") || IsUnder("/Shifts") || IsUnder("/Devices");
        var requestsOpen = IsUnder("/LeaveRequests") || IsUnder("/Approvals") || IsUnder("/SelfServices");
        var systemOpen = IsUnder("/Branches") || IsUnder("/Departments") || IsUnder("/SystemUsers") || IsUnder("/Permissions");
        var reportsOpen = IsUnder("/AttendanceReports") || IsUnder("/Reports");
        var payrollOpen = IsUnder("/Payroll");
    }

    <div class="nexora-shell">
        <aside class="nexora-sidebar" aria-label="القائمة الجانبية">
            <div class="nexora-brand-card">
                <a asp-page="/Index"
                   class="nexora-brand-link"
                   aria-label="ZYNORA HR Home">
                    <img class="nexora-brand-logo"
                         src="~/brand/zynora-logo-horizontal-light.svg"
                         alt="ZYNORA HR" />
                    <span class="nexora-brand-tagline">
                        Smarter People. Stronger Business.
                    </span>
                </a>
            </div>

            @if (isLoggedIn)
            {
                <nav class="nexora-nav nexora-stable-nav" aria-label="القائمة الرئيسية">
                    <!-- NEXORA_SAFE_MAIN_MENU_START -->
                <a asp-page="/Index" class="nexora-nav-link nexora-root-link @ActiveClass("/Index")" data-nav-area="dashboard" data-sidebar-label="&#x0644;&#x0648;&#x062D;&#x0629; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;">
                    <span class="nexora-nav-dot"></span>
                    <span>لوحة البيانات</span>
                </a>

                @if (loginRole.Equals("Admin", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-page="/Setup/Index" class="nexora-nav-link nexora-root-link @(IsUnder("/Setup") ? "active nexora-active" : "")" data-nav-area="setup" data-sidebar-label="&#x0625;&#x0639;&#x062F;&#x0627;&#x062F; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;">
                        <span class="nexora-nav-dot gold"></span>
                        <span>&#x0625;&#x0639;&#x062F;&#x0627;&#x062F; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</span>
                    </a>
                    <a asp-page="/UserAccess/Index" class="nexora-nav-link nexora-root-link @(IsUnder("/UserAccess") ? "active nexora-active" : "")" data-nav-area="identity" data-sidebar-label="&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0633;&#x062A;&#x062E;&#x062F;&#x0645;&#x064A;&#x0646;">
                        <span class="nexora-nav-dot"></span>
                        <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0633;&#x062A;&#x062E;&#x062F;&#x0645;&#x064A;&#x0646;</span>
                    </a>
                }
                @if (hasVisiblePeopleNavigation)
                {
                    <details name="nexora-main-menu" class="nexora-nav-group" @(employeesOpen ? "open" : "")>
                        <summary data-nav-area="people" data-sidebar-label="&#x0623;&#x0634;&#x062E;&#x0627;&#x0635;">
                            <span class="nexora-nav-dot gold"></span>
                            <span class="nexora-nav-text">أشخاص</span>
                            <span class="nexora-chevron"></span>
                        </summary>
                        @* بنية درج كيان: عنوان المجموعة أول صف + روابط مباشرة + أكورديونات فرعية حصرية (قسم 20 بالدراسة) *@
                        <div class="nexora-nav-group-links" data-ky-title="أشخاص">
                            @if (canViewPeopleDirectory)
                            {
                                <a asp-page="/Employees/Index" class="nexora-nav-link ky-drawer-title @ActiveClass("/Employees/Index")">
                                    <span>أشخاص</span>
                                </a>
                                <a asp-page="/Employees/Index" class="nexora-nav-link @ActiveClass("/Employees/Index")">
                                    <span>قائمة الموظفين</span>
                                </a>
                            }

                            @if (canImportPeople)
                            {
                                <a asp-page="/Employees/Import" class="nexora-nav-link @(IsUnder("/Employees/Import") ? "active nexora-active" : "")">
                                    <span>&#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;&#x064A;&#x0646;</span>
                                </a>
                            }

                            @if (canUseLegacyPeopleAdministration)
                            {
                                <details class="ky-acc" @(IsUnder("/Engagement") || IsUnder("/EmployeeProfiles") || IsUnder("/EmployeeUpdates") || IsUnder("/Violations") || IsUnder("/AssetsManagement") || IsUnder("/EmployeeTasks") || IsUnder("/LeaveBalances") || IsUnder("/Alerts") ? "open" : "")>
                                    <summary><span>عمليات الموارد البشرية</span><span class="ky-acc-chev"></span></summary>
                                    <div class="ky-acc-body">
                                        <a asp-page="/Engagement/Index" class="nexora-nav-link @(IsUnder("/Engagement") || IsUnder("/EmployeeProfiles") ? "active nexora-active" : "")">
                                            <span>تفاعل الموظفين</span>
                                        </a>
                                        <a asp-page="/EmployeeUpdates/Index" class="nexora-nav-link @(IsUnder("/EmployeeUpdates") ? "active nexora-active" : "")">
                                            <span>تحديثات الموظف</span>
                                        </a>
                                        <a asp-page="/Violations/Index" class="nexora-nav-link @(IsUnder("/Violations") ? "active nexora-active" : "")">
                                            <span>حالات المخالفات</span>
                                        </a>
                                        <a asp-page="/AssetsManagement/Index" class="nexora-nav-link @(IsUnder("/AssetsManagement") ? "active nexora-active" : "")">
                                            <span>إدارة العهد</span>
                                        </a>
                                        <a asp-page="/EmployeeTasks/Index" class="nexora-nav-link @(IsUnder("/EmployeeTasks") ? "active nexora-active" : "")">
                                            <span>مهام التعيين والإنهاء</span>
                                        </a>
                                        <a asp-page="/LeaveBalances/Index" class="nexora-nav-link @(IsUnder("/LeaveBalances") ? "active nexora-active" : "")">
                                            <span>أرصدة الإجازات</span>
                                        </a>
                                        <a asp-page="/Alerts/Index" class="nexora-nav-link @(IsUnder("/Alerts") ? "active nexora-active" : "")">
                                            <span>التنبيهات والانتهاءات</span>
                                        </a>
                                    </div>
                                </details>

                                <a asp-page="/EmployeeDocuments/Index" class="nexora-nav-link @(IsUnder("/EmployeeDocuments") ? "active nexora-active" : "")">
                                    <span>مركز الوثائق</span>
                                </a>
                            }

                            @if (canViewOrganization)
                            {
                                <a asp-page="/Organization/Index" class="nexora-nav-link @(IsUnder("/Organization/Index") || (IsUnder("/Organization") && !IsUnder("/Organization/Chart")) ? "active nexora-active" : "")">
                                    <span>الهياكل التنظيمية</span>
                                </a>
                                <a href="/Organization/Index#tab=chart" class="nexora-nav-link @(IsUnder("/Organization/Chart") ? "active nexora-active" : "")">
                                    <span>الهيكل الإداري</span>
                                </a>
                            }

                            @if (canUseLegacyPeopleAdministration)
                            {
                                <a asp-page="/PeopleReports/Index" class="nexora-nav-link @(IsUnder("/PeopleReports") ? "active nexora-active" : "")">
                                    <span>التقارير</span>
                                </a>

                                <details class="ky-acc" @(IsUnder("/DisciplinaryRules") || IsUnder("/EmployeeProfileSettings") || IsUnder("/HrSettings") ? "open" : "")>
                                    <summary><span>إعدادات الموارد البشرية</span><span class="ky-acc-chev"></span></summary>
                                    <div class="ky-acc-body">
                                        <a asp-page="/DisciplinaryRules/Index" class="nexora-nav-link @(IsUnder("/DisciplinaryRules") ? "active nexora-active" : "")">
                                            <span>إعدادات المخالفات</span>
                                        </a>
                                        @* NEXORA_EMPLOYEE_PROFILE_SETTINGS_NAV_LINK *@
                                        <a asp-page="/EmployeeProfileSettings/Index" class="nexora-nav-link @(IsUnder("/EmployeeProfileSettings") ? "active nexora-active" : "")">
                                            <span>&#x0625;&#x0639;&#x062F;&#x0627;&#x062F;&#x0627;&#x062A; &#x062D;&#x0642;&#x0648;&#x0644; &#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;</span>
                                        </a>
                                        <a asp-page="/HrSettings/ProbationPeriod" class="nexora-nav-link @(IsUnder("/HrSettings/ProbationPeriod") ? "active nexora-active" : "")">
                                            <span>فترة التجربة</span>
                                        </a>
                                        <a asp-page="/HrSettings/NoticePeriod" class="nexora-nav-link @(IsUnder("/HrSettings/NoticePeriod") ? "active nexora-active" : "")">
                                            <span>فترة الإنذار</span>
                                        </a>
                                        <a asp-page="/HrSettings/SelfServiceSettings" class="nexora-nav-link @(IsUnder("/HrSettings/SelfServiceSettings") ? "active nexora-active" : "")">
                                            <span>إعدادات الخدمة الذاتية</span>
                                        </a>
                                        <a asp-page="/HrSettings/TerminationReasons" class="nexora-nav-link @(IsUnder("/HrSettings/TerminationReasons") ? "active nexora-active" : "")">
                                            <span>أسباب الإيقاف</span>
                                        </a>
                                        <a asp-page="/HrSettings/NotificationCenter" class="nexora-nav-link @(IsUnder("/HrSettings/NotificationCenter") ? "active nexora-active" : "")">
                                            <span>مركز الإشعارات</span>
                                        </a>
                                        <a asp-page="/HrSettings/Lookups" class="nexora-nav-link @(IsUnder("/HrSettings/Lookups") ? "active nexora-active" : "")">
                                            <span>القوائم المرجعية</span>
                                        </a>
                                        <a href="/HrSettings/EmployeeCodeSchema" class="nexora-nav-link @(IsUnder("/HrSettings/EmployeeCodeSchema") ? "active nexora-active" : "")">
                                            <span>مخطط رمز الموظف</span>
                                        </a>
                                    </div>
                                </details>
                            }

                            @if (canManagePeoplePermissions)
                            {
                                <a asp-page="/EmployeePermissions/Index" class="nexora-nav-link @(IsUnder("/EmployeePermissions") ? "active nexora-active" : "")">
                                    <span>بطاقات الموظفين</span>
                                </a>
                            }
                        </div>
                    </details>
                }

                <details name="nexora-main-menu" class="nexora-nav-group" @(attendanceOpen ? "open" : "")>
                    <summary data-nav-area="attendance" data-sidebar-label="&#x0627;&#x0644;&#x062D;&#x0636;&#x0648;&#x0631; &#x0648;&#x0627;&#x0644;&#x0627;&#x0646;&#x0635;&#x0631;&#x0627;&#x0641;">
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">الحضور والانصراف</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/AttendanceOperations/Index" class="nexora-nav-link @(IsUnder("/AttendanceOperations") ? "active nexora-active" : "")">
                            <span>مراقبة الحضور</span>
                        </a>
                        <a asp-page="/AttendanceRecords/Index" class="nexora-nav-link @(IsUnder("/AttendanceRecords") ? "active nexora-active" : "")">
                            <span>سجلات الحضور</span>
                        </a>
                        <a asp-page="/AttendanceImports/Index" class="nexora-nav-link @(IsUnder("/AttendanceImports") ? "active nexora-active" : "")">
                            <span>استيراد البصمات</span>
                        </a>
                        <a asp-page="/AttendanceProcessing/Index" class="nexora-nav-link @(IsUnder("/AttendanceProcessing") ? "active nexora-active" : "")">
                            <span>معالجة الحضور</span>
                        </a>
                        <a asp-page="/AttendanceCorrections/Index" class="nexora-nav-link @(IsUnder("/AttendanceCorrections") ? "active nexora-active" : "")">
                            <span>تصحيحات الحضور</span>
                        </a>
                        <a asp-page="/Shifts/Index" class="nexora-nav-link @(IsUnder("/Shifts") ? "active nexora-active" : "")">
                            <span>الشفتات</span>
                        </a>
                        <a asp-page="/Devices/Index" class="nexora-nav-link @(IsUnder("/Devices") ? "active nexora-active" : "")">
                            <span>الأجهزة</span>
                        </a>
                    </div>
                </details>

                <details name="nexora-main-menu" class="nexora-nav-group" @(payrollOpen ? "open" : "")>
                    <summary data-nav-area="payroll" data-sidebar-label="&#x0627;&#x0644;&#x0631;&#x0648;&#x0627;&#x062A;&#x0628;">
                        <span class="nexora-nav-dot gold"></span>
                        <span class="nexora-nav-text">&#x0627;&#x0644;&#x0631;&#x0648;&#x0627;&#x062A;&#x0628;</span>
                        <span class="nexora-chevron"></span>
                    </summary>
                    <div class="nexora-nav-group-links">
                        <a asp-page="/Payroll/TaxSocialSecurity" class="nexora-nav-link @(IsUnder("/Payroll") ? "active nexora-active" : "")">
                            <span>&#x0627;&#x0644;&#x0636;&#x0631;&#x0627;&#x0626;&#x0628; &#x0648;&#x0627;&#x0644;&#x0636;&#x0645;&#x0627;&#x0646;</span>
                        </a>
                        <a asp-page="/EmployeeUpdates/Index" asp-route-section="financial" class="nexora-nav-link">
                            <span>&#x062A;&#x062D;&#x062F;&#x064A;&#x062B; &#x0627;&#x0644;&#x0645;&#x0639;&#x0644;&#x0648;&#x0645;&#x0627;&#x062A; &#x0627;&#x0644;&#x0645;&#x0627;&#x0644;&#x064A;&#x0629;</span>
                        </a>
                        <a asp-page="/EmployeeUpdates/Index" asp-route-section="payment" class="nexora-nav-link">
                            <span>&#x0645;&#x0639;&#x0644;&#x0648;&#x0645;&#x0627;&#x062A; &#x0627;&#x0644;&#x062F;&#x0641;&#x0639;</span>
                        </a>
                    </div>
                </details>
                    <!-- NEXORA_SAFE_MAIN_MENU_END -->
                </nav>
            }
        </aside>

        <div class="nexora-main">
            <header class="nexora-topbar">
                <div class="nexora-topbar-left">
                    <div>
                        <div class="nexora-page-title">@pageTitle</div>
                        <div class="nexora-page-subtitle">زينورا · عمليات موارد بشرية ذكية</div>
                    </div>
                </div>

                <div class="nexora-controls">
                    <button type="button"
                            class="nexora-theme-toggle"
                            data-zynora-theme-toggle
                            aria-label="تفعيل الوضع الداكن"
                            title="تغيير المظهر">
                        <svg class="nexora-theme-icon nexora-theme-icon--sun"
                             viewBox="0 0 24 24"
                             aria-hidden="true">
                            <circle cx="12" cy="12" r="4"></circle>
                            <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path>
                        </svg>
                        <svg class="nexora-theme-icon nexora-theme-icon--moon"
                             viewBox="0 0 24 24"
                             aria-hidden="true">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
                        </svg>
                    </button>

                    @if (isLoggedIn)
                    {
                        <div class="nexora-user-chip">
                            <span class="nexora-user-avatar">@(string.IsNullOrWhiteSpace(loginDisplayName) ? "Z" : loginDisplayName.Trim()[0])</span>
                            <span class="nexora-user-copy">
                                <span class="nexora-user-name">@loginDisplayName</span>
                                <span class="nexora-user-role">@loginRole</span>
                            </span>
                        </div>

                        <a asp-page="/Account/Logout"
                           class="nexora-pill-button nexora-logout-button">
                            خروج
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Account/Login" class="nexora-pill-button">دخول</a>
                    }
                </div>
            </header>

            <main class="nexora-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        window.SA_AUTH = {
            role: "@loginRole",
            employeeId: "@loginEmployeeId"
        };
    </script>

    <script src="~/js/table-pagination.js" asp-append-version="true"></script>
    <script src="~/js/hrms-ui.js" asp-append-version="true"></script>
    <script src="~/js/zynora-theme.js" asp-append-version="true"></script>
    <script src="~/js/zynora-kayan-nav.js" asp-append-version="true"></script>
    <script src="~/js/nexora-ui-stabilization-phase1.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
<script src="~/js/nexora-calendar-v18.js" asp-append-version="true" defer></script>
<script src="~/js/nexora-country-nationality-link.js" asp-append-version="true"></script>
    <script src="~/js/nexora-setup-modals.js" asp-append-version="true"></script>
    <script src="~/js/nexora-select-system.js" asp-append-version="true"></script>
    <script src="~/js/nexora-employee-updates-accounting-format.js" asp-append-version="true"></script>
</body>
</html>




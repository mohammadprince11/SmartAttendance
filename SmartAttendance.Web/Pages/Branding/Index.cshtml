@page
@model SmartAttendance.Web.Pages.Branding.IndexModel
@{
    ViewData["Title"] = "الهوية والثيم";
    var p = Model.Profile;
}

@section Styles {
    <link rel="stylesheet" href="~/css/zynora-branding-studio.css" asp-append-version="true" />
}

<div class="brand-studio" data-preview-url="@Url.Page("Index", "Preview")">
    @if (TempData["BrandingMessage"] is string message)
    {
        <div class="brand-toast">@message</div>
    }

    <div class="brand-head">
        <div>
            <h1 class="brand-title">الهوية والثيم</h1>
            <p class="brand-sub">صمّم هوية <strong>@Model.CompanyName</strong> — الألوان والشعار — والنظام يولّد الثيم كاملاً تلقائياً.</p>
        </div>
        <span class="brand-status @(Model.PublishedVersionId.HasValue ? "is-live" : "is-default")">
            @(Model.PublishedVersionId.HasValue ? $"منشور · إصدار #{Model.PublishedVersionId}" : "هوية ZYNORA الافتراضية")
        </span>
    </div>

    <form method="post" enctype="multipart/form-data" class="brand-grid">
        @if (Model.EditingVersionId.HasValue)
        {
            <input type="hidden" name="EditingVersionId" value="@Model.EditingVersionId" />
        }
        <section class="brand-panel">
            @if (Model.EditingVersionId.HasValue)
            {
                <div class="brand-editing-banner">
                    <span>تعدّل الإصدار #@Model.EditingVersionId — الحفظ يحدّثه في مكانه.</span>
                    <a asp-page="Index" class="brand-editing-cancel">إلغاء التعديل</a>
                </div>
            }
            <h2 class="brand-panel-title">ألوان الهوية</h2>

            <div class="brand-field">
                <label>الاسم المعروض</label>
                <input type="text" name="DisplayName" value="@p.DisplayName" placeholder="@Model.CompanyName" class="brand-input" />
            </div>

            <div class="brand-colors">
                @{
                    var swatches = new[]
                    {
                        ("PrimaryHex", "اللون الرئيسي", string.IsNullOrWhiteSpace(p.PrimaryHex) ? SmartAttendance.Web.Pages.Branding.IndexModel.DefaultPrimary : p.PrimaryHex),
                        ("SecondaryHex", "اللون الثانوي", string.IsNullOrWhiteSpace(p.SecondaryHex) ? SmartAttendance.Web.Pages.Branding.IndexModel.DefaultSecondary : p.SecondaryHex),
                        ("AccentHex", "لون التمييز", string.IsNullOrWhiteSpace(p.AccentHex) ? SmartAttendance.Web.Pages.Branding.IndexModel.DefaultAccent : p.AccentHex),
                    };
                }
                @foreach (var (name, label, value) in swatches)
                {
                    <div class="brand-color" data-color-field="@name">
                        <label>@label</label>
                        <div class="brand-color-row">
                            <input type="color" value="@value" class="brand-color-dot" data-role="picker" />
                            <input type="text" name="@name" value="@value" class="brand-input brand-hex" data-role="hex" maxlength="7" />
                        </div>
                    </div>
                }
            </div>

            <div class="brand-ladder-wrap">
                <span class="brand-ladder-label">سلّم درجات اللون الرئيسي</span>
                <div class="brand-ladder" id="brand-ladder"></div>
            </div>

            <h2 class="brand-panel-title">أصول الهوية</h2>
            <p class="brand-hint">صور نقطية فقط (PNG / JPG، والأيقونة تقبل ICO) — الحد 3MB.</p>

            <div class="brand-uploads">
                <div class="brand-field">
                    <label>الشعار</label>
                    @if (!string.IsNullOrWhiteSpace(p.LogoPath))
                    {
                        <img src="@p.LogoPath" class="brand-asset-preview" alt="logo" />
                    }
                    <input type="file" name="LogoFile" accept="image/png,image/jpeg" class="brand-file" />
                </div>
                <div class="brand-field">
                    <label>أيقونة المتصفح (favicon)</label>
                    @if (!string.IsNullOrWhiteSpace(p.FaviconPath))
                    {
                        <img src="@p.FaviconPath" class="brand-asset-preview brand-asset-small" alt="favicon" />
                    }
                    <input type="file" name="FaviconFile" accept="image/png,image/x-icon,.ico" class="brand-file" />
                </div>
                <div class="brand-field">
                    <label>خلفية شاشة الدخول</label>
                    @if (!string.IsNullOrWhiteSpace(p.LoginBackgroundPath))
                    {
                        <img src="@p.LoginBackgroundPath" class="brand-asset-preview" alt="login background" />
                    }
                    <input type="file" name="LoginBackgroundFile" accept="image/png,image/jpeg" class="brand-file" />
                </div>
            </div>

            <div class="brand-actions">
                <button type="submit" asp-page-handler="SaveDraft" class="brand-btn brand-btn-ghost">حفظ كمسودّة</button>
                <button type="submit" asp-page-handler="Publish" class="brand-btn brand-btn-primary">
                    @(Model.EditingVersionId.HasValue ? "حفظ ونشر التعديل" : "نشر الهوية")
                </button>
                @if (Model.PublishedVersionId.HasValue)
                {
                    <button type="submit" asp-page-handler="Reset" class="brand-btn brand-btn-ghost">العودة للافتراضي</button>
                }
            </div>
        </section>

        <section class="brand-panel">
            <h2 class="brand-panel-title">معاينة حيّة</h2>
            <div class="brand-validation" id="brand-validation"></div>

            <div class="brand-preview" id="brand-preview">
                <div class="bp-shell">
                    <div class="bp-nav" id="bp-nav">
                        <span class="bp-nav-item is-active" role="button" tabindex="0"
                              data-bp-view="dashboard"
                              data-bp-title="لوحة البيانات" data-bp-text="نظرة عامة على المؤشرات بهويتك الجديدة.">لوحة البيانات</span>
                        <span class="bp-nav-item" role="button" tabindex="0"
                              data-bp-view="employees"
                              data-bp-title="الموظفون" data-bp-text="قائمة الموظفين والإجراءات بهويتك الجديدة.">الموظفون</span>
                        <span class="bp-nav-item" role="button" tabindex="0"
                              data-bp-view="attendance"
                              data-bp-title="الحضور" data-bp-text="سجلّ الحضور والانصراف بهويتك الجديدة.">الحضور</span>
                    </div>
                    <div class="bp-body">
                        <div class="bp-card">
                            <div class="bp-card-title" id="bp-card-title">لوحة البيانات</div>
                            <p class="bp-card-text" id="bp-card-text">نظرة عامة على المؤشرات بهويتك الجديدة.</p>

                            @* Dashboard: KPI tiles *@
                            <div class="bp-view" data-bp-view="dashboard">
                                <div class="bp-kpis">
                                    <div class="bp-kpi">
                                        <span class="bp-kpi-num">1,357</span>
                                        <span class="bp-kpi-label">إجمالي الموظفين</span>
                                    </div>
                                    <div class="bp-kpi">
                                        <span class="bp-kpi-num">92%</span>
                                        <span class="bp-kpi-label">نسبة الحضور</span>
                                    </div>
                                    <div class="bp-kpi">
                                        <span class="bp-kpi-num">34</span>
                                        <span class="bp-kpi-label">طلبات معلّقة</span>
                                    </div>
                                </div>
                            </div>

                            @* Employees: list rows *@
                            <div class="bp-view" data-bp-view="employees" hidden>
                                <div class="bp-list">
                                    <div class="bp-emp">
                                        <span class="bp-avatar">أ</span>
                                        <span class="bp-emp-info">
                                            <span class="bp-emp-name">أحمد الرشيد</span>
                                            <span class="bp-emp-role">محاسب أول</span>
                                        </span>
                                        <span class="bp-chip bp-chip-success">نشط</span>
                                    </div>
                                    <div class="bp-emp">
                                        <span class="bp-avatar">س</span>
                                        <span class="bp-emp-info">
                                            <span class="bp-emp-name">سارة الحربي</span>
                                            <span class="bp-emp-role">أخصائية موارد</span>
                                        </span>
                                        <span class="bp-chip bp-chip-warning">إجازة</span>
                                    </div>
                                    <div class="bp-emp">
                                        <span class="bp-avatar">م</span>
                                        <span class="bp-emp-info">
                                            <span class="bp-emp-name">محمد العتيبي</span>
                                            <span class="bp-emp-role">فني صيانة</span>
                                        </span>
                                        <span class="bp-chip bp-chip-danger">منتهٍ</span>
                                    </div>
                                </div>
                            </div>

                            @* Attendance: check-in rows *@
                            <div class="bp-view" data-bp-view="attendance" hidden>
                                <div class="bp-list">
                                    <div class="bp-att">
                                        <span class="bp-emp-name">أحمد الرشيد</span>
                                        <span class="bp-att-times">08:02 — 16:10</span>
                                        <span class="bp-chip bp-chip-success">حاضر</span>
                                    </div>
                                    <div class="bp-att">
                                        <span class="bp-emp-name">سارة الحربي</span>
                                        <span class="bp-att-times">09:18 — 16:05</span>
                                        <span class="bp-chip bp-chip-warning">تأخّر</span>
                                    </div>
                                    <div class="bp-att">
                                        <span class="bp-emp-name">محمد العتيبي</span>
                                        <span class="bp-att-times">— : —</span>
                                        <span class="bp-chip bp-chip-danger">غائب</span>
                                    </div>
                                </div>
                            </div>

                            <div class="bp-row">
                                <span class="bp-btn-primary" role="button">إجراء رئيسي</span>
                                <span class="bp-btn-soft" role="button">ثانوي</span>
                                <span class="bp-badge">شارة</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </form>

    @if (Model.Versions.Count > 0)
    {
        <section class="brand-panel brand-history">
            <h2 class="brand-panel-title">سجلّ الإصدارات</h2>
            <table class="brand-table">
                <thead>
                    <tr><th>#</th><th>الحالة</th><th>الفحص</th><th>أُنشئ</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Versions)
                    {
                        <tr class="@(v.Status == SmartAttendance.Web.Infrastructure.Theming.ThemeStore.StatusPublished ? "is-published" : "")">
                            <td>@v.Id</td>
                            <td><span class="brand-vstatus v-@v.Status.ToLowerInvariant()">@VersionLabel(v.Status)</span></td>
                            <td>@v.ValidationLevel</td>
                            <td>@v.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="brand-row-actions">
                                @if (v.Status != SmartAttendance.Web.Infrastructure.Theming.ThemeStore.StatusPublished
                                    && v.Status != SmartAttendance.Web.Infrastructure.Theming.ThemeStore.StatusRejected)
                                {
                                    <form method="post" asp-page-handler="Rollback" class="brand-inline-form">
                                        <input type="hidden" name="versionId" value="@v.Id" />
                                        <button type="submit" class="brand-btn brand-btn-mini">استرجاع</button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="EditVersion" class="brand-inline-form">
                                    <input type="hidden" name="versionId" value="@v.Id" />
                                    <button type="submit" class="brand-btn brand-btn-mini">تعديل</button>
                                </form>
                                <form method="post" asp-page-handler="DeleteVersion" class="brand-inline-form">
                                    <input type="hidden" name="versionId" value="@v.Id" />
                                    <button type="submit" class="brand-btn brand-btn-mini brand-btn-danger" data-zyconfirm="تأكيد الحذف؟">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
</div>

@functions {
    private static string VersionLabel(string status) => status switch
    {
        "Published" => "منشور",
        "Validated" => "جاهز",
        "Archived" => "مؤرشف",
        "Rejected" => "مرفوض",
        _ => "مسودّة",
    };
}

@section Scripts {
    <script src="~/js/zynora-branding-studio.js" asp-append-version="true"></script>
}

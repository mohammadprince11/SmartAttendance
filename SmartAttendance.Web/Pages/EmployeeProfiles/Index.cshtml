@model SmartAttendance.Web.Pages.EmployeeProfiles.IndexModel
@{
    ViewData["Title"] = "عمليات الموارد البشرية";
    var tab = Model.Tab;
    var templateOrder = new[] { "holiday", "circular", "workhours", "welcome", "promotion", "appreciation", "marriage", "condolence" };
    var templates = templateOrder
        .Select(k => Model.AnnouncementTemplates.FirstOrDefault(t => t.Key.Equals(k, System.StringComparison.OrdinalIgnoreCase)))
        .Where(t => t != null)
        .ToList();
    var templateGroupMap = new Dictionary<string, string>(System.StringComparer.OrdinalIgnoreCase)
    {
        ["holiday"] = "official",
        ["circular"] = "official",
        ["workhours"] = "official",
        ["welcome"] = "employees",
        ["promotion"] = "employees",
        ["appreciation"] = "recognition",
        ["marriage"] = "occasions",
        ["condolence"] = "occasions"
    };
    var templateGroupLabels = new Dictionary<string, string>(System.StringComparer.OrdinalIgnoreCase)
    {
        ["all"] = "الكل",
        ["official"] = "رسمي",
        ["employees"] = "موظفون",
        ["recognition"] = "تكريم",
        ["occasions"] = "مناسبات"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/nexora-announcement-studio-dynamic.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nexora-hr-operations-page.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/nexora-announcement-studio-dynamic.js" asp-append-version="true"></script>
    <script>
        (() => {
            const root = document.getElementById("nxApprovedAnnouncementStudio");
            const picker = root?.querySelector("[data-ann-date-picker]");
            const hidden = root?.querySelector('[data-ann-field="date"]');

            if (!root || !picker || !hidden) {
                return;
            }

            const displayToIso = (value) => {
                const text = (value || "").trim();

                let match = text.match(/^(\\d{2})\\/(\\d{2})\\/(\\d{4})$/);

                if (match) {
                    return `${match[3]}-${match[2]}-${match[1]}`;
                }

                match = text.match(/^(\\d{4})-(\\d{2})-(\\d{2})$/);

                return match ? text : "";
            };

            const isoToDisplay = (value) => {
                const match = (value || "").match(
                    /^(\\d{4})-(\\d{2})-(\\d{2})$/
                );

                return match
                    ? `${match[3]}/${match[2]}/${match[1]}`
                    : "";
            };

            const syncPickerFromHidden = () => {
                const nextValue = displayToIso(hidden.value);

                if (picker.value !== nextValue) {
                    picker.value = nextValue;
                    picker.dispatchEvent(
                        new Event("change", { bubbles: false })
                    );
                }
            };

            const syncHiddenFromPicker = () => {
                hidden.value = isoToDisplay(picker.value);
                hidden.dataset.auto = "false";
                hidden.dispatchEvent(
                    new Event("input", { bubbles: true })
                );
            };

            picker.addEventListener("input", syncHiddenFromPicker);
            picker.addEventListener("change", syncHiddenFromPicker);

            const scheduleSync = () => {
                window.requestAnimationFrame(syncPickerFromHidden);
            };

            root.addEventListener("click", scheduleSync);
            root.addEventListener("change", scheduleSync);
            root.addEventListener("input", (event) => {
                if (event.target !== picker) {
                    scheduleSync();
                }
            });

            syncPickerFromHidden();
        })();
    </script>
}

<section class="nx-approved-page nx-approved-page--@tab" dir="rtl">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="nx-approved-alert">@Model.StatusMessage</div>
    }

    <header class="nx-approved-header">
        <div class="nx-approved-title-icon" aria-hidden="true">HR</div>
        <div class="nx-approved-title">
            <span class="nx-approved-eyebrow">NEXORA PEOPLE OPERATIONS</span>
            <h1>عمليات الموارد البشرية</h1>
            <p>مركز موحّد للتواصل وصوت الموظف والحالات والمجتمع والتقدير والحملات.</p>
        </div>
        <nav class="nx-approved-tabs" aria-label="أقسام عمليات الموارد البشرية">
            <a class="@(tab == "overview" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="overview">نظرة عامة</a>
            <a class="@(tab == "announcements" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements">التواصل</a>
            <a class="@(tab == "polls" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="polls">صوت الموظف</a>
            <a class="@(tab == "feedback" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="feedback">الحالات</a>
            <a class="@(tab == "wall" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="wall">المجتمع</a>
            <a class="@(tab == "recognition" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="recognition">التقدير</a>
            <a class="@(tab == "campaigns" ? "active" : "")" asp-page="./Index" asp-route-section="engagement" asp-route-tab="campaigns">الحملات</a>
        </nav>
    </header>

    @if (tab == "overview")
    {
        <section class="nx-ops-overview" aria-label="لوحة عمليات الموارد البشرية">
            <section class="nx-ops-kpi-grid">
                <article class="nx-ops-kpi cyan">
                    <span>المحتوى النشط</span>
                    <strong>@Model.ActivePeopleOperationsItems</strong>
                    <small>@Model.PublishedAnnouncements إعلان · @Model.PublishedPolls استطلاع</small>
                </article>
                <article class="nx-ops-kpi gold">
                    <span>الإعلانات</span>
                    <strong>@Model.TotalAnnouncements</strong>
                    <small>@Model.PublishedAnnouncements منشور · @Model.DraftAnnouncements مسودة</small>
                </article>
                <article class="nx-ops-kpi violet">
                    <span>صوت الموظف</span>
                    <strong>@Model.TotalPollVotes</strong>
                    <small>@Model.TotalPolls استطلاع · إجمالي الأصوات المسجلة</small>
                </article>
                <article class="nx-ops-kpi rose">
                    <span>الحالات المفتوحة</span>
                    <strong>@Model.OpenPeopleCases</strong>
                    <small>@Model.TotalFeedback إجمالي الشكاوى والمقترحات</small>
                </article>
            </section>

            <section class="nx-ops-command-grid">
                <article class="nx-ops-command-card">
                    <header>
                        <div>
                            <span class="nx-ops-label">إجراءات سريعة</span>
                            <h2>ابدأ عملية جديدة</h2>
                        </div>
                        <span class="nx-ops-status-dot live">مباشر</span>
                    </header>
                    <div class="nx-ops-quick-actions">
                        <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements">إنشاء إعلان</a>
                        <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="polls">إنشاء استطلاع</a>
                        <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="appreciation">تكريم موظف</a>
                        <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="campaigns">إطلاق حملة</a>
                    </div>
                </article>

                <article class="nx-ops-command-card nx-ops-health">
                    <header>
                        <div>
                            <span class="nx-ops-label">حالة المركز</span>
                            <h2>ملخص التشغيل الحالي</h2>
                        </div>
                        <span class="nx-ops-health-score">@Model.ActivePeopleOperationsItems</span>
                    </header>
                    <div class="nx-ops-health-list">
                        <div><span>إعلانات منشورة</span><strong>@Model.PublishedAnnouncements</strong></div>
                        <div><span>استبيانات منشورة</span><strong>@Model.PublishedPolls</strong></div>
                        <div><span>حالات بانتظار المعالجة</span><strong>@Model.OpenPeopleCases</strong></div>
                        <div><span>إجمالي التفاعلات المسجلة</span><strong>@Model.TotalPollVotes</strong></div>
                    </div>
                </article>
            </section>

            <section class="nx-ops-module-grid">
                <a class="nx-ops-module-card communication" asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements">
                    <span>01</span><strong>التواصل والإعلانات</strong><small>قوالب جاهزة، نشر مباشر، واستهداف الموظفين.</small>
                </a>
                <a class="nx-ops-module-card voice" asp-page="./Index" asp-route-section="engagement" asp-route-tab="polls">
                    <span>02</span><strong>صوت الموظف</strong><small>استبيانات وانتخابات ومتابعة المشاركة الفعلية.</small>
                </a>
                <a class="nx-ops-module-card cases" asp-page="./Index" asp-route-section="engagement" asp-route-tab="feedback">
                    <span>03</span><strong>الحالات</strong><small>الشكاوى والمقترحات والردود وحالة المعالجة.</small>
                </a>
                <a class="nx-ops-module-card community" asp-page="./Index" asp-route-section="engagement" asp-route-tab="wall">
                    <span>04</span><strong>المجتمع</strong><small>المحتوى المنشور الذي يظهر في حائط الموظفين.</small>
                </a>
                <a class="nx-ops-module-card recognition" asp-page="./Index" asp-route-section="engagement" asp-route-tab="recognition">
                    <span>05</span><strong>التقدير والإنجازات</strong><small>ترقيات وشكر وتقدير وترحيب بالموظفين.</small>
                </a>
                <a class="nx-ops-module-card campaigns" asp-page="./Index" asp-route-section="engagement" asp-route-tab="campaigns">
                    <span>06</span><strong>الحملات والمناسبات</strong><small>عطل وتعاميم وتغيير دوام وحملات داخلية.</small>
                </a>
            </section>

            <section class="nx-ops-activity-grid">
                <article class="nx-ops-activity-card">
                    <header><h2>أحدث الإعلانات</h2><a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements">عرض الكل</a></header>
                    @if (Model.Announcements.Count == 0)
                    {
                        <div class="nx-ops-empty">لا توجد إعلانات بعد.</div>
                    }
                    @foreach (var item in Model.Announcements.Take(4))
                    {
                        <div class="nx-ops-activity-row">
                            <span class="@(item.IsPublished ? "live" : "draft")">@Model.PublishText(item.IsPublished)</span>
                            <div><strong>@item.Title</strong><small>@item.Category · @Model.DisplayDate(item.PublishDate)</small></div>
                        </div>
                    }
                </article>

                <article class="nx-ops-activity-card">
                    <header><h2>أحدث الاستبيانات</h2><a asp-page="./Index" asp-route-section="engagement" asp-route-tab="polls">عرض الكل</a></header>
                    @if (Model.Polls.Count == 0)
                    {
                        <div class="nx-ops-empty">لا توجد استطلاعات بعد.</div>
                    }
                    @foreach (var item in Model.Polls.Take(4))
                    {
                        <div class="nx-ops-activity-row">
                            <span class="@(item.IsPublished ? "live" : "draft")">@Model.PublishText(item.IsPublished)</span>
                            <div><strong>@item.Title</strong><small>@item.VotesCount تصويت · @Model.TargetText(item)</small></div>
                        </div>
                    }
                </article>

                <article class="nx-ops-activity-card">
                    <header><h2>أحدث الحالات</h2><a asp-page="./Index" asp-route-section="engagement" asp-route-tab="feedback">عرض الكل</a></header>
                    @if (Model.FeedbackItems.Count == 0)
                    {
                        <div class="nx-ops-empty">لا توجد حالات بعد.</div>
                    }
                    @foreach (var item in Model.FeedbackItems.Take(4))
                    {
                        <div class="nx-ops-activity-row">
                            <span class="@Model.StatusClass(item.Status)">@Model.StatusText(item.Status)</span>
                            <div><strong>@item.Title</strong><small>@item.Type · @item.EmployeeName</small></div>
                        </div>
                    }
                </article>
            </section>
        </section>
    }
    else if (tab == "announcements")
    {
        <section class="nx-ann-studio" id="nxApprovedAnnouncementStudio">
            <section class="nx-template-strip" aria-labelledby="nxAnnouncementTemplateTitle">
                <div class="nx-section-heading nx-template-heading">
                    <div>
                        <span>مكتبة التواصل</span>
                        <h2 id="nxAnnouncementTemplateTitle">قوالب الإعلانات الجاهزة</h2>
                    </div>
                    <div class="nx-template-heading__aside">
                        <span class="nx-template-count"><b>@templates.Count</b> قوالب احترافية</span>
                        <small>مكتبة فاخرة ومنظمة: اختر الفئة ثم القالب، وستتحدث المعاينة والحقول تلقائياً مع بقاء النص قابلاً للتعديل.</small>
                    </div>
                </div>

                <div class="nx-template-toolbar">
                    <div class="nx-template-filter-group" role="toolbar" aria-label="تصفية قوالب الإعلانات">
                        <button type="button" class="nx-template-filter active" data-ann-filter="all">الكل</button>
                        <button type="button" class="nx-template-filter" data-ann-filter="official">رسمي</button>
                        <button type="button" class="nx-template-filter" data-ann-filter="employees">موظفون</button>
                        <button type="button" class="nx-template-filter" data-ann-filter="recognition">تكريم</button>
                        <button type="button" class="nx-template-filter" data-ann-filter="occasions">مناسبات</button>
                    </div>
                    <div class="nx-template-toolbar__aside">
                        <span class="nx-template-toolbar__hint">اسحب المكتبة أو استخدم الأسهم للتنقل بين القوالب.</span>
                        <div class="nx-template-scroll-actions" aria-label="التنقل بين القوالب">
                            <button type="button" class="nx-template-scroll-action" data-ann-template-scroll="prev" aria-label="القوالب السابقة">&#x203A;</button>
                            <button type="button" class="nx-template-scroll-action" data-ann-template-scroll="next" aria-label="القوالب التالية">&#x2039;</button>
                        </div>
                    </div>
                </div>

                <div class="nx-template-grid-shell">
                    <div class="nx-template-grid" role="radiogroup" aria-label="اختيار قالب الإعلان" data-ann-template-grid>
                        @foreach (var template in templates)
                        {
                            var checkedTemplate = template!.Key.Equals("holiday", System.StringComparison.OrdinalIgnoreCase);
                            var templateGroup = templateGroupMap.TryGetValue(template.Key, out var groupKey)
                                ? groupKey
                                : "official";
                            var templateGroupLabel = templateGroupLabels.TryGetValue(templateGroup, out var groupLabel)
                                ? groupLabel
                                : template.Category;
                            <label class="nx-template-card @(checkedTemplate ? "active" : "") @template.CssClass nx-template-card--@template.Key"
                                   data-ann-template-card="@template.Key"
                                   data-ann-template-group="@templateGroup"
                                   role="radio"
                                   aria-checked="@(checkedTemplate ? "true" : "false")"
                                   title="@template.Name">
                                @if (checkedTemplate)
                                {
                                    <input form="nxAnnCreateForm" type="radio" name="Announcement.TemplateKey" value="@template.Key" aria-label="@template.Name" checked />
                                }
                                else
                                {
                                    <input form="nxAnnCreateForm" type="radio" name="Announcement.TemplateKey" value="@template.Key" aria-label="@template.Name" />
                                }

                                <span class="nx-template-card__glow" aria-hidden="true"></span>

                                <span class="nx-template-card__visual" aria-hidden="true">
                                    <img src="@Url.Content("~/brand/announcement-studio/cards/" + template.AssetKey + ".png")" alt="" />
                                    <span class="nx-template-card__shade"></span>
                                    <span class="nx-template-card__topline">
                                        <span class="nx-template-card__group">@templateGroupLabel</span>
                                        <span class="nx-template-card__icon">@template.Icon</span>
                                    </span>
                                    <span class="nx-template-card__hero-copy">
                                        <small>@template.Category</small>
                                        <strong>@template.Name</strong>
                                    </span>
                                </span>

                                <span class="nx-template-card__content">
                                    <span class="nx-template-card__meta">
                                        <span>@template.Category</span>
                                        <span>جاهز للتعديل</span>
                                    </span>
                                    <small>@template.Description</small>
                                </span>

                                <span class="nx-template-card__check" aria-hidden="true">
                                    <i>✓</i>
                                    <em>محدد</em>
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </section>

            <section class="nx-main-grid">
                <section class="nx-preview-panel">
                    <header class="nx-card-head">
                        <div>
                            <h2>معاينة الإعلان</h2>
                            <p>المعاينة ديناميكية: العنوان والوصف والاسم والتاريخ تظهر من الحقول مباشرة.</p>
                        </div>
                        <span class="nx-mini-pill">👁 مباشر</span>
                    </header>

                    <div class="nx-preview-stage">
                        <button type="button" class="nx-arrow nx-arrow-right" data-ann-step="prev" data-nexora-hover="off" aria-label="القالب السابق">‹</button>

                        <article class="nx-live-card holiday" id="nxLiveAnnouncementCard">
                            <div class="nx-live-art">
                                <img id="nxLiveArtImage" src="@Url.Content("~/brand/announcement-studio/art/holiday.png")" alt="Artwork" />
                            </div>

                            <div class="nx-live-copy">
                                <span id="nxLiveCategory">عطلة رسمية</span>
                                <small id="nxLivePreTitle">بمناسبة المناسبة الوطنية</small>
                                <h2 id="nxLiveTitle">عطلة رسمية</h2>
                                <p id="nxLiveBody">تعلن إدارة الموارد البشرية أن الدوام سيكون متوقفاً يوم الخميس الموافق 15 أيار 2026</p>
                                <strong id="nxLiveDate">15/05/2026</strong>
                                <em id="nxLiveFooter">قسم الموارد البشرية</em>
                            </div>
                        </article>

                        <button type="button" class="nx-arrow nx-arrow-left" data-ann-step="next" data-nexora-hover="off" aria-label="القالب التالي">›</button>
                    </div>

                    <div class="nx-thumb-row">
                        @foreach (var template in templates)
                        {
                            <button type="button" class="nx-thumb @(template!.Key == "holiday" ? "active" : "")" data-ann-template-button="@template.Key" title="@template.Name">
                                <img src="@Url.Content("~/brand/announcement-studio/thumbs/" + template.AssetKey + ".png")" alt="@template.Name" />
                            </button>
                        }
                    </div>

                    <div class="nx-dots">
                        @for (var i = 0; i < templates.Count; i++)
                        {
                            <i class="@(templates[i]!.Key == "holiday" ? "active" : "")"></i>
                        }
                    </div>
                </section>

                <section class="nx-create-panel">
                    <header class="nx-card-head">
                        <div>
                            <h2>إنشاء إعلان</h2>
                            <p>استخدم القالب الجاهز أو اكتب إعلان مخصص.</p>
                        </div>
                        <span class="nx-mini-pill gold">إنشاء</span>
                    </header>

                    <form id="nxAnnCreateForm" method="post" asp-page-handler="CreateAnnouncement" class="nx-form">
                        <div class="nx-mode-tabs">
                            <label data-ann-mode-tab="Template">
                                <input name="Announcement.UseTemplateMode" type="radio" value="Template" checked data-ann-mode="Template" />
                                <span>باستخدام قالب جاهز</span>
                            </label>
                            <label data-ann-mode-tab="Custom">
                                <input name="Announcement.UseTemplateMode" type="radio" value="Custom" data-ann-mode="Custom" />
                                <span>تصميم مخصص / نص حر</span>
                            </label>
                        </div>

                        <div class="nx-custom-help" data-ann-custom-help>
                            في التصميم المخصص، اكتب العنوان والوصف بنفسك بدون استخدام قوالب ثابتة. المعاينة تتحدث مباشرة من النص الذي تكتبه.
                        </div>

                        <div class="nx-form-row">
                            <div class="nx-field">
                                <label>العنوان *</label>
                                <input name="Announcement.Title" data-ann-field="title" value="عطلة رسمية" placeholder="مثال: تهنئة بمناسبة الترقية" />
                            </div>
                            <div class="nx-field">
                                <label>نوع القالب *</label>
                                <select name="Announcement.TemplateKey" data-ann-field="template" data-ann-template-select>
                                    @foreach (var template in Model.AnnouncementTemplates)
                                    {
                                        if (template.Key == "holiday")
                                        {
                                            <option value="@template.Key" selected>@template.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@template.Key">@template.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="nx-form-row">
                            <div class="nx-field">
                                <label>الفئة *</label>
                                <select name="Announcement.Category" data-ann-field="category">
                                    <option value="عام">عام</option>
                                    <option value="تعميم إداري">تعميم إداري</option>
                                    <option value="تعليمات">تعليمات</option>
                                    <option value="شكر وتقدير">شكر وتقدير</option>
                                    <option value="تهنئة">تهنئة</option>
                                    <option value="تعزية">تعزية</option>
                                    <option value="عطلة رسمية" selected>عطلة رسمية</option>
                                    <option value="ترحيب">ترحيب</option>
                                    <option value="وداع">وداع</option>
                                </select>
                            </div>
                            <div class="nx-field">
                                <label>التوجيه *</label>
                                <select name="Announcement.TargetType">
                                    <option value="All" selected>جميع الموظفين</option>
                                    <option value="Employee">موظفون محددون</option>
                                    <option value="Department">قسم محدد</option>
                                    <option value="Branch">فرع محدد</option>
                                </select>
                            </div>
                        </div>

                        <div class="nx-field">
                            <label>الوصف *</label>
                            <textarea name="Announcement.Body" data-ann-field="body">تعلن إدارة الموارد البشرية أن الدوام سيكون متوقفاً يوم الخميس الموافق 15 أيار 2026</textarea>
                        </div>

                        <div class="nx-form-row">
                            <div class="nx-field">
                                <label>اسم الموظف / الشخص المعني</label>
                                <input name="Announcement.PersonName" data-ann-field="person" placeholder="مثال: محمد علي زيدان" />
                            </div>
                            <div class="nx-field">
                                <label>معلومة إضافية</label>
                                <input name="Announcement.SecondaryName" data-ann-field="secondary" placeholder="مثال: المنصب، اسم المولود، جهة التواصل" />
                            </div>
                        </div>

                        <div class="nx-form-row">
                            <div class="nx-field">
                                <label>القسم / الجهة</label>
                                <input name="Announcement.DepartmentName" data-ann-field="department" value="قسم الموارد البشرية" placeholder="مثال: قسم الموارد البشرية" />
                            </div>
                            <div class="nx-field">
                                <label>التاريخ / المناسبة</label>
                                <input type="date"
                                       id="nxAnnouncementDatePicker"
                                       data-ann-date-picker
                                       value="2026-05-15"
                                       aria-label="التاريخ أو المناسبة" />
                                <input type="hidden"
                                       name="Announcement.EffectiveDateText"
                                       data-ann-field="date"
                                       value="15/05/2026" />
                            </div>
                        </div>

                        <div class="nx-form-row">
                            <div class="nx-field">
                                <label>القسم</label>
                                <select name="Announcement.DepartmentId">
                                    <option value="">اختر قسم</option>
                                    @foreach (var department in Model.Departments)
                                    {
                                        <option value="@department.Id">@department.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="nx-field">
                                <label>الفرع</label>
                                <select name="Announcement.BranchId">
                                    <option value="">اختر فرع</option>
                                    @foreach (var branch in Model.Branches)
                                    {
                                        <option value="@branch.Id">@branch.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <details class="nx-employee-picker">
                            <summary>الموظفون المحددون <span>يستخدم عند اختيار توجيه موظفين محددين</span></summary>
                            <div class="nx-employee-grid">
                                @foreach (var employee in Model.Employees)
                                {
                                    <label>
                                        <input type="checkbox" name="Announcement.EmployeeIds" value="@employee.Id" />
                                        <strong>@employee.FullName</strong>
                                        <small>@employee.EmployeeNo</small>
                                    </label>
                                }
                            </div>
                        </details>

                        <div class="nx-form-footer">
                            <label class="nx-check">
                                <input name="Announcement.PublishNow" type="checkbox" value="true" checked />
                                <input name="Announcement.PublishNow" type="hidden" value="false" />
                                <span>نشر الإعلان الآن</span>
                            </label>
                            <div class="nx-actions">
                                <button type="button" class="nx-btn preview" data-ann-preview-button>تحديث المعاينة</button>
                                <button type="submit" class="nx-btn publish">إنشاء ونشر الإعلان</button>
                            </div>
                        </div>
                    </form>
                </section>
            </section>

            <section class="nx-recent-panel">
                <header class="nx-card-head">
                    <div>
                        <h2>آخر الإعلانات</h2>
                        <p>إدارة الإعلانات المنشورة والمسودات ومراجعة التوجيهات.</p>
                    </div>
                    <div class="nx-table-tools">
                        <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements">عرض الكل</a>
                        <span>فلترة</span>
                    </div>
                </header>

                <div class="nx-table-wrap">
                    <table class="nx-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>العنوان</th>
                                <th>الفئة</th>
                                <th>التوجيه</th>
                                <th>تاريخ النشر</th>
                                <th>نشر بواسطة</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Announcements.Count == 0)
                            {
                                <tr><td colspan="8" class="nx-empty">لا توجد إعلانات حالياً.</td></tr>
                            }
                            @{
                                var rowNo = 1;
                            }
                            @foreach (var item in Model.Announcements)
                            {
                                var rowTemplate = Model.AnnouncementTemplates.FirstOrDefault(x => x.Key.Equals(item.TemplateKey ?? "custom", System.StringComparison.OrdinalIgnoreCase));
                                var rowIcon = rowTemplate?.Icon ?? "📣";
                                <tr>
                                    <td>@rowNo</td>
                                    <td>
                                        <div class="nx-title-cell">
                                            <span>@rowIcon</span>
                                            <div>
                                                <strong>@item.Title</strong>
                                                <small>@item.Body</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="nx-badge neutral">@item.Category</span></td>
                                    <td>@Model.TargetText(item)</td>
                                    <td>@Model.DisplayDate(item.PublishDate)</td>
                                    <td>@item.CreatedBy</td>
                                    <td><span class="nx-badge @(item.IsPublished ? "published" : "draft")">@Model.PublishText(item.IsPublished)</span></td>
                                    <td>
                                        <div class="nx-row-actions">
                                            <form method="post" asp-page-handler="ToggleAnnouncement" asp-route-id="@item.Id" asp-route-publish="@(!item.IsPublished)">
                                                <button type="submit">@(item.IsPublished ? "مسودة" : "نشر")</button>
                                            </form>
                                            <form method="post" asp-page-handler="DeleteAnnouncement" asp-route-id="@item.Id" onsubmit="return confirm('هل تريد حذف الإعلان؟');">
                                                <button type="submit" class="danger">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                rowNo++;
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </section>
    }

    else if (tab == "polls")
    {
        <section class="nx-pulse-studio" id="nxEmployeePulseStudio">
            <header class="nx-pulse-hero">
                <div class="nx-pulse-title">
                    <span>EMPLOYEE PULSE STUDIO</span>
                    <h1>نبض الموظفين</h1>
                    <p>أنشئ استبيانات وقياس نبض الموظفين، انتخابات داخلية، وتحليل فوري لمستوى الرضا.</p>
                </div>
                <div class="nx-pulse-score">
                    <span>مؤشر نبض الموظفين</span>
                    <strong>78%</strong>
                    <small>نبض عام جيد</small>
                </div>
            </header>

            <section class="nx-pulse-template-panel">
                <div class="nx-pulse-section-title">
                    <div>
                        <span>قوالب جاهزة</span>
                        <h2>اختر نوع الاستبيان</h2>
                    </div>
                    <small>القالب يغيّر طريقة العرض والأسئلة المقترحة فقط. يمكنك تعديل النص والخيارات.</small>
                </div>

                <div class="nx-pulse-template-grid">
                    <label class="nx-pulse-template active" data-pulse-template="satisfaction">
                        <input type="radio" name="PulseTemplate" value="satisfaction" checked />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/satisfaction.png")" alt="رضا الموظفين" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="workplace">
                        <input type="radio" name="PulseTemplate" value="workplace" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/workplace.png")" alt="بيئة العمل" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="supervisor">
                        <input type="radio" name="PulseTemplate" value="supervisor" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/supervisor.png")" alt="تقييم المشرف" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="transport">
                        <input type="radio" name="PulseTemplate" value="transport" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/transport.png")" alt="النقل والسكن" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="meals">
                        <input type="radio" name="PulseTemplate" value="meals" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/meals.png")" alt="الوجبات" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="employee_month">
                        <input type="radio" name="PulseTemplate" value="employee_month" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/employee_month.png")" alt="موظف الشهر" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="ideas">
                        <input type="radio" name="PulseTemplate" value="ideas" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/ideas.png")" alt="اقتراحات تحسين" />
                    </label>
                    <label class="nx-pulse-template" data-pulse-template="custom">
                        <input type="radio" name="PulseTemplate" value="custom" />
                        <img src="@Url.Content("~/brand/pulse-studio/templates/custom.png")" alt="تصميم مخصص" />
                    </label>
                </div>
            </section>

            <section class="nx-pulse-main-grid">
                <section class="nx-pulse-phone-panel">
                    <header class="nx-pulse-card-head">
                        <div>
                            <h2>معاينة الاستطلاع كما يراه الموظف</h2>
                            <p>المعاينة تتغير مباشرة حسب العنوان والسؤال والخيارات.</p>
                        </div>
                        <span class="nx-pulse-pill">👁 مباشر</span>
                    </header>

                    <div class="nx-phone-stage">
                        <button type="button" class="nx-pulse-arrow nx-pulse-arrow-right">‹</button>

                        <article class="nx-phone-preview">
                            <div class="nx-phone-top"></div>
                            <div class="nx-phone-content">
                                <span id="nxPulseStep">سؤال 1/1</span>
                                <h3 id="nxPulseQuestion">ما مدى رضاك عن بيئة العمل في شركتنا؟</h3>
                                <p id="nxPulseDescription">اختر التقييم الذي يعبر عن رأيك</p>

                                <div class="nx-pulse-faces" id="nxPulseFaces">
                                    <button type="button"><strong>😡</strong><small>غير راض إطلاقاً</small></button>
                                    <button type="button"><strong>☹️</strong><small>غير راض</small></button>
                                    <button type="button"><strong>😐</strong><small>محايد</small></button>
                                    <button type="button"><strong>🙂</strong><small>راض</small></button>
                                    <button type="button"><strong>😀</strong><small>راض جداً</small></button>
                                </div>

                                <textarea readonly placeholder="اكتب تعليقك اختياري"></textarea>
                                <button type="button" class="nx-phone-submit">إرسال الإجابة</button>
                                <div class="nx-phone-lock">🔒 هذا الاستطلاع سري<br />لن تظهر أسماء في النتائج</div>
                            </div>
                        </article>

                        <button type="button" class="nx-pulse-arrow nx-pulse-arrow-left">›</button>
                    </div>
                </section>

                <section class="nx-pulse-score-panel">
                    <header class="nx-pulse-card-head">
                        <div>
                            <h2>مؤشر صوت الموظف</h2>
                            <p>المؤشرات أدناه مرتبطة بالاستطلاعات والتصويتات المسجلة فعلياً.</p>
                        </div>
                        <span class="nx-pulse-pill">⚡ LIVE DATA</span>
                    </header>

                    <div class="nx-score-body">
                        <div class="nx-score-ring">
                            <strong>@Model.TotalPollVotes</strong>
                            <span>صوت مسجل</span>
                        </div>
                        <div class="nx-score-legend">
                            <div><i class="good"></i><b>@Model.PublishedPolls</b><span>استطلاع منشور</span></div>
                            <div><i class="warn"></i><b>@Model.DraftPolls</b><span>مسودة</span></div>
                            <div><i class="bad"></i><b>@Model.TotalPolls</b><span>إجمالي الاستطلاعات</span></div>
                        </div>
                    </div>

                    <div class="nx-pulse-mini-kpis">
                        <article><strong>@Model.TotalPolls</strong><span>إجمالي الاستطلاعات</span></article>
                        <article><strong>@Model.PublishedPolls</strong><span>منشور حالياً</span></article>
                        <article><strong>@Model.DraftPolls</strong><span>محفوظ كمسودة</span></article>
                        <article><strong>@Model.TotalPollVotes</strong><span>إجمالي الأصوات</span></article>
                    </div>
                </section>

                <section class="nx-pulse-create-panel">
                    <header class="nx-pulse-card-head">
                        <div>
                            <h2>إنشاء استطلاع / انتخاب</h2>
                            <p>استخدم قالب جاهز أو نص مخصص.</p>
                        </div>
                        <span class="nx-pulse-plus">+</span>
                    </header>

                    <form id="nxPulseForm" method="post" asp-page-handler="CreatePoll" class="nx-pulse-form">
                        <div class="nx-pulse-mode">
                            <label>
                                <input type="radio" name="PulseMode" value="template" checked />
                                <span>باستخدام قالب جاهز</span>
                            </label>
                            <label>
                                <input type="radio" name="PulseMode" value="custom" />
                                <span>تصميم مخصص / نص حر</span>
                            </label>
                        </div>

                        <div class="nx-pulse-field">
                            <label>عنوان الاستطلاع *</label>
                            <input name="Poll.Title" data-pulse-field="title" value="استطلاع رضا الموظفين - مايو 2026" placeholder="اكتب عنوان الاستطلاع" />
                        </div>

                        <div class="nx-pulse-field">
                            <label>السؤال *</label>
                            <textarea name="Poll.Question" data-pulse-field="question">ما مدى رضاك عن بيئة العمل في شركتنا؟</textarea>
                        </div>

                        <div class="nx-pulse-field">
                            <label>الخيارات *</label>
                            <textarea name="Poll.OptionsText" data-pulse-field="options">غير راض إطلاقاً&#10;غير راض&#10;محايد&#10;راض&#10;راض جداً</textarea>
                            <small>كل خيار بسطر مستقل. يمكن استخدامها كتقييم، اختيار، أو انتخاب.</small>
                        </div>

                        <div class="nx-pulse-form-row">
                            <div class="nx-pulse-field">
                                <label>نوع الاستطلاع *</label>
                                <select name="Poll.Category" data-pulse-field="category">
                                    <option value="استطلاع" selected>استطلاع</option>
                                    <option value="انتخاب">انتخاب</option>
                                    <option value="تصويت داخلي">تصويت داخلي</option>
                                    <option value="نبض الموظفين">نبض الموظفين</option>
                                </select>
                            </div>
                            <div class="nx-pulse-field">
                                <label>نوع الخصوصية</label>
                                <select name="PulsePrivacy" data-pulse-field="privacy">
                                    <option value="anonymous" selected>سري بدون أسماء</option>
                                    <option value="visible">ظاهر للإدارة بالأسماء</option>
                                </select>
                            </div>
                        </div>

                        <div class="nx-pulse-form-row">
                            <div class="nx-pulse-field">
                                <label>توجيه الاستطلاع إلى *</label>
                                <select name="Poll.TargetType">
                                    <option value="All" selected>جميع الموظفين</option>
                                    <option value="Employee">موظفون محددون</option>
                                    <option value="Department">قسم محدد</option>
                                    <option value="Branch">فرع محدد</option>
                                </select>
                            </div>
                            <div class="nx-pulse-field">
                                <label>الفئة</label>
                                <input name="PulseAudienceLabel" value="رضا الموظفين" data-pulse-field="label" />
                            </div>
                        </div>

                        <details class="nx-pulse-employee-picker">
                            <summary>الموظفون المحددون <span>يفعل عند اختيار موظفون محددون</span></summary>
                            <div class="nx-pulse-employee-grid">
                                @foreach (var employee in Model.Employees)
                                {
                                    <label>
                                        <input type="checkbox" name="Poll.EmployeeIds" value="@employee.Id" />
                                        <strong>@employee.FullName</strong>
                                        <small>@employee.EmployeeNo</small>
                                    </label>
                                }
                            </div>
                        </details>

                        <div class="nx-pulse-form-row">
                            <div class="nx-pulse-field">
                                <label>القسم</label>
                                <select name="Poll.DepartmentId">
                                    <option value="">اختر قسم</option>
                                    @foreach (var department in Model.Departments)
                                    {
                                        <option value="@department.Id">@department.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="nx-pulse-field">
                                <label>الفرع</label>
                                <select name="Poll.BranchId">
                                    <option value="">اختر فرع</option>
                                    @foreach (var branch in Model.Branches)
                                    {
                                        <option value="@branch.Id">@branch.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="nx-pulse-form-footer">
                            <label class="nx-pulse-check">
                                <input name="Poll.PublishNow" type="checkbox" value="true" checked />
                                <input name="Poll.PublishNow" type="hidden" value="false" />
                                <span>نشر الاستطلاع الآن</span>
                            </label>
                            <button type="submit">حفظ / نشر الاستطلاع</button>
                        </div>
                    </form>
                </section>
            </section>

            <section class="nx-pulse-dashboard-grid">
                <article class="nx-pulse-analytics-card nx-ops-data-note">
                    <header><h3>تحليل الفروع والأقسام</h3></header>
                    <div>
                        <strong>بيانات فعلية فقط</strong>
                        <p>تظهر المقارنات بعد تسجيل أصوات كافية وربط كل نتيجة بجمهورها المستهدف.</p>
                    </div>
                </article>

                <article class="nx-pulse-analytics-card nx-ops-data-note">
                    <header><h3>المواضيع التي تحتاج متابعة</h3></header>
                    <div>
                        <strong>@Model.TotalPollVotes صوت مسجل</strong>
                        <p>لن يعرض النظام نسباً تقديرية أو مواضيع وهمية. التحليل سيُبنى من نتائج الاستبيانات الفعلية.</p>
                    </div>
                </article>

                <article class="nx-pulse-analytics-card nx-ops-data-note">
                    <header><h3>الخصوصية والثقة</h3></header>
                    <div>
                        <strong>نتائج موثوقة</strong>
                        <p>الاستطلاعات السرية تبقى دون أسماء، والاستطلاعات الظاهرة تستخدم فقط عند اختيارها صراحة.</p>
                    </div>
                </article>

                <article class="nx-pulse-analytics-card nx-pulse-recent">
                    <header><h3>آخر الاستطلاعات</h3><a>عرض الكل</a></header>
                    @if (Model.Polls.Count == 0)
                    {
                        <div class="nx-pulse-empty">لا توجد استطلاعات حالياً.</div>
                    }
                    @foreach (var item in Model.Polls.Take(5))
                    {
                        <div class="nx-pulse-recent-row">
                            <span class="@(item.IsPublished ? "active" : "closed")">@Model.PublishText(item.IsPublished)</span>
                            <div>
                                <strong>@item.Title</strong>
                                <small>@item.Category · @Model.TargetText(item) · @item.VotesCount تصويت</small>
                            </div>
                            <div class="nx-pulse-row-actions">
                                <form method="post" asp-page-handler="TogglePoll" asp-route-id="@item.Id" asp-route-publish="@(!item.IsPublished)">
                                    <button type="submit">@(item.IsPublished ? "مسودة" : "نشر")</button>
                                </form>
                                <form method="post" asp-page-handler="DeletePoll" asp-route-id="@item.Id" onsubmit="return confirm('هل تريد حذف الاستطلاع؟');">
                                    <button type="submit" class="danger">حذف</button>
                                </form>
                            </div>
                        </div>
                    }
                </article>
            </section>
        </section>
    }

    else if (tab == "feedback")
    {
        <section class="nx-feedback-page">
            <section class="nx-kpis">
                <article><span>إجمالي الوارد</span><strong>@Model.TotalFeedback</strong></article>
                <article><span>مفتوحة</span><strong>@Model.OpenFeedback</strong></article>
                <article><span>قيد المعالجة</span><strong>@Model.PendingFeedback</strong></article>
                <article><span>تم الرد / مغلقة</span><strong>@Model.AnsweredFeedback</strong></article>
            </section>

            <div class="nx-feedback-list">
                @if (Model.FeedbackItems.Count == 0)
                {
                    <div class="nx-empty">لا توجد شكاوى أو مقترحات.</div>
                }
                @foreach (var item in Model.FeedbackItems)
                {
                    <article class="nx-feedback-card">
                        <div>
                            <div class="nx-tags"><span class="nx-badge neutral">@item.Type</span><span class="nx-badge @Model.StatusClass(item.Status)">@Model.StatusText(item.Status)</span><span class="nx-badge draft">@item.Priority</span></div>
                            <h3>@item.Title</h3>
                            <p>@item.Message</p>
                            <small>الموظف: @item.EmployeeName | الرقم: @item.EmployeeNo | التاريخ: @Model.DisplayDate(item.CreatedAt)</small>
                            @if (!string.IsNullOrWhiteSpace(item.AdminReply))
                            {
                                <div class="nx-admin-reply"><strong>رد الإدارة - @item.RepliedBy</strong><span>@item.AdminReply</span></div>
                            }
                        </div>
                        <div class="nx-feedback-actions">
                            <form method="post" asp-page-handler="ReplyFeedback">
                                <input type="hidden" name="FeedbackReply.Id" value="@item.Id" />
                                <select name="FeedbackReply.Status"><option value="Answered">تم الرد</option><option value="Pending">قيد المعالجة</option><option value="Closed">مغلقة</option></select>
                                <textarea name="FeedbackReply.Reply" placeholder="اكتب رد الإدارة"></textarea>
                                <button type="submit">حفظ الرد</button>
                            </form>
                            <form method="post" asp-page-handler="CloseFeedback" asp-route-id="@item.Id"><button type="submit" class="danger">إغلاق الطلب</button></form>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
    else if (tab == "wall")
    {
        <section class="nx-wall-grid">
            @if (!Model.Announcements.Any(x => x.IsPublished))
            {
                <div class="nx-ops-empty nx-ops-empty--wide">
                    لا توجد منشورات على الحائط حالياً. انشر إعلاناً من تبويب التواصل ليظهر هنا.
                </div>
            }
            @foreach (var item in Model.Announcements.Where(x => x.IsPublished))
            {
                var wallTemplate = Model.AnnouncementTemplates.FirstOrDefault(x => x.Key.Equals(item.TemplateKey ?? "custom", System.StringComparison.OrdinalIgnoreCase));
                <article class="nx-wall-card">
                    <img src="@Url.Content("~/brand/announcement-studio/cards/" + (wallTemplate?.AssetKey ?? "custom") + ".png")" alt="@item.Category" />
                    <div>
                        <span class="nx-badge neutral">@item.Category</span>
                        <h3>@item.Title</h3>
                        <p>@item.Body</p>
                        <small>@Model.TargetText(item) | @Model.DisplayDate(item.PublishDate)</small>
                    </div>
                </article>
            }
        </section>
    }
    else if (tab == "recognition")
    {
        <section class="nx-ops-special-page">
            <header class="nx-ops-special-head">
                <div>
                    <span class="nx-ops-label">RECOGNITION</span>
                    <h2>التقدير والإنجازات</h2>
                    <p>حوّل إنجازات الموظفين والترقيات ورسائل الشكر إلى محتوى مهني يظهر في تجربة الموظف.</p>
                </div>
                <a class="nx-ops-primary-action" asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="appreciation">إنشاء تكريم</a>
            </header>

            <section class="nx-ops-template-launcher">
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="appreciation">
                    <span>🏆</span><strong>شكر وتقدير</strong><small>تكريم موظف أو فريق بسبب إنجاز واضح.</small>
                </a>
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="promotion">
                    <span>📈</span><strong>ترقية موظف</strong><small>إعلان الترقية والمنصب الجديد وتاريخ السريان.</small>
                </a>
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="welcome">
                    <span>🤝</span><strong>موظف جديد</strong><small>ترحيب بالموظف وربطه بالقسم وموقع العمل.</small>
                </a>
            </section>

            <section class="nx-ops-records-card">
                <header><h2>سجل التقدير</h2><span>@Model.RecognitionAnnouncements.Count عنصر</span></header>
                @if (Model.RecognitionAnnouncements.Count == 0)
                {
                    <div class="nx-ops-empty">لا توجد سجلات تقدير حالياً.</div>
                }
                @foreach (var item in Model.RecognitionAnnouncements)
                {
                    <article class="nx-ops-record-row">
                        <span class="@(item.IsPublished ? "live" : "draft")">@Model.PublishText(item.IsPublished)</span>
                        <div><strong>@item.Title</strong><small>@item.Category · @Model.TargetText(item) · @Model.DisplayDate(item.PublishDate)</small></div>
                    </article>
                }
            </section>
        </section>
    }
    else if (tab == "campaigns")
    {
        <section class="nx-ops-special-page">
            <header class="nx-ops-special-head">
                <div>
                    <span class="nx-ops-label">CAMPAIGNS</span>
                    <h2>الحملات والمناسبات</h2>
                    <p>ابدأ بحملة أو تعميم جاهز، ثم حدّد الجمهور وانشره مباشرة من استوديو التواصل.</p>
                </div>
                <a class="nx-ops-primary-action" asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="circular">إنشاء حملة</a>
            </header>

            <section class="nx-ops-template-launcher">
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="holiday">
                    <span>📅</span><strong>عطلة رسمية</strong><small>إشعار العطلة وتاريخ العودة والتعليمات.</small>
                </a>
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="circular">
                    <span>📄</span><strong>تعميم إداري</strong><small>توجيه رسمي مع تاريخ بدء التطبيق.</small>
                </a>
                <a asp-page="./Index" asp-route-section="engagement" asp-route-tab="announcements" asp-route-preset="workhours">
                    <span>🕘</span><strong>تغيير الدوام</strong><small>تحديث وقت العمل والمواقع المشمولة.</small>
                </a>
            </section>

            <section class="nx-ops-records-card">
                <header><h2>سجل الحملات والتعاميم</h2><span>@Model.CampaignAnnouncements.Count عنصر</span></header>
                @if (Model.CampaignAnnouncements.Count == 0)
                {
                    <div class="nx-ops-empty">لا توجد حملات أو تعاميم حالياً.</div>
                }
                @foreach (var item in Model.CampaignAnnouncements)
                {
                    <article class="nx-ops-record-row">
                        <span class="@(item.IsPublished ? "live" : "draft")">@Model.PublishText(item.IsPublished)</span>
                        <div><strong>@item.Title</strong><small>@item.Category · @Model.TargetText(item) · @Model.DisplayDate(item.PublishDate)</small></div>
                    </article>
                }
            </section>
        </section>
    }
</section>

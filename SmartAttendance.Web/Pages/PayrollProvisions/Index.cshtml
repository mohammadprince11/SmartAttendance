@page "/PayrollProvisions"
@model SmartAttendance.Web.Pages.PayrollProvisions.IndexModel

@{
    ViewData["Title"] = "حساب الاحتياطي";
    var acc = "#f59e0b";
    string M(decimal v) => v.ToString("#,0.##");
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .rv-page { display:flex; flex-direction:column; gap:14px; color:var(--sa-text,#DCEAF4); --acc:@acc; }
    .rv-head { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
        padding:16px 20px; border:1px solid rgba(73,111,151,.22); border-radius:20px;
        background:radial-gradient(circle at 92% 8%,color-mix(in srgb,var(--acc) 14%,transparent),transparent 40%),linear-gradient(135deg,rgba(9,31,52,.95),rgba(5,16,29,.95)); }
    html[data-theme="light"] .rv-head { background:linear-gradient(135deg,#fff,#f2f7fb); }
    .rv-head h1 { margin:0; font-size:20px; font-weight:1000; }
    .rv-head p { margin:2px 0 0; font-size:12px; color:var(--sa-muted,#8FA8BC); font-weight:800; }
    .rv-btn { min-height:34px; padding:6px 14px; border-radius:10px; border:1px solid rgba(73,111,151,.3); font-size:12.5px; font-weight:900; cursor:pointer; background:transparent; color:inherit; text-decoration:none; display:inline-flex; align-items:center; }
    .rv-btn.solid { background:var(--acc); color:#04141d; border:0; }
    .rv-kpis { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; }
    .rv-kpi { padding:14px 16px; border:1px solid rgba(73,111,151,.22); border-radius:16px; background:var(--sa-surface,rgba(8,25,43,.9)); position:relative; overflow:hidden; }
    .rv-kpi::before { content:""; position:absolute; inset-inline-start:0; top:0; bottom:0; width:4px; background:var(--acc); }
    .rv-kpi b { display:block; font-size:20px; font-weight:1000; direction:ltr; }
    .rv-kpi.t b { color:var(--acc); }
    .rv-kpi span { font-size:11px; font-weight:900; color:var(--sa-muted,#8FA8BC); }
    .rv-bar { display:flex; align-items:end; gap:8px; flex-wrap:wrap; padding:12px 14px; border:1px solid rgba(73,111,151,.22); border-radius:16px; background:var(--sa-surface,rgba(8,25,43,.9)); }
    .rv-bar label { font-size:11px; font-weight:900; color:var(--sa-muted,#8FA8BC); display:flex; flex-direction:column; gap:4px; }
    .rv-bar input, .rv-bar select { min-height:34px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:4px 10px; font-weight:800; font-size:12.5px; }
    html[data-theme="light"] .rv-bar input, html[data-theme="light"] .rv-bar select { background:#fff; }
    .rv-card { border:1px solid rgba(73,111,151,.22); border-radius:18px; overflow-x:auto; background:var(--sa-surface,rgba(8,25,43,.9)); }
    .rv-table { width:100%; border-collapse:collapse; font-size:12.5px; min-width:920px; }
    .rv-table th { text-align:start; padding:10px 12px; font-size:11px; font-weight:1000; color:var(--sa-muted,#8FA8BC); border-bottom:1px solid rgba(73,111,151,.22); background:rgba(0,0,0,.12); }
    html[data-theme="light"] .rv-table th { background:#f2f7fb; }
    .rv-table td { padding:9px 12px; border-bottom:1px solid rgba(143,168,188,.08); white-space:nowrap; }
    .rv-table tfoot td { font-weight:1000; border-top:2px solid color-mix(in srgb,var(--acc) 40%,transparent); background:rgba(0,0,0,.1); }
    .rv-emp b { font-weight:900; } .rv-emp span { color:var(--sa-muted,#8FA8BC); font-size:11px; }
    .rv-num { direction:ltr; font-weight:900; }
    .rv-num.acc { color:var(--acc); }
    .rv-empty { padding:34px; text-align:center; color:var(--sa-muted,#8FA8BC); font-weight:800; }
</style>

<section class="rv-page" dir="rtl">
    <header class="rv-head">
        <div>
            <h1>💰 حساب الاحتياطي (مخصصات الالتزامات)</h1>
            <p>الالتزام المتراكم بتاريخ محدّد لكل موظف نشط: مخصص نهاية الخدمة + مخصص رصيد الإجازات. تحليلي/محاسبي.</p>
        </div>
        @{
            var exportQs = $"AsOf={Model.AsOf}&Year={Model.ResolvedYear}&Search={Model.Search}&FDept={Model.FDept}&FBranch={Model.FBranch}";
        }
        <a href="/PayrollProvisions?handler=Export&@exportQs" class="rv-btn">⬇ تصدير CSV</a>
    </header>

    <div class="rv-kpis">
        <div class="rv-kpi"><b>@Model.Data.EmployeeCount</b><span>موظفون نشطون</span></div>
        <div class="rv-kpi"><b>@M(Model.Data.TotalEos)</b><span>مخصص نهاية الخدمة</span></div>
        <div class="rv-kpi"><b>@M(Model.Data.TotalLeave)</b><span>مخصص رصيد الإجازات</span></div>
        <div class="rv-kpi t"><b>@M(Model.Data.Total)</b><span>إجمالي الاحتياطي</span></div>
    </div>

    <form method="get" class="rv-bar">
        <label>بتاريخ (as-of)<input type="date" name="AsOf" value="@Model.AsOf" /></label>
        <label>سنة الرصيد
            <select name="Year">
                @for (var y = DateTime.Today.Year - 2; y <= DateTime.Today.Year + 1; y++)
                { <option value="@y" selected="@(y == Model.ResolvedYear)">@y</option> }
            </select>
        </label>
        <label>بحث<input type="text" name="Search" value="@Model.Search" placeholder="رمز/اسم" style="min-width:150px" /></label>
        <label>القسم<select name="FDept"><option value="">الكل</option>@foreach (var s in Model.AllDepartments){<option value="@s" selected="@(Model.FDept==s)">@s</option>}</select></label>
        <label>الفرع<select name="FBranch"><option value="">الكل</option>@foreach (var s in Model.AllBranches){<option value="@s" selected="@(Model.FBranch==s)">@s</option>}</select></label>
        <button type="submit" class="rv-btn solid">تطبيق</button>
        <a href="/PayrollProvisions" class="rv-btn">إزالة</a>
    </form>

    <div class="rv-card">
        @if (Model.Data.Rows.Count == 0)
        {
            <div class="rv-empty">لا موظفون نشطون مطابقون — تأكّد من الرواتب الأساسية بالملف المالي.</div>
        }
        else
        {
            <table class="rv-table">
                <thead>
                    <tr>
                        <th>الموظف</th><th>القسم</th><th>تاريخ التعيين</th><th>سنوات الخدمة</th><th>الأساسي</th>
                        <th>مخصص نهاية الخدمة</th><th>أيام الإجازة</th><th>مخصص الإجازات</th><th>إجمالي الاحتياطي</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Data.Rows.Take(500))
                    {
                        <tr>
                            <td class="rv-emp"><b>@r.EmployeeName</b> <span>· @r.EmployeeNo</span></td>
                            <td>@r.Department</td>
                            <td class="rv-num">@(r.HireDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="rv-num">@r.Years.ToString("0.##")</td>
                            <td class="rv-num">@M(r.Basic)</td>
                            <td class="rv-num">@M(r.EosProvision)</td>
                            <td class="rv-num">@r.LeaveDays.ToString("0.##")</td>
                            <td class="rv-num">@M(r.LeaveProvision)</td>
                            <td class="rv-num acc">@M(r.Total)</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5">الإجمالي (@Model.Data.EmployeeCount موظف@(Model.Data.Rows.Count > 500 ? " — يُعرض أول 500، والتصدير كامل" : ""))</td>
                        <td class="rv-num">@M(Model.Data.TotalEos)</td>
                        <td></td>
                        <td class="rv-num">@M(Model.Data.TotalLeave)</td>
                        <td class="rv-num acc">@M(Model.Data.Total)</td>
                    </tr>
                </tfoot>
            </table>
        }
    </div>
</section>

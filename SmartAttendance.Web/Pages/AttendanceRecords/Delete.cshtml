@page
@model SmartAttendance.Web.Pages.AttendanceRecords.DeleteModel

@{
    ViewData["Title"] = "حذف سجل حضور";
}

<div class="page-header">
    <div>
        <h1>حذف سجل حضور</h1>
        <p>تأكيد حذف سجل الحضور</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this attendance record?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>رقم الموظف</label>
            <div class="form-control">@Model.AttendanceRecord.EmployeeNo</div>
        </div>

        <div class="form-group">
            <label>اسم الموظف</label>
            <div class="form-control">@Model.AttendanceRecord.EmployeeName</div>
        </div>

        <div class="form-group">
            <label>تاريخ الحضور</label>
            <div class="form-control">@Model.AttendanceRecord.AttendanceDate</div>
        </div>

        <div class="form-group">
            <label>ختم الدخول</label>
            <div class="form-control">@Model.AttendanceRecord.CheckIn.ToString("yyyy-MM-dd HH:mm")</div>
        </div>

        <div class="form-group">
            <label>ختم الخروج</label>
            <div class="form-control">@(Model.AttendanceRecord.CheckOut?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
        </div>

        <div class="form-group">
            <label>الحالة</label>
            <div class="form-control">@Model.AttendanceRecord.Status</div>
        </div>

        <div class="form-group">
            <label>المصدر</label>
            <div class="form-control">@Model.AttendanceRecord.Source</div>
        </div>

        <div class="form-group">
            <label>الجهاز</label>
            <div class="form-control">@(string.IsNullOrWhiteSpace(Model.AttendanceRecord.DeviceName) ? "-" : Model.AttendanceRecord.DeviceName)</div>
        </div>

        <div class="form-group">
            <label>ملاحظات</label>
            <div class="form-control">@Model.AttendanceRecord.Notes</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.AttendanceRecord.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

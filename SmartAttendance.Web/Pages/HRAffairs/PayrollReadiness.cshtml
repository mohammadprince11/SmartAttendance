@page
@model SmartAttendance.Web.Pages.HRAffairs.PayrollReadinessModel

@{
    ViewData["Title"] = "جاهزية الراتب";
}

<link rel="stylesheet" href="~/css/hr-affairs-final.css" asp-append-version="true" />

<div class="hr-final-page">
    <section class="hr-final-hero">
        <div>
            <span class="hr-final-eyebrow">NEXORA Payroll Readiness</span>
            <h1>جاهزية الراتب</h1>
            <p>تقرير HR لتحديد الموظفين الذين يحتاجون مراجعة قبل إغلاق الراتب.</p>
        </div>

        <div class="hr-final-actions">
            <a asp-page="/HRAffairs/Index" class="hr-final-btn secondary">شؤون الموظفين</a>
            <a asp-page="/Employees/Index" class="hr-final-btn primary">الموظفون</a>
        </div>
    </section>

    <section class="hr-final-kpis">
        <div class="hr-final-kpi"><span>المعروض</span><strong>@Model.TotalRows</strong><small>موظف</small></div>
        <div class="hr-final-kpi ok"><span>جاهز</span><strong>@Model.ReadyRows</strong><small>بدون مخاطر</small></div>
        <div class="hr-final-kpi warn"><span>يحتاج مراجعة</span><strong>@Model.RiskRows</strong><small>قبل الإغلاق</small></div>
        <div class="hr-final-kpi danger"><span>غياب</span><strong>@Model.Rows.Sum(x => x.AbsentCount)</strong><small>ضمن الفترة</small></div>
        <div class="hr-final-kpi warn"><span>بصمة ناقصة</span><strong>@Model.Rows.Sum(x => x.MissingPunchCount)</strong><small>تحتاج تصحيح</small></div>
        <div class="hr-final-kpi warn"><span>طلبات معلقة</span><strong>@Model.Rows.Sum(x => x.PendingRequests)</strong><small>بانتظار موافقة</small></div>
    </section>

    <form method="get" class="hr-final-filter">
        <div class="hr-final-field">
            <label>من تاريخ</label>
            <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="hr-final-field">
            <label>إلى تاريخ</label>
            <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="hr-final-field">
            <label>بحث</label>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="كود، اسم، فرع، قسم..." />
        </div>
        <div class="hr-final-field">
            <label>عدد النتائج</label>
            <select name="MaxRows">
                <option value="100" selected="@(Model.MaxRows == 100)">100</option>
                <option value="200" selected="@(Model.MaxRows == 200)">200</option>
                <option value="500" selected="@(Model.MaxRows == 500)">500</option>
                <option value="1000" selected="@(Model.MaxRows == 1000)">1000</option>
            </select>
        </div>
        <div class="hr-final-actions">
            <button type="submit" class="hr-final-btn primary">تطبيق</button>
            <a asp-page="./PayrollReadiness" class="hr-final-btn secondary">مسح</a>
        </div>
    </form>

    <section class="hr-final-table-card">
        <div class="hr-final-table-head">
            <div>
                <h2>قائمة جاهزية الراتب</h2>
                <p>مرتبة حسب أعلى مخاطر تشغيلية.</p>
            </div>
        </div>

        <div class="hr-final-table-wrap">
            <table class="hr-final-table">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الموظف</th>
                        <th>الفرع</th>
                        <th>القسم</th>
                        <th>الغياب</th>
                        <th>التأخير</th>
                        <th>بصمة ناقصة</th>
                        <th>طلبات معلقة</th>
                        <th>مستندات</th>
                        <th>المؤشر</th>
                        <th>ملف</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Any())
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.EmployeeNo</td>
                                <td class="hr-final-name">@row.FullName</td>
                                <td>@row.BranchName</td>
                                <td>@row.DepartmentName</td>
                                <td>@row.AbsentCount</td>
                                <td>@row.LateCount</td>
                                <td>@row.MissingPunchCount</td>
                                <td>@row.PendingRequests</td>
                                <td>@(row.ExpiredDocuments + row.ExpiringDocuments)</td>
                                <td><span class="hr-final-pill @row.RiskClass">@row.RiskText</span></td>
                                <td><a asp-page="/Employees/Profile" asp-route-id="@row.EmployeeId" class="hr-final-btn secondary">ملف</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="11" class="hr-final-empty">لا توجد نتائج.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

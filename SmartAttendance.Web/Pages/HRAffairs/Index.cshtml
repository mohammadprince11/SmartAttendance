@page
@model SmartAttendance.Web.Pages.HRAffairs.IndexModel

@{
    ViewData["Title"] = "شؤون الموظفين";
}

<link rel="stylesheet" href="~/css/hr-affairs-final.css" asp-append-version="true" />

<div class="hr-final-page">
    <section class="hr-final-hero">
        <div>
            <span class="hr-final-eyebrow">NEXORA HR Affairs</span>
            <h1>شؤون الموظفين</h1>
            <p>
                مركز موحد لإدارة الموظفين، ملف الموظف الشامل، جاهزية الراتب، استثناءات الحضور، العقود، المستندات، والطلبات.
            </p>
        </div>

        <div class="hr-final-actions">
            <a asp-page="/Employees/Index" class="hr-final-btn primary">قائمة الموظفين</a>
            <a asp-page="/Employees/Create" class="hr-final-btn secondary">إضافة موظف</a>
            <a asp-page="/Employees/Import" class="hr-final-btn gold">استيراد موظفين</a>
        </div>
    </section>

    <section class="hr-final-kpis">
        <div class="hr-final-kpi ok">
            <span>الموظفون الفعالون</span>
            <strong>@Model.ActiveEmployees</strong>
            <small>داخل النظام</small>
        </div>

        <div class="hr-final-kpi">
            <span>غير فعال</span>
            <strong>@Model.InactiveEmployees</strong>
            <small>إيقاف / انتهاء خدمة</small>
        </div>

        <div class="hr-final-kpi warn">
            <span>بيانات ناقصة</span>
            <strong>@Model.MissingStructure</strong>
            <small>قسم أو منصب غير مكتمل</small>
        </div>

        <div class="hr-final-kpi warn">
            <span>استثناءات الحضور</span>
            <strong>@Model.AttendanceExceptions</strong>
            <small>آخر 30 يوم</small>
        </div>

        <div class="hr-final-kpi danger">
            <span>طلبات معلقة</span>
            <strong>@Model.PendingRequests</strong>
            <small>بانتظار موافقة</small>
        </div>

        <div class="hr-final-kpi danger">
            <span>مخاطر عقود/مستندات</span>
            <strong>@(Model.ExpiredDocuments + Model.ExpiringDocuments + Model.ContractRisk)</strong>
            <small>تحتاج متابعة</small>
        </div>
    </section>

    <section class="hr-final-grid">
        <div class="hr-final-card">
            <h2>Employee 360</h2>
            <p>ملف شامل لكل موظف يحتوي الحضور، الطلبات، المستندات، المخاطر، وجاهزية الراتب.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/Employees/Index" class="hr-final-btn primary">فتح الموظفين</a>
            </div>
        </div>

        <div class="hr-final-card">
            <h2>جاهزية الراتب</h2>
            <p>كشف الموظفين الذين يحتاجون مراجعة قبل إغلاق الراتب بسبب الغياب أو البصمات أو الطلبات أو المستندات.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/HRAffairs/PayrollReadiness" class="hr-final-btn secondary">فتح التقرير</a>
            </div>
        </div>

        <div class="hr-final-card">
            <h2>استثناءات الحضور</h2>
            <p>عرض السجلات التي فيها تأخير، غياب، بصمة ناقصة، أو ملاحظات تحتاج مراجعة.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/HRAffairs/AttendanceExceptions" class="hr-final-btn secondary">فتح الاستثناءات</a>
            </div>
        </div>

        <div class="hr-final-card">
            <h2>العقود والمستندات</h2>
            <p>متابعة المستندات المنتهية أو القريبة من الانتهاء والعقود التي تحتاج تجديد أو مراجعة.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/HRAffairs/DocumentsRisk" class="hr-final-btn secondary">فتح المخاطر</a>
            </div>
        </div>

        <div class="hr-final-card">
            <h2>الطلبات</h2>
            <p>مركز سريع لطلبات الخدمة الذاتية: إجازة، نسيان بصمة، مغادرة، أوفر تايم وغيرها.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/HRAffairs/RequestsCenter" class="hr-final-btn secondary">فتح الطلبات</a>
            </div>
        </div>

        <div class="hr-final-card">
            <h2>إنهاء الخدمة</h2>
            <p>الوصول إلى قائمة وحركات انتهاء الخدمة وإعادة التعيين من داخل شؤون الموظفين.</p>
            <div class="hr-final-card-actions">
                <a asp-page="/Employees/EndServiceList" class="hr-final-btn secondary">قائمة انتهاء الخدمة</a>
            </div>
        </div>
    </section>
</div>

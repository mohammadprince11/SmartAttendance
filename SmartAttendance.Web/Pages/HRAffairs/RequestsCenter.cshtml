@page
@model SmartAttendance.Web.Pages.HRAffairs.RequestsCenterModel

@{
    ViewData["Title"] = "طلبات شؤون الموظفين";
}

<link rel="stylesheet" href="~/css/hr-affairs-final.css" asp-append-version="true" />

<div class="hr-final-page">
    <section class="hr-final-hero">
        <div>
            <span class="hr-final-eyebrow">NEXORA Requests Center</span>
            <h1>طلبات شؤون الموظفين</h1>
            <p>مركز متابعة طلبات الخدمة الذاتية وربطها بملف الموظف الشامل.</p>
        </div>
        <div class="hr-final-actions">
            <a asp-page="/HRAffairs/Index" class="hr-final-btn secondary">شؤون الموظفين</a>
            <a asp-page="/Approvals/Index" class="hr-final-btn primary">الموافقات</a>
        </div>
    </section>

    <section class="hr-final-kpis">
        <div class="hr-final-kpi"><span>المعروض</span><strong>@Model.Rows.Count</strong><small>طلب</small></div>
        <div class="hr-final-kpi warn"><span>معلق</span><strong>@Model.PendingCount</strong><small>بانتظار موافقة</small></div>
        <div class="hr-final-kpi ok"><span>موافق عليه</span><strong>@Model.ApprovedCount</strong><small>ضمن النتائج</small></div>
        <div class="hr-final-kpi danger"><span>مرفوض</span><strong>@Model.RejectedCount</strong><small>ضمن النتائج</small></div>
    </section>

    <form method="get" class="hr-final-filter">
        <div class="hr-final-field">
            <label>الحالة</label>
            <select name="StatusFilter">
                <option value="all" selected="@(Model.StatusFilter == "all")">الكل</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">معلق</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">موافق عليه</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">مرفوض</option>
            </select>
        </div>
        <div class="hr-final-field">
            <label>بحث</label>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="كود، اسم، نوع طلب..." />
        </div>
        <div class="hr-final-field">
            <label>عدد النتائج</label>
            <select name="MaxRows">
                <option value="100" selected="@(Model.MaxRows == 100)">100</option>
                <option value="200" selected="@(Model.MaxRows == 200)">200</option>
                <option value="500" selected="@(Model.MaxRows == 500)">500</option>
                <option value="1000" selected="@(Model.MaxRows == 1000)">1000</option>
            </select>
        </div>
        <div class="hr-final-actions">
            <button type="submit" class="hr-final-btn primary">تطبيق</button>
            <a asp-page="./RequestsCenter" class="hr-final-btn secondary">مسح</a>
        </div>
    </form>

    <section class="hr-final-table-card">
        <div class="hr-final-table-head">
            <div>
                <h2>قائمة الطلبات</h2>
                <p>آخر الطلبات حسب الفلتر الحالي.</p>
            </div>
        </div>

        <div class="hr-final-table-wrap">
            <table class="hr-final-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>الكود</th>
                        <th>الموظف</th>
                        <th>الفرع</th>
                        <th>نوع الطلب</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>المرحلة</th>
                        <th>الحالة</th>
                        <th>ملف</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Any())
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@Model.DisplayDateTime(row.CreatedAt)</td>
                                <td>@row.EmployeeNo</td>
                                <td class="hr-final-name">@row.FullName</td>
                                <td>@row.BranchName</td>
                                <td>@row.RequestType</td>
                                <td>@Model.DisplayDate(row.FromDate)</td>
                                <td>@Model.DisplayDate(row.ToDate)</td>
                                <td>@(string.IsNullOrWhiteSpace(row.CurrentStep) ? "-" : row.CurrentStep)</td>
                                <td><span class="hr-final-pill @Model.StatusClass(row.Status)">@Model.StatusName(row.Status)</span></td>
                                <td><a asp-page="/Employees/Profile" asp-route-id="@row.EmployeeId" class="hr-final-btn secondary">ملف</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="10" class="hr-final-empty">لا توجد طلبات مطابقة.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

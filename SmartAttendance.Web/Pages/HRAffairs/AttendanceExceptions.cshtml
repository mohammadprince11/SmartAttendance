@page
@model SmartAttendance.Web.Pages.HRAffairs.AttendanceExceptionsModel

@{
    ViewData["Title"] = "استثناءات الحضور";
}

<link rel="stylesheet" href="~/css/hr-affairs-final.css" asp-append-version="true" />

<div class="hr-final-page">
    <section class="hr-final-hero">
        <div>
            <span class="hr-final-eyebrow">NEXORA Attendance Exceptions</span>
            <h1>استثناءات الحضور</h1>
            <p>مركز مراجعة الغياب، التأخير، البصمات الناقصة، والملاحظات قبل إغلاق الراتب.</p>
        </div>
        <div class="hr-final-actions">
            <a asp-page="/HRAffairs/Index" class="hr-final-btn secondary">شؤون الموظفين</a>
            <a asp-page="/AttendanceOperations/Index" class="hr-final-btn primary">عمليات الحضور</a>
        </div>
    </section>

    <section class="hr-final-kpis">
        <div class="hr-final-kpi warn"><span>الاستثناءات</span><strong>@Model.TotalRows</strong><small>حسب الفلتر</small></div>
        <div class="hr-final-kpi warn"><span>تأخير</span><strong>@Model.LateCount</strong><small>سجل</small></div>
        <div class="hr-final-kpi danger"><span>غياب</span><strong>@Model.AbsentCount</strong><small>سجل</small></div>
        <div class="hr-final-kpi warn"><span>بصمة ناقصة</span><strong>@Model.MissingPunchCount</strong><small>دخول أو خروج</small></div>
    </section>

    <form method="get" class="hr-final-filter">
        <div class="hr-final-field">
            <label>من تاريخ</label>
            <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="hr-final-field">
            <label>إلى تاريخ</label>
            <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="hr-final-field">
            <label>بحث</label>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="كود، اسم، فرع، قسم..." />
        </div>
        <div class="hr-final-field">
            <label>عدد النتائج</label>
            <select name="MaxRows">
                <option value="100" selected="@(Model.MaxRows == 100)">100</option>
                <option value="200" selected="@(Model.MaxRows == 200)">200</option>
                <option value="500" selected="@(Model.MaxRows == 500)">500</option>
                <option value="1000" selected="@(Model.MaxRows == 1000)">1000</option>
            </select>
        </div>
        <div class="hr-final-actions">
            <button type="submit" class="hr-final-btn primary">تطبيق</button>
            <a asp-page="./AttendanceExceptions" class="hr-final-btn secondary">مسح</a>
        </div>
    </form>

    <section class="hr-final-table-card">
        <div class="hr-final-table-head">
            <div>
                <h2>قائمة الاستثناءات</h2>
                <p>آخر السجلات التي تحتاج مراجعة تشغيلية.</p>
            </div>
        </div>

        <div class="hr-final-table-wrap">
            <table class="hr-final-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>الكود</th>
                        <th>الموظف</th>
                        <th>الفرع</th>
                        <th>الدخول</th>
                        <th>الخروج</th>
                        <th>الحالة</th>
                        <th>المصدر</th>
                        <th>الملاحظة</th>
                        <th>ملف</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Any())
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@Model.DisplayDate(row.AttendanceDate)</td>
                                <td>@row.EmployeeNo</td>
                                <td class="hr-final-name">@row.FullName</td>
                                <td>@row.BranchName</td>
                                <td>@Model.DisplayTime(row.CheckIn)</td>
                                <td>@Model.DisplayTime(row.CheckOut)</td>
                                <td><span class="hr-final-pill @Model.StatusClass(row.Status)">@Model.StatusName(row.Status)</span></td>
                                <td>@Model.SourceName(row.Source)</td>
                                <td>@(string.IsNullOrWhiteSpace(row.Notes) ? "-" : row.Notes)</td>
                                <td><a asp-page="/Employees/Profile" asp-route-id="@row.EmployeeId" class="hr-final-btn secondary">ملف</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="10" class="hr-final-empty">لا توجد استثناءات حسب الفلتر الحالي.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

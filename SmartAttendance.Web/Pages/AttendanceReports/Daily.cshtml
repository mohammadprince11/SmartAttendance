@page
@model SmartAttendance.Web.Pages.AttendanceReports.DailyModel

@{
    ViewData["Title"] = "Daily Attendance Report";
}

<div class="page-header">
    <div>
        <h1>Daily Attendance Report</h1>
        <p>Review attendance records by date</p>
    </div>

    <a asp-page="./Monthly" class="btn-secondary">Monthly Report</a>
</div>

<div class="setup-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-bottom:20px;">
    <div class="summary-card"><div class="label">Employees</div><div class="value">@Model.Report.TotalEmployees</div></div>
    <div class="summary-card"><div class="label">Present</div><div class="value">@Model.Report.TotalPresent</div></div>
    <div class="summary-card"><div class="label">Late</div><div class="value">@Model.Report.TotalLate</div></div>
    <div class="summary-card"><div class="label">Absent</div><div class="value">@Model.Report.TotalAbsent</div></div>
    <div class="summary-card"><div class="label">Leave</div><div class="value">@Model.Report.TotalLeave</div></div>
    <div class="summary-card"><div class="label">Holiday</div><div class="value">@Model.Report.TotalHoliday</div></div>
    <div class="summary-card"><div class="label">Missing Out</div><div class="value">@Model.Report.TotalMissingCheckOut</div></div>
</div>

<div class="table-card">
    <form method="get" class="search-form">
        <input type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
        <input type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
        <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search employee, department, branch, status..." />
        <button type="submit" class="btn-primary">Search</button>
        <a asp-page="./Daily" class="btn-secondary">Clear</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Employee No</th>
                <th>Employee Name</th>
                <th>Department</th>
                <th>Branch</th>
                <th>Check In</th>
                <th>Check Out</th>
                <th>Status</th>
                <th>Source</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Report.Rows.Any())
            {
                foreach (var row in Model.Report.Rows)
                {
                    <tr>
                        <td>@row.AttendanceDate.ToString("dd/MM/yyyy")</td>
                        <td>@row.EmployeeNo</td>
                        <td style="direction:rtl">@row.EmployeeName</td>
                        <td>@row.DepartmentName</td>
                        <td>@row.BranchName</td>
                        <td>@(row.CheckIn?.ToString("HH:mm") ?? "-")</td>
                        <td>@(row.CheckOut?.ToString("HH:mm") ?? "-")</td>
                        <td>@row.Status</td>
                        <td>@row.Source</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="9" style="text-align:center;">No records found.</td></tr>
            }
        </tbody>
    </table>
</div>

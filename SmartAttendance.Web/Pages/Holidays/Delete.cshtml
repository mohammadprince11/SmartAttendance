@page
@model SmartAttendance.Web.Pages.Holidays.DeleteModel

@{
    ViewData["Title"] = "Delete Holiday";
}

<div class="page-header">
    <div>
        <h1>Delete Holiday</h1>
        <p>Confirm holiday deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this holiday?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Holiday Name</label>
            <div class="form-control">@Model.Holiday.Name</div>
        </div>

        <div class="form-group">
            <label>Date</label>
            <div class="form-control">@Model.Holiday.HolidayDate</div>
        </div>

        <div class="form-group">
            <label>Recurring</label>
            <div class="form-control">@(Model.Holiday.IsRecurring ? "Yes" : "No")</div>
        </div>

        <div class="form-group">
            <label>Description</label>
            <div class="form-control">@Model.Holiday.Description</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Holiday.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

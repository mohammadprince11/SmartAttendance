@page
@model SmartAttendance.Web.Pages.Holidays.DeleteModel

@{
    ViewData["Title"] = "حذف عطلة";
}

<div class="page-header">
    <div>
        <h1>حذف عطلة</h1>
        <p>تأكيد حذف العطلة</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this holiday?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>اسم العطلة</label>
            <div class="form-control">@Model.Holiday.Name</div>
        </div>

        <div class="form-group">
            <label>التاريخ</label>
            <div class="form-control">@Model.Holiday.HolidayDate</div>
        </div>

        <div class="form-group">
            <label>متكررة</label>
            <div class="form-control">@(Model.Holiday.IsRecurring ? "نعم" : "لا")</div>
        </div>

        <div class="form-group">
            <label>الوصف</label>
            <div class="form-control">@Model.Holiday.Description</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Holiday.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

@page
@model SmartAttendance.Web.Pages.Holidays.EditModel

@{
    ViewData["Title"] = "Edit Holiday";
}

<div class="page-header">
    <div>
        <h1>Edit Holiday</h1>
        <p>Update holiday information</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <input type="hidden" asp-for="Holiday.Id" />

        <div class="form-group">
            <label asp-for="Holiday.Name">Holiday Name</label>
            <input asp-for="Holiday.Name" class="form-control" />
            <span asp-validation-for="Holiday.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Holiday.HolidayDate">Holiday Date</label>
            <input asp-for="Holiday.HolidayDate" type="date" class="form-control" />
            <span asp-validation-for="Holiday.HolidayDate" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="Holiday.IsRecurring" />
                Recurring every year
            </label>
        </div>

        <div class="form-group">
            <label asp-for="Holiday.Description">Description</label>
            <input asp-for="Holiday.Description" class="form-control" />
            <span asp-validation-for="Holiday.Description" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Update</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

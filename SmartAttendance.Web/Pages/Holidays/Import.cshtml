@page
@model SmartAttendance.Web.Pages.Holidays.ImportModel

@{
    ViewData["Title"] = Model.PageTitle;
}

<style>
    .import-v3-wrap {
        max-width: 1180px;
        margin: 0 auto;
    }

    .import-v3-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 22px;
    }

    .import-v3-head h1 {
        margin: 0 0 8px 0;
        font-size: 30px;
        font-weight: 900;
        color: var(--sa-text, #0f172a);
    }

    .import-v3-head p {
        margin: 0;
        color: var(--sa-muted, #64748b);
        font-size: 15px;
    }

    .import-v3-card {
        background: var(--sa-surface, #ffffff);
        border: 1px solid var(--sa-border, #dbe4f0);
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 22px 55px rgba(15, 23, 42, 0.08);
        margin-bottom: 22px;
    }

    .import-v3-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    @@media (max-width: 900px) {
        .import-v3-two {
            grid-template-columns: 1fr;
        }
    }

    .import-v3-box {
        background: var(--sa-surface-2, #f8fafc);
        border: 1px solid var(--sa-border, #dbe4f0);
        border-radius: 18px;
        padding: 18px;
        min-height: 330px;
    }

    .import-v3-box-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 17px;
        font-weight: 900;
        color: var(--sa-text, #0f172a);
        margin-bottom: 8px;
    }

    .import-v3-step {
        width: 32px;
        height: 32px;
        border-radius: 12px;
        background: var(--sa-primary, #2563eb);
        color: var(--sa-surface, #ffffff);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
    }

    .import-v3-help {
        color: var(--sa-muted, #64748b);
        font-size: 13px;
        line-height: 1.6;
        margin-bottom: 14px;
    }

    .import-v3-file {
        width: 100%;
        background: var(--sa-surface, #ffffff);
        border: 2px dashed var(--sa-primary-soft, #93c5fd);
        border-radius: 16px;
        padding: 18px;
        min-height: 64px;
    }

    .import-v3-paste {
        width: 100%;
        min-height: 210px;
        resize: vertical;
        background: var(--sa-surface, #ffffff);
        border: 2px solid var(--sa-border-strong, #cbd5e1);
        border-radius: 16px;
        padding: 14px;
        font-family: Consolas, "Courier New", monospace;
        font-size: 13px;
        line-height: 1.5;
        outline: none;
        direction: ltr;
    }

    .import-v3-paste:focus,
    .import-v3-file:focus {
        border-color: var(--sa-primary, #2563eb);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }

    .import-v3-required {
        margin: 18px 0;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid var(--sa-success, #86efac);
        background: linear-gradient(135deg, var(--sa-surface-3, #ecfdf5), var(--sa-surface-3, #eff6ff));
    }

    .import-v3-required-title {
        color: var(--sa-success, #065f46);
        font-weight: 900;
        margin-bottom: 10px;
    }

    .import-v3-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .import-v3-badge {
        background: var(--sa-surface, #ffffff);
        color: var(--sa-info, #075985);
        border: 1px solid var(--sa-info, #bae6fd);
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 900;
    }

    .import-v3-note {
        background: var(--sa-surface-3, #fff7ed);
        border: 1px solid var(--sa-warning, #fed7aa);
        color: var(--sa-warning, #9a3412);
        border-radius: 16px;
        padding: 12px 14px;
        font-size: 13px;
        line-height: 1.6;
        margin-bottom: 18px;
    }

    .import-v3-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }

    .import-v3-summary {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    .import-v3-summary-card {
        background: var(--sa-surface, #ffffff);
        border: 1px solid var(--sa-border, #e2e8f0);
        border-radius: 16px;
        padding: 16px;
    }

    .import-v3-summary-card .label {
        font-size: 12px;
        color: var(--sa-muted, #64748b);
        font-weight: 800;
        margin-bottom: 6px;
    }

    .import-v3-summary-card .value {
        font-size: 28px;
        color: var(--sa-text, #0f172a);
        font-weight: 900;
    }

    .status-ready {
        color: var(--sa-success, #166534);
        font-weight: 900;
    }

    .status-error {
        color: var(--sa-danger, #991b1b);
        font-weight: 900;
    }

    .paste-visible-banner {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--sa-primary-soft, #dbeafe);
        color: var(--sa-primary, #1e40af);
        border: 1px solid var(--sa-primary-soft, #93c5fd);
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 900;
        margin-bottom: 10px;
    }
</style>

<div class="import-v3-wrap">
    <div class="import-v3-head">
        <div>
            <div class="paste-visible-banner">اللصق من إكسل مفعّل</div>
            <h1>@Model.PageTitle</h1>
            <p>ارفع ملفاً أو انسخ الصفوف من إكسل والصقها هنا مباشرة.</p>
        </div>

        <a asp-page="./Index" class="btn-secondary">رجوع للعطل</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-danger">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.ImportResult != null)
    {
        <div class="import-v3-card">
            <h2>نتيجة الاستيراد</h2>

            <div class="import-v3-summary">
                <div class="import-v3-summary-card">
                    <div class="label">أُنشئ</div>
                    <div class="value">@Model.ImportResult.CreatedCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">حُدّث</div>
                    <div class="value">@Model.ImportResult.UpdatedCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">متجاوَز</div>
                    <div class="value">@Model.ImportResult.SkippedCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">أخطاء</div>
                    <div class="value">@Model.ImportResult.ErrorCount</div>
                </div>
            </div>
        </div>
    }

    <div class="import-v3-card">
        <form method="post" enctype="multipart/form-data" asp-page-handler="Preview">
            <div class="import-v3-two">
                <div class="import-v3-box">
                    <div class="import-v3-box-title">
                        <span class="import-v3-step">1</span>
                        رفع ملف إكسل / CSV
                    </div>

                    <div class="import-v3-help">
                        اختر ملف xlsx أو csv جاهزاً. استخدم هذا إن كنت حفظت القالب كملف مسبقاً.
                    </div>

                    <input asp-for="ImportFile" type="file" accept=".xlsx,.csv" class="import-v3-file" />

                    <div class="import-v3-note" style="margin-top: 14px;">
                        إن رفعت ملفاً ولصقت بيانات في الوقت نفسه، سيُعتمد الملف المرفوع.
                    </div>
                </div>

                <div class="import-v3-box">
                    <div class="import-v3-box-title">
                        <span class="import-v3-step">2</span>
                        اللصق من إكسل
                    </div>

                    <div class="import-v3-help">
                        حدّد صف العناوين وصفوف البيانات في إكسل، اضغط Ctrl + C، ثم الصقها هنا بـ Ctrl + V.
                    </div>

                    <textarea asp-for="PastedData"
                              class="import-v3-paste"
                              placeholder="Name    HolidayDate&#10;New Year    2026-01-01"></textarea>
                </div>
            </div>

            <div class="import-v3-required">
                <div class="import-v3-required-title">الأعمدة المطلوبة لـ @Model.ImportType</div>

                <div class="import-v3-badges">
                    @foreach (var column in Model.RequiredColumns)
                    {
                        <span class="import-v3-badge">@column</span>
                    }
                </div>
            </div>

            <div class="import-v3-actions">
                <button type="submit" class="btn-primary">معاينة البيانات</button>
                <a asp-page="./Index" class="btn-secondary">إلغاء</a>
            </div>
        </form>
    </div>

    @if (Model.Preview != null)
    {
        <div class="import-v3-card">
            <div class="import-v3-head" style="margin-bottom: 0;">
                <div>
                    <h2>معاينة: @Model.Preview.FileName</h2>
                    <p>تُعرض أول @Model.Preview.PreviewLimit صفاً فقط. الاستيراد سيعالج كل الصفوف الصالحة.</p>
                </div>

                @if (Model.Preview.ReadyCount > 0)
                {
                    <form method="post" asp-page-handler="Import">
                        <input type="hidden" name="token" value="@Model.Preview.Token" />
                        <button type="submit" class="btn-primary">استيراد الصفوف الصالحة</button>
                    </form>
                }
            </div>

            <div class="import-v3-summary">
                <div class="import-v3-summary-card">
                    <div class="label">إجمالي الصفوف</div>
                    <div class="value">@Model.Preview.TotalRows</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">جاهز</div>
                    <div class="value">@Model.Preview.ReadyCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">إنشاء</div>
                    <div class="value">@Model.Preview.CreateCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">تحديث</div>
                    <div class="value">@Model.Preview.UpdateCount</div>
                </div>

                <div class="import-v3-summary-card">
                    <div class="label">أخطاء</div>
                    <div class="value">@Model.Preview.ErrorCount</div>
                </div>
            </div>
        </div>

        <div class="table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>الصف</th>
                        <th>الحالة</th>
                        <th>الإجراء</th>
                        <th>المفتاح</th>
                        <th>الرسالة</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Preview.Rows.Any())
                    {
                        foreach (var row in Model.Preview.Rows)
                        {
                            var statusClass = row.Status == "Ready" ? "status-ready" : "status-error";

                            <tr>
                                <td>@row.RowNumber</td>
                                <td class="@statusClass">@row.Status</td>
                                <td>@row.Action</td>
                                <td>@row.Key</td>
                                <td>@row.Message</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align:center;">
                                لا صفوف للمعاينة.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@page
@model SmartAttendance.Web.Pages.Holidays.IndexModel

@{
    ViewData["Title"] = "العطل الرسمية";
}

<div class="page-header">
    <div>
        <h1>العطل الرسمية</h1>
        <p>إدارة العطل الرسمية</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">استيراد إكسل</a>
        <a asp-page="./Create" class="btn-primary">+ إضافة عطلة</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث باسم العطلة أو وصفها..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>اسم العطلة</th>
                <th>التاريخ</th>
                <th>متكررة</th>
                <th>الوصف</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Holidays.Any())
            {
                foreach (var holiday in Model.Holidays)
                {
                    <tr>
                        <td>@holiday.Name</td>
                        <td>@holiday.HolidayDate</td>
                        <td>@(holiday.IsRecurring ? "نعم" : "لا")</td>
                        <td>@holiday.Description</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@holiday.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@holiday.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" style="text-align:center;">لا توجد عطل.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

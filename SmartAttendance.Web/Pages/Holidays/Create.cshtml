@page
@model SmartAttendance.Web.Pages.Holidays.CreateModel

@{
    ViewData["Title"] = "إضافة عطلة";
}

<div class="page-header">
    <div>
        <h1>إضافة عطلة</h1>
        <p>إضافة عطلة رسمية جديدة</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label asp-for="Holiday.Name">اسم العطلة</label>
            <input asp-for="Holiday.Name" class="form-control" />
            <span asp-validation-for="Holiday.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Holiday.HolidayDate">تاريخ العطلة</label>
            <input asp-for="Holiday.HolidayDate" type="date" class="form-control" />
            <span asp-validation-for="Holiday.HolidayDate" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="Holiday.IsRecurring" />
                متكررة كل سنة
            </label>
        </div>

        <div class="form-group">
            <label asp-for="Holiday.Description">الوصف</label>
            <input asp-for="Holiday.Description" class="form-control" />
            <span asp-validation-for="Holiday.Description" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">حفظ</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

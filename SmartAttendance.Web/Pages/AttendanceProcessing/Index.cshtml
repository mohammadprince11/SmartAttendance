@page
@model SmartAttendance.Web.Pages.AttendanceProcessing.IndexModel

@{
    ViewData["Title"] = "Attendance Processing";
}

<div class="page-header">
    <div>
        <h1>Attendance Processing</h1>
        <p>Calculate attendance status using records, shifts, approved leaves, and holidays</p>
    </div>

    <a asp-page="/AttendanceRecords/Index" class="btn-secondary">Attendance Records</a>
</div>

<div class="table-card">
    <form method="get" class="search-form">
        <input asp-for="FromDate" type="date" class="form-control" />

        <input asp-for="ToDate" type="date" class="form-control" />

        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="Search employee, shift, status, leave, holiday..." />

        <button type="submit" class="btn-primary">Process</button>
        <a asp-page="./Index" class="btn-secondary">Clear</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Employee No</th>
                <th>Employee Name</th>
                <th>Shift</th>
                <th>Check In</th>
                <th>Check Out</th>
                <th>Work Hours</th>
                <th>Late</th>
                <th>Early Leave</th>
                <th>Calculated Status</th>
                <th>Leave Type</th>
                <th>Holiday</th>
                <th>Original Status</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Records.Any())
            {
                foreach (var item in Model.Records)
                {
                    <tr>
                        <td>@item.AttendanceDate</td>
                        <td>@item.EmployeeNo</td>
                        <td>@item.EmployeeName</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ShiftName))
                            {
                                <span>@item.ShiftCode - @item.ShiftName</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>@(item.CheckIn?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td>@(item.CheckOut?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td>@(item.WorkingHours?.ToString("0.00") ?? "-")</td>
                        <td>@item.LateMinutes min</td>
                        <td>@(item.EarlyLeaveMinutes.HasValue ? item.EarlyLeaveMinutes + " min" : "-")</td>
                        <td>@item.CalculatedStatus</td>
                        <td>@(item.LeaveType ?? "-")</td>
                        <td>@(item.HolidayName ?? "-")</td>
                        <td>@item.OriginalStatus</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="13" style="text-align:center;">
                        No processed attendance records found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

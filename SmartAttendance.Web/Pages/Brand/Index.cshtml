@page
@{
    ViewData["Title"] = "NEXORA Brand";
}

<link rel="stylesheet" href="~/css/nexora-brand-showcase.css" asp-append-version="true" />

<div class="brand-showcase">
    <section class="brand-hero nexora-pattern">
        <div>
            <img src="~/brand/nexora-logo.svg" alt="NEXORA" class="brand-logo-wide" />
            <h1>NEXORA</h1>
            <p>منصة ذكية، فخمة، دقيقة، وجاهزة للمستقبل.</p>
            <div class="brand-hero-actions">
                <span>Dark</span>
                <span>Premium</span>
                <span>Intelligent</span>
                <span>Precise</span>
                <span>Future-ready</span>
            </div>
        </div>
    </section>

    <section class="brand-grid">
        <div class="brand-card">
            <h2>الفكرة</h2>
            <p>هوية تقنية مؤسسية لا تكشف النظام مباشرة، بل تعطي إحساس منصة ذكية شاملة قابلة للتوسع.</p>
        </div>

        <div class="brand-card">
            <h2>النبرة</h2>
            <p>واثقة، مختصرة، ذكية، مؤسسية، بدون مبالغة.</p>
        </div>

        <div class="brand-card">
            <h2>الرسالة</h2>
            <p>Intelligent Solutions. Limitless Impact.</p>
        </div>
    </section>

    <section class="brand-panel">
        <h2>ألوان الهوية</h2>
        <div class="swatches">
            <div class="swatch" style="--c:#07121F"><span>Midnight Navy</span><strong>#07121F</strong></div>
            <div class="swatch" style="--c:#0F2233"><span>Deep Space</span><strong>#0F2233</strong></div>
            <div class="swatch" style="--c:#12D9E3"><span>Electric Teal</span><strong>#12D9E3</strong></div>
            <div class="swatch" style="--c:#D7B26D"><span>Champagne Gold</span><strong>#D7B26D</strong></div>
            <div class="swatch" style="--c:#E6EAEE"><span>Soft Silver</span><strong>#E6EAEE</strong></div>
        </div>
    </section>

    <section class="brand-panel">
        <h2>نمط الواجهة</h2>
        <div class="ui-sample">
            <div class="sample-sidebar"></div>
            <div class="sample-content">
                <div class="sample-topbar"></div>
                <div class="sample-cards">
                    <div></div>
                    <div></div>
                    <div></div>
                </div>
                <div class="sample-table"></div>
            </div>
        </div>
    </section>

    <section class="brand-panel">
        <h2>نصوص الإطلاق التشويقي</h2>
        <div class="launch-copy">
            <div>
                <strong>NEXORA</strong>
                <span>A New Intelligence Is Coming</span>
                <small>Coming Soon</small>
            </div>
            <div>
                <strong>نيكسورا</strong>
                <span>شيء أذكى قادم</span>
                <small>قريباً</small>
            </div>
        </div>
    </section>
</div>

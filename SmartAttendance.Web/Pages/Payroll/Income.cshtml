@page "/Payroll/Income"
@model SmartAttendance.Web.Pages.Payroll.IncomeModel
@using System.Text.Json

@{
    ViewData["Title"] = "حركات الدخل";
    var months = new[] { "يناير","فبراير","مارس","أبريل","مايو","يونيو","يوليو","أغسطس","سبتمبر","أكتوبر","نوفمبر","ديسمبر" };
    var itemsJson = JsonSerializer.Serialize(Model.IncomeItems.Select(i => new { i.Id, i.Name, i.Taxable, i.DefaultValue }));
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .in-page { display:flex; flex-direction:column; gap:14px; color:var(--sa-text,#DCEAF4); }
    .in-head { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
        padding:16px 20px; border:1px solid rgba(73,111,151,.22); border-radius:20px;
        background:radial-gradient(circle at 92% 8%,rgba(74,222,128,.12),transparent 38%),linear-gradient(135deg,rgba(9,31,52,.95),rgba(5,16,29,.95)); }
    html[data-theme="light"] .in-head { background:linear-gradient(135deg,#fff,#f2f7fb); }
    .in-head h1 { margin:0; font-size:20px; font-weight:1000; }
    .in-head p { margin:2px 0 0; font-size:12px; color:var(--sa-muted,#8FA8BC); font-weight:800; }
    .in-btn { min-height:36px; padding:7px 16px; border-radius:12px; border:0; font-size:13px; font-weight:900; cursor:pointer; background:linear-gradient(135deg,#4ade80,#22c55e); color:#04141d; }
    .in-btn.ghost { background:transparent; border:1px solid rgba(73,111,151,.3); color:inherit; }
    .in-btn.sm { min-height:29px; padding:4px 10px; font-size:11px; }

    .in-kpis { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:10px; }
    .in-kpi { padding:14px 16px; border:1px solid rgba(73,111,151,.22); border-radius:16px; background:var(--sa-surface,rgba(8,25,43,.9)); position:relative; overflow:hidden; }
    .in-kpi::before { content:""; position:absolute; inset-inline-start:0; top:0; bottom:0; width:4px; background:var(--acc,#4ade80); }
    .in-kpi b { display:block; font-size:20px; font-weight:1000; direction:ltr; }
    .in-kpi span { font-size:11px; font-weight:900; color:var(--sa-muted,#8FA8BC); }

    .in-bar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
    .in-filter { display:flex; align-items:center; gap:8px; font-size:12px; font-weight:900; color:var(--sa-muted,#8FA8BC); flex-wrap:wrap; }
    .in-filter select, .in-filter input { min-height:34px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:4px 10px; font-weight:900; }
    html[data-theme="light"] .in-filter select, html[data-theme="light"] .in-filter input { background:#fff; }

    .in-card { border:1px solid rgba(73,111,151,.22); border-radius:18px; overflow-x:auto; background:var(--sa-surface,rgba(8,25,43,.9)); }
    .in-table { width:100%; border-collapse:collapse; font-size:13px; min-width:820px; }
    .in-table th { text-align:start; padding:12px 14px; font-size:11px; font-weight:1000; color:var(--sa-muted,#8FA8BC); border-bottom:1px solid rgba(73,111,151,.22); background:rgba(0,0,0,.14); }
    html[data-theme="light"] .in-table th { background:#f2f7fb; }
    .in-table td { padding:11px 14px; border-bottom:1px solid rgba(143,168,188,.08); vertical-align:middle; }
    .in-table tbody tr:hover td { background:rgba(74,222,128,.05); }
    .in-table tfoot td { padding:12px 14px; font-weight:1000; border-top:2px solid rgba(74,222,128,.35); background:rgba(0,0,0,.1); }
    .in-emp b { font-weight:900; } .in-emp span { display:block; font-size:11px; color:var(--sa-muted,#8FA8BC); }
    .in-amt { direction:ltr; font-weight:900; color:#4ade80; text-align:start; }
    .in-chip { display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:900; background:rgba(18,217,227,.1); color:#12D9E3; }
    .in-chip.no { background:rgba(143,168,188,.16); color:#8FA8BC; }
    .in-empty { padding:34px; text-align:center; color:var(--sa-muted,#8FA8BC); font-weight:800; }
    .in-alert { padding:10px 14px; border-radius:12px; font-size:13px; font-weight:800; border:1px solid rgba(74,222,128,.35); background:rgba(74,222,128,.08); }
    .in-alert.err { border-color:rgba(248,113,113,.4); background:rgba(248,113,113,.08); color:#f87171; }
    .in-actions { display:flex; gap:6px; justify-content:flex-end; }
    .in-actions form { display:inline; }
    .in-form label { font-size:12px; font-weight:900; display:flex; flex-direction:column; gap:4px; }
    .in-form select, .in-form input, .in-form textarea { min-height:38px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:6px 10px; font-family:inherit; }
    html[data-theme="light"] .in-form select, html[data-theme="light"] .in-form input, html[data-theme="light"] .in-form textarea { background:#fff; }
</style>

<section class="in-page" dir="rtl">
    <header class="in-head">
        <div>
            <h1>حركات الدخل</h1>
            <p>مكافآت وحوافز وبدلات لمرة واحدة لكل موظف×فترة — تُضاف تلقائياً لاحتساب المسير كبنود دخل.</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <a class="in-btn ghost" href="/Payroll/Runs">← المسير</a>
            <button type="button" class="in-btn" onclick="inOpen(0)">+ حركة دخل</button>
        </div>
    </header>

    <div class="in-kpis">
        <div class="in-kpi" style="--acc:#4ade80"><b>@Model.TotalCount</b><span>عدد الحركات</span></div>
        <div class="in-kpi" style="--acc:#12D9E3"><b>@Model.TotalAmount.ToString("#,0.##")</b><span>إجمالي الدخل للفترة</span></div>
        <div class="in-kpi" style="--acc:#a78bfa"><b>@Model.EmployeesCovered</b><span>الموظفون المشمولون</span></div>
        <div class="in-kpi" style="--acc:#facc15"><b>@($"{Model.Month:00}/{Model.Year}")</b><span>الفترة الحالية</span></div>
    </div>

    <form method="get" class="in-bar">
        <div class="in-filter">
            <span>الفترة:</span>
            <select name="Month" onchange="this.form.submit()">
                @for (var m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option>
                }
            </select>
            <select name="Year" onchange="this.form.submit()">
                @for (var y = DateTime.Today.Year - 3; y <= DateTime.Today.Year + 1; y++)
                {
                    <option value="@y" selected="@(y == Model.Year)">@y</option>
                }
            </select>
        </div>
        <div class="in-filter">
            <input type="text" name="Search" value="@Model.Search" placeholder="بحث باسم/رمز الموظف أو البند" style="min-width:240px" />
            <button type="submit" class="in-btn ghost sm">بحث</button>
        </div>
    </form>

    @if (TempData["PayrollMessage"] != null)
    {
        <div class="in-alert @((TempData["PayrollOk"] as bool?) == false ? "err" : "")">@TempData["PayrollMessage"]</div>
    }

    <div class="in-card">
        @if (Model.Items.Count == 0)
        {
            <div class="in-empty">لا حركات دخل لفترة @($"{Model.Month:00}/{Model.Year}") — أضف حركة بـ«+ حركة دخل».</div>
        }
        else
        {
            <table class="in-table">
                <thead>
                    <tr><th>الموظف</th><th>القسم</th><th>بند الدخل</th><th>المبلغ</th><th>خاضع للضريبة</th><th>ملاحظة</th><th style="text-align:end">إجراءات</th></tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>
                            <td class="in-emp"><b>@t.EmployeeName</b><span>@t.EmployeeNo</span></td>
                            <td style="font-size:12px">@(string.IsNullOrWhiteSpace(t.Department) ? "—" : t.Department)</td>
                            <td><b>@t.ItemName</b></td>
                            <td class="in-amt">@t.Amount.ToString("#,0.##")</td>
                            <td><span class="in-chip @(t.Taxable ? "" : "no")">@(t.Taxable ? "خاضع" : "معفى")</span></td>
                            <td style="font-size:12px;color:var(--sa-muted,#8FA8BC)">@(string.IsNullOrWhiteSpace(t.Note) ? "—" : t.Note)</td>
                            <td>
                                <div class="in-actions">
                                    <button type="button" class="in-btn ghost sm" onclick='inOpen(@t.Id, @Html.Raw(JsonSerializer.Serialize(new { t.EmployeeId, t.SalaryItemId, t.ItemName, t.Amount, t.Taxable, t.Note, t.Year, t.Month })))'>تعديل</button>
                                    <form method="post" asp-page-handler="Delete"><input type="hidden" name="id" value="@t.Id" /><button class="in-btn ghost sm" type="submit" style="color:#f87171" data-zyconfirm="حذف الحركة؟">حذف</button></form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr><td colspan="3">الإجمالي</td><td class="in-amt">@Model.TotalAmount.ToString("#,0.##")</td><td colspan="3"></td></tr>
                </tfoot>
            </table>
        }
    </div>

    @* سلايد إضافة/تعديل حركة دخل *@
    <div class="hrms-slideover-backdrop" id="in-backdrop" onclick="inClose()"></div>
    <aside class="hrms-slideover" id="in-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2 id="in-title">حركة دخل جديدة</h2>
            <button type="button" class="hrms-slideover-close" onclick="inClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="Save" class="in-form" style="display:flex;flex-direction:column;gap:12px">
                <input type="hidden" name="Id" id="in-Id" value="0" />
                <input type="hidden" name="ItemName" id="in-ItemName" />
                <input type="hidden" name="SalaryItemId" id="in-SalaryItemId" value="0" />

                <label>الموظف *
                    <select name="EmployeeId" id="in-EmployeeId" required>
                        <option value="">— اختر الموظف —</option>
                        @foreach (var e in Model.Employees)
                        {
                            <option value="@e.Id">@e.SearchText</option>
                        }
                    </select>
                </label>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    <label>الشهر
                        <select name="FMonth" id="in-FMonth">
                            @for (var m = 1; m <= 12; m++)
                            {
                                <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option>
                            }
                        </select>
                    </label>
                    <label>السنة<input type="number" name="FYear" id="in-FYear" min="2000" max="2100" value="@Model.Year" /></label>
                </div>

                <label>بند الدخل *
                    <select id="in-ItemSelect" onchange="inItemChanged()">
                        <option value="">— اختر من الكتالوج —</option>
                        @foreach (var i in Model.IncomeItems)
                        {
                            <option value="@i.Id">@i.Name</option>
                        }
                        <option value="__custom">أخرى (نص حر)…</option>
                    </select>
                </label>
                <label id="in-CustomWrap" hidden>اسم البند (نص حر)
                    <input type="text" id="in-CustomName" oninput="document.getElementById('in-ItemName').value=this.value" />
                </label>

                <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:end">
                    <label>المبلغ *<input type="number" name="Amount" id="in-Amount" step="0.01" min="0" required /></label>
                    <label style="flex-direction:row;align-items:center;gap:6px;min-height:38px"><input type="checkbox" name="Taxable" value="true" id="in-Taxable" checked /> خاضع للضريبة</label>
                </div>

                <label>ملاحظة<textarea name="Note" id="in-Note" rows="2"></textarea></label>

                <button type="submit" class="in-btn">حفظ الحركة</button>
            </form>
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        var IN_ITEMS = @Html.Raw(itemsJson);

        function inItemChanged() {
            var sel = document.getElementById('in-ItemSelect');
            var val = sel.value;
            var customWrap = document.getElementById('in-CustomWrap');
            if (val === '__custom') {
                customWrap.hidden = false;
                document.getElementById('in-SalaryItemId').value = 0;
                document.getElementById('in-ItemName').value = document.getElementById('in-CustomName').value || '';
                return;
            }
            customWrap.hidden = true;
            if (!val) { document.getElementById('in-ItemName').value = ''; document.getElementById('in-SalaryItemId').value = 0; return; }
            var it = IN_ITEMS.find(function (x) { return String(x.Id) === val; });
            if (it) {
                document.getElementById('in-ItemName').value = it.Name;
                document.getElementById('in-SalaryItemId').value = it.Id;
                document.getElementById('in-Taxable').checked = !!it.Taxable;
                if (it.DefaultValue && !document.getElementById('in-Amount').value) document.getElementById('in-Amount').value = it.DefaultValue;
            }
        }

        function inOpen(id, data) {
            var f = document.querySelector('#in-slide form'); f.reset();
            document.getElementById('in-Id').value = id || 0;
            document.getElementById('in-title').textContent = id ? 'تعديل حركة دخل' : 'حركة دخل جديدة';
            document.getElementById('in-CustomWrap').hidden = true;
            document.getElementById('in-ItemSelect').value = '';
            document.getElementById('in-SalaryItemId').value = 0;
            document.getElementById('in-ItemName').value = '';

            if (id && data) {
                document.getElementById('in-EmployeeId').value = data.EmployeeId;
                document.getElementById('in-FMonth').value = data.Month;
                document.getElementById('in-FYear').value = data.Year;
                document.getElementById('in-Amount').value = data.Amount;
                document.getElementById('in-Taxable').checked = !!data.Taxable;
                document.getElementById('in-Note').value = data.Note || '';
                document.getElementById('in-ItemName').value = data.ItemName || '';
                if (data.SalaryItemId && IN_ITEMS.find(function (x) { return x.Id === data.SalaryItemId; })) {
                    document.getElementById('in-ItemSelect').value = String(data.SalaryItemId);
                    document.getElementById('in-SalaryItemId').value = data.SalaryItemId;
                } else {
                    document.getElementById('in-ItemSelect').value = '__custom';
                    document.getElementById('in-CustomWrap').hidden = false;
                    document.getElementById('in-CustomName').value = data.ItemName || '';
                }
            }
            document.getElementById('in-slide').classList.add('open');
            document.getElementById('in-backdrop').classList.add('open');
        }
        function inClose() {
            document.getElementById('in-slide').classList.remove('open');
            document.getElementById('in-backdrop').classList.remove('open');
        }
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') inClose(); });
    </script>
}

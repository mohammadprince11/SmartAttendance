@page "/Payroll/Transactions"
@model SmartAttendance.Web.Pages.Payroll.TransactionsModel
@using System.Text.Json

@{
    ViewData["Title"] = Model.TypeTitle;
    var months = new[] { "يناير","فبراير","مارس","أبريل","مايو","يونيو","يوليو","أغسطس","سبتمبر","أكتوبر","نوفمبر","ديسمبر" };
    var acc = Model.IsDeduction ? "#f87171" : "#4ade80";
    var catalogJson = JsonSerializer.Serialize(Model.Catalog.Select(i => new { i.Id, i.Name, i.Taxable, i.DefaultValue }));
    var empJson = JsonSerializer.Serialize(Model.Employees.Select(e => new { e.Id, e.No, e.Name }));
    string J(object o) => JsonSerializer.Serialize(o);
    string Dt(DateOnly? d) => d?.ToString("yyyy-MM-dd") ?? "";
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<style>
    .tx-page { display:flex; flex-direction:column; gap:14px; color:var(--sa-text,#DCEAF4); --acc:@acc; }
    .tx-head { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
        padding:16px 20px; border:1px solid rgba(73,111,151,.22); border-radius:20px;
        background:radial-gradient(circle at 92% 8%,color-mix(in srgb,var(--acc) 14%,transparent),transparent 40%),linear-gradient(135deg,rgba(9,31,52,.95),rgba(5,16,29,.95)); }
    html[data-theme="light"] .tx-head { background:linear-gradient(135deg,#fff,#f2f7fb); }
    .tx-head h1 { margin:0; font-size:20px; font-weight:1000; }
    .tx-head p { margin:2px 0 0; font-size:12px; color:var(--sa-muted,#8FA8BC); font-weight:800; }
    .tx-btn { min-height:36px; padding:7px 16px; border-radius:12px; border:0; font-size:13px; font-weight:900; cursor:pointer; background:var(--acc); color:#04141d; }
    .tx-btn.ghost { background:transparent; border:1px solid rgba(73,111,151,.3); color:inherit; }
    .tx-btn.sm { min-height:29px; padding:4px 10px; font-size:11px; }
    .tx-btn.icon { width:38px; padding:0; font-size:17px; display:inline-flex; align-items:center; justify-content:center; }
    .tx-btn.icon:hover { background:color-mix(in srgb,var(--acc) 18%,transparent); border-color:color-mix(in srgb,var(--acc) 45%,transparent); }
    .tx-btn.danger { background:rgba(248,113,113,.16); border:1px solid rgba(248,113,113,.45); color:#f87171; }
    .tx-btn.danger:hover { background:rgba(248,113,113,.26); }
    .tx-btn.warn { background:rgba(250,204,21,.14); border:1px solid rgba(250,204,21,.45); color:#facc15; }
    .tx-btn.warn:hover { background:rgba(250,204,21,.24); }
    .tx-bulkbar { position:fixed; bottom:18px; inset-inline:0; margin-inline:auto; width:max-content; max-width:calc(100% - 32px);
        z-index:60; display:none; gap:10px; align-items:center; flex-wrap:wrap; padding:12px 18px;
        border:1px solid color-mix(in srgb,var(--acc) 45%,transparent); border-radius:16px;
        background:var(--sa-surface,rgba(8,25,43,.98)); box-shadow:0 14px 44px rgba(0,0,0,.55); }
    html[data-theme="light"] .tx-bulkbar { background:#fff; }
    .tx-bulkbar.show { display:flex; }
    .tx-bulkbar b { font-size:13px; font-weight:900; color:inherit; margin-inline-end:6px; }
    .tx-bulkbar b span { color:var(--acc); }
    .tx-seg { display:inline-flex; border:1px solid rgba(73,111,151,.3); border-radius:12px; overflow:hidden; }
    .tx-seg a { padding:7px 16px; font-size:13px; font-weight:900; color:inherit; text-decoration:none; }
    .tx-seg a.on { background:var(--acc); color:#04141d; }
    .tx-tabs { display:flex; gap:2px; border-bottom:1px solid rgba(73,111,151,.22); }
    .tx-tabs a { padding:11px 22px; font-size:13px; font-weight:900; color:var(--sa-muted,#8FA8BC); text-decoration:none; border-bottom:3px solid transparent; display:flex; align-items:center; gap:6px; }
    .tx-tabs a.on { color:var(--acc); border-bottom-color:var(--acc); }
    .tx-lockbanner { display:flex; align-items:center; gap:8px; padding:10px 14px; border-radius:12px; font-size:13px; font-weight:900; border:1px solid rgba(250,204,21,.4); background:rgba(250,204,21,.08); color:#facc15; }

    .tx-kpis { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:10px; }
    .tx-kpi { padding:14px 16px; border:1px solid rgba(73,111,151,.22); border-radius:16px; background:var(--sa-surface,rgba(8,25,43,.9)); position:relative; overflow:hidden; }
    .tx-kpi::before { content:""; position:absolute; inset-inline-start:0; top:0; bottom:0; width:4px; background:var(--acc); }
    .tx-kpi b { display:block; font-size:20px; font-weight:1000; direction:ltr; }
    .tx-kpi span { font-size:11px; font-weight:900; color:var(--sa-muted,#8FA8BC); }

    .tx-bar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
    .tx-filter { display:flex; align-items:center; gap:8px; font-size:12px; font-weight:900; color:var(--sa-muted,#8FA8BC); flex-wrap:wrap; }
    .tx-filter select, .tx-filter input { min-height:34px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:4px 10px; font-weight:900; }
    html[data-theme="light"] .tx-filter select, html[data-theme="light"] .tx-filter input { background:#fff; }
    .tx-adv-panel { flex-basis:100%; display:flex; flex-direction:column; gap:14px; padding:14px 16px; border:1px dashed rgba(73,111,151,.35); border-radius:14px; }
    .tx-adv-panel select, .tx-adv-panel input { min-height:34px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:4px 10px; font-weight:800; width:100%; }
    html[data-theme="light"] .tx-adv-panel select, html[data-theme="light"] .tx-adv-panel input { background:#fff; }
    .tx-adv-sec { display:flex; align-items:center; gap:8px; font-size:12px; font-weight:1000; color:var(--acc); margin-bottom:-4px; }
    .tx-adv-sec::after { content:""; flex:1; height:1px; background:color-mix(in srgb,var(--acc) 30%,transparent); }
    .tx-adv-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(190px,1fr)); gap:10px; }
    .tx-fld { display:flex; flex-direction:column; gap:4px; font-size:11px; font-weight:900; color:var(--sa-muted,#8FA8BC); }
    .tx-fld > span { display:flex; align-items:center; gap:6px; }
    .tx-fld.soon { opacity:.6; }
    .tx-fld.soon select, .tx-fld.soon input { cursor:not-allowed; background:rgba(0,0,0,.28); }
    html[data-theme="light"] .tx-fld.soon select, html[data-theme="light"] .tx-fld.soon input { background:#eef2f6; }
    .tx-soon { font-size:9px; font-weight:900; padding:1px 6px; border-radius:999px; background:rgba(250,204,21,.16); color:#facc15; }
    .tx-adv-actions { display:flex; gap:8px; align-items:center; }
    .tx-fld-range { display:flex; gap:6px; } .tx-fld-range input { width:100%; }

    .tx-card { border:1px solid rgba(73,111,151,.22); border-radius:18px; overflow-x:auto; background:var(--sa-surface,rgba(8,25,43,.9)); }
    .tx-table { width:100%; border-collapse:collapse; font-size:13px; min-width:960px; }
    .tx-table th { text-align:start; padding:12px 14px; font-size:11px; font-weight:1000; color:var(--sa-muted,#8FA8BC); border-bottom:1px solid rgba(73,111,151,.22); background:rgba(0,0,0,.14); }
    html[data-theme="light"] .tx-table th { background:#f2f7fb; }
    .tx-table td { padding:11px 14px; border-bottom:1px solid rgba(143,168,188,.08); vertical-align:middle; }
    .tx-table tbody tr:hover td { background:color-mix(in srgb,var(--acc) 6%,transparent); }
    .tx-table tfoot td { padding:12px 14px; font-weight:1000; border-top:2px solid color-mix(in srgb,var(--acc) 40%,transparent); background:rgba(0,0,0,.1); }
    .tx-ref { direction:ltr; font-weight:900; font-size:12px; }
    .tx-emp b { font-weight:900; } .tx-emp span { display:block; font-size:11px; color:var(--sa-muted,#8FA8BC); }
    .tx-amt { direction:ltr; font-weight:900; color:var(--acc); text-align:start; }
    .tx-chip { display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:900; }
    .tx-chip.in { background:rgba(18,217,227,.1); color:#12D9E3; }
    .tx-chip.out { background:rgba(250,204,21,.14); color:#facc15; }
    .tx-chip.ap { background:rgba(74,222,128,.14); color:#4ade80; }
    .tx-chip.dr { background:rgba(143,168,188,.16); color:#8FA8BC; }
    .tx-empty { padding:34px; text-align:center; color:var(--sa-muted,#8FA8BC); font-weight:800; }
    .tx-alert { padding:10px 14px; border-radius:12px; font-size:13px; font-weight:800; border:1px solid rgba(74,222,128,.35); background:rgba(74,222,128,.08); }
    .tx-alert.err { border-color:rgba(248,113,113,.4); background:rgba(248,113,113,.08); color:#f87171; }
    .tx-actions { display:flex; gap:6px; justify-content:flex-end; } .tx-actions form { display:inline; }

    /* النموذج */
    .tx-form label { font-size:12px; font-weight:900; display:flex; flex-direction:column; gap:4px; }
    .tx-form select, .tx-form input, .tx-form textarea { min-height:38px; border-radius:10px; border:1px solid rgba(73,111,151,.25); background:rgba(0,0,0,.16); color:inherit; padding:6px 10px; font-family:inherit; }
    html[data-theme="light"] .tx-form select, html[data-theme="light"] .tx-form input, html[data-theme="light"] .tx-form textarea { background:#fff; }
    .tx-toggle { display:flex; align-items:center; justify-content:space-between; padding:9px 12px; border:1px solid rgba(73,111,151,.2); border-radius:10px; font-size:13px; font-weight:900; }
    .tx-toggle input { width:auto; min-height:auto; }
    .tx-seg2 { display:inline-flex; border:1px solid rgba(73,111,151,.3); border-radius:10px; overflow:hidden; }
    .tx-seg2 label { flex-direction:row; padding:8px 14px; cursor:pointer; margin:0; }
    .tx-seg2 label.on { background:var(--acc); color:#04141d; }
    .tx-seg2 input { display:none; }
    .tx-sub { display:none; flex-direction:column; gap:10px; padding:10px 12px; border:1px dashed rgba(73,111,151,.3); border-radius:10px; background:rgba(0,0,0,.08); }
    .tx-sub.show { display:flex; }
    .tx-grid2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .tx-adv-toggle { align-self:flex-start; background:transparent; border:1px dashed rgba(73,111,151,.4); color:var(--sa-muted,#8FA8BC); border-radius:10px; padding:8px 14px; font-size:12px; font-weight:900; cursor:pointer; }
    .tx-adv-toggle.open { color:var(--acc); border-color:var(--acc); }
    .tx-hint { font-size:12px; font-weight:800; color:var(--sa-muted,#8FA8BC); padding:2px 2px 6px; }
</style>

<section class="tx-page" dir="rtl">
    <header class="tx-head">
        <div>
            <h1>@Model.TypeTitle</h1>
            <p>حركات مالية فردية لكل موظف×فترة تُغذّي المسير — نوع الدفعة، أثر رجعي، جدولة أقساط، مركز تكلفة.</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <span class="tx-seg">
                <a href="/Payroll/Transactions?type=Income" class="@(Model.IsDeduction ? "" : "on")">دخل</a>
                <a href="/Payroll/Transactions?type=Deduction" class="@(Model.IsDeduction ? "on" : "")">اقتطاع</a>
            </span>
            <a class="tx-btn ghost" href="/Payroll/Runs">← المسير</a>
            @if (!Model.IsReadOnly)
            {
                <button type="button" class="tx-btn ghost icon" title="دخل جماعي" aria-label="دخل جماعي" onclick="massOpen()">👥</button>
                <button type="button" class="tx-btn ghost icon" title="استيراد الحركات (إكسل/CSV)" aria-label="استيراد الحركات" onclick="impOpen()">📥</button>
                <button type="button" class="tx-btn" onclick="txOpen(0)">+ حركة جديدة</button>
            }
        </div>
    </header>

    <div class="tx-tabs">
        <a href="/Payroll/Transactions?type=@Model.Type&Year=@Model.Year&Month=@Model.Month&Lock=Open" class="@(Model.IsReadOnly ? "" : "on")">حركات غير مقفلة</a>
        <a href="/Payroll/Transactions?type=@Model.Type&Year=@Model.Year&Month=@Model.Month&Lock=Locked" class="@(Model.IsReadOnly ? "on" : "")">🔒 حركات مقفلة</a>
    </div>

    @if (Model.IsReadOnly && Model.Items.Count > 0)
    {
        <div class="tx-lockbanner">🔒 هذه الحركات دخلت مسيراً مقفلاً/معتمداً — للعرض فقط، لا تُعدّل ولا تُحذف.</div>
    }

    <div class="tx-kpis">
        <div class="tx-kpi"><b>@Model.TotalCount</b><span>عدد الحركات</span></div>
        <div class="tx-kpi"><b>@Model.TotalAmount.ToString("#,0.##")</b><span>الإجمالي للفترة</span></div>
        <div class="tx-kpi"><b>@Model.EmployeesCovered</b><span>الموظفون المشمولون</span></div>
        <div class="tx-kpi"><b>@($"{Model.Month:00}/{Model.Year}")</b><span>الفترة الحالية</span></div>
    </div>

    <form method="get" class="tx-bar">
        <input type="hidden" name="Type" value="@Model.Type" />
        <input type="hidden" name="Lock" value="@Model.Lock" />
        <div class="tx-filter">
            <span>الفترة:</span>
            <select name="Month" onchange="this.form.submit()">
                @for (var m = 1; m <= 12; m++)
                { <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option> }
            </select>
            <select name="Year" onchange="this.form.submit()">
                @for (var y = DateTime.Today.Year - 3; y <= DateTime.Today.Year + 1; y++)
                { <option value="@y" selected="@(y == Model.Year)">@y</option> }
            </select>
            <select name="Item" onchange="this.form.submit()">
                <option value="">كل البنود</option>
                @foreach (var i in Model.Catalog)
                { <option value="@i.Id" selected="@(Model.Item == i.Id)">@i.Name</option> }
            </select>
            <select name="Status" onchange="this.form.submit()">
                <option value="">كل الحالات</option>
                <option value="Approved" selected="@(Model.Status == "Approved")">معتمد</option>
                <option value="Draft" selected="@(Model.Status == "Draft")">مسودة</option>
            </select>
        </div>
        <div class="tx-filter">
            <input type="text" name="Search" value="@Model.Search" placeholder="بحث: موظف/بند/رقم مرجعي" style="min-width:200px" />
            <button type="submit" class="tx-btn ghost sm">بحث</button>
            <button type="button" class="tx-btn @(Model.HasAdvanced ? "" : "ghost") sm" id="adv-toggle-btn" title="فلاتر البحث المتقدم" onclick="advToggle()" style="display:inline-flex;align-items:center;gap:6px">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                <span>الفلاتر@(Model.HasAdvanced ? " (مفعّلة)" : "")</span>
            </button>
        </div>
        <div id="adv-panel" class="tx-adv-panel" style="@(Model.HasAdvanced ? "" : "display:none")">

            @* ===== تصفية الموظف (هيكل مطابق لكيان) ===== *@
            <div class="tx-adv-sec">تصفية الموظف</div>
            <div class="tx-adv-grid">
                <label class="tx-fld"><span>رمز / اسم الموظف</span>
                    <div class="empk-field">
                        <input type="text" id="adv-emp-name" class="empk-name" placeholder="اسم الموظف" readonly value="@(Model.Emp is > 0 ? Model.Employees.FirstOrDefault(e => e.Id == Model.Emp)?.Name : "")" />
                        <input type="text" id="adv-emp-code" class="empk-code" placeholder="رمز" autocomplete="off" value="@(Model.Emp is > 0 ? Model.Employees.FirstOrDefault(e => e.Id == Model.Emp)?.No : "")" />
                    </div>
                    <input type="hidden" name="Emp" id="adv-Emp" value="@(Model.Emp?.ToString() ?? "")" />
                </label>
                <label class="tx-fld"><span>المسمى الوظيفي</span>
                    <select name="JobTitle">
                        <option value="">الكل</option>
                        @foreach (var s in Model.JobTitles)
                        { <option value="@s" selected="@(Model.JobTitle == s)">@s</option> }
                    </select>
                </label>
                <label class="tx-fld"><span>القسم</span>
                    <select name="Dept">
                        <option value="">كل الأقسام</option>
                        @foreach (var s in Model.Departments)
                        { <option value="@s" selected="@(Model.Dept == s)">@s</option> }
                    </select>
                </label>
                <label class="tx-fld"><span>الفرع / الموقع</span>
                    <select name="Branch">
                        <option value="">كل الفروع</option>
                        @foreach (var s in Model.Branches)
                        { <option value="@s" selected="@(Model.Branch == s)">@s</option> }
                    </select>
                </label>
                <label class="tx-fld soon"><span>وحدة عمل <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>الهيكلية <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>كفيل <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>نوع العقد <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>مجموعة الموظفين <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>تاريخ التعيين <span class="tx-soon">قريباً</span></span>
                    <input type="date" disabled />
                </label>
                <label class="tx-fld soon"><span>حالة الموظف <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>نشط</option></select>
                </label>
            </div>

            @* ===== تصفية الحركة ===== *@
            <div class="tx-adv-sec">تصفية الحركة</div>
            <div class="tx-adv-grid">
                <label class="tx-fld"><span>الرقم المرجعي</span>
                    <input type="text" name="RefNo" value="@Model.RefNo" placeholder="IN26-…" />
                </label>
                <label class="tx-fld"><span>نوع الدفعة</span>
                    <select name="PayType">
                        <option value="">الكل</option>
                        <option value="InSalary" selected="@(Model.PayType == "InSalary")">داخل الراتب</option>
                        <option value="OutSalary" selected="@(Model.PayType == "OutSalary")">خارج الراتب</option>
                    </select>
                </label>
                <label class="tx-fld"><span>المصدر</span>
                    <select name="Src">
                        <option value="">كل المصادر</option>
                        @foreach (var s in Model.Sources)
                        { <option value="@s" selected="@(Model.Src == s)">@s</option> }
                    </select>
                </label>
                <label class="tx-fld"><span>تاريخ الحركة (من / إلى)</span>
                    <span class="tx-fld-range">
                        <input type="date" name="DateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" title="من" />
                        <input type="date" name="DateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" title="إلى" />
                    </span>
                </label>
                <label class="tx-fld"><span>المبلغ (من / إلى)</span>
                    <span class="tx-fld-range">
                        <input type="number" name="MinAmount" placeholder="من" value="@(Model.MinAmount)" step="0.01" />
                        <input type="number" name="MaxAmount" placeholder="إلى" value="@(Model.MaxAmount)" step="0.01" />
                    </span>
                </label>
                <label class="tx-fld soon"><span>رقم الدفعة (المسير) <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
                <label class="tx-fld soon"><span>حالة الطلب (الموافقات) <span class="tx-soon">قريباً</span></span>
                    <select disabled><option>الكل</option></select>
                </label>
            </div>

            <div class="tx-adv-actions">
                <button type="submit" class="tx-btn sm">تطبيق الفلاتر</button>
                <a class="tx-btn ghost sm" href="/Payroll/Transactions?type=@Model.Type&Year=@Model.Year&Month=@Model.Month&Lock=@Model.Lock">مسح المتقدم</a>
            </div>
        </div>
    </form>

    @if (TempData["PayrollMessage"] != null)
    {
        <div class="tx-alert @((TempData["PayrollOk"] as bool?) == false ? "err" : "")">@TempData["PayrollMessage"]</div>
    }

    <form method="post">
    <input type="hidden" name="Type" value="@Model.Type" />
    <input type="hidden" name="Year" value="@Model.Year" />
    <input type="hidden" name="Month" value="@Model.Month" />
    <input type="hidden" name="Lock" value="@Model.Lock" />
    <div class="tx-card">
        @if (Model.Items.Count == 0)
        {
            <div class="tx-empty">
                @if (Model.IsReadOnly)
                { <text>لا حركات مقفلة لفترة @($"{Model.Month:00}/{Model.Year}").</text> }
                else
                { <text>لا حركات @(Model.IsDeduction ? "اقتطاع" : "دخل") لفترة @($"{Model.Month:00}/{Model.Year}") — أضف بـ«+ حركة جديدة».</text> }
            </div>
        }
        else
        {
            <table class="tx-table">
                <thead>
                    <tr>
                        <th style="width:34px"><input type="checkbox" onclick="txAll(this)" /></th>
                        <th>الرقم المرجعي</th><th>الموظف</th><th>@Model.ItemLabel</th><th>المصدر</th>
                        <th>نوع الدفعة</th><th>تاريخ الحركة</th><th>المبلغ</th><th>الحالة</th>
                        @if (!Model.IsReadOnly)
                        { <th style="text-align:end">إجراءات</th> }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>
                            <td><input type="checkbox" name="SelectedIds" value="@t.Id" onchange="txSel()" /></td>
                            <td class="tx-ref">@t.ReferenceNo</td>
                            <td class="tx-emp"><b>@t.EmployeeName</b><span>@t.EmployeeNo</span></td>
                            <td><b>@t.ItemName</b></td>
                            <td style="font-size:12px">@t.Source</td>
                            <td><span class="tx-chip @(t.PaymentType == "OutSalary" ? "out" : "in")">@t.PaymentTypeLabel</span></td>
                            <td class="tx-ref">@(t.TransactionDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="tx-amt">@t.Amount.ToString("#,0.##")</td>
                            <td><span class="tx-chip @(t.Status == "Approved" ? "ap" : "dr")">@t.StatusText</span></td>
                            @if (!Model.IsReadOnly)
                            {
                            <td>
                                <div class="tx-actions">
                                    <button type="button" class="tx-btn ghost sm" onclick="txEdit(this)" data-tx="@J(new {
                                        Id = t.Id, t.EmployeeId, t.SalaryItemId, t.ItemName, t.Amount, t.Taxable, t.PaymentType,
                                        TransactionDate=Dt(t.TransactionDate), EffectiveDate=Dt(t.EffectiveDate),
                                        t.IsUnlimited, ValidFrom=Dt(t.ValidFrom), ValidTo=Dt(t.ValidTo),
                                        t.IsRetroactive, RetroactiveDate=Dt(t.RetroactiveDate), t.UpdateSocialSecurity,
                                        SocialSecurityToDate=Dt(t.SocialSecurityToDate), SalaryFromDate=Dt(t.SalaryFromDate), SalaryToDate=Dt(t.SalaryToDate),
                                        t.IsScheduled, t.InstallmentMode, t.InstallmentCount, t.InstallmentAmount, t.InstallmentMonths, FirstInstallmentDate=Dt(t.FirstInstallmentDate),
                                        t.ChangeCostCenter, t.CostCenter, t.Note, t.Status, t.Year, t.Month })">تعديل</button>
                                    <button type="submit" asp-page-handler="Delete" name="id" value="@t.Id" class="tx-btn danger sm" data-zyconfirm="حذف الحركة؟">حذف</button>
                                </div>
                            </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr><td colspan="7">الإجمالي (@Model.Items.Count حركة)</td><td class="tx-amt">@Model.TotalAmount.ToString("#,0.##")</td><td colspan="@(Model.IsReadOnly ? 1 : 2)"></td></tr>
                </tfoot>
            </table>
        }
    </div>
    @if (Model.Items.Count > 0)
    {
        <div class="tx-bulkbar" id="tx-bulkbar">
            <b>المحدد: <span id="tx-selcount">0</span></b>
            @if (Model.IsReadOnly)
            {
                <button type="submit" asp-page-handler="UnlockSelected" class="tx-btn warn" data-zyconfirm="إلغاء قفل الحركات المحددة؟">🔓 إلغاء قفل المحدد</button>
            }
            else
            {
                <button type="submit" asp-page-handler="LockSelected" class="tx-btn warn" data-zyconfirm="إقفال الحركات المحددة؟">🔒 إقفال المحدد</button>
                <button type="submit" asp-page-handler="DeleteMany" class="tx-btn danger" data-zyconfirm="حذف الحركات المحددة؟">🗑 حذف المحدد</button>
            }
        </div>
    }
    </form>

    @* ===== نموذج حركة جديدة (مطابق كيان) ===== *@
    <div class="hrms-slideover-backdrop" id="tx-backdrop" onclick="txClose()"></div>
    <aside class="hrms-slideover wide" id="tx-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2 id="tx-title">حركة جديدة</h2>
            <button type="button" class="hrms-slideover-close" onclick="txClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="Save" class="tx-form" style="display:flex;flex-direction:column;gap:12px">
                <input type="hidden" name="Type" value="@Model.Type" />
                <input type="hidden" name="Id" id="tx-Id" value="0" />
                <input type="hidden" name="ItemName" id="tx-ItemName" />
                <input type="hidden" name="SalaryItemId" id="tx-SalaryItemId" value="0" />
                <input type="hidden" name="PaymentType" id="tx-PaymentType" value="InSalary" />

                <p class="tx-hint">الحقول الأساسية تكفي لأغلب الحالات — الخيارات المتقدمة اختيارية.</p>

                <label>اسم الموظف *
                    <div class="empk-field">
                        <input type="text" id="tx-emp-name" class="empk-name" placeholder="اسم الموظف" readonly />
                        <input type="text" id="tx-emp-code" class="empk-code" placeholder="رمز" autocomplete="off" />
                    </div>
                    <input type="hidden" name="EmployeeId" id="tx-EmployeeId" />
                </label>

                <label>نوع الدفعة
                    <span class="tx-seg2" id="tx-pt">
                        <label class="on" data-pt="InSalary" onclick="txSetPt('InSalary')"><input type="radio" name="_pt" checked /> داخل الراتب</label>
                        <label data-pt="OutSalary" onclick="txSetPt('OutSalary')"><input type="radio" name="_pt" /> خارج الراتب</label>
                    </span>
                </label>

                <label>@Model.ItemLabel *
                    <select id="tx-ItemSelect" onchange="txItemChanged()">
                        <option value="">— اختر من الكتالوج —</option>
                        @foreach (var i in Model.Catalog)
                        { <option value="@i.Id">@i.Name</option> }
                        <option value="__custom">أخرى (نص حر)…</option>
                    </select>
                </label>
                <label id="tx-CustomWrap" hidden>اسم البند (نص حر)
                    <input type="text" id="tx-CustomName" oninput="document.getElementById('tx-ItemName').value=this.value" />
                </label>

                <div class="tx-grid2">
                    <label>المبلغ / القيمة *<input type="number" name="Amount" id="tx-Amount" step="0.01" min="0" required /></label>
                    <label style="flex-direction:row;align-items:center;gap:6px;min-height:38px"><input type="checkbox" name="Taxable" value="true" id="tx-Taxable" checked /> خاضع للضريبة</label>
                </div>

                <div class="tx-grid2">
                    <label>الشهر
                        <select name="FMonth" id="tx-FMonth">
                            @for (var m = 1; m <= 12; m++)
                            { <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option> }
                        </select>
                    </label>
                    <label>السنة<input type="number" name="FYear" id="tx-FYear" min="2000" max="2100" value="@Model.Year" /></label>
                </div>

                <label>تاريخ الحركة<input type="date" name="TransactionDate" id="tx-TransactionDate" /></label>

                @* ===== خيارات متقدمة (مطويّة — تُظهَر عند الحاجة فقط) ===== *@
                <button type="button" class="tx-adv-toggle" id="tx-adv-btn" onclick="txAdv()">▾ خيارات متقدمة (اختيارية)</button>
                <div id="tx-adv" style="display:none;flex-direction:column;gap:12px">
                    <label>تاريخ التنفيذ<input type="date" name="EffectiveDate" id="tx-EffectiveDate" /></label>

                    @* غير محدود *@
                    <div class="tx-toggle"><span>غير محدود (متكرر بلا نهاية)</span><input type="checkbox" name="IsUnlimited" value="true" id="tx-IsUnlimited" onchange="txToggle('unlimited', !this.checked)" /></div>
                    <div class="tx-sub" id="tx-sub-unlimited">
                        <div class="tx-grid2">
                            <label>صالح من<input type="date" name="ValidFrom" id="tx-ValidFrom" /></label>
                            <label>صالح إلى<input type="date" name="ValidTo" id="tx-ValidTo" /></label>
                        </div>
                    </div>

                    @* بأثر رجعي *@
                    <div class="tx-toggle"><span>بأثر رجعي</span><input type="checkbox" name="IsRetroactive" value="true" id="tx-IsRetroactive" onchange="txToggle('retro', this.checked)" /></div>
                    <div class="tx-sub" id="tx-sub-retro">
                        <label>تاريخ الأثر الرجعي<input type="date" name="RetroactiveDate" id="tx-RetroactiveDate" /></label>
                        <div class="tx-toggle"><span>تحديث راتب الضمان الاجتماعي</span><input type="checkbox" name="UpdateSocialSecurity" value="true" id="tx-UpdateSocialSecurity" onchange="txToggle('ss', this.checked)" /></div>
                        <div class="tx-sub" id="tx-sub-ss"><label>الحساب حتى التاريخ<input type="date" name="SocialSecurityToDate" id="tx-SocialSecurityToDate" /></label></div>
                        <div class="tx-grid2">
                            <label>راتب رجعي من<input type="date" name="SalaryFromDate" id="tx-SalaryFromDate" /></label>
                            <label>راتب رجعي إلى<input type="date" name="SalaryToDate" id="tx-SalaryToDate" /></label>
                        </div>
                    </div>

                    @* جدولة / أقساط *@
                    <div class="tx-toggle"><span>جدولة (أقساط)</span><input type="checkbox" name="IsScheduled" value="true" id="tx-IsScheduled" onchange="txToggle('sched', this.checked)" /></div>
                    <div class="tx-sub" id="tx-sub-sched">
                        <label>طريقة الجدولة
                            <select name="InstallmentMode" id="tx-InstallmentMode">
                                <option value="ByValue">حسب القيمة</option>
                                <option value="ByMonth">حسب الشهر</option>
                            </select>
                        </label>
                        <div class="tx-grid2">
                            <label>عدد الأقساط<input type="number" name="InstallmentCount" id="tx-InstallmentCount" min="1" /></label>
                            <label>قيمة القسط<input type="number" name="InstallmentAmount" id="tx-InstallmentAmount" step="0.01" /></label>
                        </div>
                        <div class="tx-grid2">
                            <label>عدد الأشهر<input type="number" name="InstallmentMonths" id="tx-InstallmentMonths" min="1" /></label>
                            <label>تاريخ أول قسط<input type="date" name="FirstInstallmentDate" id="tx-FirstInstallmentDate" /></label>
                        </div>
                    </div>

                    @* مركز التكلفة *@
                    <div class="tx-toggle"><span>تغيير مركز التكلفة</span><input type="checkbox" name="ChangeCostCenter" value="true" id="tx-ChangeCostCenter" onchange="txToggle('cc', this.checked)" /></div>
                    <div class="tx-sub" id="tx-sub-cc"><label>مركز التكلفة<input type="text" name="CostCenter" id="tx-CostCenter" /></label></div>
                </div>

                <label>الحالة
                    <select name="Status" id="tx-Status">
                        <option value="Approved">معتمد</option>
                        <option value="Draft">مسودة</option>
                    </select>
                </label>

                <label>ملاحظة<textarea name="Note" id="tx-Note" rows="2"></textarea></label>

                <button type="submit" class="tx-btn">حفظ الحركة</button>
            </form>
        </div>
    </aside>

    @* ===== دخل جماعي ===== *@
    <div class="hrms-slideover-backdrop" id="mass-backdrop" onclick="massClose()"></div>
    <aside class="hrms-slideover wide" id="mass-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2>👥 دخل جماعي — @Model.TypeTitle</h2>
            <button type="button" class="hrms-slideover-close" onclick="massClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="MassEntry" class="tx-form" style="display:flex;flex-direction:column;gap:12px">
                <input type="hidden" name="Type" value="@Model.Type" />
                <input type="hidden" name="MassItemName" id="mass-ItemName" />
                <input type="hidden" name="MassSalaryItemId" id="mass-SalaryItemId" value="0" />
                <input type="hidden" name="MassPaymentType" id="mass-PaymentType" value="InSalary" />

                <p class="tx-hint">بند ومبلغ موحّد لكل الموظفين المحددين — تُنشأ حركة مستقلة لكل موظف.</p>

                <label>@Model.ItemLabel *
                    <select id="mass-ItemSelect" onchange="massItemChanged()">
                        <option value="">— اختر من الكتالوج —</option>
                        @foreach (var i in Model.Catalog)
                        { <option value="@i.Id">@i.Name</option> }
                        <option value="__custom">أخرى (نص حر)…</option>
                    </select>
                </label>
                <label id="mass-CustomWrap" hidden>اسم البند (نص حر)
                    <input type="text" id="mass-CustomName" oninput="document.getElementById('mass-ItemName').value=this.value" />
                </label>

                <div class="tx-grid2">
                    <label>المبلغ / القيمة *<input type="number" name="MassAmount" id="mass-Amount" step="0.01" min="0" required /></label>
                    <label style="flex-direction:row;align-items:center;gap:6px;min-height:38px"><input type="checkbox" name="MassTaxable" value="true" id="mass-Taxable" checked /> خاضع للضريبة</label>
                </div>
                <div class="tx-grid2">
                    <label>نوع الدفعة
                        <select onchange="document.getElementById('mass-PaymentType').value=this.value">
                            <option value="InSalary">داخل الراتب</option>
                            <option value="OutSalary">خارج الراتب</option>
                        </select>
                    </label>
                    <label>الفترة
                        <span style="display:flex;gap:6px">
                            <select name="MassMonth">
                                @for (var m = 1; m <= 12; m++)
                                { <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option> }
                            </select>
                            <input type="number" name="MassYear" value="@Model.Year" min="2000" max="2100" style="width:88px" />
                        </span>
                    </label>
                </div>
                <label>ملاحظة<textarea name="MassNote" rows="2"></textarea></label>

                <label>الموظفون * <span id="mass-count" style="color:var(--acc)">(0 محدد)</span></label>
                <div style="display:flex;gap:6px">
                    <input type="text" id="mass-empsearch" placeholder="بحث بالاسم أو الرمز" oninput="massRenderEmps()"
                           style="flex:1;min-height:34px;border-radius:8px;border:1px solid rgba(73,111,151,.25);background:rgba(0,0,0,.16);color:inherit;padding:4px 10px;font-weight:800" />
                    <button type="button" class="tx-btn ghost sm" onclick="massSelectAll(true)">تحديد الظاهر</button>
                    <button type="button" class="tx-btn ghost sm" onclick="massSelectAll(false)">مسح الكل</button>
                </div>
                <div id="mass-emplist" style="max-height:280px;overflow-y:auto;border:1px solid rgba(73,111,151,.2);border-radius:10px;padding:4px"></div>

                <button type="submit" class="tx-btn">حفظ الدخل الجماعي</button>
            </form>
        </div>
    </aside>

    @* ===== استيراد إكسل ===== *@
    <div class="hrms-slideover-backdrop" id="imp-backdrop" onclick="impClose()"></div>
    <aside class="hrms-slideover" id="imp-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2>⬆ استيراد الحركات (إكسل / CSV)</h2>
            <button type="button" class="hrms-slideover-close" onclick="impClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="Import" enctype="multipart/form-data" class="tx-form" style="display:flex;flex-direction:column;gap:12px">
                <input type="hidden" name="Type" value="@Model.Type" />
                <div style="font-size:12px;font-weight:800;color:var(--sa-muted,#8FA8BC);border:1px dashed rgba(73,111,151,.3);border-radius:10px;padding:10px 12px;line-height:2">
                    <b style="color:var(--acc)">أعمدة الملف (الصف الأول ترويسة تُتجاهل):</b><br />
                    A: رمز الموظف · B: البند · C: المبلغ · D: نوع الدفعة (داخل/خارج — اختياري) · E: ملاحظة (اختياري)
                </div>
                <div class="tx-grid2">
                    <label>الشهر
                        <select name="ImportMonth">
                            @for (var m = 1; m <= 12; m++)
                            { <option value="@m" selected="@(m == Model.Month)">@months[m-1]</option> }
                        </select>
                    </label>
                    <label>السنة<input type="number" name="ImportYear" value="@Model.Year" min="2000" max="2100" /></label>
                </div>
                <label>الملف (.xlsx أو .csv) *<input type="file" name="importFile" accept=".xlsx,.csv" required style="min-height:auto;padding:8px" /></label>
                <button type="submit" class="tx-btn">استيراد الحركات</button>
            </form>
        </div>
    </aside>
</section>

@section Scripts {
    <script src="~/js/emp-picker.js" asp-append-version="true"></script>
    <script>
        var TX_ITEMS = @Html.Raw(catalogJson);
        var TX_EMP = @Html.Raw(empJson);
        var txEmpPicker = EmpPicker.init({
            code: document.getElementById('tx-emp-code'),
            name: document.getElementById('tx-emp-name'),
            hidden: document.getElementById('tx-EmployeeId'),
            employees: TX_EMP
        });
        EmpPicker.init({
            code: document.getElementById('adv-emp-code'),
            name: document.getElementById('adv-emp-name'),
            hidden: document.getElementById('adv-Emp'),
            employees: TX_EMP
        });
        function advToggle(){ var p=document.getElementById('adv-panel'); p.style.display = (p.style.display==='none') ? 'flex' : 'none'; }

        function txAll(cb){ document.querySelectorAll('[name=SelectedIds]').forEach(function(x){x.checked=cb.checked;}); txSel(); }
        function txSel(){
            var bar = document.getElementById('tx-bulkbar'); if(!bar) return;
            var n = document.querySelectorAll('[name=SelectedIds]:checked').length;
            var c = document.getElementById('tx-selcount'); if(c) c.textContent = n;
            bar.classList.toggle('show', n > 0);
        }

        function txSetPt(v){
            document.getElementById('tx-PaymentType').value = v;
            document.querySelectorAll('#tx-pt label').forEach(function(l){ l.classList.toggle('on', l.getAttribute('data-pt')===v); });
        }
        function txToggle(key, show){ document.getElementById('tx-sub-'+key).classList.toggle('show', !!show); }
        function txAdv(open){
            var adv = document.getElementById('tx-adv'), btn = document.getElementById('tx-adv-btn');
            var show = (open === undefined) ? adv.style.display === 'none' : open;
            adv.style.display = show ? 'flex' : 'none';
            btn.classList.toggle('open', show);
            btn.textContent = (show ? '▴' : '▾') + ' خيارات متقدمة (اختيارية)';
        }

        function txItemChanged(){
            var sel = document.getElementById('tx-ItemSelect'), val = sel.value;
            var cw = document.getElementById('tx-CustomWrap');
            if (val === '__custom'){ cw.hidden=false; document.getElementById('tx-SalaryItemId').value=0; document.getElementById('tx-ItemName').value=document.getElementById('tx-CustomName').value||''; return; }
            cw.hidden=true;
            if (!val){ document.getElementById('tx-ItemName').value=''; document.getElementById('tx-SalaryItemId').value=0; return; }
            var it = TX_ITEMS.find(function(x){ return String(x.Id)===val; });
            if (it){
                document.getElementById('tx-ItemName').value = it.Name;
                document.getElementById('tx-SalaryItemId').value = it.Id;
                document.getElementById('tx-Taxable').checked = !!it.Taxable;
                if (it.DefaultValue && !document.getElementById('tx-Amount').value) document.getElementById('tx-Amount').value = it.DefaultValue;
            }
        }

        function setVal(id, v){ var el=document.getElementById(id); if(el) el.value = (v==null?'':v); }
        function setChk(id, v){ var el=document.getElementById(id); if(el) el.checked = !!v; }

        function txEdit(btn){
            try { var d = JSON.parse(btn.getAttribute('data-tx')); txOpen(d.Id, d); }
            catch (e) { alert('تعذّر فتح التعديل: ' + e.message); }
        }

        function txOpen(id, d){
            var f = document.querySelector('#tx-slide form'); f.reset();
            document.getElementById('tx-Id').value = id || 0;
            document.getElementById('tx-title').textContent = id ? 'تعديل حركة' : 'حركة جديدة';
            ['unlimited','retro','ss','sched','cc'].forEach(function(k){ document.getElementById('tx-sub-'+k).classList.remove('show'); });
            txAdv(false);
            document.getElementById('tx-CustomWrap').hidden = true;
            document.getElementById('tx-ItemSelect').value=''; document.getElementById('tx-ItemName').value=''; document.getElementById('tx-SalaryItemId').value=0;
            txEmpPicker.set(null);
            txSetPt('InSalary');

            if (id && d){
                txEmpPicker.set(TX_EMP.find(function(x){ return x.Id === d.EmployeeId; }) || null);
                setVal('tx-FMonth', d.Month); setVal('tx-FYear', d.Year);
                setVal('tx-Amount', d.Amount); setChk('tx-Taxable', d.Taxable);
                txSetPt(d.PaymentType || 'InSalary');
                setVal('tx-TransactionDate', d.TransactionDate); setVal('tx-EffectiveDate', d.EffectiveDate);
                setChk('tx-IsUnlimited', d.IsUnlimited); txToggle('unlimited', !d.IsUnlimited);
                setVal('tx-ValidFrom', d.ValidFrom); setVal('tx-ValidTo', d.ValidTo);
                setChk('tx-IsRetroactive', d.IsRetroactive); txToggle('retro', d.IsRetroactive);
                setVal('tx-RetroactiveDate', d.RetroactiveDate);
                setChk('tx-UpdateSocialSecurity', d.UpdateSocialSecurity); txToggle('ss', d.UpdateSocialSecurity);
                setVal('tx-SocialSecurityToDate', d.SocialSecurityToDate);
                setVal('tx-SalaryFromDate', d.SalaryFromDate); setVal('tx-SalaryToDate', d.SalaryToDate);
                setChk('tx-IsScheduled', d.IsScheduled); txToggle('sched', d.IsScheduled);
                setVal('tx-InstallmentMode', d.InstallmentMode || 'ByValue');
                setVal('tx-InstallmentCount', d.InstallmentCount); setVal('tx-InstallmentAmount', d.InstallmentAmount);
                setVal('tx-InstallmentMonths', d.InstallmentMonths); setVal('tx-FirstInstallmentDate', d.FirstInstallmentDate);
                setChk('tx-ChangeCostCenter', d.ChangeCostCenter); txToggle('cc', d.ChangeCostCenter);
                setVal('tx-CostCenter', d.CostCenter); setVal('tx-Note', d.Note); setVal('tx-Status', d.Status || 'Approved');
                document.getElementById('tx-ItemName').value = d.ItemName || '';
                if (d.SalaryItemId && TX_ITEMS.find(function(x){return x.Id===d.SalaryItemId;})){
                    document.getElementById('tx-ItemSelect').value = String(d.SalaryItemId);
                    document.getElementById('tx-SalaryItemId').value = d.SalaryItemId;
                } else if (d.ItemName){
                    document.getElementById('tx-ItemSelect').value='__custom';
                    document.getElementById('tx-CustomWrap').hidden=false;
                    document.getElementById('tx-CustomName').value=d.ItemName;
                }
                if (d.IsRetroactive || d.IsScheduled || d.ChangeCostCenter || d.IsUnlimited || d.EffectiveDate || d.ValidFrom) txAdv(true);
            } else {
                var today = new Date().toISOString().slice(0,10);
                setVal('tx-TransactionDate', today);
            }
            document.getElementById('tx-slide').classList.add('open');
            document.getElementById('tx-backdrop').classList.add('open');
        }
        function txClose(){ document.getElementById('tx-slide').classList.remove('open'); document.getElementById('tx-backdrop').classList.remove('open'); }

        // ===== دخل جماعي =====
        function massItemChanged(){
            var sel=document.getElementById('mass-ItemSelect'), val=sel.value, cw=document.getElementById('mass-CustomWrap');
            if(val==='__custom'){ cw.hidden=false; document.getElementById('mass-SalaryItemId').value=0; document.getElementById('mass-ItemName').value=document.getElementById('mass-CustomName').value||''; return; }
            cw.hidden=true;
            if(!val){ document.getElementById('mass-ItemName').value=''; document.getElementById('mass-SalaryItemId').value=0; return; }
            var it=TX_ITEMS.find(function(x){ return String(x.Id)===val; });
            if(it){ document.getElementById('mass-ItemName').value=it.Name; document.getElementById('mass-SalaryItemId').value=it.Id; document.getElementById('mass-Taxable').checked=!!it.Taxable; if(it.DefaultValue && !document.getElementById('mass-Amount').value) document.getElementById('mass-Amount').value=it.DefaultValue; }
        }
        function massCount(){ document.getElementById('mass-count').textContent='('+document.querySelectorAll('#mass-emplist input:checked').length+' محدد)'; }
        function massBuildEmps(){
            document.getElementById('mass-emplist').innerHTML = TX_EMP.map(function(e){
                var key=((e.No||'')+' '+(e.Name||'')).toLowerCase();
                return '<label class="mass-emp" data-s="'+key+'" style="display:flex;align-items:center;gap:8px;padding:6px 8px;font-weight:800;cursor:pointer;border-radius:8px">'
                    +'<input type="checkbox" name="MassEmployeeIds" value="'+e.Id+'" onchange="massCount()" />'
                    +'<span style="flex:1">'+(e.Name||'')+'</span>'
                    +'<span style="direction:ltr;color:var(--sa-muted,#8FA8BC);font-size:12px">'+(e.No||'')+'</span></label>';
            }).join('');
        }
        function massRenderEmps(){
            var q=(document.getElementById('mass-empsearch').value||'').trim().toLowerCase();
            document.querySelectorAll('#mass-emplist .mass-emp').forEach(function(l){ l.style.display = (!q || l.getAttribute('data-s').indexOf(q)>=0) ? 'flex' : 'none'; });
        }
        function massSelectAll(on){
            document.querySelectorAll('#mass-emplist .mass-emp').forEach(function(l){ if(l.style.display!=='none'){ l.querySelector('input').checked=on; } });
            massCount();
        }
        function massOpen(){
            document.querySelector('#mass-slide form').reset();
            document.getElementById('mass-ItemName').value=''; document.getElementById('mass-SalaryItemId').value=0;
            document.getElementById('mass-CustomWrap').hidden=true; document.getElementById('mass-PaymentType').value='InSalary';
            massBuildEmps(); massRenderEmps(); massCount();
            document.getElementById('mass-slide').classList.add('open'); document.getElementById('mass-backdrop').classList.add('open');
        }
        function massClose(){ document.getElementById('mass-slide').classList.remove('open'); document.getElementById('mass-backdrop').classList.remove('open'); }

        function impOpen(){ document.getElementById('imp-slide').classList.add('open'); document.getElementById('imp-backdrop').classList.add('open'); }
        function impClose(){ document.getElementById('imp-slide').classList.remove('open'); document.getElementById('imp-backdrop').classList.remove('open'); }

        document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ txClose(); massClose(); impClose(); } });
    </script>
}

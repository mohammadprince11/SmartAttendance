@page
@model SmartAttendance.Web.Pages.AttendanceOperations.IndexModel

@{
    ViewData["Title"] = "إدارة الحضور";
    var importOpen = (Model.Tab ?? "").Equals("import", StringComparison.OrdinalIgnoreCase) || Model.Preview != null || Model.ImportResult != null;
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-operations-stable.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-operations-edit-highlight-fix.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-operations-notes-fix.css" asp-append-version="true" />

<div class="hrms-page attendance-operations-page">
    <div class="page-header">
        <div>
            <h1>إدارة الحضور</h1>
            <p>معالجة الحضور مع التعديل والاستيراد من نفس الصفحة.</p>
        </div>

        <div class="attendance-header-actions">
            <button type="button" class="hrms-btn-primary" data-open-import>استيراد ملف</button>
            <a asp-page="/AttendanceRecords/Index" class="hrms-btn-secondary">سجلات الحضور الخام</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="hrms-alert success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="hrms-alert danger">@Model.ErrorMessage</div>
    }

    <section class="attendance-filter-card">
        <form method="get" class="attendance-filter-form">
            <input type="hidden" name="Tab" value="process" />

            <div class="filter-grid">
                <div class="hrms-field">
                    <label>من تاريخ</label>
                    <input asp-for="ProcessFromDate" type="date" />
                </div>

                <div class="hrms-field">
                    <label>إلى تاريخ</label>
                    <input asp-for="ProcessToDate" type="date" />
                </div>

                <div class="hrms-field">
                    <label>بحث</label>
                    <input asp-for="ProcessSearchTerm" placeholder="كود الموظف أو الاسم" />
                </div>

                <div class="hrms-field">
                    <label>عدد النتائج</label>
                    <select asp-for="MaxRows">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                    </select>
                </div>

                <div class="filter-actions">
                    <button class="hrms-btn-primary" type="submit">معالجة</button>
                    <a asp-page="./Index" class="hrms-btn-secondary">مسح</a>
                </div>
            </div>
        </form>
    </section>

    <section class="attendance-results-card">
        <div class="results-head">
            <div>
                <h2>نتائج معالجة الحضور</h2>
                <p>
                    عرض @Model.ProcessedRecords.Count من @Model.ProcessTotalResults سجل.
                    @if (Model.ProcessIsLimited)
                    {
                        <span>النتائج محدودة للأداء، استخدم البحث أو فترة أصغر.</span>
                    }
                </p>
            </div>
        </div>

        <div class="attendance-table-wrap">
            <table class="attendance-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>كود الموظف</th>
                        <th>اسم الموظف</th>
                        <th>الشفت</th>
                        <th>الدخول</th>
                        <th>الخروج</th>
                        <th>ساعات العمل</th>
                        <th>التأخير</th>
                        <th>الخروج المبكر</th>
                        <th>الحالة</th>
                        <th>الملاحظة</th>
                        <th>تعديل</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ProcessedRecords)
                    {
                        var statusText = SmartAttendance.Web.Pages.AttendanceOperations.IndexModel.ProcessingAutoStatusText(item.CheckIn, item.CheckOut, item.CalculatedStatus);
                        var statusValue = SmartAttendance.Web.Pages.AttendanceOperations.IndexModel.ProcessingStatusValueForEdit(item.CheckIn, item.CheckOut, item.CalculatedStatus);
                        var shiftText = string.IsNullOrWhiteSpace(item.ShiftName) ? "-" : $"{item.ShiftCode} - {item.ShiftName}";

                        <tr class="@(Model.IsAttendanceEdited(item.EmployeeNo, item.AttendanceDate) ? "manual-edit-row" : "")">
                            <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.EmployeeNo</td>
                            <td>@item.EmployeeName</td>
                            <td>@shiftText</td>
                            <td>@(item.CheckIn?.ToString("HH:mm") ?? "-")</td>
                            <td>@(item.CheckOut?.ToString("HH:mm") ?? "-")</td>
                            <td>@(item.WorkingHours?.ToString("0.##") ?? "-")</td>
                            <td>@item.LateMinutes دقيقة</td>
                            <td>@(item.EarlyLeaveMinutes.HasValue ? $"{item.EarlyLeaveMinutes} دقيقة" : "-")</td>
                            <td><span class="attendance-status">@statusText</span></td>
                            <td class="attendance-note-cell">@Model.GetAttendanceNote(item.EmployeeNo, item.AttendanceDate)</td>
                            <td>
                                <button type="button"
                                        class="hrms-btn-secondary"
                                        data-edit-attendance
                                        data-employeeno="@item.EmployeeNo"
                                        data-employee="@item.EmployeeName"
                                        data-date="@item.AttendanceDate.ToString("yyyy-MM-dd")"
                                        data-checkin="@(item.CheckIn?.ToString("HH:mm") ?? "")"
                                        data-checkout="@(item.CheckOut?.ToString("HH:mm") ?? "")"
                                        data-status="@statusValue">
                                    تعديل
                                </button>
                            </td>
                        </tr>
                    }

                    @if (!Model.ProcessedRecords.Any())
                    {
                        <tr>
                            <td colspan="12" class="hrms-empty">لا توجد نتائج معالجة.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @* ===== البصمات الأخرى (نمط كيان): أزواج بدلالة غير-حضورية، خارج اشتقاق اليومية ===== *@
    <section class="attendance-results-card">
        <div class="results-head">
            <div>
                <h2>البصمات الأخرى</h2>
                <p>
                    بصمات بدلالة غير-حضورية (استراحة · صلاة · مهمة عمل…) —
                    <strong>لا تدخل احتساب أول دخول وآخر خروج</strong> فلا تؤثر على ساعات العمل والخروج المبكر.
                </p>
            </div>
            @if (Model.OtherSemantics.Any())
            {
                <button type="button" class="hrms-btn-primary" data-open-other>إضافة بصمات أخرى</button>
            }
        </div>

        <div class="attendance-table-wrap">
            <table class="attendance-table other-punch-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>كود الموظف</th>
                        <th>اسم الموظف</th>
                        <th>نوع البصمة</th>
                        <th>البداية</th>
                        <th>النهاية</th>
                        <th>الفترة</th>
                        <th>حذف</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var punch in Model.OtherPunches)
                    {
                        <tr>
                            <td>@punch.Date.ToString("yyyy-MM-dd")</td>
                            <td>@punch.EmployeeNo</td>
                            <td>@punch.EmployeeName</td>
                            <td><span class="attendance-status">@punch.SemanticName</span></td>
                            <td>@(punch.CheckIn?.ToString("HH:mm") ?? "-")</td>
                            <td>@(punch.CheckOut?.ToString("HH:mm") ?? "-")</td>
                            <td>@(punch.DurationHours?.ToString("0.##") is { Length: > 0 } h ? $"{h} س" : "-")</td>
                            <td>
                                <form method="post" asp-page-handler="DeleteOtherPunch" style="display:inline">
                                    <input type="hidden" name="id" value="@punch.Id" />
                                    <input type="hidden" name="ProcessFromDate" value="@Model.ProcessFromDate?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="ProcessToDate" value="@Model.ProcessToDate?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="MaxRows" value="@Model.MaxRows" />
                                    <button type="submit" class="hrms-btn-secondary" data-zyconfirm="حذف البصمة؟">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }

                    @if (!Model.OtherPunches.Any())
                    {
                        <tr>
                            <td colspan="8" class="hrms-empty">
                                @if (Model.OtherSemantics.Any())
                                {
                                    <text>لا بصمات أخرى في هذه الفترة.</text>
                                }
                                else
                                {
                                    <text>لا دلالات بصمات معرّفة — عرّفها من «إعدادات الحضور» ليمكن تسجيل بصمات أخرى.</text>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <div class="attendance-modal-backdrop" data-other-modal>
        <div class="attendance-modal">
            <div class="attendance-modal-head">
                <div>
                    <h2>إضافة بصمات أخرى</h2>
                    <p>بصمة بدلالة غير-حضورية — تُسجَّل ولا تُحتسب في اشتقاق اليومية.</p>
                </div>
                <button type="button" data-close-other>×</button>
            </div>

            <form method="post" asp-page-handler="AddOtherPunch">
                <input type="hidden" name="ProcessFromDate" value="@Model.ProcessFromDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="ProcessToDate" value="@Model.ProcessToDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="ProcessSearchTerm" value="@Model.ProcessSearchTerm" />
                <input type="hidden" name="MaxRows" value="@Model.MaxRows" />

                <div class="modal-grid">
                    <div class="hrms-field">
                        <label>نوع البصمة *</label>
                        <select asp-for="OtherPunch.PunchSemanticId">
                            @foreach (var semantic in Model.OtherSemantics)
                            {
                                <option value="@semantic.Id">@semantic.Name</option>
                            }
                        </select>
                    </div>

                    <div class="hrms-field">
                        <label>كود الموظف *</label>
                        <input asp-for="OtherPunch.EmployeeNo" placeholder="مثال: 11230" />
                    </div>

                    <div class="hrms-field">
                        <label>التاريخ *</label>
                        <input asp-for="OtherPunch.Date" type="date" />
                    </div>

                    <div class="hrms-field">
                        <label>ملاحظة</label>
                        <input asp-for="OtherPunch.Notes" placeholder="اختياري" />
                    </div>

                    <div class="hrms-field">
                        <label>البداية *</label>
                        <input asp-for="OtherPunch.CheckIn" type="time" />
                    </div>

                    <div class="hrms-field">
                        <label>النهاية</label>
                        <input asp-for="OtherPunch.CheckOut" type="time" />
                    </div>
                </div>

                <div class="edit-help-note">
                    هذه البصمة لا تدخل احتساب أول دخول وآخر خروج — فاستراحةٌ بعد الخروج لا تُطيل ساعات العمل.
                </div>

                <div class="modal-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ البصمة</button>
                    <button type="button" class="hrms-btn-secondary" data-close-other>إلغاء</button>
                </div>
            </form>
        </div>
    </div>

    <div class="attendance-modal-backdrop" data-edit-modal>
        <div class="attendance-modal">
            <div class="attendance-modal-head">
                <div>
                    <h2>تعديل الحضور</h2>
                    <p data-edit-selected>اختر سجل من الجدول.</p>
                </div>
                <button type="button" data-close-edit>×</button>
            </div>

            <form method="post" asp-page-handler="SavePunches" data-preserve-filter="true">
                <input type="hidden" name="Tab" value="process" />
                <input type="hidden" name="ProcessFromDate" value="@Model.ProcessFromDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="ProcessToDate" value="@Model.ProcessToDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="ProcessSearchTerm" value="@Model.ProcessSearchTerm" />
                <input type="hidden" name="MaxRows" value="@Model.MaxRows" />

                <input asp-for="Correction.EmployeeNo" type="hidden" id="editEmployeeNo" />
                <input asp-for="Correction.Date" type="hidden" id="editDate" />

                @* أزواج بصمات اليوم — يُبنى بالـJS من خريطة AttendancePairsJson *@
                <div class="punch-pairs" id="editPairs"></div>

                <button type="button" class="hrms-btn-secondary punch-add" data-add-pair>+ إضافة زوج بصمة</button>

                <div class="hrms-field" style="margin-top:12px">
                    <label>ملاحظة</label>
                    <input asp-for="Correction.Notes" id="editNotes" placeholder="اكتب سبب التعديل حتى يظهر في سجل العمليات" />
                </div>

                <div class="edit-help-note">
                    اليوم قد يحمل أزواج بصمات متعددة. <strong>الحالة والتأخير وساعات العمل تُشتق تلقائياً</strong>
                    من أول دخول وآخر خروج — لا تُفرض يدوياً. أفرغ وقتَي الزوج لحذفه.
                </div>

                <div class="modal-actions">
                    <button type="submit" class="hrms-btn-primary">حفظ البصمات</button>
                    <button type="button" class="hrms-btn-secondary" data-close-edit>إلغاء</button>
                </div>
            </form>
        </div>
    </div>

    <div class="attendance-modal-backdrop @(importOpen ? "is-open" : "")" data-import-modal>
        <div class="attendance-modal attendance-import-modal">
            <div class="attendance-modal-head">
                <div>
                    <h2>استيراد الحضور</h2>
                    <p>رفع ملف Excel أو CSV ثم معاينة السجلات قبل الاستيراد.</p>
                </div>
                <button type="button" data-close-import>×</button>
            </div>

            <form method="post" enctype="multipart/form-data" asp-page-handler="Preview">
                <input type="hidden" name="Tab" value="import" />

                <div class="modal-grid">
                    <div class="hrms-field">
                        <label>ملف الحضور</label>
                        <input asp-for="AttendanceFile" type="file" accept=".xlsx,.csv" />
                    </div>

                    <div class="hrms-field">
                        <label>الأعمدة المطلوبة</label>
                        <div class="hint-box">EmployeeCardNumber, AttendanceDate, FunctionType, MachineName</div>
                    </div>

                    <div class="modal-actions compact">
                        <button type="submit" class="hrms-btn-primary">معاينة الملف</button>
                    </div>
                </div>
            </form>

            @if (Model.Preview != null)
            {
                <div class="results-head inside-modal">
                    <div>
                        <h2>معاينة: @Model.Preview.FileName</h2>
                        <p>جاهز: @Model.Preview.ReadyToImportCount | تحذيرات: @Model.Preview.WarningCount | أخطاء: @Model.Preview.ErrorCount</p>
                    </div>

                    @if (Model.Preview.ReadyToImportCount > 0)
                    {
                        <form method="post" asp-page-handler="Import">
                            <input type="hidden" name="Tab" value="import" />
                            <input type="hidden" name="token" value="@Model.Preview.Token" />
                            <button type="submit" class="hrms-btn-primary">استيراد السجلات الصالحة</button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // خريطة «كود الموظف|التاريخ» ← أزواج بصمات اليوم (يبنيها الخادم)
        window.ATTENDANCE_PAIRS = @Html.Raw(Model.AttendancePairsJson);
    </script>
    <script src="~/js/attendance-operations-final.js" asp-append-version="true"></script>
}

@page
@model SmartAttendance.Web.Pages.Setup.IndexModel
@using SmartAttendance.Domain.Enums

@{
    ViewData["Title"] = "\u0625\u0639\u062f\u0627\u062f \u0627\u0644\u0634\u0631\u0643\u0629";
    var setup = Model.Setup;
    var hasCompanies = Model.Companies.Count > 0;
    var policyCount = setup?.CutoffPolicies.Count ?? 0;
    var activePolicyCount = setup?.CutoffPolicies.Count(x => x.IsActive) ?? 0;
    var hasAvailableCutoffTypes = setup != null && Model.HasAvailableCutoffTypes();
}

@* NEXORA_ACTIVE_CUTOFF_TYPE_MARKUP_START *@<div class="nexora-setup-page nx-company-setup-page">
    <section class="nexora-setup-hero nx-company-setup-hero">
        <div>
            <span class="nexora-setup-kicker">NEXORA SETUP</span>
            <h1>&#x0625;&#x0639;&#x062F;&#x0627;&#x062F; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0648;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</h1>
            <p>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0647;&#x0648;&#x064A;&#x0629; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;&#x060C; &#x062F;&#x0648;&#x0631;&#x0629; &#x0627;&#x0644;&#x0631;&#x0627;&#x062A;&#x0628;&#x060C; &#x0648;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642; &#x0627;&#x0644;&#x0645;&#x062A;&#x0639;&#x062F;&#x062F;&#x0629; &#x0645;&#x0646; &#x0645;&#x0643;&#x0627;&#x0646; &#x0648;&#x0627;&#x062D;&#x062F;.</p>
        </div>

        @if (hasCompanies)
        {
            <form method="get" class="nx-company-selector" aria-label="Company selector">
                <label for="CompanyId">&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</label>
                <select asp-for="CompanyId" data-company-selector>
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Id">@company.Name - @company.Code</option>
                    }
                </select>
                <button type="submit" class="nx-setup-btn nx-setup-btn-secondary">&#x0639;&#x0631;&#x0636;</button>
            </form>
        }
    </section>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="nx-setup-alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="nx-setup-alert-danger">@errorMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="nx-setup-alert-danger"></div>
    }

    @if (!hasCompanies)
    {
        <section class="nexora-setup-card nx-company-empty">
            <div class="nx-company-empty-mark">N</div>
            <h2>&#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x0634;&#x0631;&#x0643;&#x0629; &#x0628;&#x0639;&#x062F;</h2>
            <p>&#x0623;&#x0636;&#x0641; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0627;&#x0644;&#x0623;&#x0648;&#x0644;&#x0649;&#x060C; &#x062B;&#x0645; &#x0627;&#x0631;&#x062C;&#x0639; &#x0644;&#x0625;&#x0643;&#x0645;&#x0627;&#x0644; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0639;&#x0627;&#x0631; &#x0648;&#x0627;&#x0644;&#x0628;&#x0644;&#x062F; &#x0648;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;.</p>
            <a asp-page="/Companies/Create" class="nx-setup-btn nx-setup-btn-primary">&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0634;&#x0631;&#x0643;&#x0629;</a>
        </section>
    }
    else if (setup != null)
    {
        <nav class="nx-company-setup-nav" aria-label="Setup sections">
            <a href="#company-profile">&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</a>
<a href="#cutoff-policies">&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</a>
        </nav>

        <section class="nx-company-setup-summary">
<article>
                <span>&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</span>
                <strong>@policyCount</strong>
            </article>
            <article>
                <span>&#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x0641;&#x0639;&#x0627;&#x0644;&#x0629;</span>
                <strong>@activePolicyCount</strong>
            </article>
        </section>

        <section id="company-profile" class="nexora-setup-card nx-company-section">
            <div class="nexora-setup-card-head">
                <div>
                    <span>COMPANY PROFILE</span>
                    <strong>&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</strong>
                    <small>&#x0627;&#x0644;&#x0647;&#x0648;&#x064A;&#x0629; &#x0627;&#x0644;&#x0631;&#x0633;&#x0645;&#x064A;&#x0629; &#x0648;&#x0627;&#x0644;&#x0625;&#x0639;&#x062F;&#x0627;&#x062F;&#x0627;&#x062A; &#x0627;&#x0644;&#x0645;&#x062D;&#x0644;&#x064A;&#x0629; &#x0644;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;.</small>
                </div>
            </div>

            <form method="post" enctype="multipart/form-data" asp-page-handler="SaveProfile" class="nx-company-profile-layout">
                <input type="hidden" asp-for="Profile.CompanyId" />
                <input type="hidden" asp-for="Profile.CompanyCode" />

                <aside class="nx-company-logo-card">
                    <div class="nx-company-logo-preview" data-logo-preview>
                        @if (!string.IsNullOrWhiteSpace(Model.Profile.LogoPath))
                        {
                            <img src="@Model.Profile.LogoPath" alt="Company logo" />
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(Model.Profile.Name) ? "N" : Model.Profile.Name.Trim()[0])</span>
                        }
                    </div>
                    <strong>&#x0634;&#x0639;&#x0627;&#x0631; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</strong>
                    <small>PNG, JPG, WEBP - 5MB MAX</small>
                    <label class="nx-setup-btn nx-setup-btn-secondary nx-company-file-button">
                        <span>&#x0627;&#x062E;&#x062A;&#x064A;&#x0627;&#x0631; &#x0634;&#x0639;&#x0627;&#x0631;</span>
                        <input asp-for="LogoFile" type="file" accept=".png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp" data-logo-file />
                    </label>
                    <span asp-validation-for="LogoFile" class="text-danger"></span>

                    @if (!string.IsNullOrWhiteSpace(Model.Profile.LogoPath))
                    {
                        <label class="nx-setup-check nx-company-remove-logo">
                            <input asp-for="RemoveLogo" />
                            <span>&#x062D;&#x0630;&#x0641; &#x0627;&#x0644;&#x0634;&#x0639;&#x0627;&#x0631; &#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x064A;</span>
                        </label>
                    }
                </aside>

                <div class="nx-setup-form-grid nx-company-profile-fields">
                    <label class="nx-setup-field">
                        <span>&#x0631;&#x0645;&#x0632; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</span>
                        <input value="@Model.Profile.CompanyCode" readonly class="nx-company-readonly" />
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</span>
                        <input asp-for="Profile.Name" />
                        <span asp-validation-for="Profile.Name" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0628;&#x0631;&#x064A;&#x062F; &#x0627;&#x0644;&#x0625;&#x0644;&#x0643;&#x062A;&#x0631;&#x0648;&#x0646;&#x064A;</span>
                        <input asp-for="Profile.Email" type="email" />
                        <span asp-validation-for="Profile.Email" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0631;&#x0642;&#x0645; &#x0627;&#x0644;&#x0647;&#x0627;&#x062A;&#x0641;</span>
                        <input asp-for="Profile.Phone" />
                        <span asp-validation-for="Profile.Phone" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0628;&#x0644;&#x062F;</span>
                        <select asp-for="Profile.CountryCode" asp-items="Model.CountryOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0628;&#x0644;&#x062F;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.CountryCode" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0639;&#x0645;&#x0644;&#x0629;</span>
                        <select asp-for="Profile.CurrencyCode" asp-items="Model.CurrencyOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;&#x0629;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.CurrencyCode" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field nx-setup-field-wide">
                        <span>&#x0627;&#x0644;&#x0645;&#x0646;&#x0637;&#x0642;&#x0629; &#x0627;&#x0644;&#x0632;&#x0645;&#x0646;&#x064A;&#x0629;</span>
                        <select asp-for="Profile.TimeZoneId" asp-items="Model.TimeZoneOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0645;&#x0646;&#x0637;&#x0642;&#x0629; &#x0627;&#x0644;&#x0632;&#x0645;&#x0646;&#x064A;&#x0629;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.TimeZoneId" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field nx-setup-field-wide">
                        <span>&#x0627;&#x0644;&#x0639;&#x0646;&#x0648;&#x0627;&#x0646;</span>
                        <textarea asp-for="Profile.Address" rows="3"></textarea>
                        <span asp-validation-for="Profile.Address" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-check">
                        <input asp-for="Profile.IsActive" />
                        <span>&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629;</span>
                    </label>

                    <div class="nx-setup-modal__actions nx-company-form-actions">
                        <button type="submit" class="nx-setup-btn nx-setup-btn-primary">&#x062D;&#x0641;&#x0638; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</button>
                    </div>
                </div>
            </form>
        </section>

        <section id="cutoff-policies" class="nexora-setup-card nx-company-section">
            <div class="nexora-setup-card-head">
                <div>
                    <span>PAYROLL CUTOFF POLICIES</span>
                    <strong>&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</strong>
                    <small>&#x062D;&#x062F;&#x062F; &#x0641;&#x062A;&#x0631;&#x0629; &#x0627;&#x0644;&#x0627;&#x062D;&#x062A;&#x0633;&#x0627;&#x0628; &#x0648;&#x0623;&#x0646;&#x0648;&#x0627;&#x0639; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x062F;&#x0627;&#x062E;&#x0644; &#x0643;&#x0644; &#x0633;&#x064A;&#x0627;&#x0633;&#x0629;.</small>
                </div>

                <div class="nx-cutoff-add-control">
                    @if (hasAvailableCutoffTypes)
                    {
                        <a asp-page="./Index" asp-route-companyId="@setup.CompanyId" asp-route-newPolicy="true" class="nx-setup-btn nx-setup-btn-primary">&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x063A;&#x0644;&#x0642;</a>
                    }
                    else
                    {
                        <button type="button" class="nx-setup-btn nx-setup-btn-primary nx-cutoff-add-disabled" disabled>
                            &#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x063A;&#x0644;&#x0642;
                        </button>
                        <small>&#x062C;&#x0645;&#x064A;&#x0639; &#x0627;&#x0644;&#x0623;&#x0646;&#x0648;&#x0627;&#x0639; &#x0645;&#x0631;&#x062A;&#x0628;&#x0637;&#x0629; &#x0628;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629;.</small>
                    }
                </div>
            </div>

            <div class="nexora-setup-table-wrap">
                <table class="nexora-setup-table nx-cutoff-policy-table">
                    <thead>
                        <tr>
                            <th>&#x0627;&#x0644;&#x0627;&#x0633;&#x0645;</th>
                            <th>&#x0642;&#x0627;&#x0639;&#x062F;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</th>
                            <th>&#x0645;&#x0646;</th>
                            <th>&#x0625;&#x0644;&#x0649;</th>
                            <th>&#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x0629;</th>
                            <th>&#x0627;&#x0644;&#x0625;&#x062C;&#x0631;&#x0627;&#x0621;&#x0627;&#x062A;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (setup.CutoffPolicies.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="nx-setup-empty">&#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x063A;&#x0644;&#x0642; &#x062D;&#x0627;&#x0644;&#x064A;&#x0627;.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var policy in setup.CutoffPolicies)
                            {
                                <tr>
                                    <td>
                                        <strong class="nx-setup-title">@policy.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(policy.Notes))
                                        {
                                            <small class="nx-policy-note">@policy.Notes</small>
                                        }
                                    </td>
                                    <td><span class="nx-cutoff-rule-badge">&#x0634;&#x0647;&#x0631;&#x064A; &#x0645;&#x062A;&#x0643;&#x0631;&#x0631;</span></td>
                                    <td><span class="nx-setup-code">@policy.FromDay</span></td>
                                    <td><span class="nx-setup-code">@policy.ToDay</span></td>
                                    <td>
                                        <span class="nx-setup-status @(policy.IsActive ? "is-active" : "is-inactive")">
                                            @(policy.IsActive ? "\u0641\u0639\u0627\u0644\u0629" : "\u063A\u064A\u0631 \u0641\u0639\u0627\u0644\u0629")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="nx-setup-row-actions">
                                            <a asp-page="./Index" asp-route-companyId="@setup.CompanyId" asp-route-editPolicyId="@policy.Id" class="btn-table btn-edit">&#x062A;&#x0639;&#x062F;&#x064A;&#x0644;</a>
                                            <form method="post" asp-page-handler="DeleteCutoff" data-confirm-delete data-policy-name="@policy.Name">
                                                <input type="hidden" name="companyId" value="@setup.CompanyId" />
                                                <input type="hidden" name="policyId" value="@policy.Id" />
                                                <button type="button"
                                                        class="btn-table btn-delete"
                                                        data-cutoff-delete-open
                                                        data-nx-setup-open="cutoff-delete-modal">
                                                    &#x062D;&#x0630;&#x0641;
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <div id="cutoff-policy-modal" class="nx-setup-modal @(Model.OpenPolicyModal ? "is-open" : "")" aria-hidden="@(Model.OpenPolicyModal ? "false" : "true")" data-auto-open="@(Model.OpenPolicyModal ? "true" : "false")">
            <div class="nx-setup-modal__panel" role="dialog" aria-modal="true" aria-labelledby="cutoff-policy-title">
                <button type="button" class="nx-setup-modal__close" data-nx-setup-close aria-label="Close">&times;</button>

                <div class="nx-setup-modal__head">
                    <span>PAYROLL CUTOFF</span>
                    <h2 id="cutoff-policy-title">@(Model.CutoffPolicy.Id > 0 ? "\u062A\u0639\u062F\u064A\u0644 \u0633\u064A\u0627\u0633\u0629 \u0627\u0644\u063A\u0644\u0642" : "\u0625\u0636\u0627\u0641\u0629 \u0633\u064A\u0627\u0633\u0629 \u063A\u0644\u0642")</h2>
                    <p>&#x062D;&#x062F;&#x062F; &#x0627;&#x0644;&#x0641;&#x062A;&#x0631;&#x0629; &#x0627;&#x0644;&#x0634;&#x0647;&#x0631;&#x064A;&#x0629; &#x0648;&#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x062A;&#x064A; &#x062A;&#x062F;&#x062E;&#x0644; &#x0636;&#x0645;&#x0646;&#x0647;&#x0627;.</p>
                </div>

                <form method="post" asp-page-handler="SaveCutoff" class="nx-setup-modal-form" data-cutoff-form>
                    <input type="hidden" asp-for="CutoffPolicy.Id" />
                    <input type="hidden" asp-for="CutoffPolicy.CompanyId" />

                    <div asp-validation-summary="ModelOnly" class="nx-setup-alert-danger"></div>

                    <div class="nx-setup-form-grid">
                        <label class="nx-setup-field nx-setup-field-wide">
                            <span>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629;</span>
                            <input asp-for="CutoffPolicy.Name" />
                            <span asp-validation-for="CutoffPolicy.Name" class="text-danger"></span>
                        </label>

                        <div class="nx-cutoff-basis-card nx-setup-field-wide">
                            <span>&#x0642;&#x0627;&#x0639;&#x062F;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</span>
                            <strong>&#x0634;&#x0647;&#x0631;&#x064A; &#x0645;&#x062A;&#x0643;&#x0631;&#x0631;</strong>
                            <small>&#x064A;&#x0628;&#x062F;&#x0623; &#x0627;&#x0644;&#x0627;&#x062D;&#x062A;&#x0633;&#x0627;&#x0628; &#x0645;&#x0646; &#x064A;&#x0648;&#x0645; &#x0645;&#x062D;&#x062F;&#x062F; &#x0648;&#x064A;&#x0646;&#x062A;&#x0647;&#x064A; &#x0628;&#x064A;&#x0648;&#x0645; &#x0645;&#x062D;&#x062F;&#x062F; &#x0643;&#x0644; &#x0634;&#x0647;&#x0631;.</small>
                        </div>

                        <label class="nx-setup-field">
                            <span>&#x0645;&#x0646; &#x064A;&#x0648;&#x0645;</span>
                            <input asp-for="CutoffPolicy.FromDay" type="number" min="1" max="31" />
                            <span asp-validation-for="CutoffPolicy.FromDay" class="text-danger"></span>
                        </label>

                        <label class="nx-setup-field">
                            <span>&#x0625;&#x0644;&#x0649; &#x064A;&#x0648;&#x0645;</span>
                            <input asp-for="CutoffPolicy.ToDay" type="number" min="1" max="31" />
                            <span asp-validation-for="CutoffPolicy.ToDay" class="text-danger"></span>
                        </label>

                        <fieldset class="nx-setup-field nx-setup-field-wide nx-cutoff-types-field">
                            <legend>&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;</legend>
                            <small class="nx-cutoff-lock-hint">
                                &#x0627;&#x0644;&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x0645;&#x0631;&#x062A;&#x0628;&#x0637; &#x0628;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629; &#x064A;&#x0643;&#x0648;&#x0646; &#x0645;&#x0642;&#x0641;&#x0644;&#x0627; &#x0647;&#x0646;&#x0627; &#x0644;&#x0645;&#x0646;&#x0639; &#x062A;&#x0643;&#x0631;&#x0627;&#x0631; &#x0627;&#x0644;&#x0627;&#x062D;&#x062A;&#x0633;&#x0627;&#x0628;.
                            </small>
                            <div class="nx-cutoff-type-checklist">
                                @foreach (var option in Model.CutoffTypeOptions)
                                {
                                    var optionType = (PayrollCutoffType)int.Parse(option.Value!, System.Globalization.CultureInfo.InvariantCulture);
                                    var optionId = $"cutoff-type-{option.Value}";
                                    var isSelected = Model.CutoffPolicy.PolicyTypes.Contains(optionType);
                                    var lockedByPolicy = Model.GetActiveCutoffTypeOwner(
                                        optionType,
                                        Model.CutoffPolicy.Id);
                                    var isLocked = !string.IsNullOrWhiteSpace(lockedByPolicy);

                                    <label class="nx-cutoff-type-option @(isLocked ? "is-locked" : "")" for="@optionId">
                                        @if (isSelected && isLocked)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" checked disabled />
                                        }
                                        else if (isSelected)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" checked />
                                        }
                                        else if (isLocked)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" disabled />
                                        }
                                        else
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" />
                                        }
                                        <span class="nx-cutoff-type-box" aria-hidden="true"></span>
                                        <span class="nx-cutoff-type-content">
                                            <span class="nx-cutoff-type-label">@option.Text</span>
                                            @if (isLocked)
                                            {
                                                <small class="nx-cutoff-type-lock">
                                                    <span aria-hidden="true">&#x1F512;</span>
                                                    &#x0645;&#x0633;&#x062A;&#x062E;&#x062F;&#x0645; &#x0636;&#x0645;&#x0646;: @lockedByPolicy
                                                </small>
                                            }
                                        </span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="CutoffPolicy.PolicyTypes" class="text-danger"></span>
                        </fieldset>

                        <label class="nx-setup-field nx-setup-field-wide">

                    <input type="hidden"
                           name="companyId"
                           data-department-delete-company-id />
                    <input type="hidden"
                           name="departmentId"
                           data-department-delete-id />

                    <div class="nx-cutoff-confirm-summary">
                        <span>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645; &#x0627;&#x0644;&#x0645;&#x062D;&#x062F;&#x062F;</span>
                        <strong data-department-delete-name></strong>
                        <p>&#x0644;&#x0646; &#x064A;&#x062A;&#x0645; &#x0627;&#x0644;&#x062D;&#x0630;&#x0641; &#x0625;&#x0630;&#x0627; &#x0643;&#x0627;&#x0646; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645; &#x0645;&#x0631;&#x062A;&#x0628;&#x0637;&#x0627; &#x0628;&#x0645;&#x0648;&#x0638;&#x0641;&#x064A;&#x0646; &#x0623;&#x0648; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0623;&#x062E;&#x0631;&#x0649;.</p>
                    </div>

                    <div class="nx-setup-modal__actions nx-cutoff-confirm-actions">
                        <button type="button"
                                class="nx-setup-btn nx-setup-btn-secondary"
                                data-nx-setup-close>
                            &#x0625;&#x0644;&#x063A;&#x0627;&#x0621;
                        </button>
                        <button type="submit"
                                class="nx-setup-btn nx-cutoff-confirm-delete"
                                data-entity-submit-button>
                            <span data-entity-submit-label>&#x062D;&#x0630;&#x0641; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
        @* NEXORA_SETUP_ENTITY_MODALS_END *@

        <div id="cutoff-policy-modal" class="nx-setup-modal @(Model.OpenPolicyModal ? "is-open" : "")" aria-hidden="@(Model.OpenPolicyModal ? "false" : "true")" data-auto-open="@(Model.OpenPolicyModal ? "true" : "false")">
            <div class="nx-setup-modal__panel" role="dialog" aria-modal="true" aria-labelledby="cutoff-policy-title">
                <button type="button" class="nx-setup-modal__close" data-nx-setup-close aria-label="Close">&times;</button>

                <div class="nx-setup-modal__head">
                    <span>PAYROLL CUTOFF</span>
                    <h2 id="cutoff-policy-title">@(Model.CutoffPolicy.Id > 0 ? "\u062A\u0639\u062F\u064A\u0644 \u0633\u064A\u0627\u0633\u0629 \u0627\u0644\u063A\u0644\u0642" : "\u0625\u0636\u0627\u0641\u0629 \u0633\u064A\u0627\u0633\u0629 \u063A\u0644\u0642")</h2>
                    <p>&#x062D;&#x062F;&#x062F; &#x0627;&#x0644;&#x0641;&#x062A;&#x0631;&#x0629; &#x0627;&#x0644;&#x0634;&#x0647;&#x0631;&#x064A;&#x0629; &#x0648;&#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x062A;&#x064A; &#x062A;&#x062F;&#x062E;&#x0644; &#x0636;&#x0645;&#x0646;&#x0647;&#x0627;.</p>
                </div>

                <form id="cutoff-policy-form" method="post" asp-page-handler="SaveCutoff" class="nx-setup-modal-form" data-cutoff-form>
                    <input type="hidden" asp-for="CutoffPolicy.Id" />
                    <input type="hidden" asp-for="CutoffPolicy.CompanyId" />

                    <div class="nx-cutoff-scroll-content">
                        <div asp-validation-summary="ModelOnly" class="nx-setup-alert-danger"></div>

                        <div class="nx-setup-form-grid">
                        <label class="nx-setup-field nx-setup-field-wide">
                            <span>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629;</span>
                            <input asp-for="CutoffPolicy.Name" />
                            <span asp-validation-for="CutoffPolicy.Name" class="text-danger"></span>
                        </label>

                        <div class="nx-cutoff-basis-card nx-setup-field-wide">
                            <span>&#x0642;&#x0627;&#x0639;&#x062F;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</span>
                            <strong>&#x0634;&#x0647;&#x0631;&#x064A; &#x0645;&#x062A;&#x0643;&#x0631;&#x0631;</strong>
                            <small>&#x064A;&#x0628;&#x062F;&#x0623; &#x0627;&#x0644;&#x0627;&#x062D;&#x062A;&#x0633;&#x0627;&#x0628; &#x0645;&#x0646; &#x064A;&#x0648;&#x0645; &#x0645;&#x062D;&#x062F;&#x062F; &#x0648;&#x064A;&#x0646;&#x062A;&#x0647;&#x064A; &#x0628;&#x064A;&#x0648;&#x0645; &#x0645;&#x062D;&#x062F;&#x062F; &#x0643;&#x0644; &#x0634;&#x0647;&#x0631;.</small>
                        </div>

                        <label class="nx-setup-field">
                            <span>&#x0645;&#x0646; &#x064A;&#x0648;&#x0645;</span>
                            <input asp-for="CutoffPolicy.FromDay" type="number" min="1" max="31" />
                            <span asp-validation-for="CutoffPolicy.FromDay" class="text-danger"></span>
                        </label>

                        <label class="nx-setup-field">
                            <span>&#x0625;&#x0644;&#x0649; &#x064A;&#x0648;&#x0645;</span>
                            <input asp-for="CutoffPolicy.ToDay" type="number" min="1" max="31" />
                            <span asp-validation-for="CutoffPolicy.ToDay" class="text-danger"></span>
                        </label>

                        <fieldset class="nx-setup-field nx-setup-field-wide nx-cutoff-types-field">
                            <legend>&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;</legend>
                            <small class="nx-cutoff-lock-hint">
                                &#x0627;&#x0644;&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x0645;&#x0631;&#x062A;&#x0628;&#x0637; &#x0628;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629; &#x064A;&#x0643;&#x0648;&#x0646; &#x0645;&#x0642;&#x0641;&#x0644;&#x0627; &#x0647;&#x0646;&#x0627; &#x0644;&#x0645;&#x0646;&#x0639; &#x062A;&#x0643;&#x0631;&#x0627;&#x0631; &#x0627;&#x0644;&#x0627;&#x062D;&#x062A;&#x0633;&#x0627;&#x0628;.
                            </small>
                            <div class="nx-cutoff-type-checklist">
                                @foreach (var option in Model.CutoffTypeOptions)
                                {
                                    var optionType = (PayrollCutoffType)int.Parse(option.Value!, System.Globalization.CultureInfo.InvariantCulture);
                                    var optionId = $"cutoff-type-{option.Value}";
                                    var isSelected = Model.CutoffPolicy.PolicyTypes.Contains(optionType);
                                    var lockedByPolicy = Model.GetActiveCutoffTypeOwner(
                                        optionType,
                                        Model.CutoffPolicy.Id);
                                    var isLocked = !string.IsNullOrWhiteSpace(lockedByPolicy);

                                    <label class="nx-cutoff-type-option @(isLocked ? "is-locked" : "")" for="@optionId">
                                        @if (isSelected && isLocked)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" checked disabled />
                                        }
                                        else if (isSelected)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" checked />
                                        }
                                        else if (isLocked)
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" disabled />
                                        }
                                        else
                                        {
                                            <input type="checkbox" id="@optionId" name="CutoffPolicy.PolicyTypes" value="@option.Value" />
                                        }
                                        <span class="nx-cutoff-type-box" aria-hidden="true"></span>
                                        <span class="nx-cutoff-type-content">
                                            <span class="nx-cutoff-type-label">@option.Text</span>
                                            @if (isLocked)
                                            {
                                                <small class="nx-cutoff-type-lock">
                                                    <span aria-hidden="true">&#x1F512;</span>
                                                    &#x0645;&#x0633;&#x062A;&#x062E;&#x062F;&#x0645; &#x0636;&#x0645;&#x0646;: @lockedByPolicy
                                                </small>
                                            }
                                        </span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="CutoffPolicy.PolicyTypes" class="text-danger"></span>
                        </fieldset>

                        <label class="nx-setup-field nx-setup-field-wide">
                            <span>&#x0645;&#x0644;&#x0627;&#x062D;&#x0638;&#x0627;&#x062A;</span>
                            <textarea asp-for="CutoffPolicy.Notes" rows="3"></textarea>
                            <span asp-validation-for="CutoffPolicy.Notes" class="text-danger"></span>
                        </label>

                            <label class="nx-setup-check">
                                <input asp-for="CutoffPolicy.IsActive" />
                                <span>&#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629;</span>
                            </label>
                        </div>
                    </div>

                </form>

                <div class="nx-setup-modal__actions nx-cutoff-fixed-actions">
                    <button type="button"
                            class="nx-setup-btn nx-setup-btn-secondary"
                            data-nx-setup-close>
                        &#x0625;&#x0644;&#x063A;&#x0627;&#x0621;
                    </button>
                    <button type="submit"
                            form="cutoff-policy-form"
                            class="nx-setup-btn nx-setup-btn-primary">
                        &#x062D;&#x0641;&#x0638; &#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@* NEXORA_CUTOFF_DELETE_MODAL_START *@
<div id="cutoff-delete-modal"
     class="nx-setup-modal"
     aria-hidden="true"
     inert>
    <div class="nx-setup-modal__panel nx-cutoff-confirm-panel"
         role="alertdialog"
         aria-modal="true"
         aria-labelledby="cutoff-delete-title"
         aria-describedby="cutoff-delete-description">
        <button type="button"
                class="nx-setup-modal__close"
                data-nx-setup-close
                aria-label="Close">&times;</button>

        <div class="nx-setup-modal__head">
            <span>PAYROLL CUTOFF</span>
            <h2 id="cutoff-delete-title">&#x062A;&#x0623;&#x0643;&#x064A;&#x062F; &#x062D;&#x0630;&#x0641; &#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</h2>
            <p id="cutoff-delete-description">&#x0631;&#x0627;&#x062C;&#x0639; &#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0642;&#x0628;&#x0644; &#x062A;&#x0646;&#x0641;&#x064A;&#x0630; &#x0627;&#x0644;&#x062D;&#x0630;&#x0641;.</p>
        </div>

        <div class="nx-cutoff-confirm-summary">
            <span>&#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629; &#x0627;&#x0644;&#x0645;&#x062D;&#x062F;&#x062F;&#x0629;</span>
            <strong data-delete-policy-name></strong>
            <p>&#x0633;&#x064A;&#x062A;&#x0645; &#x062A;&#x062D;&#x0631;&#x064A;&#x0631; &#x0623;&#x0646;&#x0648;&#x0627;&#x0639; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0645;&#x0631;&#x062A;&#x0628;&#x0637;&#x0629; &#x0628;&#x0647;&#x0627; &#x0644;&#x062A;&#x0635;&#x0628;&#x062D; &#x0645;&#x062A;&#x0627;&#x062D;&#x0629; &#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0623;&#x062E;&#x0631;&#x0649;.</p>
        </div>

        <div class="nx-setup-modal__actions nx-cutoff-confirm-actions">
            <button type="button"
                    class="nx-setup-btn nx-setup-btn-secondary"
                    data-nx-setup-close
                    data-delete-cancel>
                &#x0625;&#x0644;&#x063A;&#x0627;&#x0621;
            </button>

            <button type="button"
                    class="nx-setup-btn nx-cutoff-confirm-delete"
                    data-delete-confirm-submit>
                <span data-delete-confirm-label>&#x062D;&#x0630;&#x0641; &#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0629;</span>
            </button>
        </div>
    </div>
</div>
@* NEXORA_CUTOFF_DELETE_MODAL_END *@

@section Scripts {
    <script src="~/js/nexora-company-setup.js" asp-append-version="true"></script>
}

@page
@model SmartAttendance.Web.Pages.Setup.IndexModel
@using SmartAttendance.Domain.Enums

@section Styles {
    <link rel="stylesheet" href="~/css/nexora-setup-pages.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "\u0625\u0639\u062f\u0627\u062f \u0627\u0644\u0634\u0631\u0643\u0629";
    var setup = Model.Setup;
    var hasCompanies = Model.Companies.Count > 0;
    var policyCount = setup?.CutoffPolicies.Count ?? 0;
    var activePolicyCount = setup?.CutoffPolicies.Count(x => x.IsActive) ?? 0;
    var workLocationCount = Model.Branches.Count;
    var departmentCount = Model.Departments.Count;
    var hasAvailableCutoffTypes = setup != null && Model.HasAvailableCutoffTypes();
    var companyDeactivationLocked = Model.IsCompanyDeactivationLocked;
}

@* NEXORA_ACTIVE_CUTOFF_TYPE_MARKUP_START *@<div class="nexora-setup-page nx-company-setup-page">
    <section class="nexora-setup-hero nx-company-setup-hero">
        <div>
            <span class="nexora-setup-kicker">NEXORA SETUP</span>
            <h1>&#x0625;&#x0639;&#x062F;&#x0627;&#x062F; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0648;&#x0647;&#x064A;&#x0643;&#x0644; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</h1>
            <p>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0647;&#x0648;&#x064A;&#x0629; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;&#x060C; &#x0645;&#x0648;&#x0627;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;&#x060C; &#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645;&#x060C; &#x0648;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642; &#x0645;&#x0646; &#x0645;&#x0643;&#x0627;&#x0646; &#x0648;&#x0627;&#x062D;&#x062F;.</p>
        </div>

        @if (hasCompanies)
        {
            <form method="get" class="nx-company-selector" aria-label="Company selector">
                <label for="CompanyId">&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</label>
                <select asp-for="CompanyId" data-company-selector>
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </select>
                <button type="submit" class="nx-setup-btn nx-setup-btn-secondary">&#x0639;&#x0631;&#x0636;</button>
            </form>
        }
    </section>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="nx-setup-alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="nx-setup-alert-danger">@errorMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="nx-setup-alert-danger"></div>
    }

    @if (!hasCompanies)
    {
        <section class="nexora-setup-card nx-company-empty">
            <div class="nx-company-empty-mark">N</div>
            <h2>&#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x0634;&#x0631;&#x0643;&#x0629; &#x0628;&#x0639;&#x062F;</h2>
            <p>&#x0623;&#x0636;&#x0641; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0627;&#x0644;&#x0623;&#x0648;&#x0644;&#x0649;&#x060C; &#x062B;&#x0645; &#x0627;&#x0631;&#x062C;&#x0639; &#x0644;&#x0625;&#x0643;&#x0645;&#x0627;&#x0644; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0639;&#x0627;&#x0631; &#x0648;&#x0627;&#x0644;&#x0628;&#x0644;&#x062F; &#x0648;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;.</p>
            <a asp-page="/Companies/Create" class="nx-setup-btn nx-setup-btn-primary">&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0634;&#x0631;&#x0643;&#x0629;</a>
        </section>
    }
    else if (setup != null)
    {
        <nav class="nx-company-setup-nav" aria-label="Setup sections">
            <a href="#company-profile">1. &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</a>
            <a href="#work-locations">2. &#x0645;&#x0648;&#x0627;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</a>
            <a href="#departments">3. &#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645;</a>
            <a href="#cutoff-policies">4. &#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</a>
        </nav>

        <section class="nx-company-setup-summary">
            <article>
                <span>&#x0645;&#x0648;&#x0627;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</span>
                <strong>@workLocationCount</strong>
            </article>
            <article>
                <span>&#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645;</span>
                <strong>@departmentCount</strong>
            </article>
            <article>
                <span>&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x063A;&#x0644;&#x0642;</span>
                <strong>@policyCount</strong>
            </article>
            <article>
                <span>&#x0627;&#x0644;&#x0633;&#x064A;&#x0627;&#x0633;&#x0627;&#x062A; &#x0627;&#x0644;&#x0641;&#x0639;&#x0627;&#x0644;&#x0629;</span>
                <strong>@activePolicyCount</strong>
            </article>
        </section>

        <section id="company-profile" class="nexora-setup-card nx-company-section">
            <div class="nexora-setup-card-head">
                <div>
                    <span>COMPANY PROFILE</span>
                    <strong>&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</strong>
                    <small>&#x0627;&#x0644;&#x0647;&#x0648;&#x064A;&#x0629; &#x0627;&#x0644;&#x0631;&#x0633;&#x0645;&#x064A;&#x0629; &#x0648;&#x0627;&#x0644;&#x0625;&#x0639;&#x062F;&#x0627;&#x062F;&#x0627;&#x062A; &#x0627;&#x0644;&#x0645;&#x062D;&#x0644;&#x064A;&#x0629; &#x0644;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;.</small>
                </div>
            </div>

            <form method="post" enctype="multipart/form-data" asp-page-handler="SaveProfile" class="nx-company-profile-layout">
                <input type="hidden" asp-for="Profile.CompanyId" />
                <input type="hidden" asp-for="Profile.CompanyCode" />

                <aside class="nx-company-logo-card">
                    <div class="nx-company-logo-preview" data-logo-preview>
                        @if (!string.IsNullOrWhiteSpace(Model.Profile.LogoPath))
                        {
                            <img src="@Model.Profile.LogoPath" alt="Company logo" />
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(Model.Profile.Name) ? "N" : Model.Profile.Name.Trim()[0])</span>
                        }
                    </div>
                    <strong>&#x0634;&#x0639;&#x0627;&#x0631; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</strong>
                    <small>PNG, JPG, WEBP - 5MB MAX</small>
                    <label class="nx-setup-btn nx-setup-btn-secondary nx-company-file-button">
                        <span>&#x0627;&#x062E;&#x062A;&#x064A;&#x0627;&#x0631; &#x0634;&#x0639;&#x0627;&#x0631;</span>
                        <input asp-for="LogoFile" type="file" accept=".png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp" data-logo-file />
                    </label>
                    <span asp-validation-for="LogoFile" class="text-danger"></span>

                    @if (!string.IsNullOrWhiteSpace(Model.Profile.LogoPath))
                    {
                        <label class="nx-setup-check nx-company-remove-logo">
                            <input asp-for="RemoveLogo" />
                            <span>&#x062D;&#x0630;&#x0641; &#x0627;&#x0644;&#x0634;&#x0639;&#x0627;&#x0631; &#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x064A;</span>
                        </label>
                    }
                </aside>

                <div class="nx-setup-form-grid nx-company-profile-fields">
                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</span>
                        <input asp-for="Profile.Name" />
                        <span asp-validation-for="Profile.Name" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0628;&#x0631;&#x064A;&#x062F; &#x0627;&#x0644;&#x0625;&#x0644;&#x0643;&#x062A;&#x0631;&#x0648;&#x0646;&#x064A;</span>
                        <input asp-for="Profile.Email" type="email" />
                        <span asp-validation-for="Profile.Email" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0631;&#x0642;&#x0645; &#x0627;&#x0644;&#x0647;&#x0627;&#x062A;&#x0641;</span>
                        <input asp-for="Profile.Phone" />
                        <span asp-validation-for="Profile.Phone" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0628;&#x0644;&#x062F;</span>
                        <select asp-for="Profile.CountryCode" asp-items="Model.CountryOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0628;&#x0644;&#x062F;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.CountryCode" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field">
                        <span>&#x0627;&#x0644;&#x0639;&#x0645;&#x0644;&#x0629;</span>
                        <select asp-for="Profile.CurrencyCode" asp-items="Model.CurrencyOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;&#x0629;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.CurrencyCode" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field nx-setup-field-wide">
                        <span>&#x0627;&#x0644;&#x0645;&#x0646;&#x0637;&#x0642;&#x0629; &#x0627;&#x0644;&#x0632;&#x0645;&#x0646;&#x064A;&#x0629;</span>
                        <select asp-for="Profile.TimeZoneId" asp-items="Model.TimeZoneOptions" data-nexora-native="true" data-searchable-select data-search-placeholder="&#x0627;&#x0628;&#x062D;&#x062B; &#x0639;&#x0646; &#x0627;&#x0644;&#x0645;&#x0646;&#x0637;&#x0642;&#x0629; &#x0627;&#x0644;&#x0632;&#x0645;&#x0646;&#x064A;&#x0629;">
                            <option value="">--</option>
                        </select>
                        <span asp-validation-for="Profile.TimeZoneId" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-field nx-setup-field-wide">
                        <span>&#x0627;&#x0644;&#x0639;&#x0646;&#x0648;&#x0627;&#x0646;</span>
                        <textarea asp-for="Profile.Address" rows="3"></textarea>
                        <span asp-validation-for="Profile.Address" class="text-danger"></span>
                    </label>

                    <label class="nx-setup-check @(companyDeactivationLocked ? "is-locked" : "")">
                        @if (companyDeactivationLocked)
                        {
                            <input type="hidden"
                                   name="Profile.IsActive"
                                   value="true" />
                            <input type="checkbox"
                                   checked
                                   disabled
                                   aria-describedby="company-active-lock-reason" />
                        }
                        else
                        {
                            <input asp-for="Profile.IsActive" />
                        }
                        <span>&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0641;&#x0639;&#x0627;&#x0644;&#x0629;</span>
                    </label>

                    @if (companyDeactivationLocked)
                    {
                        <div id="company-active-lock-reason"
                             class="nx-setup-lock-reason nx-setup-field-wide"
                             role="note">
                            <strong>&#x0644;&#x0627; &#x064A;&#x0645;&#x0643;&#x0646; &#x062A;&#x0639;&#x0637;&#x064A;&#x0644; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x062D;&#x0627;&#x0644;&#x064A;&#x0627;</strong>
                            <span>
                                @Model.ActiveEmployeeCount &#x0645;&#x0648;&#x0638;&#x0641; &#x0641;&#x0639;&#x0627;&#x0644;&#x060C;
                                @Model.ActiveBranchCount &#x0645;&#x0648;&#x0642;&#x0639; &#x0639;&#x0645;&#x0644; &#x0641;&#x0639;&#x0627;&#x0644;&#x060C;
                                @Model.ActiveDepartmentCount &#x0642;&#x0633;&#x0645; &#x0641;&#x0639;&#x0627;&#x0644;.
                            </span>
                        </div>
                    }

                    <div class="nx-setup-modal__actions nx-company-form-actions">
                        <button type="submit" class="nx-setup-btn nx-setup-btn-primary">&#x062D;&#x0641;&#x0638; &#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</button>
                    </div>
                </div>
            </form>
        </section>


        <section id="work-locations" class="nexora-setup-card nx-company-section">
            <div class="nexora-setup-card-head">
                <div>
                    <span>WORK LOCATIONS</span>
                    <strong>&#x0645;&#x0648;&#x0627;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644; &#x0648;&#x0627;&#x0644;&#x0641;&#x0631;&#x0648;&#x0639;</strong>
                    <small>&#x0623;&#x0636;&#x0641; &#x0627;&#x0644;&#x0645;&#x0643;&#x062A;&#x0628; &#x0627;&#x0644;&#x0631;&#x0626;&#x064A;&#x0633;&#x064A;&#x060C; &#x0627;&#x0644;&#x0641;&#x0631;&#x0648;&#x0639;&#x060C; &#x0627;&#x0644;&#x0645;&#x0634;&#x0627;&#x0631;&#x064A;&#x0639;&#x060C; &#x0623;&#x0648; &#x0646;&#x0642;&#x0627;&#x0637; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644; &#x0627;&#x0644;&#x062A;&#x0627;&#x0628;&#x0639;&#x0629; &#x0644;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;.</small>
                </div>

                <div class="nexora-setup-actions">
                    <a asp-page="/Branches/Import" asp-route-companyId="@setup.CompanyId" class="nx-setup-btn nx-setup-btn-secondary">&#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F; Excel</a>
                    <button type="button"
                            class="nx-setup-btn nx-setup-btn-primary"
                            data-nx-setup-open="setup-branch-modal"
                            @(setup.Profile.IsActive ? null : "disabled")>
                        &#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0645;&#x0648;&#x0642;&#x0639; &#x0639;&#x0645;&#x0644;
                    </button>
                </div>
            </div>

            @if (!setup.Profile.IsActive)
            {
                <div class="nx-setup-modal-note">
                    &#x064A;&#x062C;&#x0628; &#x062A;&#x0641;&#x0639;&#x064A;&#x0644; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0642;&#x0628;&#x0644; &#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0645;&#x0648;&#x0642;&#x0639; &#x0639;&#x0645;&#x0644; &#x062C;&#x062F;&#x064A;&#x062F;.
                </div>
            }

            <div class="nexora-setup-table-wrap">
                <table class="nexora-setup-table">
                    <thead>
                        <tr>
                            <th>&#x0645;&#x0648;&#x0642;&#x0639; &#x0627;&#x0644;&#x0639;&#x0645;&#x0644;</th>
                            <th>&#x0627;&#x0644;&#x0639;&#x0646;&#x0648;&#x0627;&#x0646;</th>
                            <th>&#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x0629;</th>
                            <th>&#x0627;&#x0644;&#x0625;&#x062C;&#x0631;&#x0627;&#x0621;&#x0627;&#x062A;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Branches.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="nx-setup-empty">&#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x0645;&#x0648;&#x0627;&#x0642;&#x0639; &#x0639;&#x0645;&#x0644; &#x0645;&#x0633;&#x062C;&#x0644;&#x0629; &#x0644;&#x0647;&#x0630;&#x0647; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var branch in Model.Branches)
                            {
                                var branchActiveEmployeeCount =
                                    Model.GetActiveEmployeeCountForBranch(branch.Id);
                                var branchDeleteLocked =
                                    Model.IsBranchDeletionLocked(branch.Id);
                                var branchDeleteLockReason = branchDeleteLocked
                                    ? Model.GetBranchDeletionLockReason(branch.Id)
                                    : null;

                                <tr>
                                    <td>
                                        <strong class="nx-setup-title">@branch.Name</strong>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(branch.Address) ? "-" : branch.Address)</td>
                                    <td>
                                        <span class="nx-setup-status @(branch.IsActive ? "is-active" : "is-inactive")">
                                            @(branch.IsActive ? "\u0641\u0639\u0627\u0644" : "\u063a\u064a\u0631 \u0641\u0639\u0627\u0644")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="nx-setup-row-actions">
                                            <button type="button"
                                                    class="btn-table btn-edit"
                                                    data-nx-setup-open="setup-branch-edit-modal"
                                                    data-branch-edit-open
                                                    data-branch-id="@branch.Id"
                                                    data-branch-company-id="@branch.CompanyId"
                                                    data-branch-name="@branch.Name"
                                                    data-branch-address="@(branch.Address ?? string.Empty)"
                                                    data-branch-active="@(branch.IsActive ? "true" : "false")"
                                                    data-branch-active-employee-count="@branchActiveEmployeeCount">
                                                &#x062A;&#x0639;&#x062F;&#x064A;&#x0644;
                                            </button>
                                            <span class="nx-setup-delete-guard @(branchDeleteLocked ? "is-locked" : "")"
                                                  title="@branchDeleteLockReason">
                                                <button type="button"
                                                        class="btn-table btn-delete"
                                                        data-nx-setup-open="setup-branch-delete-modal"
                                                        data-branch-delete-open
                                                        data-branch-id="@branch.Id"
                                                        data-branch-company-id="@branch.CompanyId"
                                                        data-branch-name="@branch.Name"
                                                        disabled="@branchDeleteLocked"
                                                        aria-disabled="@(branchDeleteLocked ? "true" : "false")"
                                                        aria-label="@(branchDeleteLocked ? branchDeleteLockReason : "حذف موقع العمل")">
                                                    &#x062D;&#x0630;&#x0641;
                                                </button>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section id="departments" class="nexora-setup-card nx-company-section">
            <div class="nexora-setup-card-head">
                <div>
                    <span>DEPARTMENTS</span>
                    <strong>&#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645;</strong>
                    <small>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645; &#x064A;&#x062A;&#x0628;&#x0639; &#x0644;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629; &#x0648;&#x064A;&#x0645;&#x0643;&#x0646; &#x0627;&#x0633;&#x062A;&#x062E;&#x062F;&#x0627;&#x0645;&#x0647; &#x0641;&#x064A; &#x0623;&#x0643;&#x062B;&#x0631; &#x0645;&#x0646; &#x0645;&#x0648;&#x0642;&#x0639; &#x0639;&#x0645;&#x0644;.</small>
                </div>

                <div class="nexora-setup-actions">
                    <a asp-page="/Departments/Import" asp-route-companyId="@setup.CompanyId" class="nx-setup-btn nx-setup-btn-secondary">&#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F; Excel</a>
                    <button type="button"
                            class="nx-setup-btn nx-setup-btn-primary"
                            data-nx-setup-open="setup-department-modal">
                        &#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0642;&#x0633;&#x0645;
                    </button>
                </div>
            </div>

            <div class="nexora-setup-table-wrap">
                <table class="nexora-setup-table">
                    <thead>
                        <tr>
                            <th>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</th>
                            <th>&#x0627;&#x0644;&#x062D;&#x0627;&#x0644;&#x0629;</th>
                            <th>&#x0627;&#x0644;&#x0625;&#x062C;&#x0631;&#x0627;&#x0621;&#x0627;&#x062A;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Departments.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="nx-setup-empty">&#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x0623;&#x0642;&#x0633;&#x0627;&#x0645; &#x0645;&#x0633;&#x062C;&#x0644;&#x0629; &#x0644;&#x0647;&#x0630;&#x0647; &#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var department in Model.Departments)
                            {
                                var departmentActiveEmployeeCount =
                                    Model.GetActiveEmployeeCountForDepartment(department.Id);
                                var departmentDeleteLocked =
                                    Model.IsDepartmentDeletionLocked(department.Id);
                                var departmentDeleteLockReason = departmentDeleteLocked
                                    ? Model.GetDepartmentDeletionLockReason(department.Id)
                                    : null;

                                <tr>
                                    <td>
                                        <strong class="nx-setup-title">@department.Name</strong>
                                    </td>
                                    <td>
                                        <span class="nx-setup-status @(department.IsActive ? "is-active" : "is-inactive")">
                                            @(department.IsActive ? "\u0641\u0639\u0627\u0644" : "\u063a\u064a\u0631 \u0641\u0639\u0627\u0644")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="nx-setup-row-actions">
                                            <button type="button"
                                                    class="btn-table btn-edit"
                                                    data-nx-setup-open="setup-department-edit-modal"
                                                    data-department-edit-open
                                                    data-department-id="@department.Id"
                                                    data-department-company-id="@department.CompanyId"
                                                    data-department-name="@department.Name"
                                                    data-department-active="@(department.IsActive ? "true" : "false")"
                                                    data-department-active-employee-count="@departmentActiveEmployeeCount">
                                                &#x062A;&#x0639;&#x062F;&#x064A;&#x0644;
                                            </button>
                                            <span class="nx-setup-delete-guard @(departmentDeleteLocked ? "is-locked" : "")"

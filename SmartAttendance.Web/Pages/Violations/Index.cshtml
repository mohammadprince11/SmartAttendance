@page
@model SmartAttendance.Web.Pages.Violations.IndexModel

@{
    ViewData["Title"] = "حالات المخالفات";

    var rows = Model.Items;
    var pendingCount = rows.Count(x => x.ActionStatus == "بانتظار الإجراء");
    var approvedCount = rows.Count(x => x.Status == "موافق عليه");
    var directCount = rows.Count(x => x.Source == "مباشر");
    var completedCount = rows.Count(x => x.Status == "تم اتخاذ الإجراء");
}

<link rel="stylesheet" href="~/css/nexora-reference-redesign-v3.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-violations-phase1-v14.css" asp-append-version="true" />
<script src="~/js/nexora-violations-phase1-v14.js" asp-append-version="true" defer></script>

<div class="nxr-page nxv-page" dir="rtl">
    <section class="nxv-hero">
        <div>
            <div class="nxv-brand">NEXORA HR DISCIPLINARY</div>
            <h1>حالات المخالفات</h1>
            <p>تسجيل ومتابعة المخالفات المثبتة على الموظفين، مع متابعة العقوبة ومبلغ الخصم وفورمة المخالفة.</p>
        </div>

        <div class="nxv-hero-actions">
            <button type="button" class="nxv-btn primary" data-nxv-open-modal>+ إضافة مخالفة</button>
            <button type="button" class="nxv-btn" data-nxv-print>طباعة السجل</button>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="nxv-alert success">@TempData["SuccessMessage"]</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="nxv-alert danger">يرجى مراجعة الحقول المطلوبة داخل نافذة إضافة مخالفة.</div>
    }

    <section class="nxv-tabs-card">
        <div class="nxv-tabs" aria-label="تبويبات المخالفات">
            <button type="button" class="active" data-nxv-tab="all">كل الحالات</button>
            <button type="button" data-nxv-tab="pending">بانتظار الإجراء</button>
            <button type="button" data-nxv-tab="approved">موافق عليه</button>
            <button type="button" data-nxv-tab="completed">تم اتخاذ الإجراء</button>
        </div>
    </section>

    <section class="nxv-kpis">
        <div class="nxv-kpi">
            <span>إجمالي الحالات</span>
            <strong>@Model.TotalCount</strong>
            <small>كل المخالفات الحالية</small>
        </div>

        <div class="nxv-kpi warn">
            <span>بانتظار الإجراء</span>
            <strong>@pendingCount</strong>
            <small>تحتاج مراجعة HR</small>
        </div>

        <div class="nxv-kpi ok">
            <span>موافق عليه</span>
            <strong>@approvedCount</strong>
            <small>تم اعتماد الإجراء</small>
        </div>

        <div class="nxv-kpi done">
            <span>تم اتخاذ الإجراء</span>
            <strong>@completedCount</strong>
            <small>حالات مكتملة</small>
        </div>

        <div class="nxv-kpi info">
            <span>مصدر مباشر</span>
            <strong>@directCount</strong>
            <small>من الإدارة أو المسؤول المباشر</small>
        </div>
    </section>

    <section class="nxv-filter-card">
        <div class="nxv-search">
            <span>⌕</span>
            <input type="search"
                   placeholder="ابحث عن الموظف، الرقم المرجعي، نوع المخالفة، العقوبة أو مبلغ الخصم..."
                   data-nxv-search />
        </div>

        <select data-nexora-select="true" data-nxv-filter="status">
            <option value="">كل الحالات</option>
            <option value="مسودة">مسودة</option>
            <option value="بانتظار الاعتماد">بانتظار الاعتماد</option>
            <option value="موافق عليه">موافق عليه</option>
            <option value="مرفوض">مرفوض</option>
            <option value="تم اتخاذ الإجراء">تم اتخاذ الإجراء</option>
        </select>

        <select data-nexora-select="true" data-nxv-filter="source">
            <option value="">كل المصادر</option>
            <option value="مباشر">مباشر</option>
            <option value="النظام">النظام</option>
            <option value="HR">HR</option>
            <option value="فرع">فرع</option>
        </select>

        <button type="button" class="nxv-btn ghost" data-nxv-reset>إعادة تعيين</button>
    </section>

    <section class="nxv-card nxv-table-card">
        <div class="nxv-table-head">
            <div>
                <h2>سجل المخالفات</h2>
                <p>اختيار الفئة يفلتر أنواع المخالفات، والفورمة مربوطة ببيانات الموظف والمخالفة.</p>
            </div>

            <span class="nxv-count" data-nxv-count>@rows.Count حالة</span>
        </div>

        <div class="nxv-table-wrap">
            <table class="nxv-table nxv-table-v15">
                <colgroup>
                    <col class="nxv-col-ref" />
                    <col class="nxv-col-employee" />
                    <col class="nxv-col-violation" />
                    <col class="nxv-col-date" />
                    <col class="nxv-col-source" />
                    <col class="nxv-col-penalty" />
                    <col class="nxv-col-deduction" />
                    <col class="nxv-col-status" />
                    <col class="nxv-col-options" />
                </colgroup>

                <thead>
                    <tr>
                        <th>الرقم المرجعي</th>
                        <th>الموظف</th>
                        <th>المخالفة</th>
                        <th>تاريخ الحدث</th>
                        <th>المصدر</th>
                        <th>العقوبة</th>
                        <th>مبلغ الخصم</th>
                        <th>الحالة</th>
                        <th>خيارات</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in rows)
                    {
                        <tr data-nxv-row
                            data-status="@item.Status"
                            data-action="@item.ActionStatus"
                            data-source="@item.Source"
                            data-search="@($"{item.ReferenceNo} {item.EmployeeCode} {item.EmployeeName} {item.Position} {item.Branch} {item.Department} {item.ViolationTitle} {item.ViolationCategory} {item.Source} {item.Status} {item.ActionStatus} {item.FinalPenaltyAction} {item.DeductionAmount}")">
                            <td>
                                <span class="nxv-ref">@item.ReferenceNo</span>
                            </td>

                            <td>
                                <div class="nxv-employee">
                                    <span class="nxv-avatar">@item.Avatar</span>
                                    <div>
                                        <strong>@item.EmployeeName</strong>
                                        <small>@item.EmployeeCode</small>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="nxv-violation">
                                    <strong>@item.ViolationTitle</strong>
                                    <small>@item.ViolationCategory</small>
                                </div>
                            </td>

                            <td>@item.EventDate.ToString("dd/MM/yyyy")</td>

                            <td>
                                <span class="nxv-chip source">@item.Source</span>
                            </td>

                            <td>
                                <div class="nxv-violation">
                                    <strong>@(!string.IsNullOrWhiteSpace(item.FinalPenaltyAction) ? item.FinalPenaltyAction : "-")</strong>
                                    <small>@item.DisplayFinancialImpact</small>
                                </div>
                            </td>

                            <td>
                                <span class="nxv-money">@item.DeductionAmount.ToString("N0") د.ع</span>
                            </td>

                            <td>
                                <span class="nxv-status @item.StatusCss">@item.Status</span>
                            </td>

                            <td>
                                <div class="nxv-options">
                                    <a asp-page="/Employees/Profile" asp-route-id="@item.EmployeeId" title="فتح ملف الموظف">موظف</a>
                                    <a asp-page="/Violations/PrintForm" asp-route-id="@item.Id" title="عرض فورمة A4 المربوطة">فورمة</a>
                                </div>
                            </td>
                        </tr>
                    }

                    <tr class="nxv-empty" data-nxv-empty @(rows.Any() ? "hidden" : "")>
                        <td colspan="9">لا توجد مخالفات مسجلة حالياً.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <div class="nxv-modal" data-nxv-modal data-nxv-open-on-load="@Model.OpenCreateModal.ToString().ToLowerInvariant()" hidden>
        <div class="nxv-modal-backdrop" data-nxv-close-modal></div>

        <section class="nxv-modal-panel" role="dialog" aria-modal="true" aria-labelledby="nxv-modal-title">
            <form method="post" asp-page-handler="Create" class="nxv-modal-form">
                <div class="nxv-modal-head">
                    <div>
                        <div class="nxv-modal-eyebrow">NEW VIOLATION</div>
                        <h2 id="nxv-modal-title">إضافة مخالفة جديدة</h2>
                        <p>ابحث عن الموظف بالكود أو الاسم، اختر الفئة ثم نوع المخالفة، وبعدها عدّل العقوبة أو مبلغ الخصم إذا احتجت.</p>
                    </div>

                    <button type="button" class="nxv-modal-close" data-nxv-close-modal aria-label="إغلاق">×</button>
                </div>

                <div asp-validation-summary="ModelOnly" class="nxv-validation-summary"></div>

                <div class="nxv-form-scroll">
                    <div class="nxv-form-grid">
                        <label class="wide">
                            <span>الموظف</span>
                            <input type="search"
                                   list="nxv-employees-list"
                                   autocomplete="off"
                                   data-nxv-employee-search
                                   placeholder="اكتب الكود أو اسم الموظف..." />
                            <input asp-for="Input.EmployeeId" type="hidden" data-nxv-employee-id />
                            <datalist id="nxv-employees-list">
                                @foreach (var employee in Model.EmployeeOptions)
                                {
                                    <option value="@employee.SearchText" data-id="@employee.Id"></option>
                                }
                            </datalist>
                            <small asp-validation-for="Input.EmployeeId"></small>
                        </label>

                        <label>
                            <span>الفئة</span>
                            <select data-nexora-select="true" asp-for="Input.CategoryId" data-nxv-category-select>
                                <option value="">اختر الفئة أولاً</option>
                                @foreach (var category in Model.CategoryOptions)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <small asp-validation-for="Input.CategoryId"></small>
                        </label>

                        <label class="wide">
                            <span>نوع المخالفة</span>
                            <select data-nexora-select="true" asp-for="Input.ViolationTypeId" data-nxv-violation-type disabled>
                                <option value="">اختر الفئة حتى تظهر المخالفات</option>
                                @foreach (var violation in Model.ViolationOptions)
                                {
                                    <option value="@violation.Id"
                                            data-category-id="@violation.CategoryId"
                                            data-category="@violation.CategoryName"
                                            data-penalty="@violation.PenaltyAction"
                                            data-impact-type="@violation.FinancialImpactType"
                                            data-impact-value="@violation.FinancialValue.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        @violation.ViolationName
                                    </option>
                                }
                            </select>
                            <small asp-validation-for="Input.ViolationTypeId"></small>
                        </label>

                        <label>
                            <span>تاريخ الحدث</span>
                            <input asp-for="Input.EventDate" type="date" />
                            <small asp-validation-for="Input.EventDate"></small>
                        </label>

                        <label>
                            <span>المصدر</span>
                            <select data-nexora-select="true" asp-for="Input.Source">
                                <option>مباشر</option>
                                <option>النظام</option>
                                <option>HR</option>
                                <option>فرع</option>
                            </select>
                            <small asp-validation-for="Input.Source"></small>
                        </label>

                        <label>
                            <span>حالة الإجراء</span>
                            <select data-nexora-select="true" asp-for="Input.ActionStatus">
                                <option>بانتظار الإجراء</option>
                                <option>اتخذ الإجراء</option>
                                <option>قيد المراجعة</option>
                            </select>
                            <small asp-validation-for="Input.ActionStatus"></small>
                        </label>

                        <label>
                            <span>الحالة</span>
                            <select data-nexora-select="true" asp-for="Input.Status">
                                <option>مسودة</option>
                                <option>بانتظار الاعتماد</option>
                                <option>موافق عليه</option>
                                <option>مرفوض</option>
                                <option>تم اتخاذ الإجراء</option>
                            </select>
                            <small asp-validation-for="Input.Status"></small>
                        </label>

                        <label class="wide">
                            <span>العقوبة</span>
                            <input asp-for="Input.FinalPenaltyAction" data-nxv-penalty-action placeholder="تظهر العقوبة تلقائياً ويمكن تعديلها" />
                            <small asp-validation-for="Input.FinalPenaltyAction"></small>
                        </label>

                        <div class="nxv-impact-box wide">
                            <strong>أثر اللائحة</strong>
                            <span data-nxv-impact-preview>اختر نوع المخالفة حتى يظهر أثر اللائحة.</span>
                            <small>هذا وصف الجزاء من إعدادات المخالفات مثل: يوم، ساعة، أو مبلغ ثابت. لا يعني بالضرورة المبلغ النهائي في الراتب.</small>
                        </div>

                        <input asp-for="Input.FinancialImpactType" type="hidden" data-nxv-impact-type />
                        <input asp-for="Input.FinancialImpactValue" type="hidden" data-nxv-impact-value />

                        <label>
                            <span>مبلغ الخصم بالدينار</span>
                            <input asp-for="Input.DeductionAmount" type="number" min="0" step="0.01" data-nxv-deduction-amount placeholder="مثال: 25000" />
                            <small asp-validation-for="Input.DeductionAmount"></small>
                        </label>

                        <label class="wide">
                            <span>الإجراء المقترح</span>
                            <input asp-for="Input.ProposedAction" placeholder="مثال: إنذار / تعهد / خصم" />
                            <small asp-validation-for="Input.ProposedAction"></small>
                        </label>

                        <label class="wide">
                            <span>ملاحظات</span>
                            <textarea asp-for="Input.Notes" rows="3" placeholder="ملاحظات إضافية اختيارية"></textarea>
                            <small asp-validation-for="Input.Notes"></small>
                        </label>
                    </div>
                </div>

                <div class="nxv-modal-note">
                    <strong>توضيح:</strong>
                    أثر اللائحة هو القاعدة المسجلة في إعدادات المخالفات. مبلغ الخصم بالدينار هو الرقم الذي سيُستخدم لاحقاً في الرواتب والاستقطاعات.
                </div>

                <div class="nxv-modal-actions">
                    <button type="button" class="nxv-btn ghost" data-nxv-close-modal>إلغاء</button>
                    <button type="submit" class="nxv-btn primary">حفظ المخالفة</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/js/nexora-violations-dropdowns.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}





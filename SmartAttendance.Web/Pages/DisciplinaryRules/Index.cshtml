@page
@model SmartAttendance.Web.Pages.DisciplinaryRules.IndexModel
@{
    ViewData["Title"] = "Ш·ВҘШ·В№Ш·ВҜШ·В§Ш·ВҜШ·В§Ш·Ъҫ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ";
    var activeTab = Model.Tab;
    var selectedCategory = Model.SelectedCategoryId;
    var visibleTypes = Model.ViolationTypes.Where(x => selectedCategory <= 0 || x.CategoryId == selectedCategory).ToList();
    var visibleRules = Model.PenaltyRules.Where(x => selectedCategory <= 0 || x.CategoryId == selectedCategory).ToList();
}

<link rel="stylesheet" href="~/css/nexora-disciplinary-rules.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/nexora-a4-custom-file-picker-v13-1.css" asp-append-version="true" />

<section class="nxpen-page nxpen-wide" dir="rtl">
    <header class="nxpen-hero">
        <div class="nxpen-hero-copy">
            <span>HR SETTINGS / DISCIPLINARY CONFIGURATION</span>
            <h1>Ш·ВҘШ·В№Ш·ВҜШ·В§Ш·ВҜШ·В§Ш·Ъҫ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ</h1>
            <p>ШёвҖ Ш·ВЁШёвҖ ШёЩ№ ШёвҖЎШёвҖ Ш·В§ Ш·ВҜШ·ВіШ·ЪҫШёЛҶШ·Вұ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ ШёвҖһШёвҖһШ·ВҙШ·ВұШёЖ’Ш·В©: ШёвҖЎШёвҖһ Ш·ЪҫШ·ВӯШ·ЪҫШ·В§Ш·В¬ ШёвҖһШ·В¬ШёвҖ Ш·В© ШёвҖҰШёЛҶШ·В§ШёЩҫШёвҖҡШ·В§Ш·ЪҫШ·Ъә ШёвҖЎШёвҖһ ШёЩ№Ш·ВӯШёвҖҡ ШёвҖһШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫ Ш·В§ШёвҖһШ·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶Ш·Ъә ШёвҖҰШ·В§ ШёвҖЎШёЩ№ Ш·В§ШёвҖһШёЩҫШ·ВҰШ·В§Ш·Ъҫ ШёЛҶШ·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·ЪҫШ·Ъә ШёЛҶШёвҖҰШ·В§ ШёвҖЎШёЛҶ Ш·ВҙШёЖ’ШёвҖһ ШёЩҫШёЛҶШ·ВұШёвҖҰШ·В© Ш·В§ШёвҖһШ·В№ШёвҖҡШёЛҶШ·ВЁШ·В© Ш·В§ШёвҖһШ·ЪҫШёЩ№ Ш·ВіШ·ЪҫШ·ВөШ·ВҜШ·Вұ Ш·ВЁШ·В§Ш·ВіШёвҖҰ Ш·В§ШёвҖһШ·ВҙШ·ВұШёЖ’Ш·В©Ш·Ъә</p>
        </div>
</header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="nxpen-alert">@Model.StatusMessage</div>
    }

    <nav class="nxpen-tabs">
        <a class="@(activeTab == "setup" ? "active" : "")" asp-page="./Index" asp-route-tab="setup">Ш·ЪҫШёвҖЎШёЩ№Ш·ВҰШ·В©</a>
        <a class="@(activeTab == "library" ? "active" : "")" asp-page="./Index" asp-route-tab="library" asp-route-categoryId="@selectedCategory">ШёЩҫШ·ВҰШ·В© Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёЛҶШёвҖҡШ·В§Ш·ВҰШёвҖҰШ·В© Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ</a>
        <a class="@(activeTab == "designer" ? "active" : "")" asp-page="./Index" asp-route-tab="designer">ШёвҖҰШ·ВөШёвҖҰШёвҖҰ Ш·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰШ·В©</a>
        <a class="@(activeTab == "templates" ? "active" : "")" asp-page="./Index" asp-route-tab="templates">ШёвҖҡШёЛҶШ·В§ШёвҖһШ·ВЁ Ш·В§ШёвҖһШ·ВұШ·ВіШ·В§Ш·ВҰШёвҖһ ШёЛҶШ·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰ</a>
    </nav>

    <main class="nxpen-layout">
        <section class="nxpen-content">
            @if (activeTab == "setup")
            {
                <section class="nxpen-card">
                    <header class="nxpen-card-head relaxed">
                        <div>
                            <span>Configuration</span>
                            <h2>Ш·ЪҫШёвҖЎШёЩ№Ш·ВҰШ·В© ШёвҖ Ш·ВёШ·В§ШёвҖҰ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ</h2>
                            <p>ШёвҖЎШ·В°ШёвҖЎ Ш·В§ШёвҖһШ·ВөШёЩҫШ·ВӯШ·В© Ш·ЪҫШ·ВӯШ·ВҜШ·ВҜ Ш·В·Ш·ВұШёЩ№ШёвҖҡШ·В© Ш·В№ШёвҖҰШёвҖһ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·Ъҫ ШёвҖҡШ·ВЁШёвҖһ Ш·ЪҫШ·ВіШ·В¬ШёЩ№ШёвҖһШёвҖЎШ·В§ Ш·В№ШёвҖһШёвҖ° Ш·В§ШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫШёЩ№ШёвҖ : Ш·В§ШёвҖһШ·В§Ш·В№Ш·ЪҫШёвҖҰШ·В§Ш·ВҜШ·Е’ Ш·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫШ·Е’ ШёЛҶШ·ВөШёЩ№Ш·ШӣШ·В© Ш·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰШ·В© Ш·В§ШёвҖһШ·ВұШ·ВіШёвҖҰШёЩ№Ш·В©.</p>
                        </div>
                    </header>

                    <form method="post" asp-page-handler="SaveSettings" class="nxpen-settings-grid">
                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>ШёвҖһШ·В¬ШёвҖ Ш·В© Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§ШёЩҫШёвҖҡШ·В§Ш·Ъҫ</strong><p>Ш·В№ШёвҖ Ш·ВҜ Ш·В§ШёвҖһШ·ЪҫШёЩҫШ·В№ШёЩ№ШёвҖһШ·Е’ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёвҖһШ·В§ Ш·ЪҫШёЪҲШёвҖҡШёЩҫШёвҖһ ШёвҖҰШ·ВЁШ·В§Ш·ВҙШ·ВұШ·В© Ш·ВҘШёвҖһШ·В§ Ш·ВЁШ·В№Ш·ВҜ Ш·В§ШёвҖһШёвҖҰШ·ВұШёЛҶШ·Вұ Ш·ВЁШёвҖҰШ·ВіШ·В§Ш·Вұ ШёвҖһШ·В¬ШёвҖ Ш·В© Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§ШёЩҫШёвҖҡШ·В§Ш·Ъҫ.</p></div>
                            <label class="nxpen-switch"><input type="checkbox" name="requiresCommitteeApproval" value="true" checked="@Model.Settings.RequiresCommitteeApproval" /><span></span></label>
                        </article>

                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>Ш·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫ</strong><p>Ш·В§ШёвҖһШ·ВіШёвҖҰШ·В§Ш·Вӯ ШёвҖһШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫ Ш·ВЁШ·ЪҫШёвҖҡШ·ВҜШёЩ№ШёвҖҰ Ш·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶ ШёвҖҰШёвҖ  Ш·ВЁШёЛҶШ·В§Ш·ВЁШ·В© Ш·В§ШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫ Ш·ВЁШ·В№Ш·ВҜ Ш·ВөШ·ВҜШёЛҶШ·Вұ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В©.</p></div>
                            <label class="nxpen-switch"><input type="checkbox" name="allowEmployeeAppeal" value="true" checked="@Model.Settings.AllowEmployeeAppeal" /><span></span></label>
                        </article>

                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>ШёвҖҰШ·ВҜШ·В© Ш·В§ШёвҖһШ·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶</strong><p>Ш·В№Ш·ВҜШ·ВҜ Ш·В§ШёвҖһШ·ВЈШёЩ№Ш·В§ШёвҖҰ Ш·В§ШёвҖһШёвҖҰШ·ЪҫШ·В§Ш·ВӯШ·В© ШёвҖһШёвҖһШёвҖҰШёЛҶШ·ВёШёЩҫ ШёвҖһШ·ЪҫШёвҖҡШ·ВҜШёЩ№ШёвҖҰ Ш·В§Ш·В№Ш·ЪҫШ·ВұШ·В§Ш·В¶ Ш·ВЁШ·В№Ш·ВҜ Ш·В§Ш·ВіШ·ЪҫШёвҖһШ·В§ШёвҖҰ Ш·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В©.</p></div>
                            <input name="appealWindowDays" type="number" min="0" value="@Model.Settings.AppealWindowDays" />
                        </article>

                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ Ш·В§ШёвҖһШ·В§ШёЩҫШ·ЪҫШ·ВұШ·В§Ш·В¶ШёЩ№</strong><p>Ш·ВҘШ·В°Ш·В§ ШёвҖһШёвҖҰ ШёЩ№Ш·ЪҫШёвҖҰ Ш·В§Ш·В®Ш·ЪҫШёЩ№Ш·В§Ш·Вұ ШёвҖҡШ·В§ШёвҖһШ·ВЁ ШёвҖҰШ·ВӯШ·ВҜШ·ВҜШ·Е’ ШёЩ№Ш·ВіШ·ЪҫШ·В®Ш·ВҜШёвҖҰ Ш·В§ШёвҖһШёвҖ Ш·ВёШ·В§ШёвҖҰ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ Ш·В§ШёвҖһШ·В§ШёЩҫШ·ЪҫШ·ВұШ·В§Ш·В¶ШёЩ№ ШёвҖһШ·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ Ш·В§ШёвҖһШ·В№ШёвҖҡШёЛҶШ·ВЁШ·В©.</p></div>
                            <select data-nexora-select="true" name="defaultTemplateType">
                                @foreach (var templateType in Model.TemplateTypes.Where(x => x.IsActive))
                                {
                                    <option value="@templateType.Code" selected="@(templateType.Code == Model.Settings.DefaultTemplateType)">@templateType.Name</option>
                                }
                            </select>
                        </article>

                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>Ш·В§Ш·ВіШёвҖҰ Ш·В§ШёвҖһШ·В¬ШёвҖЎШ·В© Ш·В§ШёвҖһШёвҖҰШ·В№Ш·ЪҫШёвҖҰШ·ВҜШ·В©</strong><p>ШёЩ№Ш·ВёШёвҖЎШ·Вұ ШёЩҫШёЩ№ Ш·ВЈШ·ВіШёЩҫШёвҖһ Ш·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰШ·В© ШёвҖҰШ·В«ШёвҖһ ШёвҖҡШ·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§Ш·ВұШ·ВҜ Ш·В§ШёвҖһШ·ВЁШ·ВҙШ·ВұШёЩ№Ш·В© Ш·ВЈШёЛҶ ШёвҖһШ·В¬ШёвҖ Ш·В© Ш·В§ШёвҖһШ·В§ШёвҖ Ш·В¶Ш·ВЁШ·В§Ш·В·.</p></div>
                            <input name="approvingAuthorityName" value="@Model.Settings.ApprovingAuthorityName" placeholder="ШёвҖҡШ·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§Ш·ВұШ·ВҜ Ш·В§ШёвҖһШ·ВЁШ·ВҙШ·ВұШёЩ№Ш·В©" />
                        </article>

                        <article class="nxpen-setting-card">
                            <div class="nxpen-setting-copy"><strong>Ш·ВөШёЩ№Ш·ШӣШ·В© Ш·ВұШёвҖҡШёвҖҰ Ш·В§ШёвҖһШёЖ’Ш·ЪҫШ·В§Ш·ВЁ</strong><p>Ш·ЪҫШёЪҲШ·ВіШ·ЪҫШ·В®Ш·ВҜШёвҖҰ ШёвҖһШ·В§Ш·ВӯШёвҖҡШ·В§ШёвҖ№ Ш·В№ШёвҖ Ш·ВҜ Ш·ЪҫШёЛҶШёвҖһШёЩ№Ш·ВҜ Ш·ВЈШ·ВұШёвҖҡШ·В§ШёвҖҰ ШёЖ’Ш·ЪҫШ·ВЁ Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В§Ш·ЪҫШ·Е’ ШёвҖҰШ·В«Ш·В§ШёвҖһ: DISC-{yyyy}-{0000}</p></div>
                            <input name="documentNumberFormat" value="@Model.Settings.DocumentNumberFormat" placeholder="DISC-{yyyy}-{0000}" />
                        </article>

                        <article class="nxpen-form-shell">
                            <header><div><strong>ШёвҖЎШёЩ№Ш·ВҜШ·Вұ Ш·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰШ·В©</strong><p>Ш·ВҘШ·В°Ш·В§ Ш·ЪҫШ·ВұШёЖ’Ш·ЪҫШёвҖЎ ШёЩҫШ·В§Ш·ВұШ·ШӣШ·В§ШёвҖ№ Ш·ВіШёЩ№Ш·ВёШёвҖЎШ·Вұ ШёвҖЎШёЩ№Ш·ВҜШ·Вұ Ш·ЪҫШёвҖһШёвҖҡШ·В§Ш·ВҰШёЩ№ ШёЩ№Ш·ВӯШ·ЪҫШёЛҶШёЩ№ Ш·ВҙШ·В№Ш·В§Ш·Вұ NEXORA ШёЛҶШ·ВЁШёЩ№Ш·В§ШёвҖ Ш·В§Ш·Ъҫ Ш·В§ШёвҖһШёвҖ Ш·ВёШ·В§ШёвҖҰ.</p></div><small>Header</small></header>
                            <textarea name="formHeader" rows="7" placeholder="Ш·ВҙШ·ВұШёЖ’Ш·В© Ш·В§ШёвҖһШ·ВұШ·ШӣШ·ВҜ Ш·В§ШёвҖһШ·ВҜШёЛҶШёвҖһШёЩ№Ш·В©\nШёвҖҡШ·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§Ш·ВұШ·ВҜ Ш·В§ШёвҖһШ·ВЁШ·ВҙШ·ВұШёЩ№Ш·В©\nШ·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёЛҶШ·В¬Ш·ВІШ·В§Ш·ШҢ">@Model.Settings.FormHeader</textarea>
                        </article>

                        <article class="nxpen-form-shell">
                            <header><div><strong>ШёЩҫШёЛҶШ·ЪҫШ·Вұ Ш·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰШ·В©</strong><p>ШёЩ№Ш·ВёШёвҖЎШ·Вұ Ш·ВЈШ·ВіШёЩҫШёвҖһ Ш·ВұШ·ВіШ·В§ШёвҖһШ·В© Ш·В§ШёвҖһШ·В№ШёвҖҡШёЛҶШ·ВЁШ·В©Ш·Е’ ШёвҖҰШ·В«ШёвҖһ Ш·В§ШёвҖһШ·ЪҫШёЛҶШёвҖҡШёЩ№Ш·В№Ш·В§Ш·Ъҫ Ш·ВЈШёЛҶ ШёвҖҰШёвҖһШ·В§Ш·ВӯШ·ВёШ·В§Ш·Ъҫ ШёвҖҡШ·В§ШёвҖ ШёЛҶШёвҖ ШёЩ№Ш·В©.</p></div><small>Footer</small></header>
                            <textarea name="formFooter" rows="7" placeholder="ШёвҖҡШ·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҰШёЛҶШ·В§Ш·ВұШ·ВҜ Ш·В§ШёвҖһШ·ВЁШ·ВҙШ·ВұШёЩ№Ш·В©\nШёЩ№Ш·В№Ш·ЪҫШёвҖҰШ·ВҜ ШёвҖЎШ·В°Ш·В§ Ш·В§ШёвҖһШ·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ Ш·ВӯШ·ВіШ·ВЁ ШёвҖһШ·В§Ш·ВҰШ·ВӯШ·В© Ш·В§ШёвҖһШ·В¬Ш·ВІШ·В§Ш·ШҢШ·В§Ш·Ъҫ Ш·В§ШёвҖһШёвҖҰШ·В№Ш·ЪҫШёвҖҰШ·ВҜШ·В© ШёЩҫШёЩ№ Ш·В§ШёвҖһШ·ВҙШ·ВұШёЖ’Ш·В©.">@Model.Settings.FormFooter</textarea>
                        </article>

                        <footer class="nxpen-settings-actions"><button type="submit">Ш·ВӯШёЩҫШ·Вё Ш·ВҘШ·В№Ш·ВҜШ·В§Ш·ВҜШ·В§Ш·Ъҫ Ш·В§ШёвҖһШ·ЪҫШёвҖЎШёЩ№Ш·ВҰШ·В©</button></footer>
                    </form>

                    <section class="nxpen-form-preview">
                        <div class="nxpen-form-paper">
                            <header class="nxpen-paper-header">
                                @if (string.IsNullOrWhiteSpace(Model.Settings.FormHeader))
                                {
                                    <div class="nxpen-auto-header"><div class="nxpen-logo-mark">N</div><div><strong>NEXORA HR</strong><small>Disciplinary Notice / Ш·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёЛҶШ·В¬Ш·ВІШ·В§Ш·ШҢ</small></div></div>
                                }
                                else
                                {
                                    <pre>@Model.Settings.FormHeader</pre>

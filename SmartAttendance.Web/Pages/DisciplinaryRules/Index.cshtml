                                    }

                                    @foreach (var block in Model.TextBlocks.Where(x => x.Area == "Body" && x.IsActive))
                                    {
                                        <div class="nxpen-text-block" data-layer-id="@block.Id" data-layer-area="@block.Area" style="@Model.BuildTextBlockStyle(block)">@block.Text</div>
                                    }
                                </div>

                                <div class="nxpen-a4-section nxpen-a4-footer">
                                    @if (!string.IsNullOrWhiteSpace(Model.Settings.FooterImagePath))
                                    {
                                        <img src="@Model.Settings.FooterImagePath" alt="Footer" />
                                    }
                                    else
                                    {
                                        <div class="nxpen-auto-footer"><strong>@Model.Settings.ApprovingAuthorityName</strong><small>Ш·ЪҫШёвҖҰ Ш·ВҘШёвҖ Ш·ВҙШ·В§Ш·ШҢ ШёвҖЎШ·В°Ш·В§ Ш·В§ШёвҖһШ·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШёвҖ  ШёвҖ Ш·ВёШ·В§ШёвҖҰ NEXORA HR</small></div>
                                    }

                                    @foreach (var block in Model.TextBlocks.Where(x => x.Area == "Footer" && x.IsActive))
                                    {
                                        <div class="nxpen-text-block" data-layer-id="@block.Id" data-layer-area="@block.Area" style="@Model.BuildTextBlockStyle(block)">@block.Text</div>
                                    }
                                </div>
                            </div>
                        </section>
                    </section>
                </section>
            }
else
            {
                <section class="nxpen-card">
                    <header class="nxpen-card-head">
                        <div><span>Dynamic Company Forms</span><h2>ШёвҖҡШёЛҶШ·В§ШёвҖһШ·ВЁ Ш·В§ШёвҖһШ·ВұШ·ВіШ·В§Ш·ВҰШёвҖһ ШёЛҶШ·В§ШёвҖһШёЩҫШёЛҶШ·ВұШёвҖҰ</h2><p>Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ ШёЩ№ШёвҖҰШ·В«ШёвҖһ ШёвҖ Ш·Вө Ш·В§ШёвҖһШ·В№ШёвҖҡШёЛҶШ·ВЁШ·В©Ш·Е’ ШёЛҶШёЩ№Ш·ВЈШ·В®Ш·В° Ш·В§ШёвҖһШёвҖЎШёЩ№Ш·ВҜШ·Вұ ШёЛҶШ·В§ШёвҖһШёЩҫШёЛҶШ·ЪҫШ·Вұ ШёвҖҰШёвҖ  Ш·ВҘШ·В№Ш·ВҜШ·В§Ш·ВҜШ·В§Ш·Ъҫ Ш·В§ШёвҖһШ·ЪҫШёвҖЎШёЩ№Ш·ВҰШ·В©. Ш·ВҘШ·В°Ш·В§ ШёвҖһШёвҖҰ Ш·ЪҫШ·ВӯШ·ВҜШ·ВҜ ШёвҖЎШёЩ№Ш·ВҜШ·ВұШ·Е’ Ш·ВіШёЩ№Ш·ВіШ·ЪҫШ·В®Ш·ВҜШёвҖҰ Ш·В§ШёвҖһШёвҖ Ш·ВёШ·В§ШёвҖҰ ШёвҖЎШёЩ№Ш·ВҜШ·Вұ Ш·ЪҫШёвҖһШёвҖҡШ·В§Ш·ВҰШёЩ№ Ш·ВЁШ·ВҙШ·В№Ш·В§Ш·Вұ Ш·В§ШёвҖһШёвҖ Ш·ВёШ·В§ШёвҖҰ ШёЛҶШ·ЪҫШёЩҫШ·В§Ш·ВөШёЩ№ШёвҖһШёвҖЎ.</p></div>
                    </header>
                    <section class="nxpen-template-type-box">
                        <header><div><h3>Ш·ВЈШёвҖ ШёЛҶШ·В§Ш·В№ Ш·В§ШёвҖһШёвҖҡШёЛҶШ·В§ШёвҖһШ·ВЁ</h3><small>Ш·ВЈШ·В¶ШёЩҫ Ш·ВЈШёвҖ ШёЛҶШ·В§Ш·В№ ШёвҖҡШёЛҶШ·В§ШёвҖһШ·ВЁ Ш·В¬Ш·ВҜШёЩ№Ш·ВҜШ·В© Ш·ВӯШ·ВіШ·ВЁ Ш·ВіШёЩ№Ш·В§Ш·ВіШ·В© Ш·В§ШёвҖһШ·ВҙШ·ВұШёЖ’Ш·В©Ш·Е’ ШёвҖҰШ·В«ШёвҖһ Ш·ВҘШёвҖ Ш·В°Ш·В§Ш·ВұШ·Е’ Ш·В§Ш·ВіШ·ЪҫШёвҖҡШ·В·Ш·В§Ш·В№Ш·Е’ Ш·ВҘШёвҖ Ш·В°Ш·В§Ш·Вұ ШёвҖ ШёвҖЎШ·В§Ш·ВҰШёЩ№Ш·Е’ Ш·ВҘШ·ВӯШ·В§ШёвҖһШ·В© ШёвҖһШёвҖһШ·В¬ШёвҖ Ш·В©.</small></div></header>
                        <form method="post" asp-page-handler="CreateTemplateType" class="nxpen-grid-form compact">
                            <input name="name" required placeholder="Ш·В§Ш·ВіШёвҖҰ ШёвҖ ШёЛҶШ·В№ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ" />
                            <input name="code" required placeholder="Code ШёвҖҰШ·В«ШёвҖһ CommitteeReferral" />
                            <textarea name="description" placeholder="ШёЛҶШ·ВөШёЩҫ Ш·В§ШёвҖһШёвҖ ШёЛҶШ·В№"></textarea>
                            <button type="submit">Ш·ВҘШ·В¶Ш·В§ШёЩҫШ·В© ШёвҖ ШёЛҶШ·В№ ШёвҖҡШ·В§ШёвҖһШ·ВЁ</button>
                        </form>
                        <div class="nxpen-template-type-list">
                            @foreach (var templateType in Model.TemplateTypes)
                            {
                                <form method="post" asp-page-handler="UpdateTemplateType" class="nxpen-template-type-row">
                                    <input type="hidden" name="id" value="@templateType.Id" />
                                    <input name="name" value="@templateType.Name" required />
                                    <input name="code" value="@templateType.Code" required />
                                    <input name="description" value="@templateType.Description" />
                                    <label class="nxpen-switch small"><input type="checkbox" name="isActive" value="true" checked="@templateType.IsActive" /><span></span></label>
                                    <button type="submit">Ш·ВӯШёЩҫШ·Вё</button>
                                </form>
                            }
                        </div>
                    </section>
                    <section class="nxpen-template-vars"><strong>Ш·В§ШёвҖһШёвҖҰШ·ЪҫШ·ШӣШёЩ№Ш·ВұШ·В§Ш·Ъҫ</strong>@foreach (var token in Model.TemplateTokens){<button type="button" data-nxpen-token="@token">@token</button>}</section>
                    <form method="post" asp-page-handler="CreateTemplate" class="nxpen-grid-form template-form">
                        <div><label>Ш·В§Ш·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><input name="name" required placeholder="ШёвҖҰШ·В«Ш·В§ШёвҖһ: ШёвҖ ШёвҖҰШёЛҶШ·В°Ш·В¬ Ш·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ Ш·В№ШёвҖҡШёЛҶШ·ВЁШ·В©" /></div>
                        <div><label>ШёвҖ ШёЛҶШ·В№ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><select data-nexora-select="true" name="templateType">
                                        @foreach (var templateType in Model.TemplateTypes.Where(x => x.IsActive))
                                        {
                                            <option value="@templateType.Code" selected="@(templateType.Code == Model.Settings.DefaultTemplateType)">@templateType.Name</option>
                                        }
                                    </select></div>
                        <div class="wide-2"><label>Ш·В№ШёвҖ ШёЛҶШ·В§ШёвҖ  Ш·В§ШёвҖһШ·ВұШ·ВіШ·В§ШёвҖһШ·В©</label><input name="subject" required value="Ш·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёЛҶШ·В¬Ш·ВІШ·В§Ш·ШҢ - {EmployeeName}" /></div>
                        <div class="wide"><label>ШёвҖ Ш·Вө Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><textarea name="body" rows="12">@Model.DefaultTemplateBody</textarea></div>
                        <div class="wide nxpen-checks"><label class="nxpen-check-pill"><input type="checkbox" name="isDefault" value="true" /><span></span><b>ШёвҖҡШ·В§ШёвҖһШ·ВЁ Ш·В§ШёЩҫШ·ЪҫШ·ВұШ·В§Ш·В¶ШёЩ№</b></label><label class="nxpen-check-pill"><input type="checkbox" name="isActive" value="true" checked /><span></span><b>ШёЩҫШ·В№Ш·В§ШёвҖһ</b></label></div>
                        <footer class="wide"><button type="submit">Ш·ВҘШ·В¶Ш·В§ШёЩҫШ·В© ШёвҖҡШ·В§ШёвҖһШ·ВЁ</button></footer>
                    </form>
                    <section class="nxpen-form-preview">
                        <div class="nxpen-form-paper">
                            <header class="nxpen-paper-header">
                                @if (string.IsNullOrWhiteSpace(Model.Settings.FormHeader))
                                {
                                    <div class="nxpen-auto-header"><div class="nxpen-logo-mark">N</div><div><strong>NEXORA HR</strong><small>Disciplinary Notice / Ш·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В© ШёЛҶШ·В¬Ш·ВІШ·В§Ш·ШҢ</small></div></div>
                                }
                                else
                                {
                                    <pre>@Model.Settings.FormHeader</pre>
                                }
                            </header>
                            <main class="nxpen-paper-body"><h3>ШёвҖ Ш·Вө Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ ШёЩ№Ш·ВёШёвҖЎШ·Вұ ШёвҖЎШёвҖ Ш·В§ Ш·ВҜШ·В§Ш·В®ШёвҖһ ШёЩҫШёЛҶШ·ВұШёвҖҰШ·В© Ш·В§ШёвҖһШ·ВҙШ·ВұШёЖ’Ш·В©</h3><p>Ш·В§ШёвҖһШ·ВіШёЩ№Ш·ВҜ/Ш·В©: {EmployeeName}<br />Ш·В§ШёвҖһШёвҖҰШ·В®Ш·В§ШёвҖһШёЩҫШ·В©: {ViolationName}<br />Ш·В§ШёвҖһШ·В№ШёвҖҡШёЛҶШ·ВЁШ·В©: {PenaltyAction}<br />Ш·В§ШёвҖһШ·ВЈШ·В«Ш·Вұ Ш·В§ШёвҖһШёвҖҰШ·В§ШёвҖһШёЩ№: {FinancialImpact}</p></main>
                            <footer class="nxpen-paper-footer">
                                @if (string.IsNullOrWhiteSpace(Model.Settings.FormFooter))
                                {
                                    <span>@Model.Settings.ApprovingAuthorityName</span><small>Ш·ЪҫШёвҖҰ Ш·ВҘШёвҖ Ш·ВҙШ·В§Ш·ШҢ ШёвҖЎШ·В°Ш·В§ Ш·В§ШёвҖһШ·ВҘШ·ВҙШ·В№Ш·В§Ш·Вұ ШёвҖҰШёвҖ  ШёвҖ Ш·ВёШ·В§ШёвҖҰ NEXORA HR</small>
                                }
                                else
                                {
                                    <pre>@Model.Settings.FormFooter</pre>
                                }
                            </footer>
                        </div>
                    </section>

                    <div class="nxpen-edit-list">
                        @foreach (var template in Model.MessageTemplates)
                        {
                            <details class="nxpen-edit-item @(template.IsActive ? "" : "disabled")">
                                <summary><span>@(template.IsDefault ? "ГўЪ©вҖҰ" : "ГўЕ“вҖ°")</span><strong>@template.Name</strong><small>@Model.DisplayTemplateType(template.TemplateType) / @template.Subject</small></summary>
                                <form method="post" asp-page-handler="UpdateTemplate" class="nxpen-grid-form edit template-form">
                                    <input type="hidden" name="id" value="@template.Id" />
                                    <div><label>Ш·В§Ш·ВіШёвҖҰ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><input name="name" value="@template.Name" required /></div>
                                    <div><label>ШёвҖ ШёЛҶШ·В№ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><select data-nexora-select="true" name="templateType">
                                        @foreach (var templateType in Model.TemplateTypes.Where(x => x.IsActive))
                                        {
                                            <option value="@templateType.Code" selected="@(templateType.Code == template.TemplateType)">@templateType.Name</option>
                                        }
                                    </select></div>
                                    <div class="wide-2"><label>Ш·В§ШёвҖһШ·В№ШёвҖ ШёЛҶШ·В§ШёвҖ </label><input name="subject" value="@template.Subject" required /></div>
                                    <div class="wide"><label>ШёвҖ Ш·Вө Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</label><textarea name="body" rows="12">@template.Body</textarea></div>
                                    <div class="wide nxpen-checks"><label class="nxpen-check-pill"><input type="checkbox" name="isDefault" value="true" checked="@template.IsDefault" /><span></span><b>Ш·В§ШёЩҫШ·ЪҫШ·ВұШ·В§Ш·В¶ШёЩ№</b></label><label class="nxpen-check-pill"><input type="checkbox" name="isActive" value="true" checked="@template.IsActive" /><span></span><b>ШёЩҫШ·В№Ш·В§ШёвҖһ</b></label></div>
                                    <footer class="wide"><button type="submit">Ш·ВӯШёЩҫШ·Вё Ш·ЪҫШ·В№Ш·ВҜШёЩ№ШёвҖһ Ш·В§ШёвҖһШёвҖҡШ·В§ШёвҖһШ·ВЁ</button></footer>
                                </form>
                            </details>
                        }
                    </div>
                </section>
            }
        </section>
    </main>
</section>


@page
@model SmartAttendance.Web.Pages.EmployeeShifts.DeleteModel

@{
    ViewData["Title"] = "حذف مناوبة موظف";
}

<div class="page-header">
    <div>
        <h1>حذف مناوبة موظف</h1>
        <p>تأكيد حذف مناوبة الموظف</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this employee shift?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>رقم الموظف</label>
            <div class="form-control">@Model.EmployeeShift.EmployeeNo</div>
        </div>

        <div class="form-group">
            <label>اسم الموظف</label>
            <div class="form-control">@Model.EmployeeShift.EmployeeName</div>
        </div>

        <div class="form-group">
            <label>المناوبة</label>
            <div class="form-control">@Model.EmployeeShift.ShiftCode - @Model.EmployeeShift.ShiftName</div>
        </div>

        <div class="form-group">
            <label>ساري من</label>
            <div class="form-control">@Model.EmployeeShift.EffectiveFrom</div>
        </div>

        <div class="form-group">
            <label>ساري إلى</label>
            <div class="form-control">@(Model.EmployeeShift.EffectiveTo?.ToString() ?? "-")</div>
        </div>

        <div class="form-group">
            <label>الحالي</label>
            <div class="form-control">@(Model.EmployeeShift.IsCurrent ? "نعم" : "لا")</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.EmployeeShift.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

@page
@model SmartAttendance.Web.Pages.EmployeeShifts.CreateModel

@{
    ViewData["Title"] = "إسناد مناوبة";
}

<div class="page-header">
    <div>
        <h1>إسناد مناوبة</h1>
        <p>إسناد مناوبة ويوم راحة أسبوعية لموظف</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label asp-for="EmployeeShift.EmployeeId">الموظف</label>
            <select asp-for="EmployeeShift.EmployeeId" class="form-control">
                <option value="">-- Select Employee --</option>

                @foreach (var employee in Model.Employees)
                {
                    <option value="@employee.Id">@employee.EmployeeNo - @employee.FullName</option>
                }
            </select>
            <span asp-validation-for="EmployeeShift.EmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeShift.ShiftId">المناوبة</label>
            <select asp-for="EmployeeShift.ShiftId" class="form-control">
                <option value="">-- Select Shift --</option>

                @foreach (var shift in Model.Shifts)
                {
                    <option value="@shift.Id">@shift.Code - @shift.Name (@shift.StartTime.ToString("HH:mm") - @shift.EndTime.ToString("HH:mm"))</option>
                }
            </select>
            <span asp-validation-for="EmployeeShift.ShiftId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeShift.EffectiveFrom">ساري من</label>
            <input asp-for="EmployeeShift.EffectiveFrom" type="date" class="form-control" />
            <span asp-validation-for="EmployeeShift.EffectiveFrom" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeShift.EffectiveTo">ساري إلى</label>
            <input asp-for="EmployeeShift.EffectiveTo" type="date" class="form-control" />
            <span asp-validation-for="EmployeeShift.EffectiveTo" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeShift.WeeklyOffDays">أيام الراحة الأسبوعية</label>
            <input asp-for="EmployeeShift.WeeklyOffDays"
                   class="form-control"
                   placeholder="مثال: الجمعة أو الجمعة,السبت" />
            <small style="color:#64748b;font-weight:700;">
                Supported: Friday, Saturday, Sunday... You can also write Arabic day names مثل: الجمعة
            </small>
            <span asp-validation-for="EmployeeShift.WeeklyOffDays" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="EmployeeShift.IsCurrent" />
                Current Shift
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">حفظ</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

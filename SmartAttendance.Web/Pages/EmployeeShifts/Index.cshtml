@page
@model SmartAttendance.Web.Pages.EmployeeShifts.IndexModel

@{
    ViewData["Title"] = "مناوبات الموظفين";
}

<div class="page-header">
    <div>
        <h1>مناوبات الموظفين</h1>
        <p>إسناد المناوبات وأيام الراحة الأسبوعية للموظفين بتواريخ سريان</p>
    </div>

    <a asp-page="./Create" class="btn-primary">+ إسناد مناوبة</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث بالموظف أو المناوبة أو الراحة الأسبوعية..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>رقم الموظف</th>
                <th>اسم الموظف</th>
                <th>المناوبة</th>
                <th>الراحة الأسبوعية</th>
                <th>ساري من</th>
                <th>ساري إلى</th>
                <th>الحالي</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.EmployeeShifts.Any())
            {
                foreach (var item in Model.EmployeeShifts)
                {
                    <tr>
                        <td>@item.EmployeeNo</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.ShiftCode - @item.ShiftName</td>
                        <td>@(string.IsNullOrWhiteSpace(item.WeeklyOffDays) ? "-" : item.WeeklyOffDays)</td>
                        <td>@item.EffectiveFrom</td>
                        <td>@(item.EffectiveTo?.ToString() ?? "-")</td>
                        <td>@(item.IsCurrent ? "نعم" : "لا")</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="text-align:center;">
                        لا توجد مناوبات موظفين.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

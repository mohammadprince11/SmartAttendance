@page
@model SmartAttendance.Web.Pages.IndexModel
@using SmartAttendance.Web.Infrastructure.Hrms

@*
    لوحة التحكم القابلة للبناء — نمط لوحة أشخاص كيان (فحص حي 2026-07-22):
    صف عدادات ثم شبكة بطاقات رسوم 3 أعمدة (col-xl-4 عند كيان). كل عنصر ويدجت
    معرف بجدول DashboardWidgets: المستخدم يختار «شنو يظهر» (مقياس) و«شلون يظهر»
    (رقم/أشرطة/أعمدة/دونات/جدول) من درج «تخصيص اللوحة»، ويرتب ويخفي ويحذف.
    الرسوم CSS خالصة (أشرطة/أعمدة/دونات conic-gradient) بلا مكتبات.
*@

@{
    ViewData["Title"] = "لوحة التحكم";
    var today = DateTime.Today;

    // ألوان أجزاء الدونات والأعمدة (تدوير ثابت)
    var paletteColors = new[] { "#12D9E3", "#4ade80", "#facc15", "#f87171", "#a78bfa", "#60a5fa", "#f472b6", "#fb923c" };

    var counters = Model.VisibleWidgets.Where(w => w.Widget.ChartKind == "Number").ToList();
    var charts = Model.VisibleWidgets.Where(w => w.Widget.ChartKind != "Number").ToList();
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/zynora-exec-dashboard.css" asp-append-version="true" />

<section class="zxd-page" dir="rtl">

    @* ---------- الهيدر ---------- *@
    <header class="zxd-head">
        <div>
            <h1>لوحة التحكم</h1>
            <div class="zxd-date">@today.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar-IQ")) · @Model.SelectedCompanyName</div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <form method="get" class="zxd-company">
                <select name="CompanyId" onchange="this.form.submit()">
                    @foreach (var company in Model.CompanyOptions)
                    {
                        <option value="@company.Id" selected="@(company.Id == Model.CompanyId)">@company.Name (@company.EmployeeCount)</option>
                    }
                </select>
            </form>
            <button type="button" class="zxd-more" style="border-style:dashed" onclick="zxdOpenBuilder()">تخصيص اللوحة</button>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="zxd-alert">@TempData["SuccessMessage"]</div>
    }

    @* ---------- صف العدادات (ويدجتات «رقم») ---------- *@
    @if (counters.Count > 0)
    {
        <div class="zxd-card">
            <div class="zxd-stats">
                @foreach (var (widget, data) in counters)
                {
                    <div class="zxd-stat">
                        <b>@data.Single.ToString("N0")</b>
                        <span>@widget.DisplayTitle</span>
                    </div>
                }
            </div>
        </div>
    }

    @* ---------- شبكة بطاقات الرسوم (نمط كيان: 3 أعمدة) ---------- *@
    <div class="zxd-grid">
        @foreach (var (widget, data) in charts)
        {
            var rows = data.Rows;
            var total = Math.Max(1, rows.Sum(r => r.Total));
            var max = Math.Max(1, rows.Count == 0 ? 1 : rows.Max(r => r.Total));

            <div class="zxd-card">
                <h2>@widget.DisplayTitle <span class="zxd-badge">@total.ToString("N0")</span></h2>
                <div class="zxd-card-body">
                @if (rows.Count == 0 || rows.All(r => r.Total == 0))
                {
                    <div class="zxd-empty">لا يوجد بيانات</div>
                }
                else if (widget.ChartKind == "HBars")
                {
                    <div class="zxd-dist">
                        @foreach (var (row, index) in rows.Take(30).Select((r, i) => (r, i)))
                        {
                            <div class="zxd-dist-row" hidden="@(index >= 5)" data-more="@(index >= 5 ? "1" : null)">
                                <span class="n" title="@row.Name">@row.Name</span>
                                <span class="bar"><i style="width:@(Math.Max(3, row.Total * 100 / max))%"></i></span>
                                <span class="v">@row.Total (@(row.Total * 100 / total)%)</span>
                            </div>
                        }
                    </div>
                    @if (rows.Count > 5)
                    {
                        <button type="button" class="zxd-showmore" onclick="zxdShowMore(this)">عرض المزيد (@(Math.Min(rows.Count, 30) - 5))</button>
                    }
                }
                else if (widget.ChartKind == "Columns")
                {
                    <div class="zxd-cols">
                        @foreach (var row in rows.Take(11))
                        {
                            <div class="zxd-col" title="@row.Name: @row.Total">
                                <i style="height:@(Math.Max(4, row.Total * 100 / max))%"></i>
                                <span class="v">@row.Total</span>
                                <span class="n">@row.Name</span>
                            </div>
                        }
                    </div>
                }
                else if (widget.ChartKind == "Donut")
                {
                    var slices = rows.Take(5).ToList();
                    var otherTotal = rows.Skip(5).Sum(r => r.Total);
                    if (otherTotal > 0) { slices.Add(("أخرى", otherTotal)); }
                    var acc = 0.0;
                    var stops = new List<string>();
                    for (var i = 0; i < slices.Count; i++)
                    {
                        var start = acc;
                        acc += slices[i].Total * 360.0 / total;
                        stops.Add($"{paletteColors[i % paletteColors.Length]} {start:0.#}deg {acc:0.#}deg");
                    }
                    <div class="zxd-donut-wrap">
                        <div class="zxd-donut" style="background:conic-gradient(@string.Join(", ", stops))"><i></i></div>
                        <div class="zxd-legend">
                            @for (var i = 0; i < slices.Count; i++)
                            {
                                <span><i style="background:@paletteColors[i % paletteColors.Length]"></i>@slices[i].Name <b>@slices[i].Total</b></span>
                            }
                        </div>
                    </div>
                }
                else @* Table *@
                {
                    <table class="zxd-table">
                        <thead><tr><th>الاسم</th><th>العدد</th><th>النسبة</th></tr></thead>
                        <tbody>
                            @foreach (var (row, index) in rows.Take(30).Select((r, i) => (r, i)))
                            {
                                <tr hidden="@(index >= 5)" data-more="@(index >= 5 ? "1" : null)">
                                    <td>@row.Name</td>
                                    <td class="zxd-ltr">@row.Total</td>
                                    <td class="zxd-ltr">@(row.Total * 100 / total)%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (rows.Count > 5)
                    {
                        <button type="button" class="zxd-showmore" onclick="zxdShowMore(this)">عرض المزيد (@(Math.Min(rows.Count, 30) - 5))</button>
                    }
                }
                </div>
            </div>
        }
    </div>

    @* ---------- درج «تخصيص اللوحة» (نمط hrms-slideover المجرب بكل الشاشات) ---------- *@
    <div class="hrms-slideover-backdrop" id="zxd-backdrop" onclick="zxdCloseBuilder()"></div>
    <aside class="hrms-slideover" id="zxd-builder" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2>تخصيص اللوحة</h2>
            <button type="button" class="hrms-slideover-close" onclick="zxdCloseBuilder()">×</button>
        </div>
        <div class="hrms-slideover-body zxd-builder-body">

            <h3>الويدجتات الحالية <small>رتّب بالأسهم، أظهر/أخفِ بالمربع</small></h3>
            <form method="post" asp-page-handler="SaveLayout" id="zxd-layout-form">
                <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
                <input type="hidden" name="OrderedIds" id="zxd-ordered" />
                <ul class="zxd-wlist" id="zxd-wlist">
                    @foreach (var widget in Model.AllWidgets)
                    {
                        <li data-id="@widget.Id">
                            <label><input type="checkbox" name="VisibleIds" value="@widget.Id" checked="@widget.IsVisible" /></label>
                            <span class="t">@widget.DisplayTitle</span>
                            <span class="k">@DashboardWidgetStore.ChartKinds.FirstOrDefault(c => c.Key == widget.ChartKind).Label</span>
                            <span class="mv">
                                <button type="button" onclick="zxdMove(this, -1)">▲</button>
                                <button type="button" onclick="zxdMove(this, 1)">▼</button>
                            </span>
                            <button type="button" class="zxd-del" title="حذف"
                                    onclick="zxdDelete(this, @widget.Id)">×</button>
                        </li>
                    }
                </ul>
                <button type="submit" class="zxd-more" style="margin-top:10px" onclick="zxdCollectOrder()">حفظ التخطيط</button>
            </form>

            <form method="post" asp-page-handler="DeleteWidget" id="zxd-delete-form" hidden>
                <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
                <input type="hidden" name="id" id="zxd-delete-id" />
            </form>

            <h3 style="margin-top:18px">إضافة ويدجت</h3>
            <form method="post" asp-page-handler="AddWidget" class="zxd-addform">
                <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
                <label>المقياس (شنو يظهر)
                    <select name="Metric" id="zxd-metric" onchange="zxdMetricChanged()">
                        @foreach (var (key, label, isCounter) in DashboardWidgetStore.Metrics)
                        {
                            <option value="@key" data-counter="@(isCounter ? "1" : "0")">@label</option>
                        }
                    </select>
                </label>
                <label id="zxd-kind-wrap">شكل العرض (شلون يظهر)
                    <select name="ChartKind" id="zxd-kind">
                        @foreach (var (key, label) in DashboardWidgetStore.ChartKinds.Where(c => c.Key != "Number"))
                        {
                            <option value="@key">@label</option>
                        }
                    </select>
                </label>
                <label>عنوان مخصص (اختياري)
                    <input type="text" name="Title" placeholder="فارغ = تسمية المقياس" />
                </label>
                <button type="submit" class="zxd-more">إضافة</button>
            </form>
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        function zxdOpenBuilder() {
            document.getElementById('zxd-builder').classList.add('open');
            document.getElementById('zxd-backdrop').classList.add('open');
        }
        function zxdCloseBuilder() {
            document.getElementById('zxd-builder').classList.remove('open');
            document.getElementById('zxd-backdrop').classList.remove('open');
        }
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') zxdCloseBuilder(); });

        // «عرض المزيد»: يظهر بقية الصفوف المخفية بنفس البطاقة
        function zxdShowMore(btn) {
            var body = btn.closest('.zxd-card-body');
            body.querySelectorAll('[data-more]').forEach(function (el) { el.hidden = false; });
            btn.remove();
        }

        // ترتيب: تحريك عنصر القائمة أعلى/أسفل
        function zxdMove(btn, dir) {
            var li = btn.closest('li');
            if (dir < 0 && li.previousElementSibling) li.parentNode.insertBefore(li, li.previousElementSibling);
            if (dir > 0 && li.nextElementSibling) li.parentNode.insertBefore(li.nextElementSibling, li);
        }
        function zxdCollectOrder() {
            var ids = Array.from(document.querySelectorAll('#zxd-wlist li')).map(function (li) { return li.dataset.id; });
            document.getElementById('zxd-ordered').value = ids.join(',');
        }
        // حذف بنقرتين بلا نافذة تأكيد قديمة: النقرة الأولى تسلّح الزر («تأكيد؟»)
        // والثانية خلال 3 ثوانٍ تنفذ — وإلا يرجع لحاله.
        function zxdDelete(btn, id) {
            if (btn.dataset.armed) {
                document.getElementById('zxd-delete-id').value = id;
                document.getElementById('zxd-delete-form').submit();
                return;
            }
            btn.dataset.armed = '1';
            btn.classList.add('armed');
            btn.textContent = 'تأكيد الحذف؟';
            setTimeout(function () {
                delete btn.dataset.armed;
                btn.classList.remove('armed');
                btn.textContent = '×';
            }, 3000);
        }

        // العدادات شكلها «رقم» حصراً — نخفي منتقي الشكل لها
        function zxdMetricChanged() {
            var option = document.getElementById('zxd-metric').selectedOptions[0];
            document.getElementById('zxd-kind-wrap').hidden = option.dataset.counter === '1';
        }
        zxdMetricChanged();
    </script>
}

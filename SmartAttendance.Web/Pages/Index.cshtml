@page
@model SmartAttendance.Web.Pages.IndexModel

@*
    لوحة التحكم التنفيذية — إعادة تصميم (2026-07) بأفكار من فحص حي لكيان وZenHR:
    - من كيان: قوائم اليوم بالأسماء (تبويبات) + جملة استبصار طبيعية + KPI قابلة للنقر.
    - من ZenHR: شارة الفترة الزمنية على كل بطاقة + بطاقات أقل وأنظف.
    - حذف التكرار: «نبض اليوم» كان يكرر أرقام KPI — الأشرطة اندمجت ببطاقات KPI نفسها.
    - التوزيعات الفارغة (أغلبها «غير محدد») تُخفى تلقائياً حتى تمتلئ بياناتها.
    كل البيانات من IndexModel (دفعة SQL واحدة) — الواجهة عرض فقط.
*@

@{
    ViewData["Title"] = "لوحة التحكم";

    static string SafeName(string? value) =>
        string.IsNullOrWhiteSpace(value) || value == "Not Set" ? "غير محدد" : value;

    static string StatusText(string? status) => status switch
    {
        "Pending" => "معلق",
        "Approved" => "مقبول",
        "Rejected" => "مرفوض",
        _ => string.IsNullOrWhiteSpace(status) ? "-" : status
    };

    static string StatusClass(string? status) => status switch
    {
        "Pending" => "pending",
        "Approved" => "approved",
        "Rejected" => "rejected",
        _ => ""
    };

    static int BarWidth(int value, int max) => max <= 0 ? 0 : Math.Max(3, (int)Math.Round(value * 100.0 / max));

    var activeTotal = Math.Max(1, Model.ActiveEmployees);
    var today = DateTime.Today;
    var presentPct = (Model.TodayPresent + Model.TodayLate) * 100 / activeTotal;

    // توزيعة «ذات معنى» = فيها أكثر من صف وأغلبها ليس «غير محدد» (وإلا تُخفى — تقليل الحشو)
    static bool IsMeaningful(List<SmartAttendance.Web.Pages.IndexModel.NameCountRow> rows)
    {
        if (rows.Count <= 1) return false;
        var total = rows.Sum(r => r.Total);
        var notSet = rows.FirstOrDefault(r => r.Name == "غير محدد")?.Total ?? 0;
        return total > 0 && notSet * 100.0 / total < 90;
    }

    var distributions = new (string Title, List<SmartAttendance.Web.Pages.IndexModel.NameCountRow> Rows)[]
    {
        ("حسب الفرع", Model.ByBranch),
        ("حسب القسم", Model.ByDepartment),
        ("حسب الجنس", Model.ByGender),
        ("حسب البلد", Model.ByCountry),
        ("حسب الجنسية", Model.ByNationality),
        ("حسب نوع العقد", Model.ByContractType),
    }.Where(d => IsMeaningful(d.Rows)).ToArray();
}

<link rel="stylesheet" href="~/css/zynora-exec-dashboard.css" asp-append-version="true" />

<section class="zxd-page" dir="rtl">

    @* ---------- الهيدر: عنوان + تاريخ + محدد الشركة ---------- *@
    <header class="zxd-head">
        <div>
            <h1>لوحة التحكم التنفيذية</h1>
            <div class="zxd-date">@today.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar-IQ")) · @Model.SelectedCompanyName</div>
        </div>
        <form method="get" class="zxd-company">
            <select name="CompanyId" onchange="this.form.submit()">
                @foreach (var company in Model.CompanyOptions)
                {
                    <option value="@company.Id" selected="@(company.Id == Model.CompanyId)">@company.Name (@company.EmployeeCount)</option>
                }
            </select>
        </form>
    </header>

    @* ---------- شريط KPI: الأشرطة مدمجة بالبطاقات (بدل بطاقة «نبض اليوم» المكررة) ---------- *@
    <div class="zxd-kpis">
        <a class="zxd-kpi" href="/Employees">
            <span class="ic">👥</span>
            <div class="zxd-kpi-body">
                <b>@Model.Employees.ToString("N0")</b><span>إجمالي الموظفين</span>
                <small>فعال @Model.ActiveEmployees.ToString("N0") · غير فعال @Model.InactiveEmployees.ToString("N0")</small>
            </div>
        </a>
        <a class="zxd-kpi green" href="/DayAttendance">
            <span class="ic">✅</span>
            <div class="zxd-kpi-body">
                <b>@Model.TodayPresent.ToString("N0")</b><span>حضور اليوم</span>
                <span class="kbar green"><i style="width:@BarWidth(Model.TodayPresent, activeTotal)%"></i></span>
            </div>
        </a>
        <a class="zxd-kpi amber" href="/DayAttendance">
            <span class="ic">⏰</span>
            <div class="zxd-kpi-body">
                <b>@Model.TodayLate.ToString("N0")</b><span>متأخرون اليوم</span>
                <span class="kbar amber"><i style="width:@BarWidth(Model.TodayLate, activeTotal)%"></i></span>
            </div>
        </a>
        <a class="zxd-kpi red" href="/DayAttendance">
            <span class="ic">🚫</span>
            <div class="zxd-kpi-body">
                <b>@Model.TodayAbsent.ToString("N0")</b><span>غياب اليوم</span>
                <span class="kbar red"><i style="width:@BarWidth(Model.TodayAbsent, activeTotal)%"></i></span>
            </div>
        </a>
        <a class="zxd-kpi amber" href="/AttendanceCorrections">
            <span class="ic">↩️</span>
            <div class="zxd-kpi-body">
                <b>@Model.TodayMissingOut.ToString("N0")</b><span>بلا بصمة خروج</span>
                <span class="kbar teal"><i style="width:@BarWidth(Model.TodayMissingOut, activeTotal)%"></i></span>
            </div>
        </a>
        <a class="zxd-kpi" href="/Approvals">
            <span class="ic">📨</span>
            <div class="zxd-kpi-body">
                <b>@Model.PendingRequests.ToString("N0")</b><span>طلبات معلقة</span>
                <small>بانتظار موافقتك</small>
            </div>
        </a>
    </div>

    @* ---------- جملة الاستبصار (نمط كيان) ---------- *@
    <div class="zxd-insight">
        <span class="zxd-chip @(Model.PulseFromEngine ? "approved" : "pending")">@(Model.PulseFromEngine ? "محرك الحضور" : "السجلات الخام")</span>
        من أصل <b>@Model.ActiveEmployees.ToString("N0")</b> موظفاً نشطاً حضر اليوم
        <b>@((Model.TodayPresent + Model.TodayLate).ToString("N0"))</b> (@presentPct%) —
        منهم <b>@Model.TodayLate.ToString("N0")</b> متأخرون،
        و<b>@Model.TodayAbsent.ToString("N0")</b> غائبون،
        و<b>@Model.TodayMissingOut.ToString("N0")</b> بلا بصمة خروج.
    </div>

    @* ---------- متابعة اليوم بالأسماء (نمط كيان) + آخر 30 يوماً والطلبات ---------- *@
    <div class="zxd-row-2">
        <div class="zxd-card">
            <h2>
                متابعة اليوم
                <span class="zxd-tabs" id="zxd-today-tabs">
                    <button type="button" class="active" data-tab="late" onclick="zxdTab('late')">متأخرون (@Model.TodayLateList.Count)</button>
                    <button type="button" data-tab="noout" onclick="zxdTab('noout')">بلا خروج (@Model.TodayMissingOutList.Count)</button>
                </span>
            </h2>
            <div data-panel="late">
                @if (Model.TodayLateList.Count == 0)
                {
                    <div class="zxd-empty">لا متأخرين اليوم 🎉</div>
                }
                else
                {
                    <table class="zxd-table">
                        <thead><tr><th>الموظف</th><th>ختم الدخول</th><th>التأخير</th></tr></thead>
                        <tbody>
                            @foreach (var row in Model.TodayLateList)
                            {
                                <tr>
                                    <td>@row.EmployeeName <small style="color:var(--zxd-muted)">@row.EmployeeNo</small></td>
                                    <td style="direction:ltr;text-align:start">@(row.CheckIn?.ToString("HH:mm") ?? "-")</td>
                                    <td>@(row.LateHours > 0 ? $"{row.LateHours:0.##} س" : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div data-panel="noout" hidden>
                @if (Model.TodayMissingOutList.Count == 0)
                {
                    <div class="zxd-empty">لا بصمات خروج مفقودة اليوم 🎉</div>
                }
                else
                {
                    <table class="zxd-table">
                        <thead><tr><th>الموظف</th><th>ختم الدخول</th></tr></thead>
                        <tbody>
                            @foreach (var row in Model.TodayMissingOutList)
                            {
                                <tr>
                                    <td>@row.EmployeeName <small style="color:var(--zxd-muted)">@row.EmployeeNo</small></td>
                                    <td style="direction:ltr;text-align:start">@(row.CheckIn?.ToString("HH:mm") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="zxd-card">
            <h2>المؤشرات والطلبات <small class="zxd-period">آخر 30 يوماً</small></h2>
            <div class="zxd-minis">
                <div class="zxd-mini"><b>@Model.Late30.ToString("N0")</b><span>حالات تأخر</span></div>
                <div class="zxd-mini"><b>@Model.Absent30.ToString("N0")</b><span>حالات غياب</span></div>
                <div class="zxd-mini"><b>@Model.MissingPunches30.ToString("N0")</b><span>بصمات مفقودة</span></div>
                <div class="zxd-mini"><b>@Model.Contracts30.ToString("N0")</b><span>عقود جديدة</span></div>
            </div>
            @{
                var reqMax = Math.Max(1, Math.Max(Model.PendingRequests, Math.Max(Model.ApprovedRequests30, Model.RejectedRequests30)));
            }
            <div class="zxd-pulse" style="margin-top:14px">
                <div class="zxd-pulse-row amber"><b>طلبات معلقة</b><span class="bar"><i style="width:@BarWidth(Model.PendingRequests, reqMax)%"></i></span><span>@Model.PendingRequests</span></div>
                <div class="zxd-pulse-row green"><b>مقبولة</b><span class="bar"><i style="width:@BarWidth(Model.ApprovedRequests30, reqMax)%"></i></span><span>@Model.ApprovedRequests30</span></div>
                <div class="zxd-pulse-row red"><b>مرفوضة</b><span class="bar"><i style="width:@BarWidth(Model.RejectedRequests30, reqMax)%"></i></span><span>@Model.RejectedRequests30</span></div>
            </div>
            <div class="zxd-more-wrap">
                <a class="zxd-more" href="/Approvals">شاشة الموافقات</a>
            </div>
        </div>
    </div>

    @* ---------- توزيعات القوى العاملة: ذات البيانات فقط (الفارغة تُخفى تلقائياً) ---------- *@
    @if (distributions.Length > 0)
    {
        <div class="zxd-card">
            <h2>توزيع القوى العاملة <small>@Model.Employees.ToString("N0") موظفاً · فروع @Model.Branches · أقسام @Model.Departments</small></h2>
            <div class="zxd-dists" style="--cols:@Math.Min(distributions.Length, 3)">
                @foreach (var (title, rows) in distributions)
                {
                    <div>
                        <h3 class="zxd-dist-title">@title</h3>
                        <div class="zxd-dist">
                            @{
                                var max = rows.Max(r => r.Total);
                                var total = Math.Max(1, rows.Sum(r => r.Total));
                            }
                            @foreach (var row in rows.Take(6))
                            {
                                <div class="zxd-dist-row">
                                    <span class="n" title="@SafeName(row.Name)">@SafeName(row.Name)</span>
                                    <span class="bar"><i style="width:@BarWidth(row.Total, max)%"></i></span>
                                    <span class="v">@row.Total (@((row.Total * 100 / total))%)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ---------- العقود قريبة الانتهاء + آخر الطلبات ---------- *@
    <div class="zxd-row-2">
        <div class="zxd-card">
            <h2>عقود قريبة الانتهاء <small class="zxd-period">خلال 60 يوماً · @Model.ExpiringContracts.Count عقداً</small></h2>
            @if (Model.ExpiringContracts.Count == 0)
            {
                <div class="zxd-empty">لا عقود قريبة الانتهاء 🎉</div>
            }
            else
            {
                <table class="zxd-table">
                    <thead><tr><th>الموظف</th><th>المنصب</th><th>تاريخ الانتهاء</th><th>المتبقي</th></tr></thead>
                    <tbody>
                        @foreach (var contract in Model.ExpiringContracts.Take(8))
                        {
                            var daysLeft = contract.ContractEndDate.HasValue
                                ? contract.ContractEndDate.Value.DayNumber - DateOnly.FromDateTime(today).DayNumber
                                : 0;
                            <tr>
                                <td>@contract.EmployeeName <small style="color:var(--zxd-muted)">@contract.EmployeeNo</small></td>
                                <td>@SafeName(contract.Position)</td>
                                <td style="direction:ltr;text-align:start">@(contract.ContractEndDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td><span class="zxd-chip @(daysLeft <= 14 ? "danger" : "pending")">@daysLeft يوم</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="zxd-card">
            <h2>آخر طلبات الخدمة الذاتية <a class="zxd-more" href="/SelfServices">عرض كل الطلبات</a></h2>
            @if (Model.LatestRequests.Count == 0)
            {
                <div class="zxd-empty">لا طلبات حديثة</div>
            }
            else
            {
                <table class="zxd-table">
                    <thead><tr><th>الموظف</th><th>النوع</th><th>الحالة</th><th>التاريخ</th></tr></thead>
                    <tbody>
                        @foreach (var request in Model.LatestRequests.Take(8))
                        {
                            <tr>
                                <td>@request.EmployeeName</td>
                                <td>@request.RequestType</td>
                                <td><span class="zxd-chip @StatusClass(request.Status)">@StatusText(request.Status)</span></td>
                                <td style="direction:ltr;text-align:start">@(request.CreatedAt?.ToString("MM-dd HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function zxdTab(name) {
            document.querySelectorAll('#zxd-today-tabs button').forEach(function (btn) {
                btn.classList.toggle('active', btn.dataset.tab === name);
            });
            document.querySelectorAll('[data-panel]').forEach(function (panel) {
                panel.hidden = panel.dataset.panel !== name;
            });
        }
    </script>
}

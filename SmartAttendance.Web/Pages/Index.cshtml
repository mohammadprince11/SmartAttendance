@page
@model IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .dashboard-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .dashboard-card .label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 8px;
    }

    .dashboard-card .value {
        font-size: 30px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .dashboard-card .hint {
        margin-top: 8px;
        font-size: 12px;
        color: #64748b;
    }

    .dashboard-sections {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 20px;
        align-items: start;
    }

    .dashboard-side {
        display: grid;
        gap: 20px;
    }

    @@media (max-width: 1100px) {
        .dashboard-sections {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p>SmartAttendance overview for @Model.Today</p>
    </div>

    <a asp-page="/AttendanceProcessing/Index" class="btn-primary">Attendance Processing</a>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="label">Companies</div>
        <div class="value">@Model.Cards.CompaniesCount</div>
        <div class="hint">Registered companies</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Branches</div>
        <div class="value">@Model.Cards.BranchesCount</div>
        <div class="hint">Active structure level</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Departments</div>
        <div class="value">@Model.Cards.DepartmentsCount</div>
        <div class="hint">Departments under branches</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Employees</div>
        <div class="value">@Model.Cards.EmployeesCount</div>
        <div class="hint">Active: @Model.Cards.ActiveEmployeesCount</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Devices</div>
        <div class="value">@Model.Cards.DevicesCount</div>
        <div class="hint">Active: @Model.Cards.ActiveDevicesCount</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Shifts</div>
        <div class="value">@Model.Cards.ShiftsCount</div>
        <div class="hint">Configured work shifts</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Attendance Records</div>
        <div class="value">@Model.Cards.AttendanceRecordsCount</div>
        <div class="hint">Raw attendance records</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Approved Leaves</div>
        <div class="value">@Model.Cards.ApprovedLeavesCount</div>
        <div class="hint">All approved leave entries</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="label">Today Present / Late</div>
        <div class="value">@Model.Cards.TodayPresentCount</div>
        <div class="hint">Based on today attendance records</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Today On Leave</div>
        <div class="value">@Model.Cards.TodayLeaveCount</div>
        <div class="hint">Approved leaves covering today</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Today Holiday</div>
        <div class="value">@Model.Cards.TodayHolidayCount</div>
        <div class="hint">Official holiday indicator</div>
    </div>

    <div class="dashboard-card">
        <div class="label">Missing Check Out</div>
        <div class="value">@Model.Cards.TodayMissingCheckOutCount</div>
        <div class="hint">Today records without Check Out</div>
    </div>
</div>

<div class="dashboard-sections">
    <div class="table-card">
        <div class="page-header" style="margin-bottom: 12px;">
            <div>
                <h2>Recent Attendance</h2>
                <p>Last 10 attendance records</p>
            </div>
            <a asp-page="/AttendanceRecords/Index" class="btn-secondary">View All</a>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Employee No</th>
                    <th>Employee Name</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Status</th>
                    <th>Source</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.RecentAttendance.Any())
                {
                    foreach (var item in Model.RecentAttendance)
                    {
                        <tr>
                            <td>@item.AttendanceDate</td>
                            <td>@item.EmployeeNo</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.CheckIn.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.CheckOut?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>@item.Status</td>
                            <td>@item.Source</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center;">No attendance records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="dashboard-side">
        <div class="table-card">
            <div class="page-header" style="margin-bottom: 12px;">
                <div>
                    <h2>Current Leaves</h2>
                    <p>Approved leaves for today</p>
                </div>
                <a asp-page="/LeaveRequests/Index" class="btn-secondary">View</a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Type</th>
                        <th>Period</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.CurrentLeaves.Any())
                    {
                        foreach (var item in Model.CurrentLeaves)
                        {
                            <tr>
                                <td>@item.EmployeeNo - @item.EmployeeName</td>
                                <td>@item.LeaveType</td>
                                <td>@item.FromDate to @item.ToDate</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" style="text-align:center;">No employees on leave today.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-card">
            <div class="page-header" style="margin-bottom: 12px;">
                <div>
                    <h2>Upcoming Holidays</h2>
                    <p>Next official holidays</p>
                </div>
                <a asp-page="/Holidays/Index" class="btn-secondary">View</a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Holiday</th>
                        <th>Date</th>
                        <th>Recurring</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.UpcomingHolidays.Any())
                    {
                        foreach (var item in Model.UpcomingHolidays)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.HolidayDate</td>
                                <td>@(item.IsRecurring ? "Yes" : "No")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" style="text-align:center;">No upcoming holidays found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

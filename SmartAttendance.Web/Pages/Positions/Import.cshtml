@page
@model SmartAttendance.Web.Pages.Positions.ImportModel
@{
    ViewData["Title"] = "Positions Import";
}

<link rel="stylesheet" href="~/css/positions.css" asp-append-version="true" />

<div class="nxp-positions-page nxp-import-page" dir="rtl">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="nxp-alert nxp-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="nxp-alert nxp-alert--error">@errorMessage</div>
    }

    <section class="nxp-hero">
        <div class="nxp-hero__content">
            <p class="nxp-eyebrow">NEXORA HR</p>
            <h1>&#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F; &#x0627;&#x0644;&#x0645;&#x0646;&#x0627;&#x0635;&#x0628;</h1>
            <span>&#x0627;&#x0631;&#x0641;&#x0639; Excel Template &#x0623;&#x0648; &#x0627;&#x0644;&#x0635;&#x0642; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;. &#x0627;&#x0644;&#x0645;&#x0637;&#x0644;&#x0648;&#x0628; &#x0641;&#x0642;&#x0637;: PositionName &#x0648 Department.</span>
        </div>

        <div class="nxp-hero__links" aria-label="Positions import actions">
            <a asp-page="/Positions/Index">&#x0627;&#x0644;&#x0639;&#x0648;&#x062F;&#x0629; &#x0644;&#x0644;&#x0645;&#x0646;&#x0627;&#x0635;&#x0628;</a>
            <a asp-page-handler="Template">&#x062A;&#x062D;&#x0645;&#x064A;&#x0644; Excel Template</a>
        </div>
    </section>

    <section class="nxp-card">
        <div class="nxp-card__head">
            <div>
                <h2>&#x0645;&#x0635;&#x062F;&#x0631; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;</h2>
                <p>&#x0627;&#x0633;&#x062A;&#x062E;&#x062F;&#x0645; &#x0646;&#x0641;&#x0633; &#x0623;&#x0633;&#x0645;&#x0627;&#x0621; &#x0627;&#x0644;&#x0623;&#x0639;&#x0645;&#x062F;&#x0629; &#x062D;&#x062A;&#x0649; &#x062A;&#x0642;&#x0631;&#x0623; &#x0627;&#x0644;&#x0635;&#x0641;&#x062D;&#x0629; &#x0627;&#x0644;&#x0645;&#x0644;&#x0641; &#x0628;&#x0634;&#x0643;&#x0644; &#x0635;&#x062D;&#x064A;&#x062D;.</p>
            </div>
        </div>

        <form method="post" asp-page-handler="Preview" enctype="multipart/form-data" class="nxp-import-form">
            <div class="nxp-import-grid">
                <article class="nxp-import-box">
                    <strong>1 - Excel / CSV</strong>
                    <p>&#x0627;&#x0644;&#x0645;&#x0644;&#x0641; &#x064A;&#x0642;&#x0628;&#x0644; .xlsx &#x0623;&#x0648 .csv &#x0623;&#x0648 .tsv</p>
                    <input asp-for="UploadFile" type="file" accept=".xlsx,.csv,.tsv,.txt" />
                </article>

                <article class="nxp-import-box">
                    <strong>2 - Paste</strong>
                    <p>&#x0646;&#x0633;&#x062E; &#x0645;&#x0628;&#x0627;&#x0634;&#x0631; &#x0645;&#x0646; Excel.</p>
                    <textarea asp-for="PasteData" rows="7" placeholder="PositionName&#9;Department&#10;HR Operations Supervisor&#9;Human Resources"></textarea>
                </article>
            </div>

            <div class="nxp-import-columns">
                <div>
                    <small>&#x0623;&#x0639;&#x0645;&#x062F;&#x0629; &#x0645;&#x0637;&#x0644;&#x0648;&#x0628;&#x0629;</small>
                    @foreach (var column in Model.RequiredColumns)
                    {
                        <span>@column</span>
                    }
                </div>

                <div>
                    <small>&#x0623;&#x0639;&#x0645;&#x062F;&#x0629; &#x0627;&#x062E;&#x062A;&#x064A;&#x0627;&#x0631;&#x064A;&#x0629;</small>
                    @foreach (var column in Model.OptionalColumns)
                    {
                        <span>@column</span>
                    }
                </div>
            </div>

            <div class="nxp-form-actions">
                <a asp-page="/Positions/Index" class="nxp-btn nxp-btn--ghost">&#x0625;&#x0644;&#x063A;&#x0627;&#x0621;</a>
                <button type="submit" class="nxp-btn nxp-btn--primary">&#x0645;&#x0639;&#x0627;&#x064A;&#x0646;&#x0629; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;</button>
            </div>
        </form>
    </section>

    @if (Model.PreviewRows.Count > 0)
    {
        <section class="nxp-kpis" aria-label="Positions import summary">
            <article><span>Total Rows</span><strong>@Model.TotalRows</strong></article>
            <article><span>Ready</span><strong>@Model.ReadyRows</strong></article>
            <article><span>Create</span><strong>@Model.CreateRows</strong></article>
            <article><span>Update</span><strong>@Model.UpdateRows</strong></article>
        </section>

        <section class="nxp-card">
            <div class="nxp-card__head nxp-card__head--filters">
                <div>
                    <h2>Preview: @Model.SourceFileName</h2>
                    <p>&#x0633;&#x064A;&#x062A;&#x0645; &#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F; &#x0627;&#x0644;&#x0635;&#x0641;&#x0648;&#x0641; &#x0627;&#x0644;&#x062C;&#x0627;&#x0647;&#x0632;&#x0629; &#x0641;&#x0642;&#x0637;.</p>
                </div>

                <form method="post" asp-page-handler="Import">
                    <input type="hidden" asp-for="PreviewToken" />
                    <button type="submit" class="nxp-btn nxp-btn--primary" @(Model.ReadyRows == 0 ? "disabled" : null)>&#x0627;&#x0639;&#x062A;&#x0645;&#x0627;&#x062F; &#x0627;&#x0644;&#x0627;&#x0633;&#x062A;&#x064A;&#x0631;&#x0627;&#x062F;</button>
                </form>
            </div>

            <div class="nxp-table-wrap">
                <table class="nxp-table">
                    <thead>
                        <tr>
                            <th>Row</th>
                            <th>Position</th>
                            <th>Department</th>
                            <th>Action</th>
                            <th>Status</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.PreviewRows)
                    {
                        <tr>
                            <td>@row.RowNumber</td>
                            <td>@row.Key</td>
                            <td>@row.Department</td>
                            <td>@row.Action</td>
                            <td><span class="nxp-import-status nxp-import-status--@row.Status.ToLowerInvariant()">@row.Status</span></td>
                            <td>@row.Message</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
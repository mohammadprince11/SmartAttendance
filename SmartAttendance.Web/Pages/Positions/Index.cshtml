@section Scripts {
    <script>
        (() => {
            const normalize = value => (value || '').toString().trim().toLowerCase();
            const search = document.getElementById('positionSearch');
            const category = document.getElementById('categoryFilter');
            const level = document.getElementById('levelFilter');
            const status = document.getElementById('statusFilter');
            const rows = Array.from(document.querySelectorAll('[data-position-row]'));
            const pager = document.getElementById('positionsPager');
            const pageSummary = document.getElementById('positionsPageSummary');
            const pageIndicator = document.getElementById('positionsPageIndicator');
            const previousPageButton = document.getElementById('positionsPrevPage');
            const nextPageButton = document.getElementById('positionsNextPage');
            const pageSize = 25;
            let currentPage = 1;
            let filteredRows = [];

            function renderPage() {
                const totalItems = filteredRows.length;
                const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }

                const startIndex = (currentPage - 1) * pageSize;
                const endIndex = Math.min(startIndex + pageSize, totalItems);

                rows.forEach(row => {
                    row.hidden = true;
                });

                filteredRows.slice(startIndex, endIndex).forEach((row, index) => {
                    row.hidden = false;
                    const sequenceCell = row.querySelector('[data-position-sequence]');

                    if (sequenceCell) {
                        sequenceCell.textContent = (startIndex + index + 1).toString();
                    }
                });

                if (pager) {
                    pager.hidden = totalItems <= pageSize;
                }

                if (pageSummary) {
                    pageSummary.textContent = totalItems === 0
                        ? 'لا توجد نتائج مطابقة'
                        : `عرض ${startIndex + 1}-${endIndex} من ${totalItems}`;
                }

                if (pageIndicator) {
                    pageIndicator.textContent = `${currentPage} / ${totalPages}`;
                }

                if (previousPageButton) {
                    previousPageButton.disabled = currentPage <= 1;
                }

                if (nextPageButton) {
                    nextPageButton.disabled = currentPage >= totalPages;
                }
            }

            function applyFilters(resetPage = true) {
                const q = normalize(search?.value);
                const categoryValue = category?.value || 'all';
                const levelValue = level?.value || 'all';
                const statusValue = status?.value || 'all';

                filteredRows = rows.filter(row => {
                    const matchesSearch = !q || normalize(row.dataset.search).includes(q);
                    const matchesCategory = categoryValue === 'all' || row.dataset.category === categoryValue;
                    const matchesLevel = levelValue === 'all' || row.dataset.level === levelValue;
                    const matchesStatus = statusValue === 'all'
                        || row.dataset.status === statusValue
                        || row.dataset.linked === statusValue;

                    return matchesSearch && matchesCategory && matchesLevel && matchesStatus;
                });

                if (resetPage) {
                    currentPage = 1;
                }

                renderPage();
            }

            [search, category, level, status].forEach(element => {
                element?.addEventListener('input', () => applyFilters(true));
                element?.addEventListener('change', () => applyFilters(true));
            });

            previousPageButton?.addEventListener('click', () => {
                if (currentPage > 1) {
                    currentPage -= 1;
                    renderPage();
                }
            });

            nextPageButton?.addEventListener('click', () => {
                const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));

                if (currentPage < totalPages) {
                    currentPage += 1;
                    renderPage();
                }
            });

            applyFilters(true);

            const modal = document.querySelector('[data-employees-modal]');
            const backdrop = document.querySelector('[data-employees-backdrop]');
            const closeButton = document.querySelector('[data-employees-close]');
            const title = document.querySelector('[data-employees-title]');
            const loading = document.querySelector('[data-employees-loading]');
            const list = document.querySelector('[data-employees-list]');

            function closeModal() {
                modal.hidden = true;
                backdrop.hidden = true;
                modal.setAttribute('aria-hidden', 'true');
                document.documentElement.classList.remove('nxp-modal-open');
                document.body.classList.remove('nxp-modal-open');
            }

            function openModal() {
                modal.hidden = false;
                backdrop.hidden = false;
                modal.setAttribute('aria-hidden', 'false');
                document.documentElement.classList.add('nxp-modal-open');
                document.body.classList.add('nxp-modal-open');
            }

            closeButton?.addEventListener('click', closeModal);
            backdrop?.addEventListener('click', closeModal);

            document.querySelectorAll('[data-employees-button]').forEach(button => {
                button.addEventListener('click', async () => {
                    const id = button.dataset.positionId;
                    list.innerHTML = '';
                    loading.hidden = false;
                    openModal();

                    try {
                        const response = await fetch(`/Positions?handler=Employees&id=${encodeURIComponent(id)}`, {
                            headers: { 'Accept': 'application/json' }
                        });
                        const data = await response.json();

                        loading.hidden = true;
                        if (!data.ok) {
                            list.innerHTML = `<div class="nxp-empty">${data.message || 'تعذر تحميل البيانات.'}</div>`;
                            return;
                        }

                        title.textContent = `الموظفون المرتبطون - ${data.position}`;

                        if (!data.employees || data.employees.length === 0) {
                            list.innerHTML = '<div class="nxp-empty">لا يوجد موظفون مرتبطون بهذا المنصب.</div>';
                            return;
                        }

                        list.innerHTML = data.employees.map(employee => `
                            <article>
                                <strong>${employee.name}</strong>
                                <span>${employee.employeeNo || 'بدون رقم وظيفي'}</span>
                                <small>${employee.status}</small>
                            </article>
                        `).join('');
                    } catch (error) {
                        loading.hidden = true;
                        list.innerHTML = '<div class="nxp-empty">حدث خطأ أثناء تحميل الموظفين.</div>';
                    }
                });
            });
        })();
    </script>
}

@page
@model SmartAttendance.Web.Pages.Positions.IndexModel
@{
    ViewData["Title"] = "المناصب الوظيفية";
}

<link rel="stylesheet" href="~/css/positions.css" asp-append-version="true" />

<div class="nxp-positions-page" dir="rtl">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="nxp-alert nxp-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="nxp-alert nxp-alert--error">@errorMessage</div>
    }

    <section class="nxp-hero">
        <div class="nxp-hero__content">
            <p class="nxp-eyebrow">NEXORA HR</p>
            <h1>المناصب الوظيفية</h1>
            <span>إدارة المناصب الرسمية وربطها بالقسم والفئة والمستوى، مع منع حذف أي منصب مستخدم داخل ملفات الموظفين.</span>
        </div>
        <div class="nxp-hero__links" aria-label="إعدادات المناصب">
            <a asp-page="/PositionCategories/Index">إدارة الفئات</a>
            <a asp-page="/PositionLevels/Index">إدارة المستويات</a>
        </div>
    </section>

    <section class="nxp-kpis" aria-label="ملخص المناصب الوظيفية">
        <article>
            <span>إجمالي المناصب</span>
            <strong>@Model.TotalPositions</strong>
        </article>
        <article>
            <span>المناصب الفعالة</span>
            <strong>@Model.ActivePositions</strong>
        </article>
        <article>
            <span>مناصب مرتبطة بموظفين</span>
            <strong>@Model.LinkedPositions</strong>
        </article>
        <article>
            <span>موظفون مثبتون على مناصب</span>
            <strong>@Model.TotalLinkedEmployees</strong>
        </article>
    </section>

    <section class="nxp-card nxp-form-card" id="positionFormArea">
        <div class="nxp-card__head">
            <div>
                <h2>@(Model.Input.Id > 0 ? "تعديل منصب وظيفي" : "بيانات المنصب الوظيفي")</h2>
                <p>نفس النموذج يستخدم للإضافة والتعديل. المنصب الجديد يكون فعال تلقائياً.</p>
            </div>
        </div>

        <form method="post" asp-page-handler="Save" id="positionForm" class="nxp-form" autocomplete="off">
            <input asp-for="Input.Id" type="hidden" />
            <input asp-for="Input.OriginalArabicName" type="hidden" />

            <label class="nxp-field nxp-field--wide">
                <span>اسم المنصب <b>*</b></span>
                <input asp-for="Input.ArabicName" required maxlength="200" placeholder="مثال: مشرف عمليات الموارد البشرية" />
            </label>

            <label class="nxp-field">
                <span>القسم</span>
                <select asp-for="Input.DepartmentId">
                    <option value="">بدون قسم محدد</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.Id">@department.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field">
                <span>الفئة <a asp-page="/PositionCategories/Index">إدارة</a></span>
                <select asp-for="Input.Category">
                    <option value="">غير محدد</option>
                    @foreach (var category in Model.Categories.Where(item => item.IsActive || item.Name == Model.Input.Category))
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field">
                <span>المستوى <a asp-page="/PositionLevels/Index">إدارة</a></span>
                <select asp-for="Input.Level">
                    <option value="">غير محدد</option>
                    @foreach (var level in Model.Levels.Where(item => item.IsActive || item.Name == Model.Input.Level))
                    {
                        <option value="@level.Name">@level.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field nxp-field--wide">
                <span>وصف مختصر</span>
                <textarea asp-for="Input.Description" rows="3" maxlength="1200" placeholder="اكتب وصفاً مختصراً للمنصب أو نطاق المسؤوليات..."></textarea>
            </label>

            <label class="nxp-check">
                <input type="hidden" name="Input.IsActive" value="false" />
                <input asp-for="Input.IsActive" value="true" />
                <span>المنصب فعال</span>
            </label>

            <div class="nxp-form-actions">
                <button type="submit" class="nxp-btn nxp-btn--primary">حفظ المنصب</button>
                <a asp-page="/Positions/Index" class="nxp-btn nxp-btn--ghost">تفريغ النموذج</a>
            </div>
        </form>
    </section>

    <section class="nxp-card">
        <div class="nxp-card__head nxp-card__head--filters">
            <div>
                <h2>قائمة المناصب</h2>
                <p>الفلاتر تعمل مباشرة بدون زر بحث.</p>
            </div>

            <div class="nxp-filters nxp-filters--positions" aria-label="فلاتر المناصب">
                <input id="positionSearch" type="search" placeholder="بحث مباشر عن منصب..." />

                <select id="departmentFilter">
                    <option value="all">كل الأقسام</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.Id">@department.Name</option>
                    }
                    <option value="none">بدون قسم</option>
                </select>

                <select id="categoryFilter">
                    <option value="all">كل الفئات</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                    <option value="none">بدون فئة</option>
                </select>

                <select id="levelFilter">
                    <option value="all">كل المستويات</option>
                    @foreach (var level in Model.Levels)
                    {
                        <option value="@level.Name">@level.Name</option>
                    }
                    <option value="none">بدون مستوى</option>
                </select>

                <select id="statusFilter">
                    <option value="all">كل الحالات</option>
                    <option value="active">فعال</option>
                    <option value="inactive">غير فعال</option>
                    <option value="linked">مرتبط بموظفين</option>
                    <option value="unlinked">غير مرتبط</option>
                </select>
            </div>
        </div>

        @if (!Model.Positions.Any())
        {
            <div class="nxp-empty">لا توجد مناصب مسجلة حالياً.</div>
        }
        else
        {
            <div class="nxp-table-wrap">
                <table class="nxp-table" id="positionsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المنصب</th>
                            <th>القسم</th>
                            <th>الفئة</th>
                            <th>المستوى</th>
                            <th>الموظفون</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Positions.Count; i++)
                        {
                            var position = Model.Positions[i];
                            var canDelete = position.EmployeeCount == 0;
                            <tr data-position-row
                                data-search="@position.SearchText"
                                data-department="@(position.DepartmentId?.ToString() ?? "none")"
                                data-category="@(string.IsNullOrWhiteSpace(position.Category) ? "none" : position.Category)"
                                data-level="@(string.IsNullOrWhiteSpace(position.Level) ? "none" : position.Level)"
                                data-status="@(position.IsActive ? "active" : "inactive")"
                                data-linked="@(position.EmployeeCount > 0 ? "linked" : "unlinked")">
                                <td>@(i + 1)</td>
                                <td>
                                    <div class="nxp-position-name">
                                        <strong>@position.ArabicName</strong>
                                        @if (!string.IsNullOrWhiteSpace(position.Description))
                                        {
                                            <span>@position.Description</span>
                                        }
                                    </div>
                                </td>
                                <td>@(position.DepartmentName ?? "بدون قسم")</td>
                                <td>@(string.IsNullOrWhiteSpace(position.Category) ? "غير محدد" : position.Category)</td>
                                <td>@(string.IsNullOrWhiteSpace(position.Level) ? "غير محدد" : position.Level)</td>
                                <td>
                                    <div class="nxp-employee-count">
                                        <strong>@position.EmployeeCount</strong>
                                        <span>موظف</span>
                                    </div>
                                    @if (position.EmployeeCount > 0)
                                    {
                                        <button type="button" class="nxp-link-btn" data-employees-button data-position-id="@position.Id">عرض الموظفين</button>
                                    }
                                </td>
                                <td>
                                    <span class="nxp-status @(position.IsActive ? "is-active" : "is-inactive")">@(position.IsActive ? "فعال" : "غير فعال")</span>
                                </td>
                                <td>
                                    <div class="nxp-actions">
                                        <a class="nxp-icon-btn" asp-page="/Positions/Index" asp-route-editId="@position.Id" asp-fragment="positionFormArea">تعديل</a>

                                        <form method="post" asp-page-handler="Toggle" asp-route-id="@position.Id" class="nxp-inline-form">
                                            <button type="submit" class="nxp-icon-btn nxp-icon-btn--muted">@(position.IsActive ? "إيقاف" : "تفعيل")</button>
                                        </form>

                                        <form method="post" asp-page-handler="Delete" asp-route-id="@position.Id" class="nxp-inline-form">
                                            <button type="submit" class="nxp-icon-btn nxp-icon-btn--danger" disabled="@(!canDelete)" title="@(canDelete ? "حذف المنصب" : "لا يمكن حذف منصب مرتبط بموظفين")">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

<div class="nxp-modal-backdrop" data-employees-backdrop hidden></div>
<section class="nxp-modal" data-employees-modal hidden aria-hidden="true">
    <div class="nxp-modal__card" dir="rtl">
        <div class="nxp-modal__head">
            <div>
                <span>NEXORA HR</span>
                <h2 data-employees-title>الموظفون المرتبطون</h2>
            </div>
            <button type="button" data-employees-close aria-label="إغلاق">×</button>
        </div>
        <div class="nxp-modal__body">
            <div class="nxp-loading" data-employees-loading hidden>جاري تحميل البيانات...</div>
            <div class="nxp-employee-list" data-employees-list></div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const normalize = value => (value || '').toString().trim().toLowerCase();
            const search = document.getElementById('positionSearch');
            const department = document.getElementById('departmentFilter');
            const category = document.getElementById('categoryFilter');
            const level = document.getElementById('levelFilter');
            const status = document.getElementById('statusFilter');
            const rows = Array.from(document.querySelectorAll('[data-position-row]'));

            function applyFilters() {
                const q = normalize(search?.value);
                const departmentValue = department?.value || 'all';
                const categoryValue = category?.value || 'all';
                const levelValue = level?.value || 'all';
                const statusValue = status?.value || 'all';

                rows.forEach(row => {
                    const matchesSearch = !q || normalize(row.dataset.search).includes(q);
                    const matchesDepartment = departmentValue === 'all' || row.dataset.department === departmentValue;
                    const matchesCategory = categoryValue === 'all' || row.dataset.category === categoryValue;
                    const matchesLevel = levelValue === 'all' || row.dataset.level === levelValue;
                    const matchesStatus = statusValue === 'all'
                        || row.dataset.status === statusValue
                        || row.dataset.linked === statusValue;

                    row.hidden = !(matchesSearch && matchesDepartment && matchesCategory && matchesLevel && matchesStatus);
                });
            }

            [search, department, category, level, status].forEach(element => {
                element?.addEventListener('input', applyFilters);
                element?.addEventListener('change', applyFilters);
            });

            applyFilters();

            const modal = document.querySelector('[data-employees-modal]');
            const backdrop = document.querySelector('[data-employees-backdrop]');
            const closeButton = document.querySelector('[data-employees-close]');
            const title = document.querySelector('[data-employees-title]');
            const loading = document.querySelector('[data-employees-loading]');
            const list = document.querySelector('[data-employees-list]');

            function closeModal() {
                modal.hidden = true;
                backdrop.hidden = true;
                modal.setAttribute('aria-hidden', 'true');
                document.documentElement.classList.remove('nxp-modal-open');
                document.body.classList.remove('nxp-modal-open');
            }

            function openModal() {
                modal.hidden = false;
                backdrop.hidden = false;
                modal.setAttribute('aria-hidden', 'false');
                document.documentElement.classList.add('nxp-modal-open');
                document.body.classList.add('nxp-modal-open');
            }

            closeButton?.addEventListener('click', closeModal);
            backdrop?.addEventListener('click', closeModal);

            document.querySelectorAll('[data-employees-button]').forEach(button => {
                button.addEventListener('click', async () => {
                    const id = button.dataset.positionId;
                    list.innerHTML = '';
                    loading.hidden = false;
                    openModal();

                    try {
                        const response = await fetch(`/Positions?handler=Employees&id=${encodeURIComponent(id)}`, {
                            headers: { 'Accept': 'application/json' }
                        });
                        const data = await response.json();

                        loading.hidden = true;
                        if (!data.ok) {
                            list.innerHTML = `<div class="nxp-empty">${data.message || 'تعذر تحميل البيانات.'}</div>`;
                            return;
                        }

                        title.textContent = `الموظفون المرتبطون - ${data.position}`;

                        if (!data.employees || data.employees.length === 0) {
                            list.innerHTML = '<div class="nxp-empty">لا يوجد موظفون مرتبطون بهذا المنصب.</div>';
                            return;
                        }

                        list.innerHTML = data.employees.map(employee => `
                            <article>
                                <strong>${employee.name}</strong>
                                <span>${employee.employeeNo || 'بدون رقم وظيفي'}</span>
                                <small>${employee.status}</small>
                            </article>
                        `).join('');
                    } catch (error) {
                        loading.hidden = true;
                        list.innerHTML = '<div class="nxp-empty">حدث خطأ أثناء تحميل الموظفين.</div>';
                    }
                });
            });
        })();
    </script>
}

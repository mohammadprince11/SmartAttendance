<script>
/* NEXORA_FIX20C_V2_PROFILE_POPUPS_SCRIPT */
(() => {
    const backdrop = document.querySelector('[data-nxp-profile-backdrop]');
    const modals = Array.from(document.querySelectorAll('[data-nxp-profile-modal]'));

    function closeAll() {
        modals.forEach(modal => {
            modal.hidden = true;
            modal.setAttribute('aria-hidden', 'true');
        });

        if (backdrop) {
            backdrop.hidden = true;
        }

        document.documentElement.classList.remove('nxp-profile-modal-open');
        document.body.classList.remove('nxp-profile-modal-open');
    }

    function openModal(key) {
        const modal = document.querySelector(`[data-nxp-profile-modal="${key}"]`);
        if (!modal) return;

        closeAll();
        modal.hidden = false;
        modal.setAttribute('aria-hidden', 'false');

        if (backdrop) {
            backdrop.hidden = false;
        }

        document.documentElement.classList.add('nxp-profile-modal-open');
        document.body.classList.add('nxp-profile-modal-open');

        const firstField = modal.querySelector('textarea, input, select, button');
        window.setTimeout(() => firstField?.focus(), 80);
    }

    document.querySelectorAll('[data-nxp-profile-open]').forEach(button => {
        button.addEventListener('click', () => openModal(button.dataset.nxpProfileOpen));
    });

    document.querySelectorAll('[data-nxp-profile-close]').forEach(button => {
        button.addEventListener('click', closeAll);
    });

    backdrop?.addEventListener('click', closeAll);

    document.addEventListener('keydown', event => {
        if (event.key === 'Escape') {
            closeAll();
        }
    });
})();
</script>


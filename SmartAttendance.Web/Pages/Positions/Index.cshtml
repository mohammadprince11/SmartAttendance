@page
@model SmartAttendance.Web.Pages.Positions.IndexModel
@{
    ViewData["Title"] = "المناصب الوظيفية";
}

<link rel="stylesheet" href="~/css/positions.css" asp-append-version="true" />

<div class="nxp-positions-page" dir="rtl">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="nxp-alert nxp-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="nxp-alert nxp-alert--error">@errorMessage</div>
    }

    <section class="nxp-admin-header" aria-labelledby="positionsAdminTitle">
        <div class="nxp-admin-header__top">
            <div class="nxp-admin-header__identity">
                <span class="nxp-admin-header__eyebrow">إدارة الهيكل الوظيفي</span>
                <h1 id="positionsAdminTitle">المناصب الوظيفية</h1>
                <p>إدارة المسميات الوظيفية وتصنيفها وربطها بالموظفين ضمن شركة محددة.</p>
            </div>

            <nav class="nxp-admin-header__actions" aria-label="إجراءات إدارة المناصب">
                <a asp-page="/Positions/Import" asp-route-companyId="@Model.CompanyId">استيراد Excel</a>
                <a asp-page="/PositionCategories/Index">إدارة الفئات</a>
                <a asp-page="/PositionLevels/Index">إدارة المستويات</a>
            </nav>
        </div>

        @if (Model.Companies.Count > 0)
        {
            <form method="get" class="nxp-admin-header__company" aria-label="اختيار الشركة">
                <label for="CompanyId">الشركة الحالية</label>
                <select asp-for="CompanyId">
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </select>
                <button type="submit" class="nxp-btn nxp-btn--ghost">تطبيق</button>
            </form>
        }
    </section>

    <section class="nxp-kpis" aria-label="ملخص المناصب الوظيفية">
        <article>
            <span>إجمالي المناصب</span>
            <strong>@Model.TotalPositions</strong>
        </article>
        <article>
            <span>المناصب الفعالة</span>
            <strong>@Model.ActivePositions</strong>
        </article>
        <article>
            <span>مناصب مرتبطة بموظفين</span>
            <strong>@Model.LinkedPositions</strong>
        </article>
        <article>
            <span>موظفون مثبتون على مناصب</span>
            <strong>@Model.TotalLinkedEmployees</strong>
        </article>
    </section>

    <section class="nxp-card nxp-form-card" id="positionFormArea">
        <div class="nxp-card__head">
            <div>
                <h2>@(Model.Input.Id > 0 ? "تعديل منصب وظيفي" : "بيانات المنصب الوظيفي")</h2>
                <p>نفس النموذج يستخدم للإضافة والتعديل. المنصب الجديد يكون فعال تلقائياً.</p>
            </div>
        </div>

        <form method="post" asp-page-handler="Save" id="positionForm" class="nxp-form" autocomplete="off">
            <input asp-for="Input.Id" type="hidden" />
            <input asp-for="Input.CompanyId" type="hidden" />
            <input asp-for="Input.OriginalArabicName" type="hidden" />

            <label class="nxp-field nxp-field--wide">
                <span>اسم المنصب <b>*</b></span>
                <input asp-for="Input.ArabicName" required maxlength="200" placeholder="مثال: مشرف عمليات الموارد البشرية" />
            </label>

            <label class="nxp-field">
                <span>&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</span>
                <input value="@Model.SelectedCompanyName" readonly />
            </label>

            <label class="nxp-field">
                <span>الفئة <a asp-page="/PositionCategories/Index">إدارة</a></span>
                <select asp-for="Input.Category">
                    <option value="">غير محدد</option>
                    @foreach (var category in Model.Categories.Where(item => item.IsActive || item.Name == Model.Input.Category))
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field">
                <span>المستوى <a asp-page="/PositionLevels/Index">إدارة</a></span>
                <select asp-for="Input.Level">
                    <option value="">غير محدد</option>
                    @foreach (var level in Model.Levels.Where(item => item.IsActive || item.Name == Model.Input.Level))
                    {
                        <option value="@level.Name">@level.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field nxp-field--reference">
                <span>&#x0627;&#x0644;&#x0643;&#x0641;&#x0627;&#x0621;&#x0627;&#x062A; <button type="button" class="nxp-label-manage" data-nxp-reference-open="competencies">&#x0625;&#x062F;&#x0627;&#x0631;&#x0629;</button></span>
                <select asp-for="Input.Competencies">
                    <option value="">&#x063A;&#x064A;&#x0631; &#x0645;&#x062D;&#x062F;&#x062F;</option>
                    @foreach (var item in Model.CompetencyOptions.Where(item => item.IsActive || item.Name == Model.Input.Competencies))
                    {
                        <option value="@item.Name">@item.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field nxp-field--reference">
                <span>&#x0627;&#x0644;&#x062F;&#x0631;&#x062C;&#x0629; &#x0627;&#x0644;&#x0639;&#x0644;&#x0645;&#x064A;&#x0629; <button type="button" class="nxp-label-manage" data-nxp-reference-open="education">&#x0625;&#x062F;&#x0627;&#x0631;&#x0629;</button></span>
                <select asp-for="Input.Education">
                    <option value="">&#x063A;&#x064A;&#x0631; &#x0645;&#x062D;&#x062F;&#x062F;</option>
                    @foreach (var item in Model.EducationOptions.Where(item => item.IsActive || item.Name == Model.Input.Education))
                    {
                        <option value="@item.Name">@item.Name</option>
                    }
                </select>
            </label>

            <label class="nxp-field nxp-field--reference">
                <span>&#x0627;&#x0644;&#x062A;&#x062E;&#x0635;&#x0635; <button type="button" class="nxp-label-manage" data-nxp-reference-open="specializations">&#x0625;&#x062F;&#x0627;&#x0631;&#x0629;</button></span>
                <select asp-for="Input.EducationSpecialization">
                    <option value="">&#x063A;&#x064A;&#x0631; &#x0645;&#x062D;&#x062F;&#x062F;</option>
                    @foreach (var item in Model.EducationSpecializationOptions.Where(item => item.IsActive || item.Name == Model.Input.EducationSpecialization))
                    {
                        <option value="@item.Name">@item.Name</option>
                    }
                </select>
            </label>
            @* NEXORA_FIX20G_SPECIALIZATION_FIELD *@

            <label class="nxp-field nxp-field--reference">
                <span>&#x0627;&#x0644;&#x0634;&#x0647;&#x0627;&#x062F;&#x0627;&#x062A; <button type="button" class="nxp-label-manage" data-nxp-reference-open="certifications">&#x0625;&#x062F;&#x0627;&#x0631;&#x0629;</button></span>
                <select asp-for="Input.Certifications">
                    <option value="">&#x063A;&#x064A;&#x0631; &#x0645;&#x062D;&#x062F;&#x062F;</option>
                    @foreach (var item in Model.CertificationOptions.Where(item => item.IsActive || item.Name == Model.Input.Certifications))
                    {
                        <option value="@item.Name">@item.Name</option>
                    }
                </select>
            </label>
            @* NEXORA_FIX20D_REFERENCE_DROPDOWN_FIELDS *@

            <div class="nxp-position-profile-launchers" data-nxp-profile-launchers>
                <button type="button" class="nxp-profile-launcher" data-nxp-profile-open="job">
                    <span>&#x0627;&#x0644;&#x0648;&#x0635;&#x0641; &#x0627;&#x0644;&#x0648;&#x0638;&#x064A;&#x0641;&#x064A;</span>
                    <strong>&#x0627;&#x0644;&#x0647;&#x062F;&#x0641; &#x0648;&#x0627;&#x0644;&#x0645;&#x0647;&#x0627;&#x0645; &#x0648;KPI</strong>
                </button>

                </div>

            <div class="nxp-profile-modal-backdrop" data-nxp-profile-backdrop hidden></div>

            <section class="nxp-profile-modal" data-nxp-profile-modal="job" hidden aria-hidden="true">
                <div class="nxp-profile-modal__card" dir="rtl">
                    <header class="nxp-profile-modal__head">
                        <div>
                            <span>&#x0628;&#x0637;&#x0627;&#x0642;&#x0629; &#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;</span>
                            <h3>&#x0627;&#x0644;&#x0648;&#x0635;&#x0641; &#x0627;&#x0644;&#x0648;&#x0638;&#x064A;&#x0641;&#x064A;</h3>
                        </div>
                        <button type="button" data-nxp-profile-close>&times;</button>
                    </header>

                    <div class="nxp-profile-modal__body">
                        <label class="nxp-field nxp-field--wide">
                            <span>&#x0647;&#x062F;&#x0641; &#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;</span>
                            <textarea asp-for="Input.JobPurpose" rows="3" maxlength="2000" placeholder="&#x0645;&#x0627; &#x0627;&#x0644;&#x063A;&#x0631;&#x0636; &#x0645;&#x0646; &#x0647;&#x0630;&#x0627; &#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;&#x061F;"></textarea>
                        </label>

                        <label class="nxp-field nxp-field--wide">
                            <span>&#x0627;&#x0644;&#x0645;&#x0647;&#x0627;&#x0645; &#x0648;&#x0627;&#x0644;&#x0645;&#x0633;&#x0624;&#x0648;&#x0644;&#x064A;&#x0627;&#x062A;</span>
                            <textarea asp-for="Input.KeyResponsibilities" rows="5" maxlength="4000" placeholder="&#x0627;&#x0643;&#x062A;&#x0628; &#x0627;&#x0644;&#x0645;&#x0647;&#x0627;&#x0645; &#x0627;&#x0644;&#x0631;&#x0626;&#x064A;&#x0633;&#x064A;&#x0629;..."></textarea>
                        </label>

                        <label class="nxp-field">
                            <span>&#x0627;&#x0644;&#x0645;&#x062A;&#x0637;&#x0644;&#x0628;&#x0627;&#x062A;</span>
                            <textarea asp-for="Input.JobRequirements" rows="4" maxlength="3000" placeholder="&#x0627;&#x0644;&#x062E;&#x0628;&#x0631;&#x0629;&#x060C; &#x0627;&#x0644;&#x0634;&#x0647;&#x0627;&#x062F;&#x0629;&#x060C; &#x0627;&#x0644;&#x0644;&#x063A;&#x0627;&#x062A;..."></textarea>
                        </label>

                        <label class="nxp-field">
                            <span>&#x0627;&#x0644;&#x0645;&#x0647;&#x0627;&#x0631;&#x0627;&#x062A;</span>
                            <textarea asp-for="Input.RequiredSkills" rows="4" maxlength="3000" placeholder="&#x0627;&#x0644;&#x0645;&#x0647;&#x0627;&#x0631;&#x0627;&#x062A; &#x0627;&#x0644;&#x0641;&#x0646;&#x064A;&#x0629; &#x0648;&#x0627;&#x0644;&#x0634;&#x062E;&#x0635;&#x064A;&#x0629;..."></textarea>
                        </label>

                        <label class="nxp-field nxp-field--wide">
                            <span>KPI</span>
                            <textarea asp-for="Input.JobKpis" rows="4" maxlength="3000" placeholder="&#x0645;&#x0624;&#x0634;&#x0631;&#x0627;&#x062A; &#x0627;&#x0644;&#x0623;&#x062F;&#x0627;&#x0621; &#x0627;&#x0644;&#x0631;&#x0626;&#x064A;&#x0633;&#x064A;&#x0629;..."></textarea>
                        </label>
                    </div>

                    <footer class="nxp-profile-modal__footer" data-nxp-profile-footer="job">
                        <button type="button" class="nxp-btn nxp-btn--ghost" data-nxp-profile-close>&#x0625;&#x0644;&#x063A;&#x0627;&#x0621;</button>
                        <button type="submit" class="nxp-btn nxp-btn--primary">&#x062D;&#x0641;&#x0638; &#x0627;&#x0644;&#x0645;&#x0646;&#x0635;&#x0628;</button>
                    </footer>
                    @* NEXORA_FIX20F_JOB_MODAL_FOOTER *@</div>
            </section>

            @* NEXORA_FIX20C_V2_PROFILE_POPUPS_FIELDS *@

            <label class="nxp-check">
                <input type="hidden" name="Input.IsActive" value="false" />
                <input asp-for="Input.IsActive" value="true" />
                <span>المنصب فعال</span>
            </label>

            <div class="nxp-form-actions">
                <button type="submit" class="nxp-btn nxp-btn--primary">حفظ المنصب</button>
                <a asp-page="/Positions/Index" asp-route-companyId="@Model.CompanyId" class="nxp-btn nxp-btn--ghost">تفريغ النموذج</a>
            </div>
        </form>
    </section>

    <section class="nxp-card">
        <div class="nxp-card__head nxp-card__head--filters">
            <div>
                <h2>قائمة المناصب</h2>
                <p>الفلاتر تعمل مباشرة بدون زر بحث.</p>
            </div>

            <div class="nxp-filters nxp-filters--positions" aria-label="فلاتر المناصب">
                <input id="positionSearch" type="search" placeholder="بحث مباشر عن منصب..." />

                <select id="categoryFilter">
                    <option value="all">كل الفئات</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                    <option value="none">بدون فئة</option>
                </select>

                <select id="levelFilter">
                    <option value="all">كل المستويات</option>
                    @foreach (var level in Model.Levels)
                    {
                        <option value="@level.Name">@level.Name</option>
                    }
                    <option value="none">بدون مستوى</option>
                </select>

                <select id="statusFilter">
                    <option value="all">كل الحالات</option>
                    <option value="active">فعال</option>
                    <option value="inactive">غير فعال</option>
                    <option value="linked">مرتبط بموظفين</option>
                    <option value="unlinked">غير مرتبط</option>
                </select>
            </div>
        </div>

        @if (!Model.Positions.Any())
        {
            <div class="nxp-empty">لا توجد مناصب مسجلة حالياً.</div>
        }
        else
        {
            <div class="nxp-table-wrap">
                <table class="nxp-table" id="positionsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المنصب</th>
                            <th>&#x0627;&#x0644;&#x0634;&#x0631;&#x0643;&#x0629;</th>
                            <th>الفئة</th>
                            <th>المستوى</th>
                            <th>الموظفون</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Positions.Count; i++)
                        {
                            var position = Model.Positions[i];
                            var canDelete = position.EmployeeCount == 0;
                            <tr data-position-row
                                data-search="@position.SearchText"
                                data-category="@(string.IsNullOrWhiteSpace(position.Category) ? "none" : position.Category)"
                                data-level="@(string.IsNullOrWhiteSpace(position.Level) ? "none" : position.Level)"
                                data-status="@(position.IsActive ? "active" : "inactive")"
                                data-linked="@(position.EmployeeCount > 0 ? "linked" : "unlinked")">
                                <td data-position-sequence>@(i + 1)</td>
                                <td>
                                    <div class="nxp-position-name">
                                        <strong>@position.ArabicName</strong>
                                        @if (!string.IsNullOrWhiteSpace(position.Description))
                                        {
                                            <span>@position.Description</span>
                                        }
                                    </div>
                                </td>
                                <td>@position.CompanyName</td>
                                <td>@(string.IsNullOrWhiteSpace(position.Category) ? "غير محدد" : position.Category)</td>
                                <td>@(string.IsNullOrWhiteSpace(position.Level) ? "غير محدد" : position.Level)</td>
                                <td>
                                    <div class="nxp-employee-count">
                                        <strong>@position.EmployeeCount</strong>
                                        <span>موظف</span>
                                    </div>
                                    @if (position.EmployeeCount > 0)
                                    {
                                        <button type="button" class="nxp-link-btn" data-employees-button data-position-id="@position.Id">عرض الموظفين</button>
                                    }
                                </td>
                                <td>
                                    <span class="nxp-status @(position.IsActive ? "is-active" : "is-inactive")">@(position.IsActive ? "فعال" : "غير فعال")</span>
                                </td>
                                <td>
                                    <div class="nxp-actions">
                                        <a class="nxp-icon-btn" asp-page="/Positions/Index" asp-route-companyId="@Model.CompanyId" asp-route-editId="@position.Id" asp-fragment="positionFormArea">تعديل</a>

                                        <form method="post" asp-page-handler="Toggle" asp-route-id="@position.Id" class="nxp-inline-form">
                                            <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
                                            <button type="submit" class="nxp-icon-btn nxp-icon-btn--muted">@(position.IsActive ? "إيقاف" : "تفعيل")</button>
                                        </form>

                                        <form method="post" asp-page-handler="Delete" asp-route-id="@position.Id" class="nxp-inline-form">
                                            <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
                                            <button type="submit" class="nxp-icon-btn nxp-icon-btn--danger" disabled="@(!canDelete)" title="@(canDelete ? "حذف المنصب" : "لا يمكن حذف منصب مرتبط بموظفين")">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="nxp-pagination" id="positionsPager" hidden>
                <div class="nxp-pagination__summary" id="positionsPageSummary"></div>
                <div class="nxp-pagination__controls">
                    <button type="button" class="nxp-pagination__button" id="positionsPrevPage">السابق</button>
                    <span class="nxp-pagination__indicator" id="positionsPageIndicator"></span>
                    <button type="button" class="nxp-pagination__button" id="positionsNextPage">التالي</button>
                </div>
            </div>
        }
    </section>
</div>


<div class="nxp-reference-modal-backdrop" data-nxp-reference-backdrop hidden></div>

<section class="nxp-reference-modal" data-nxp-reference-modal="competencies" hidden aria-hidden="true">
    <div class="nxp-reference-modal__card" dir="rtl">
        <header class="nxp-reference-modal__head">
            <div>
                <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0631;&#x0627;&#x062C;&#x0639;</span>
                <h3>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0643;&#x0641;&#x0627;&#x0621;&#x0627;&#x062A;</h3>
            </div>
            <button type="button" data-nxp-reference-close>&times;</button>
        </header>

        <form method="post" asp-page-handler="SaveReference" asp-route-type="competencies" class="nxp-reference-modal__body">
            <label class="nxp-field nxp-field--wide">
                <span>&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0643;&#x0641;&#x0627;&#x0621;&#x0629;</span>
                <input name="ReferenceInput.Name" maxlength="240" placeholder="&#x0645;&#x062B;&#x0627;&#x0644;: &#x0627;&#x0644;&#x0642;&#x064A;&#x0627;&#x062F;&#x0629;" />
            </label>
            <button type="submit" class="nxp-btn nxp-btn--primary">&#x062D;&#x0641;&#x0638;</button>
        </form>

        <div class="nxp-reference-modal__list">
            @foreach (var item in Model.CompetencyOptions)
            {
                <span>@item.Name</span>
            }
        </div>
    </div>
</section>

<section class="nxp-reference-modal" data-nxp-reference-modal="education" hidden aria-hidden="true">
    <div class="nxp-reference-modal__card" dir="rtl">
        <header class="nxp-reference-modal__head">
            <div>
                <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0631;&#x0627;&#x062C;&#x0639;</span>
                <h3>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x062F;&#x0631;&#x062C;&#x0627;&#x062A; &#x0627;&#x0644;&#x0639;&#x0644;&#x0645;&#x064A;&#x0629;</h3>
            </div>
            <button type="button" data-nxp-reference-close>&times;</button>
        </header>

        <form method="post" asp-page-handler="SaveReference" asp-route-type="education" class="nxp-reference-modal__body">
            <label class="nxp-field nxp-field--wide">
                <span>&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x062F;&#x0631;&#x062C;&#x0629; &#x0639;&#x0644;&#x0645;&#x064A;&#x0629;</span>
                <input name="ReferenceInput.Name" maxlength="240" placeholder="&#x0645;&#x062B;&#x0627;&#x0644;: &#x0628;&#x0643;&#x0627;&#x0644;&#x0648;&#x0631;&#x064A;&#x0648;&#x0633;" />
            </label>
            <button type="submit" class="nxp-btn nxp-btn--primary">&#x062D;&#x0641;&#x0638;</button>
        </form>

        <div class="nxp-reference-modal__list">
            @foreach (var item in Model.EducationOptions)
            {
                <span>@item.Name</span>
            }
        </div>
    </div>
</section>


<section class="nxp-reference-modal" data-nxp-reference-modal="specializations" hidden aria-hidden="true">
    <div class="nxp-reference-modal__card" dir="rtl">
        <header class="nxp-reference-modal__head">
            <div>
                <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0631;&#x0627;&#x062C;&#x0639;</span>
                <h3>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x062A;&#x062E;&#x0635;&#x0635;&#x0627;&#x062A;</h3>
            </div>
            <button type="button" data-nxp-reference-close>&times;</button>
        </header>

        <form method="post" asp-page-handler="SaveReference" asp-route-type="specializations" class="nxp-reference-modal__body">
            <label class="nxp-field nxp-field--wide">
                <span>&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x062A;&#x062E;&#x0635;&#x0635;</span>
                <input name="ReferenceInput.Name" maxlength="240" placeholder="&#x0645;&#x062B;&#x0627;&#x0644;: &#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0623;&#x0639;&#x0645;&#x0627;&#x0644;" />
            </label>
            <button type="submit" class="nxp-btn nxp-btn--primary">&#x062D;&#x0641;&#x0638;</button>
        </form>

        <div class="nxp-reference-modal__list">
            @foreach (var item in Model.EducationSpecializationOptions)
            {
                <span>@item.Name</span>
            }
        </div>
    </div>
</section>
@* NEXORA_FIX20G_SPECIALIZATION_MODAL *@
<section class="nxp-reference-modal" data-nxp-reference-modal="certifications" hidden aria-hidden="true">
    <div class="nxp-reference-modal__card" dir="rtl">
        <header class="nxp-reference-modal__head">
            <div>
                <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x0645;&#x0631;&#x0627;&#x062C;&#x0639;</span>

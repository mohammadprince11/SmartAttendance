@page
@model SmartAttendance.Web.Pages.SystemUsers.CreateModel

@{
    ViewData["Title"] = "إضافة مستخدم";
}

<div class="page-header">
    <div>
        <h1>إضافة مستخدم</h1>
        <p>إنشاء سجل دور لمستخدم نظام</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label asp-for="SystemUser.FullName">الاسم الكامل</label>
            <input asp-for="SystemUser.FullName" class="form-control" />
            <span asp-validation-for="SystemUser.FullName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SystemUser.UserName">اسم المستخدم</label>
            <input asp-for="SystemUser.UserName" class="form-control" />
            <span asp-validation-for="SystemUser.UserName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SystemUser.Email">البريد الإلكتروني</label>
            <input asp-for="SystemUser.Email" class="form-control" />
            <span asp-validation-for="SystemUser.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SystemUser.Role">الدور</label>
            <select asp-for="SystemUser.Role" asp-items="Model.Roles" class="form-control"></select>
            <span asp-validation-for="SystemUser.Role" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="SystemUser.IsActive" />
                نشط
            </label>
        </div>

        <div class="form-group">
            <label asp-for="SystemUser.Notes">ملاحظات</label>
            <input asp-for="SystemUser.Notes" class="form-control" />
            <span asp-validation-for="SystemUser.Notes" class="text-danger"></span>
        </div>

        <div class="alert-success">
            هذه الصفحة تدير الأدوار فقط. سيُضاف الدخول وكلمات المرور لاحقاً في مرحلة المصادقة.
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">حفظ</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

@page
@model SmartAttendance.Web.Pages.SystemUsers.IndexModel

@{
    ViewData["Title"] = "مستخدمو النظام";
}

<div class="page-header">
    <div>
        <h1>مستخدمو النظام</h1>
        <p>إدارة مستخدمي النظام وأدوارهم</p>
    </div>

    <a asp-page="./Create" class="btn-primary">+ إضافة مستخدم</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث بالاسم أو اسم المستخدم أو البريد أو الدور..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>الاسم الكامل</th>
                <th>اسم المستخدم</th>
                <th>البريد الإلكتروني</th>
                <th>الدور</th>
                <th>نشط</th>
                <th>ملاحظات</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Users.Any())
            {
                foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td>@(user.IsActive ? "نعم" : "لا")</td>
                        <td>@user.Notes</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@user.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@user.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center;">
                        No system users found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

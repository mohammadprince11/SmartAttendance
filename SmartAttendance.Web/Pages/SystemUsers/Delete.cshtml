@page
@model SmartAttendance.Web.Pages.SystemUsers.DeleteModel

@{
    ViewData["Title"] = "حذف مستخدم";
}

<div class="page-header">
    <div>
        <h1>حذف مستخدم</h1>
        <p>تأكيد حذف مستخدم النظام</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this system user?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>الاسم الكامل</label>
            <div class="form-control">@Model.SystemUser.FullName</div>
        </div>

        <div class="form-group">
            <label>اسم المستخدم</label>
            <div class="form-control">@Model.SystemUser.UserName</div>
        </div>

        <div class="form-group">
            <label>البريد الإلكتروني</label>
            <div class="form-control">@Model.SystemUser.Email</div>
        </div>

        <div class="form-group">
            <label>الدور</label>
            <div class="form-control">@Model.SystemUser.Role</div>
        </div>

        <div class="form-group">
            <label>نشط</label>
            <div class="form-control">@(Model.SystemUser.IsActive ? "نعم" : "لا")</div>
        </div>

        <div class="form-group">
            <label>ملاحظات</label>
            <div class="form-control">@Model.SystemUser.Notes</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.SystemUser.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

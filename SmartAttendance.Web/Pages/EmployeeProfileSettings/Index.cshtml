@page
@model SmartAttendance.Web.Pages.EmployeeProfileSettings.IndexModel
@{
    ViewData["Title"] = "\u0625\u0639\u062F\u0627\u062F\u0627\u062A \u062D\u0642\u0648\u0644 \u0645\u0644\u0641 \u0627\u0644\u0645\u0648\u0638\u0641";
    var message = TempData["ProfileSettingsMessage"] as string;
    var error = TempData["ProfileSettingsError"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/nexora-employee-profile-settings.css" asp-append-version="true" />
}


@section Scripts {
    <script src="~/js/nexora-employee-profile-settings-modals.js" asp-append-version="true"></script>
    <script>
        // Show the dropdown-options textarea only when the field type is "select".
        (function () {
            function sync(select) {
                var scope = select.closest('form') || document;
                var optionsField = scope.querySelector('[data-nxr-options-field]');
                if (optionsField) optionsField.hidden = select.value !== 'select';
            }
            document.querySelectorAll('[data-nxr-fieldtype]').forEach(function (select) {
                select.addEventListener('change', function () { sync(select); });
                sync(select);
            });
        })();
    </script>
}

<div class="nxr-profile-settings-page nxr-profile-settings-page-v2" dir="rtl">
    <section class="nxr-profile-settings-hero">
        <div>
            <span>&#x0625;&#x062F;&#x0627;&#x0631;&#x0629; &#x0627;&#x0644;&#x062D;&#x0642;&#x0648;&#x0644; &#x0627;&#x0644;&#x062F;&#x064A;&#x0646;&#x0627;&#x0645;&#x064A;&#x0643;&#x064A;&#x0629;</span>
            <h1>&#x0625;&#x0639;&#x062F;&#x0627;&#x062F;&#x0627;&#x062A; &#x062D;&#x0642;&#x0648;&#x0644; &#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;</h1>
            <p>&#x062A;&#x062D;&#x0643;&#x0645; &#x0628;&#x0627;&#x0644;&#x062D;&#x0642;&#x0648;&#x0644; &#x0627;&#x0644;&#x0625;&#x0636;&#x0627;&#x0641;&#x064A;&#x0629; &#x0627;&#x0644;&#x062A;&#x064A; &#x062A;&#x0638;&#x0647;&#x0631; &#x062F;&#x0627;&#x062E;&#x0644; &#x0635;&#x0641;&#x062D;&#x0627;&#x062A; &#x0625;&#x0636;&#x0627;&#x0641;&#x0629;&#x060C; &#x062A;&#x0639;&#x062F;&#x064A;&#x0644;&#x060C; &#x0648;&#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;.</p>
        </div>
        <div class="nxr-profile-settings-badge">
            <strong>@Model.TotalFields</strong>
            <span>&#x062D;&#x0642;&#x0644; &#x0645;&#x0639;&#x0631;&#x0651;&#x0641;</span>
        </div>
    </section>

    <!-- NEXORA_FIX08B_PROFILE_SETTINGS_UI_MARKER -->
    <section class="nxr-profile-settings-guide" aria-label="Profile fields guide">
        <div class="nxr-profile-settings-guide-item">
            <strong>01</strong>
            <span>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</span>
            <p>&#x062D;&#x062F;&#x062F; &#x0645;&#x0643;&#x0627;&#x0646; &#x0638;&#x0647;&#x0648;&#x0631; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644; &#x062F;&#x0627;&#x062E;&#x0644; &#x0645;&#x0644;&#x0641; &#x0627;&#x0644;&#x0645;&#x0648;&#x0638;&#x0641;.</p>
        </div>
        <div class="nxr-profile-settings-guide-item">
            <strong>02</strong>
            <span>&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</span>
            <p>&#x0646;&#x0635;&#x060C; &#x0631;&#x0642;&#x0645;&#x060C; &#x062A;&#x0627;&#x0631;&#x064A;&#x062E;&#x060C; &#x0623;&#x0648; &#x0646;&#x0635; &#x0637;&#x0648;&#x064A;&#x0644;.</p>
        </div>
        <div class="nxr-profile-settings-guide-item">
            <strong>03</strong>
            <span>&#x0627;&#x0644;&#x062A;&#x0631;&#x062A;&#x064A;&#x0628;</span>
            <p>&#x0627;&#x0644;&#x0631;&#x0642;&#x0645; &#x0627;&#x0644;&#x0623;&#x0635;&#x063A;&#x0631; &#x064A;&#x0638;&#x0647;&#x0631; &#x0623;&#x0648;&#x0644;&#x0627;&#x064B; &#x062F;&#x0627;&#x062E;&#x0644; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;.</p>
        </div>
    </section>
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="nxr-profile-settings-alert success">@message</div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="nxr-profile-settings-alert danger">@error</div>
    }

    <section class="nxr-profile-settings-card">
        <div class="nxr-profile-settings-card-head">
            <div>
                <span>&#x0628;&#x0646;&#x0627;&#x0621; &#x0627;&#x0644;&#x062D;&#x0642;&#x0648;&#x0644;</span>
                <h2>&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x062D;&#x0642;&#x0644; &#x062C;&#x062F;&#x064A;&#x062F;</h2>
                <p>&#x0627;&#x062E;&#x062A;&#x0631; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;&#x060C; &#x0627;&#x0643;&#x062A;&#x0628; &#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;&#x060C; &#x0648;&#x062D;&#x062F;&#x062F; &#x0646;&#x0648;&#x0639;&#x0647;. &#x0627;&#x0644;&#x0645;&#x0641;&#x062A;&#x0627;&#x062D; &#x064A;&#x062A;&#x0648;&#x0644;&#x062F; &#x062A;&#x0644;&#x0642;&#x0627;&#x0626;&#x064A;&#x0627;&#x064B; &#x0644;&#x062D;&#x0645;&#x0627;&#x064A;&#x0629; &#x0627;&#x0644;&#x0628;&#x064A;&#x0627;&#x0646;&#x0627;&#x062A;.</p>
            </div>
        </div>

        <form method="post" asp-page-handler="AddField" class="nxr-profile-settings-form">
            <div class="nxr-profile-settings-field">
                <label asp-for="Field.SectionKey">&#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</label>
                <select asp-for="Field.SectionKey">
                    @foreach (var profileSection in Model.Sections)
                    {
                        <option value="@profileSection.Key">@profileSection.Label</option>
                    }
                </select>
            </div>

            <div class="nxr-profile-settings-field span-2">
                <label asp-for="Field.FieldLabel">&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</label>
                <input asp-for="Field.FieldLabel" placeholder="&#x0645;&#x062B;&#x0627;&#x0644;: &#x0631;&#x0642;&#x0645; &#x062C;&#x0648;&#x0627;&#x0632; &#x0627;&#x0644;&#x0633;&#x0641;&#x0631;" />
            </div>

            <div class="nxr-profile-settings-field">
                <label asp-for="Field.FieldType">&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</label>
                <select asp-for="Field.FieldType" data-nxr-fieldtype>
                    <option value="text">نص</option>
                    <option value="number">رقم</option>
                    <option value="date">تاريخ</option>
                    <option value="textarea">نص طويل</option>
                    <option value="select">قائمة منسدلة</option>
                    <option value="checkbox">خانة اختيار</option>
                </select>
            </div>

            <div class="nxr-profile-settings-field span-2" data-nxr-options-field hidden>
                <label asp-for="Field.FieldOptions">خيارات القائمة (خيار بكل سطر)</label>
                <textarea asp-for="Field.FieldOptions" rows="3" placeholder="مثال:&#10;أعزب&#10;متزوج"></textarea>
            </div>

            <div class="nxr-profile-settings-field">
                <label asp-for="Field.SortOrder">&#x0627;&#x0644;&#x062A;&#x0631;&#x062A;&#x064A;&#x0628;</label>
                <input asp-for="Field.SortOrder" type="number" min="0" />
            </div>

            <label class="nxr-profile-settings-check">
                <input asp-for="Field.IsRequired" />
                <span>&#x062D;&#x0642;&#x0644; &#x0645;&#x0637;&#x0644;&#x0648;&#x0628;</span>
            </label>

            <div class="nxr-profile-settings-actions">
                <button type="submit">&#x0625;&#x0636;&#x0627;&#x0641;&#x0629; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</button>
            </div>
        </form>
    </section>

    <section class="nxr-profile-settings-card">
        <div class="nxr-profile-settings-card-head">
            <div>
                <span>بناء الأقسام</span>
                <h2>إضافة قسم جديد</h2>
                <p>أنشئ قسماً (مجموعة حقول) جديداً يظهر داخل ملف الموظف — ثم أضف له حقولاً من الأعلى.</p>
            </div>
        </div>
        <form method="post" asp-page-handler="AddSection" class="nxr-profile-settings-form">
            <div class="nxr-profile-settings-field span-2">
                <label>اسم القسم</label>
                <input name="Section.Label" placeholder="مثال: معلومات السكن" required />
            </div>
            <div class="nxr-profile-settings-field">
                <label>الترتيب</label>
                <input name="Section.SortOrder" type="number" min="0" value="0" />
            </div>
            <div class="nxr-profile-settings-actions">
                <button type="submit">إضافة القسم</button>
            </div>
        </form>
    </section>

    <section class="nxr-profile-settings-list-head">
        <div>
            <span>&#x0627;&#x0644;&#x0623;&#x0642;&#x0633;&#x0627;&#x0645; &#x0627;&#x0644;&#x0645;&#x0639;&#x062A;&#x0645;&#x062F;&#x0629;</span>
            <h2>&#x0627;&#x0644;&#x062D;&#x0642;&#x0648;&#x0644; &#x0627;&#x0644;&#x0645;&#x0636;&#x0627;&#x0641;&#x0629;</h2>
        </div>
        <small>@Model.TotalFields &#x062D;&#x0642;&#x0644;</small>
    </section>
    <section class="nxr-profile-settings-sections">
        @foreach (var profileSection in Model.Sections)
        {
            <article class="nxr-profile-settings-section @(profileSection.IsActive ? "" : "is-disabled")">
                <header>
                    <div>
                        <span>@(profileSection.IsSystem ? "قسم نظام" : "قسم مخصص")@(profileSection.IsActive ? "" : " · معطل")</span>
                        <h3>@profileSection.Label</h3>
                    </div>
                    <div class="nxr-profile-settings-row-actions" style="display:flex;align-items:center;gap:8px">
                        <div class="nxr-profile-settings-edit-shell" data-nxr-edit-shell>
                            <button type="button" class="nxr-profile-settings-edit-trigger">تعديل القسم</button>
                            <form method="post" asp-page-handler="UpdateSection" asp-route-id="@profileSection.Id" class="nxr-profile-settings-edit-form">
                                <div class="nxr-profile-settings-field">
                                    <label>اسم القسم</label>
                                    <input name="Section.Label" value="@profileSection.Label" />
                                </div>
                                <div class="nxr-profile-settings-field">
                                    <label>الترتيب</label>
                                    <input name="Section.SortOrder" type="number" min="0" value="@profileSection.SortOrder" />
                                </div>
                                <div class="nxr-profile-settings-actions">
                                    <button type="submit">حفظ</button>
                                </div>
                            </form>
                        </div>
                        @if (!profileSection.IsSystem)
                        {
                            <form method="post" asp-page-handler="ToggleSection" asp-route-id="@profileSection.Id">
                                <button type="submit">@(profileSection.IsActive ? "تعطيل" : "تفعيل")</button>
                            </form>
                            <form method="post" asp-page-handler="DeleteSection" asp-route-id="@profileSection.Id" data-zyconfirm="حذف القسم؟">
                                <button type="submit" class="danger">حذف</button>
                            </form>
                        }
                        <strong>@profileSection.Fields.Count</strong>
                    </div>
                </header>

                @if (profileSection.Fields.Count == 0)
                {
                    <div class="nxr-profile-settings-empty">
                        &#x0644;&#x0627; &#x062A;&#x0648;&#x062C;&#x062F; &#x062D;&#x0642;&#x0648;&#x0644; &#x0645;&#x0636;&#x0627;&#x0641;&#x0629; &#x062D;&#x0627;&#x0644;&#x064A;&#x0627;&#x064B; &#x062F;&#x0627;&#x062E;&#x0644; &#x0647;&#x0630;&#x0627; &#x0627;&#x0644;&#x0642;&#x0633;&#x0645;.
                    </div>
                }
                else
                {
                    <div class="nxr-profile-settings-field-list">
                        @foreach (var field in profileSection.Fields)
                        {
                            <div class="nxr-profile-settings-field-row @(field.IsActive ? "" : "is-disabled")">
                                <div class="nxr-profile-settings-field-main">
                                    <b>@field.FieldLabel</b>
                                    <span>@field.FieldTypeLabel</span>
                                </div>

                                <div class="nxr-profile-settings-pills">
                                    @if (field.IsRequired)
                                    {
                                        <small class="required">&#x0645;&#x0637;&#x0644;&#x0648;&#x0628;</small>
                                    }
                                    else
                                    {
                                        <small>&#x0627;&#x062E;&#x062A;&#x064A;&#x0627;&#x0631;&#x064A;</small>
                                    }

                                    @if (field.IsActive)
                                    {
                                        <small class="active">&#x0641;&#x0639;&#x0627;&#x0644;</small>
                                    }
                                    else
                                    {
                                        <small>&#x0645;&#x0639;&#x0637;&#x0644;</small>
                                    }

                                    <small>#@field.SortOrder</small>
                                </div>

                                <div class="nxr-profile-settings-row-actions">
                                    <div class="nxr-profile-settings-edit-shell" data-nxr-edit-shell>
                                            @* NEXORA_FIX08G_STABLE_EDIT_MODAL_MARKER *@
                                            <button type="button" class="nxr-profile-settings-edit-trigger">&#x062A;&#x0639;&#x062F;&#x064A;&#x0644;</button>

                                            <form method="post"
                                              asp-page-handler="UpdateField"
                                              asp-route-id="@field.Id"
                                              class="nxr-profile-settings-edit-form">
                                            <div class="nxr-profile-settings-field">
                                                <label>&#x0627;&#x0644;&#x0642;&#x0633;&#x0645;</label>
                                                <select name="EditField.SectionKey">
                                                    @foreach (var editSection in Model.Sections)
                                                    {
                                                        <option value="@editSection.Key" selected="@(editSection.Key.Equals(field.SectionKey, System.StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@editSection.Label</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="nxr-profile-settings-field">
                                                <label>&#x0627;&#x0633;&#x0645; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</label>
                                                <input name="EditField.FieldLabel" value="@field.FieldLabel" />
                                            </div>

                                            <div class="nxr-profile-settings-field">
                                                <label>&#x0646;&#x0648;&#x0639; &#x0627;&#x0644;&#x062D;&#x0642;&#x0644;</label>
                                                <select name="EditField.FieldType" data-nxr-fieldtype>
                                                    <option value="text" selected="@(field.FieldType == "text" ? "selected" : null)">&#x0646;&#x0635;</option>
                                                    <option value="number" selected="@(field.FieldType == "number" ? "selected" : null)">&#x0631;&#x0642;&#x0645;</option>
                                                    <option value="date" selected="@(field.FieldType == "date" ? "selected" : null)">&#x062A;&#x0627;&#x0631;&#x064A;&#x062E;</option>
                                                    <option value="textarea" selected="@(field.FieldType == "textarea" ? "selected" : null)">&#x0646;&#x0635; &#x0637;&#x0648;&#x064A;&#x0644;</option>
                                                    <option value="select" selected="@(field.FieldType == "select" ? "selected" : null)">قائمة منسدلة</option>
                                                    <option value="checkbox" selected="@(field.FieldType == "checkbox" ? "selected" : null)">خانة اختيار</option>
                                                </select>
                                            </div>

                                            <div class="nxr-profile-settings-field" data-nxr-options-field hidden="@(field.FieldType == "select" ? null : "hidden")">
                                                <label>خيارات القائمة (خيار بكل سطر)</label>
                                                <textarea name="EditField.FieldOptions" rows="3">@field.FieldOptions</textarea>
                                            </div>

                                            <div class="nxr-profile-settings-field">
                                                <label>&#x0627;&#x0644;&#x062A;&#x0631;&#x062A;&#x064A;&#x0628;</label>
                                                <input name="EditField.SortOrder" type="number" min="0" value="@field.SortOrder" />
                                            </div>

                                            <label class="nxr-profile-settings-check">
                                                <input type="hidden" name="EditField.IsRequired" value="false" />
                                                <input type="checkbox" name="EditField.IsRequired" value="true" checked="@(field.IsRequired ? "checked" : null)" />
                                                <span>&#x062D;&#x0642;&#x0644; &#x0645;&#x0637;&#x0644;&#x0648;&#x0628;</span>
                                            </label>

                                            <div class="nxr-profile-settings-actions">
                                                <button type="submit">&#x062D;&#x0641;&#x0638; &#x0627;&#x0644;&#x062A;&#x0639;&#x062F;&#x064A;&#x0644;</button>
                                            </div>
                                        </form>
                                        </div>

                                    <form method="post" asp-page-handler="ToggleField" asp-route-id="@field.Id">
                                        <button type="submit">
                                            @(field.IsActive ? "\u062A\u0639\u0637\u064A\u0644" : "\u062A\u0641\u0639\u064A\u0644")
                                        </button>
                                    </form>

                                    <form method="post" data-nxr-field-delete-form asp-page-handler="DeleteField"
                                          asp-route-id="@field.Id">
                                        <button type="submit" class="danger">&#x062D;&#x0630;&#x0641;</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </article>
        }
    </section>
</div>
@page
@model SmartAttendance.Web.Pages.UserAccess.IndexModel

@{
    ViewData["Title"] = "إدارة مستخدمي النظام";
    var editorTitle = Model.Input.IsEditing
        ? "تحديث وربط الحساب"
        : "إنشاء حساب موحد";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/user-access.css"
          asp-append-version="true" />
}

<div class="nx-identity-page"
     data-identity-management>
    <section class="nx-identity-hero">
        <div>
            <span class="nx-identity-kicker">
                NEXORA IDENTITY MANAGEMENT
            </span>
            <h1>إدارة مستخدمي النظام</h1>
            <p>
                مركز موحد لحسابات الدخول، هويات الصلاحيات،
                وربط المستخدمين بالموظفين.
            </p>
        </div>

        <div class="nx-identity-stats">
            <article>
                <strong>@Model.TotalCount</strong>
                <span>إجمالي الهويات</span>
            </article>
            <article>
                <strong>@Model.LinkedCount</strong>
                <span>ربط صحيح</span>
            </article>
            <article>
                <strong>@Model.NeedsReviewCount</strong>
                <span>تحتاج مراجعة</span>
            </article>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="nx-identity-alert success">
            @Model.SuccessMessage
        </div>
    }

    @if (TempData["ErrorMessage"] is string tempError)
    {
        <div class="nx-identity-alert danger">
            @tempError
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PageError))
    {
        <div class="nx-identity-alert danger">
            @Model.PageError
        </div>
    }

    <div class="nx-identity-layout">
        <aside class="nx-identity-editor">
            <div class="nx-identity-panel-head">
                <div>
                    <span class="nx-identity-section-label">
                        @(Model.Input.IsEditing ? "EDIT IDENTITY" : "NEW IDENTITY")
                    </span>
                    <h2>@editorTitle</h2>
                </div>

                @if (Model.Input.IsEditing)
                {
                    <a asp-page="./Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Status="@Model.Status"
                       class="nx-identity-btn secondary">
                        إلغاء
                    </a>
                }
            </div>

            <form method="post"
                  asp-page-handler="Save"
                  class="nx-identity-form">
                <input asp-for="Input.LoginId"
                       type="hidden" />
                <input asp-for="Input.SystemUserId"
                       type="hidden" />

                <label class="nx-identity-field wide">
                    <span>الموظف المرتبط</span>
                    <select asp-for="Input.EmployeeId"
                            data-employee-select>
                        <option value="">
                            بدون ربط بموظف
                        </option>
                        @foreach (var employee in Model.Employees)
                        {
                            var unavailable =
                                employee.IsLinked &&
                                employee.Id != Model.Input.EmployeeId;

                            <option value="@employee.Id"
                                    disabled="@unavailable">
                                @employee.DisplayText
                            </option>
                        }
                    </select>
                    <small>
                        يمنع النظام ربط الموظف بأكثر من حساب.
                    </small>
                </label>

                <label class="nx-identity-field">
                    <span>الاسم الكامل</span>
                    <input asp-for="Input.FullName"
                           maxlength="150"
                           autocomplete="name" />
                    <small>
                        عند اختيار موظف يعتمد النظام اسم الموظف المسجل.
                    </small>
                </label>

                <label class="nx-identity-field">
                    <span>اسم المستخدم</span>
                    <input asp-for="Input.UserName"
                           maxlength="100"
                           required
                           autocomplete="username" />
                </label>

                <label class="nx-identity-field">
                    <span>البريد الإلكتروني</span>
                    <input asp-for="Input.Email"
                           type="email"
                           maxlength="150"
                           autocomplete="email" />
                </label>

                <label class="nx-identity-field">
                    <span>دور التوافق</span>
                    <select asp-for="Input.CompatibilityRole"
                            data-role-select>
                        @foreach (var role in Model.Roles)
                        {
                            <option value="@role.Value"
                                    data-template="@role.SystemTemplate">
                                @role.Label · @role.Value
                            </option>
                        }
                    </select>
                    <small>
                        الدور قالب أولي؛ الصلاحيات المباشرة تبقى المرجع النهائي.
                    </small>
                </label>

                <label class="nx-identity-field">
                    <span>
                        @(Model.Input.LoginId > 0
                            ? "كلمة مرور جديدة"
                            : "كلمة المرور")
                    </span>
                    <div class="nx-identity-password">
                        <input asp-for="Input.Password"
                               type="password"
                               minlength="8"
                               autocomplete="new-password"
                               data-password-input />
                        <button type="button"
                                data-toggle-password
                                aria-label="إظهار أو إخفاء كلمة المرور">
                            عرض
                        </button>
                    </div>
                    @if (Model.Input.LoginId > 0)
                    {
                        <small>
                            اتركها فارغة للإبقاء على كلمة المرور الحالية.
                        </small>
                    }
                </label>

                <label class="nx-identity-field">
                    <span>تأكيد كلمة المرور</span>
                    <input asp-for="Input.ConfirmPassword"
                           type="password"
                           minlength="8"
                           autocomplete="new-password"
                           data-password-confirm />
                </label>

                <label class="nx-identity-field wide">
                    <span>ملاحظات إدارية</span>
                    <textarea asp-for="Input.Notes"
                              maxlength="500"
                              rows="3"></textarea>
                </label>

                <label class="nx-identity-active wide">
                    <input asp-for="Input.IsActive" />
                    <span>الحساب فعال ويسمح له بتسجيل الدخول</span>
                </label>

                <div class="nx-identity-form-summary wide">
                    <span>قالب SystemUser:</span>
                    <strong data-system-template>Viewer</strong>
                </div>

                <button type="submit"
                        class="nx-identity-btn primary wide">
                    @(Model.Input.IsEditing
                        ? "حفظ التحديث والربط"
                        : "إنشاء الحساب الموحد")
                </button>
            </form>
        </aside>

        <main class="nx-identity-list-area">
            <section class="nx-identity-filter-panel">
                <form method="get"
                      class="nx-identity-filters">
                    <label>
                        <span>بحث</span>
                        <input asp-for="Search"
                               placeholder="الاسم، المستخدم، الموظف، الدور..." />
                    </label>

                    <label>
                        <span>حالة الربط</span>
                        <select asp-for="Status">
                            <option value="">جميع الحالات</option>
                            <option value="Linked">مرتبط بشكل صحيح</option>
                            <option value="NeedsSync">يحتاج مزامنة</option>
                            <option value="LoginOnly">حساب دخول فقط</option>
                            <option value="SystemOnly">هوية صلاحيات فقط</option>
                            <option value="Conflict">تعارض في الربط</option>
                        </select>
                    </label>

                    <div class="nx-identity-filter-actions">
                        <button type="submit"
                                class="nx-identity-btn primary">
                            تطبيق
                        </button>
                        <a asp-page="./Index"
                           class="nx-identity-btn secondary">
                            مسح
                        </a>
                    </div>
                </form>
            </section>

            <section class="nx-identity-list">
                @foreach (var identity in Model.Identities)
                {
                    <article class="nx-identity-card">
                        <header>
                            <div class="nx-identity-person">
                                <span class="nx-identity-avatar">
                                    @(string.IsNullOrWhiteSpace(identity.DisplayName)
                                        ? "N"
                                        : identity.DisplayName.Trim()[0])
                                </span>

                                <div>
                                    <h3>
                                        @(string.IsNullOrWhiteSpace(identity.DisplayName)
                                            ? identity.UserName
                                            : identity.DisplayName)
                                    </h3>
                                    <code>@identity.UserName</code>
                                </div>
                            </div>

                            <span class="nx-identity-link-status @identity.StatusCss">
                                @identity.StatusLabel
                            </span>
                        </header>

                        <div class="nx-identity-details">
                            <span>
                                <strong>الموظف:</strong>
                                @(string.IsNullOrWhiteSpace(identity.EmployeeName)
                                    ? "غير مرتبط"
                                    : $"{identity.EmployeeNo} - {identity.EmployeeName}")
                            </span>
                            <span>
                                <strong>دور الدخول:</strong>
                                @identity.CompatibilityRole
                            </span>
                            <span>
                                <strong>قالب الصلاحيات:</strong>
                                @identity.SystemRoleLabel
                            </span>
                            <span>
                                <strong>الصلاحيات المباشرة:</strong>
                                @identity.PermissionCount
                            </span>
                            <span>
                                <strong>الحالة:</strong>
                                @(identity.IsActive ? "فعال" : "متوقف")
                            </span>
                            <span>
                                <strong>آخر دخول:</strong>
                                @(identity.LastLoginAt?.ToString("yyyy/MM/dd HH:mm")
                                    ?? "لم يسجل الدخول")
                            </span>
                        </div>

                        @if (identity.LinkStatus ==
                            IndexModel.IdentityLinkStatus.Conflict)
                        {
                            <div class="nx-identity-conflict-note">
                                يوجد أكثر من سجل يطابق الموظف أو اسم المستخدم.
                                أوقف التعديل حتى تتم مراجعة التعارض يدوياً.
                            </div>
                        }

                        <footer>
                            <div class="nx-identity-ids">
                                <span>Login #@identity.LoginId</span>
                                <span>System #@identity.SystemUserId</span>
                            </div>

                            <div class="nx-identity-actions">
                                @if (identity.CanEdit)
                                {
                                    <a asp-page="./Index"
                                       asp-route-EditLoginId="@identity.LoginId"
                                       asp-route-EditSystemUserId="@identity.SystemUserId"
                                       asp-route-Search="@Model.Search"
                                       asp-route-Status="@Model.Status"
                                       class="nx-identity-btn secondary">
                                        @(identity.LoginId == 0 ||
                                          identity.SystemUserId == 0
                                            ? "إكمال الربط"
                                            : "تعديل")
                                    </a>
                                }

                                @if (identity.CanToggle)
                                {
                                    <form method="post"
                                          asp-page-handler="Toggle"
                                          asp-route-loginId="@identity.LoginId"
                                          asp-route-search="@Model.Search"
                                          asp-route-status="@Model.Status"
                                          data-toggle-identity
                                          data-message="@(identity.IsActive
                                              ? "سيتم تعطيل تسجيل الدخول لهذا الحساب."
                                              : "سيتم تفعيل تسجيل الدخول لهذا الحساب.")">
                                        <button type="submit"
                                                class="nx-identity-btn @(identity.IsActive ? "danger" : "success")">
                                            @(identity.IsActive ? "تعطيل" : "تفعيل")
                                        </button>
                                    </form>
                                }
                            </div>
                        </footer>
                    </article>
                }

                @if (!Model.Identities.Any())
                {
                    <div class="nx-identity-empty">
                        <h3>لا توجد نتائج</h3>
                        <p>غيّر البحث أو حالة الربط لعرض حسابات أخرى.</p>
                    </div>
                }
            </section>
        </main>
    </div>
</div>

@section Scripts {
    <script src="~/js/user-access.js"
            asp-append-version="true"></script>
}

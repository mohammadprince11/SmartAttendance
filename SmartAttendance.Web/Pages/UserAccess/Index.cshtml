@page
@model SmartAttendance.Web.Pages.UserAccess.IndexModel

@*
    إدارة مستخدمي النظام — أعيد تصميمها بنمط كيان (2026-07):
    شريط عنوان بعدادات ← فلاتر ← جدول هويات نظيف ← سلايد إنشاء/تعديل.
    كل المعالجات بالـ PageModel كما هي (Save/Toggle + تعبئة التعديل عبر
    EditLoginId/EditSystemUserId بالسيرفر) — هذه الواجهة عرض وتفاعل فقط.
*@

@{
    ViewData["Title"] = "إدارة مستخدمي النظام";
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/zynora-user-access.css" asp-append-version="true" />

<section class="zua-page" dir="rtl">

    @* ---------- العنوان + العدادات ---------- *@
    <header class="zua-head">
        <div>
            <h1>إدارة مستخدمي النظام</h1>
            <p>حسابات الدخول وهويات الصلاحيات وربطها بالموظفين — بمكان واحد.</p>
        </div>
        <div class="zua-stats">
            <div class="zua-stat"><b>@Model.TotalCount</b><span>إجمالي الهويات</span></div>
            <div class="zua-stat ok"><b>@Model.LinkedCount</b><span>مرتبط صحيح</span></div>
            <div class="zua-stat warn"><b>@Model.NeedsReviewCount</b><span>يحتاج مراجعة</span></div>
            <div class="zua-stat"><b>@Model.Identities.Count(x => x.IsActive)</b><span>فعال</span></div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="zua-alert">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.PageError))
    {
        <div class="zua-alert error">@Model.PageError</div>
    }

    @* ---------- الفلاتر + زر الإنشاء ---------- *@
    <form method="get" class="zua-filters">
        <input type="search" name="Search" value="@Model.Search" placeholder="بحث بالاسم، اسم المستخدم، الموظف..." />
        <select name="Status" onchange="this.form.submit()">
            <option value="">جميع الحالات</option>
            <option value="linked" selected="@(Model.Status == "linked")">مرتبط بشكل صحيح</option>
            <option value="review" selected="@(Model.Status == "review")">يحتاج مراجعة</option>
            <option value="active" selected="@(Model.Status == "active")">فعال</option>
            <option value="inactive" selected="@(Model.Status == "inactive")">معطل</option>
        </select>
        <button type="submit" class="zua-btn ghost">بحث</button>
        <button type="button" class="zua-btn" onclick="zuaOpenCreate()">+ مستخدم جديد</button>
    </form>

    @* ---------- الجدول ---------- *@
    <div class="zua-table-card">
        @if (Model.Identities.Count == 0)
        {
            <div class="zua-empty">لا هويات مطابقة للفلاتر الحالية.</div>
        }
        else
        {
            <table class="zua-table">
                <thead>
                    <tr>
                        <th>المستخدم</th>
                        <th>الموظف المرتبط</th>
                        <th>الدور</th>
                        <th>حالة الربط</th>
                        <th>الحالة</th>
                        <th>آخر دخول</th>
                        <th style="text-align:end">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Identities)
                    {
                        <tr>
                            <td>
                                <div class="zua-user">
                                    <span class="zua-avatar">@(string.IsNullOrWhiteSpace(row.DisplayName) ? "؟" : row.DisplayName.Trim()[..1])</span>
                                    <div>
                                        <b>@row.DisplayName</b>
                                        <small>@row.UserName</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (row.EmployeeId.HasValue && !string.IsNullOrWhiteSpace(row.EmployeeName))
                                {
                                    <a href="/Employees/Profile?id=@row.EmployeeId" style="color:var(--zua-teal);text-decoration:none;font-weight:800">@row.EmployeeName</a>
                                    <small style="color:var(--zua-muted)"> @row.EmployeeNo</small>
                                }
                                else
                                {
                                    <span style="color:var(--zua-muted)">بلا ربط</span>
                                }
                            </td>
                            <td><span class="zua-chip role">@row.CompatibilityRole</span></td>
                            <td><span class="zua-chip @row.StatusCss">@row.StatusLabel</span></td>
                            <td><span class="zua-chip @(row.IsActive ? "on" : "off")">@(row.IsActive ? "فعال" : "معطل")</span></td>
                            <td style="direction:ltr;text-align:end;font-size:12px;color:var(--zua-muted)">
                                @(row.LastLoginAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")
                            </td>
                            <td>
                                <div class="zua-actions">
                                    @if (row.CanEdit)
                                    {
                                        <a class="zua-btn ghost" style="display:inline-flex;align-items:center;text-decoration:none"
                                           href="?EditLoginId=@row.LoginId&EditSystemUserId=@row.SystemUserId&Search=@Model.Search&Status=@Model.Status">تعديل</a>
                                    }
                                    @if (row.CanToggle)
                                    {
                                        <form method="post" asp-page-handler="Toggle" style="display:inline">
                                            <input type="hidden" name="loginId" value="@row.LoginId" />
                                            <input type="hidden" name="search" value="@Model.Search" />
                                            <input type="hidden" name="status" value="@Model.Status" />
                                            <button type="submit" class="zua-btn ghost">@(row.IsActive ? "تعطيل" : "تفعيل")</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ---------- سلايد الإنشاء/التعديل (نفس نمط سلايدات الملف 360°) ---------- *@
    <div class="hrms-slideover-backdrop" id="zua-backdrop" onclick="zuaClose()"></div>
    <aside class="hrms-slideover" id="zua-slide" aria-hidden="true">
        <div class="hrms-slideover-head">
            <h2 id="zua-slide-title">@(Model.Input.IsEditing ? "تعديل الحساب" : "حساب جديد")</h2>
            <button type="button" class="hrms-slideover-close" onclick="zuaClose()">×</button>
        </div>
        <div class="hrms-slideover-body">
            <form method="post" asp-page-handler="Save" class="zua-form">
                <input type="hidden" asp-for="Input.LoginId" />
                <input type="hidden" asp-for="Input.SystemUserId" />
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="Status" value="@Model.Status" />

                <label>الموظف المرتبط (اختياري)
                    <select asp-for="Input.EmployeeId">
                        <option value="">بدون ربط بموظف</option>
                        @foreach (var employee in Model.Employees)
                        {
                            <option value="@employee.Id">@employee.FullName — @employee.EmployeeNo@(employee.IsLinked ? " · مرتبط" : "")</option>
                        }
                    </select>
                    <span class="hint">عند اختيار موظف يُعتمد اسمه تلقائياً إن تُرك الاسم فارغاً.</span>
                </label>

                <div class="row2">
                    <label>الاسم الكامل
                        <input asp-for="Input.FullName" placeholder="اسم العرض" />
                    </label>
                    <label>اسم المستخدم *
                        <input asp-for="Input.UserName" required dir="ltr" placeholder="username" />
                    </label>
                </div>

                <div class="row2">
                    <label>البريد الإلكتروني
                        <input asp-for="Input.Email" type="email" dir="ltr" placeholder="user@company.com" />
                    </label>
                    <label>الدور
                        <select asp-for="Input.CompatibilityRole">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.Value">@role.Label</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="row2">
                    <label>كلمة المرور @(Model.Input.IsEditing ? "(فارغة = بلا تغيير)" : "*")
                        <input asp-for="Input.Password" type="password" dir="ltr" autocomplete="new-password" />
                    </label>
                    <label>تأكيد كلمة المرور
                        <input asp-for="Input.ConfirmPassword" type="password" dir="ltr" autocomplete="new-password" />
                    </label>
                </div>

                <label>ملاحظات
                    <textarea asp-for="Input.Notes" rows="2"></textarea>
                </label>

                <label style="flex-direction:row;align-items:center;gap:8px">
                    <input asp-for="Input.IsActive" type="checkbox" style="min-height:auto" /> الحساب فعال
                </label>

                <button type="submit" class="zua-btn">@(Model.Input.IsEditing ? "حفظ التعديلات" : "إنشاء الحساب")</button>
            </form>
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        // فتح/إغلاق سلايد الحساب — التعديل يفتح تلقائياً عندما يعبّئه السيرفر (EditLoginId).
        function zuaOpen() {
            document.getElementById('zua-slide').classList.add('open');
            document.getElementById('zua-backdrop').classList.add('open');
        }
        function zuaClose() {
            document.getElementById('zua-slide').classList.remove('open');
            document.getElementById('zua-backdrop').classList.remove('open');
        }
        function zuaOpenCreate() {
            var form = document.querySelector('#zua-slide form');
            form.reset();
            document.getElementById('Input_LoginId').value = '0';
            document.getElementById('Input_SystemUserId').value = '0';
            document.getElementById('zua-slide-title').textContent = 'حساب جديد';
            zuaOpen();
        }
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') zuaClose(); });

        @if (Model.Input.IsEditing)
        {
            @:zuaOpen();
        }
    </script>
}

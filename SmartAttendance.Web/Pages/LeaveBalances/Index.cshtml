@page
@using SmartAttendance.Domain.Enums
@model SmartAttendance.Web.Pages.LeaveBalances.IndexModel

@{
    ViewData["Title"] = "أرصدة الإجازات";
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />

<div class="hrms-page">
    <div class="page-header">
        <div>
            <h1>أرصدة الإجازات</h1>
            <p>المستحق والمستخدم والمتبقي لكل موظف حسب القانون العراقي (سنوية 21 يوم، مرضية 30 يوم).</p>
        </div>
        <form method="get" class="hrms-inline-form">
            @if (Model.CompanyOptions.Count > 1)
            {
                <label for="company-filter">الشركة</label>
                <select id="company-filter" name="CompanyId" onchange="this.form.submit()">
                    @foreach (var option in Model.CompanyOptions)
                    {
                        <option value="@option.Id" selected="@(Model.CompanyId == option.Id)">@option.Name</option>
                    }
                </select>
            }
            <label for="year-filter">السنة</label>
            <select id="year-filter" name="Year" onchange="this.form.submit()">
                @foreach (var year in Model.YearOptions)
                {
                    <option value="@year" selected="@(Model.Year == year)">@year</option>
                }
            </select>
            <label for="search-filter">بحث</label>
            <input id="search-filter" type="search" name="Search" value="@Model.Search" placeholder="اسم أو رقم وظيفي" />
            <button type="submit" class="hrms-btn-secondary">تطبيق</button>
            <button type="button" class="hrms-btn-primary" onclick="carryOpen()">⇄ ترحيل إلى @(Model.Year + 1)</button>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(Model.CarryMessage))
    {
        <div class="hrms-badge approved" style="display:block;padding:10px 14px;margin-bottom:12px">@Model.CarryMessage</div>
    }

    @* ===== حوار ترحيل الأرصدة ===== *@
    <div id="carry-backdrop" onclick="carryClose()"
         style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:80"></div>
    <div id="carry-modal" role="dialog" aria-modal="true"
         style="display:none;position:fixed;z-index:81;inset-inline:0;top:12vh;margin-inline:auto;width:min(460px,calc(100% - 32px));
                background:var(--sa-surface,#0b2135);border:1px solid var(--sa-border,rgba(73,111,151,.4));border-radius:16px;
                box-shadow:0 20px 60px rgba(0,0,0,.6);padding:20px;color:var(--sa-text,#DCEAF4)">
        <h2 style="margin:0 0 6px;font-size:17px;font-weight:1000">ترحيل أرصدة الإجازات</h2>
        <p style="margin:0 0 14px;font-size:12.5px;font-weight:800;color:var(--sa-muted,#8FA8BC)">
            يُرحّل رصيد الموظفين <b>المتبقّي</b> في سنة <b>@Model.Year</b> إلى «مُرحّل» سنة
            <b>@(Model.Year + 1)</b> للشركة المحددة. العملية آمنة للإعادة (تضبط لا تُراكم).
        </p>
        <form method="post" asp-page-handler="CarryOver">
            <input type="hidden" name="CompanyId" value="@Model.CompanyId" />
            <input type="hidden" name="Year" value="@Model.Year" />

            <div style="font-size:12px;font-weight:900;margin-bottom:6px">أنواع الإجازات المُرحّلة</div>
            <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px">
                @foreach (var type in Model.TrackedTypes)
                {
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;font-weight:800;cursor:pointer">
                        <input type="checkbox" name="CarryTypes" value="@type" checked="@(type == LeaveType.Annual)" />
                        @Model.LeaveTypeText(type)
                        @if (type != LeaveType.Annual)
                        {
                            <span style="font-size:11px;color:var(--sa-muted,#8FA8BC);font-weight:700">(عادةً لا تُرحّل)</span>
                        }
                    </label>
                }
            </div>

            <label style="display:flex;flex-direction:column;gap:4px;font-size:12px;font-weight:900;margin-bottom:16px">
                الحد الأقصى للترحيل لكل نوع (اختياري — اتركه فارغاً بلا سقف)
                <input type="number" name="CarryCap" min="0" step="0.5" placeholder="مثال: 21"
                       style="min-height:38px;border-radius:10px;border:1px solid var(--sa-border,rgba(73,111,151,.3));background:var(--sa-input,rgba(0,0,0,.16));color:inherit;padding:6px 10px" />
            </label>

            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" class="hrms-btn-secondary" onclick="carryClose()">إلغاء</button>
                <button type="submit" class="hrms-btn-primary">تنفيذ الترحيل</button>
            </div>
        </form>
    </div>

    <div class="hrms-stats-card">
        <div class="hrms-stats">
            <div class="hrms-stat">
                <span>عدد الموظفين</span>
                <strong>@Model.EmployeeCount</strong>
            </div>
            <div class="hrms-stat">
                <span>تجاوزوا الرصيد</span>
                <strong>@Model.OverLimitCount</strong>
            </div>
            <div class="hrms-stat">
                <span>إجمالي السنوية المستخدمة</span>
                <strong>@Model.TotalAnnualUsed.ToString("0.#")</strong>
            </div>
            <div class="hrms-stat">
                <span>إجمالي السنوية المتبقية</span>
                <strong>@Model.TotalAnnualRemaining.ToString("0.#")</strong>
            </div>
        </div>
    </div>

    <div class="hrms-table-card">
        <div class="page-header">
            <div>
                <h2>الأرصدة لسنة @Model.Year @(string.IsNullOrEmpty(Model.SelectedCompanyName) ? "" : "— " + Model.SelectedCompanyName)</h2>
                <p>المستحق يُحسب من السياسة الافتراضية ما لم يُضبط يدوياً لكل موظف. المستخدم من الطلبات المعتمدة.</p>
            </div>
        </div>

        @if (Model.Rows.Count == 0)
        {
            <div class="hrms-empty">لا يوجد موظفون فعالون مطابقون ضمن الشركة والبحث المحددين.</div>
        }
        else
        {
            <div class="hrms-table-wrap">
                <table class="hrms-table">
                    <thead>
                        <tr>
                            <th>الرقم الوظيفي</th>
                            <th class="text-start">الموظف</th>
                            <th class="text-start">القسم</th>
                            @foreach (var type in Model.TrackedTypes)
                            {
                                <th>@Model.LeaveTypeText(type) — مستحق</th>
                                <th>مستخدم</th>
                                <th>متبقي</th>
                            }
                            <th>ضبط</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.EmployeeNo</td>
                                <td class="text-start">@row.FullName</td>
                                <td class="text-start">@row.DepartmentName</td>
                                @foreach (var type in Model.TrackedTypes)
                                {
                                    var cell = row.Cells[type];
                                    <td>
                                        @cell.Entitled.ToString("0.#")
                                        @if (cell.CarriedOver > 0)
                                        {
                                            <span style="opacity:.7">(+@cell.CarriedOver.ToString("0.#") مُرحّل)</span>
                                        }
                                        @if (cell.HasOverride)
                                        {
                                            <span class="hrms-badge approved">مضبوط</span>
                                        }
                                    </td>
                                    <td>@cell.Used.ToString("0.#")</td>
                                    <td>
                                        <span class="hrms-badge @Model.RemainingClass(cell.Remaining)">@cell.Remaining.ToString("0.#")</span>
                                    </td>
                                }
                                <td>
                                    <a asp-page="/LeaveBalances/Adjust"
                                       asp-route-employeeId="@row.EmployeeId"
                                       asp-route-year="@Model.Year"
                                       asp-route-companyId="@Model.CompanyId"
                                       class="hrms-btn-secondary">ضبط</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function carryOpen() {
            document.getElementById('carry-backdrop').style.display = 'block';
            document.getElementById('carry-modal').style.display = 'block';
        }
        function carryClose() {
            document.getElementById('carry-backdrop').style.display = 'none';
            document.getElementById('carry-modal').style.display = 'none';
        }
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') carryClose(); });
    </script>
}

@page
@model SmartAttendance.Web.Pages.Reports.CreateModel

@{
    ViewData["Title"] = "Create Report";
}

<link rel="stylesheet" href="~/css/reports-rebuild.css" asp-append-version="true" />

<div class="reports-page">
    <div class="page-header reports-header">
        <div>
            <h1 data-reports-text="createReport">إنشاء تقرير</h1>
            <p data-reports-text="createReportSubtitle">اختر مصدر التقرير، الأعمدة، الترتيب، ثم احفظه ضمن تقاريري.</p>
        </div>

        <a asp-page="./Index" class="reports-secondary-action">
            <span data-reports-text="backToReports">الرجوع للتقارير</span>
        </a>
    </div>

    <div class="create-report-layout">
        <aside class="create-report-panel">
            <h2 data-reports-text="reportSettings">إعدادات التقرير</h2>

            <div class="report-form-group">
                <label for="reportName" data-reports-text="reportName">اسم التقرير</label>
                <input id="reportName"
                       type="text"
                       placeholder="مثال: تقرير موظفي HQ"
                       data-reports-placeholder="reportNamePlaceholder" />
            </div>

            <div class="report-form-group">
                <label for="reportSource" data-reports-text="reportSource">مصدر التقرير</label>
                <select id="reportSource">
                    <option value="employees" data-reports-text="employeeFile">ملف الموظفين</option>
                    <option value="attendance" data-reports-text="attendanceRecords">الحضور والانصراف</option>
                </select>
            </div>

            <div class="report-form-group">
                <label data-reports-text="quickFilters">فلاتر اختيارية</label>
                <input id="reportSearch"
                       type="text"
                       placeholder="بحث..."
                       data-reports-placeholder="generalSearch" />

                <div class="report-filter-row">
                    <input id="fromDate" type="date" />
                    <input id="toDate" type="date" />
                </div>
            </div>

            <div class="report-builder-actions">
                <button type="button" class="reports-primary-action" id="saveReportButton">
                    <span data-reports-text="saveReport">حفظ التقرير</span>
                </button>

                <button type="button" class="reports-secondary-action" id="previewReportButton">
                    <span data-reports-text="preview">معاينة</span>
                </button>
            </div>
        </aside>

        <section class="create-report-panel report-fields-panel">
            <div class="fields-panel-head">
                <div>
                    <h2 data-reports-text="chooseColumns">اختيار الأعمدة</h2>
                    <p data-reports-text="chooseColumnsHint">اضغط على الحقول لإضافتها إلى التقرير، ويمكنك ترتيبها.</p>
                </div>
            </div>

            <div class="fields-dual-layout">
                <div class="fields-box">
                    <div class="fields-box-head">
                        <strong data-reports-text="availableFields">الحقول المتاحة</strong>
                        <input id="availableFieldSearch"
                               type="text"
                               placeholder="بحث..."
                               data-reports-placeholder="searchFields" />
                    </div>

                    <div class="field-list" id="availableFields">
                        @foreach (var field in Model.EmployeeFields.Concat(Model.AttendanceFields))
                        {
                            <button type="button"
                                    class="field-pill"
                                    data-source="@field.Source"
                                    data-field-key="@field.Key"
                                    data-label-ar="@field.LabelAr"
                                    data-label-en="@field.LabelEn">
                                <span class="field-label-ar">@field.LabelAr</span>
                                <span class="field-label-en">@field.LabelEn</span>
                            </button>
                        }
                    </div>
                </div>

                <div class="fields-box">
                    <div class="fields-box-head">
                        <strong data-reports-text="selectedFields">أعمدة التقرير</strong>
                        <button type="button" class="mini-link-button" id="clearFieldsButton" data-reports-text="clear">مسح</button>
                    </div>

                    <div class="selected-field-list" id="selectedFields"></div>

                    <div class="fields-empty-note" id="selectedFieldsEmpty" data-reports-text="selectedFieldsEmpty">
                        لم تختر أي عمود بعد.
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/js/reports-create.js" asp-append-version="true"></script>
}

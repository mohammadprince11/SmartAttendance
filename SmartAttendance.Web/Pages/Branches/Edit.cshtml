@page
@model SmartAttendance.Web.Pages.Branches.EditModel

@{
    ViewData["Title"] = "تعديل موقع عمل";
}

<div class="nexora-setup-page nx-setup-form-page">
    <section class="nexora-setup-hero">
        <div>
            <span class="nexora-setup-kicker">مواقع العمل</span>
            <h1>تعديل موقع عمل</h1>
            <p>تحديث بيانات الموقع أو الفرع وربطه بالشركة الصحيحة.</p>
        </div>
        <a asp-page="./Index" class="btn-secondary nx-setup-btn nx-setup-btn-secondary">الرجوع للقائمة</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-danger nx-setup-alert-danger">@Model.ErrorMessage</div>
    }

    <section class="nexora-setup-card">
        <form method="post" class="nx-setup-modal-form">
            <input type="hidden" asp-for="Branch.Id" />

            <div class="nx-setup-form-grid">

                <label class="nx-setup-field">
                    <span>اسم موقع العمل</span>
                    <input asp-for="Branch.Name" />
                    <span asp-validation-for="Branch.Name" class="text-danger"></span>
                </label>

                <label class="nx-setup-field">
                    <span>العنوان</span>
                    <input asp-for="Branch.Address" />
                    <span asp-validation-for="Branch.Address" class="text-danger"></span>
                </label>

                <label class="nx-setup-check">
                    <input asp-for="Branch.IsActive" />
                    <span>الموقع فعال ويمكن استخدامه داخل النظام</span>
                </label>
            </div>

            <div class="nx-setup-modal__actions">
                <a asp-page="./Index" class="nx-setup-btn nx-setup-btn-secondary">إلغاء</a>
                <button type="submit" class="nx-setup-btn nx-setup-btn-primary">حفظ التعديل</button>
            </div>
        </form>
    </section>
</div>

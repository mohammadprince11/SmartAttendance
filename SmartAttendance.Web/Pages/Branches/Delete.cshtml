@page
@model SmartAttendance.Web.Pages.Branches.DeleteModel

@{
    ViewData["Title"] = "Delete Branch";
}

<div class="page-header">
    <div>
        <h1>Delete Branch</h1>
        <p>Confirm branch deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this branch?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Company</label>
            <div class="form-control">@Model.Branch.CompanyName</div>
        </div>

        <div class="form-group">
            <label>Branch Code</label>
            <div class="form-control">@Model.Branch.Code</div>
        </div>

        <div class="form-group">
            <label>Branch Name</label>
            <div class="form-control">@Model.Branch.Name</div>
        </div>

        <div class="form-group">
            <label>Address</label>
            <div class="form-control">@Model.Branch.Address</div>
        </div>

        <div class="form-group">
            <label>Status</label>
            <div class="form-control">
                @(Model.Branch.IsActive ? "Active" : "Inactive")
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Branch.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
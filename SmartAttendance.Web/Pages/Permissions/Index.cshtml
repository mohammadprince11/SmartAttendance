@page
@model SmartAttendance.Web.Pages.Permissions.IndexModel

@{
    ViewData["Title"] = "الصلاحيات";
}

<div class="page-header">
    <div>
        <h1>الصلاحيات</h1>
        <p>إدارة رموز الصلاحيات المرنة المستخدمة في النظام</p>
    </div>

    <div class="form-actions">
        <form method="post" asp-page-handler="Seed">
            <button type="submit" class="btn-secondary">زرع الصلاحيات الافتراضية</button>
        </form>

        <a asp-page="./Create" class="btn-primary">+ إضافة صلاحية</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث بالوحدة أو الرمز أو الاسم..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>الوحدة</th>
                <th>الرمز</th>
                <th>الاسم</th>
                <th>نشط</th>
                <th>الترتيب</th>
                <th>الوصف</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Permissions.Any())
            {
                foreach (var permission in Model.Permissions)
                {
                    <tr>
                        <td>@permission.Module</td>
                        <td>@permission.Code</td>
                        <td>@permission.Name</td>
                        <td>@(permission.IsActive ? "نعم" : "لا")</td>
                        <td>@permission.DisplayOrder</td>
                        <td>@permission.Description</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@permission.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@permission.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center;">
                        No permissions found. Click "Seed Default Permissions" to add the standard list.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

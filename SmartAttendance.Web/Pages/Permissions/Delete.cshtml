@page
@model SmartAttendance.Web.Pages.Permissions.DeleteModel

@{
    ViewData["Title"] = "Delete Permission";
}

<div class="page-header">
    <div>
        <h1>Delete Permission</h1>
        <p>Confirm permission deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this permission?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Module</label>
            <div class="form-control">@Model.Permission.Module</div>
        </div>

        <div class="form-group">
            <label>Code</label>
            <div class="form-control">@Model.Permission.Code</div>
        </div>

        <div class="form-group">
            <label>Name</label>
            <div class="form-control">@Model.Permission.Name</div>
        </div>

        <div class="form-group">
            <label>Active</label>
            <div class="form-control">@(Model.Permission.IsActive ? "Yes" : "No")</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Permission.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

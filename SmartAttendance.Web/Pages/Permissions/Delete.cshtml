@page
@model SmartAttendance.Web.Pages.Permissions.DeleteModel

@{
    ViewData["Title"] = "حذف صلاحية";
}

<div class="page-header">
    <div>
        <h1>حذف صلاحية</h1>
        <p>تأكيد حذف الصلاحية</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this permission?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>الوحدة</label>
            <div class="form-control">@Model.Permission.Module</div>
        </div>

        <div class="form-group">
            <label>الرمز</label>
            <div class="form-control">@Model.Permission.Code</div>
        </div>

        <div class="form-group">
            <label>الاسم</label>
            <div class="form-control">@Model.Permission.Name</div>
        </div>

        <div class="form-group">
            <label>نشط</label>
            <div class="form-control">@(Model.Permission.IsActive ? "نعم" : "لا")</div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Permission.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

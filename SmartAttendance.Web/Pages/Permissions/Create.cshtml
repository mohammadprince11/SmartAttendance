@page
@model SmartAttendance.Web.Pages.Permissions.CreateModel

@{
    ViewData["Title"] = "إضافة صلاحية";
}

<div class="page-header">
    <div>
        <h1>إضافة صلاحية</h1>
        <p>إنشاء صلاحية مرنة جديدة</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label asp-for="Permission.Module">الوحدة</label>
            <input asp-for="Permission.Module" class="form-control" placeholder="Employees" />
            <span asp-validation-for="Permission.Module" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Permission.Code">الرمز</label>
            <input asp-for="Permission.Code" class="form-control" placeholder="Employees.View" />
            <span asp-validation-for="Permission.Code" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Permission.Name">الاسم</label>
            <input asp-for="Permission.Name" class="form-control" placeholder="View Employees" />
            <span asp-validation-for="Permission.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Permission.DisplayOrder">ترتيب العرض</label>
            <input asp-for="Permission.DisplayOrder" type="number" class="form-control" />
            <span asp-validation-for="Permission.DisplayOrder" class="text-danger"></span>
        </div>

        <div class="form-group checkbox-group">
            <label>
                <input asp-for="Permission.IsActive" />
                نشط
            </label>
        </div>

        <div class="form-group">
            <label asp-for="Permission.Description">الوصف</label>
            <input asp-for="Permission.Description" class="form-control" />
            <span asp-validation-for="Permission.Description" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">حفظ</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

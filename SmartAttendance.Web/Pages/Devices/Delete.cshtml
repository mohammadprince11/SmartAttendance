@page
@model SmartAttendance.Web.Pages.Devices.DeleteModel

@{
    ViewData["Title"] = "Delete Device";
}

<div class="page-header">
    <div>
        <h1>Delete Device</h1>
        <p>Confirm device deletion</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this device?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>Branch</label>
            <div class="form-control">@Model.Device.BranchName</div>
        </div>

        <div class="form-group">
            <label>Device Name</label>
            <div class="form-control">@Model.Device.Name</div>
        </div>

        <div class="form-group">
            <label>IP Address</label>
            <div class="form-control">@Model.Device.IpAddress</div>
        </div>

        <div class="form-group">
            <label>Port</label>
            <div class="form-control">@Model.Device.Port</div>
        </div>

        <div class="form-group">
            <label>Serial Number</label>
            <div class="form-control">@Model.Device.SerialNumber</div>
        </div>

        <div class="form-group">
            <label>Model</label>
            <div class="form-control">@Model.Device.Model</div>
        </div>

        <div class="form-group">
            <label>Firmware Version</label>
            <div class="form-control">@Model.Device.FirmwareVersion</div>
        </div>

        <div class="form-group">
            <label>Status</label>
            <div class="form-control">
                @(Model.Device.IsActive ? "Active" : "Inactive")
            </div>
        </div>

        <div class="form-group">
            <label>Enabled</label>
            <div class="form-control">
                @(Model.Device.IsEnabled ? "Enabled" : "Disabled")
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Device.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">Delete</button>
            <a asp-page="./Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

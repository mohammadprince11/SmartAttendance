@page
@model SmartAttendance.Web.Pages.Devices.DeleteModel

@{
    ViewData["Title"] = "حذف جهاز";
}

<div class="page-header">
    <div>
        <h1>حذف جهاز</h1>
        <p>تأكيد حذف الجهاز</p>
    </div>

    <a asp-page="./Index" class="btn-secondary">رجوع للقائمة</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-card">
    <div class="alert-danger">
        Are you sure you want to delete this device?
    </div>

    <div class="details-grid">
        <div class="form-group">
            <label>الفرع</label>
            <div class="form-control">@Model.Device.BranchName</div>
        </div>

        <div class="form-group">
            <label>اسم الجهاز</label>
            <div class="form-control">@Model.Device.Name</div>
        </div>

        <div class="form-group">
            <label>عنوان IP</label>
            <div class="form-control">@Model.Device.IpAddress</div>
        </div>

        <div class="form-group">
            <label>المنفذ</label>
            <div class="form-control">@Model.Device.Port</div>
        </div>

        <div class="form-group">
            <label>الرقم التسلسلي</label>
            <div class="form-control">@Model.Device.SerialNumber</div>
        </div>

        <div class="form-group">
            <label>الطراز</label>
            <div class="form-control">@Model.Device.Model</div>
        </div>

        <div class="form-group">
            <label>إصدار البرنامج الثابت</label>
            <div class="form-control">@Model.Device.FirmwareVersion</div>
        </div>

        <div class="form-group">
            <label>الحالة</label>
            <div class="form-control">
                @(Model.Device.IsActive ? "Active" : "Inactive")
            </div>
        </div>

        <div class="form-group">
            <label>مفعّل</label>
            <div class="form-control">
                @(Model.Device.IsEnabled ? "Enabled" : "Disabled")
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Device.Id" />

        <div class="form-actions">
            <button type="submit" class="btn-table btn-delete">حذف</button>
            <a asp-page="./Index" class="btn-secondary">إلغاء</a>
        </div>
    </form>
</div>

@page
@model SmartAttendance.Web.Pages.Devices.IndexModel

@{
    ViewData["Title"] = "الأجهزة";
}

<div class="page-header">
    <div>
        <h1>الأجهزة</h1>
        <p>إدارة أجهزة الحضور</p>
    </div>

    <div class="form-actions">
        <a asp-page="./Import" class="btn-secondary">استيراد إكسل</a>
        <a asp-page="./Create" class="btn-primary">+ إضافة جهاز</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="table-card">
    <form method="get" class="search-form">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               placeholder="بحث باسم الجهاز أو العنوان أو الرقم التسلسلي..." />

        <button type="submit" class="btn-primary">بحث</button>
        <a asp-page="./Index" class="btn-secondary">مسح</a>
    </form>

    <table class="data-table">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>عنوان IP</th>
                <th>المنفذ</th>
                <th>الرقم التسلسلي</th>
                <th>نشط</th>
                <th>مفعّل</th>
                <th style="width: 160px;">إجراءات</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Devices.Any())
            {
                foreach (var device in Model.Devices)
                {
                    <tr>
                        <td>@device.Name</td>
                        <td>@device.IpAddress</td>
                        <td>@device.Port</td>
                        <td>@device.SerialNumber</td>
                        <td>@(device.IsActive ? "نعم" : "لا")</td>
                        <td>@(device.IsEnabled ? "نعم" : "لا")</td>
                        <td>
                            <a asp-page="./Edit" asp-route-id="@device.Id" class="btn-table btn-edit">تعديل</a>
                            <a asp-page="./Delete" asp-route-id="@device.Id" class="btn-table btn-delete">حذف</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center;">لا توجد أجهزة.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@page
@model SmartAttendance.Web.Pages.MyProfile.IndexModel

@{
    ViewData["Title"] = "ملفي الشخصي";
    var employee = Model.Employee;
}

<link rel="stylesheet" href="~/css/hrms-core.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/my-profile.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/my-profile-phase1.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/my-profile-attendance-header-fix.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/my-profile-table-align-fix.css" asp-append-version="true" />

@if (employee != null)
{
    <div class="my-profile-page">
        <div class="page-header">
            <div>
                <h1>صفحتي</h1>
                <p>بياناتي الوظيفية وسجلات الحضور والانصراف الخاصة بي.</p>
            </div>

            <div class="my-profile-actions">
<a asp-page="/LeaveRequests/Index" class="my-btn-secondary">طلباتي</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="my-alert success">@Model.SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="my-alert error">@Model.ErrorMessage</div>
        }

        <section class="my-hero-card">
            <div class="my-avatar">SA</div>
            <div>
                <h2>@employee.FullName</h2>
                <p>@employee.EmployeeNo · @employee.Branch · @employee.Department</p>
                <div class="my-chips">
                    @if (string.IsNullOrWhiteSpace(employee.Position))
                    {
                        <span>بدون منصب</span>
                    }
                    else
                    {
                        <span>@employee.Position</span>
                    }

                    @if (employee.IsActive)
                    {
                        <span>فعال</span>
                    }
                    else
                    {
                        <span>غير فعال</span>
                    }

                    @if (string.IsNullOrWhiteSpace(employee.DirectManager))
                    {
                        <span>بدون مدير مباشر</span>
                    }
                    else
                    {
                        <span>@employee.DirectManager</span>
                    }
                </div>
            </div>
        </section>

        <section class="my-stats-grid">
            <div class="my-stat">
                <span>سجلات الحضور</span>
                <strong>@Model.TotalAttendance</strong>
                <small>كل السجلات</small>
            </div>

            <div class="my-stat">
                <span>حاضر</span>
                <strong>@Model.PresentCount</strong>
                <small>حاضر</small>
            </div>

            <div class="my-stat">
                <span>متأخر</span>
                <strong>@Model.LateCount</strong>
                <small>متأخر</small>
            </div>

            <div class="my-stat">
                <span>طلبات معلقة</span>
                <strong>@Model.PendingRequestsCount</strong>
                <small>بانتظار الموافقة</small>
            </div>
        </section>

        <section class="my-tabs">
            <button type="button" class="active" data-my-tab="hr">شؤون الموظفين</button>
            <button type="button" data-my-tab="attendance">الحضور والانصراف</button>
            <button type="button" data-my-tab="requests">طلباتي</button>
        </section>

        <section class="my-panel active" data-my-panel="hr">
            <div class="my-card">
                <div class="my-card-head">
                    <div>
                        <h2>بياناتي الوظيفية</h2>
                        <p>يمكنك تعديل البيانات الشخصية فقط.</p>
                    </div>
                    <button type="button" class="my-btn-secondary" data-toggle-profile-edit>تعديل بياناتي</button>
                </div>

                <form method="post" asp-page-handler="SaveProfile" class="my-edit-form" data-profile-form>
                    <div class="my-info-grid">
                        <div><span>رقم الموظف</span><strong>@employee.EmployeeNo</strong></div>

                        <div class="editable">
                            <span>الاسم الكامل</span>
                            <strong data-view>@employee.FullName</strong>
                            <input asp-for="ProfileInput.FullName" data-edit />
                        </div>

                        <div><span>الفرع</span><strong>@employee.Branch</strong></div>
                        <div><span>القسم</span><strong>@employee.Department</strong></div>
                        <div><span>المنصب</span><strong>@employee.Position</strong></div>

                        <div class="editable">
                            <span>الهاتف</span>
                            <strong data-view>@employee.Phone</strong>
                            <input asp-for="ProfileInput.Phone" data-edit />
                        </div>

                        <div class="editable">
                            <span>الإيميل</span>
                            <strong data-view>@employee.Email</strong>
                            <input asp-for="ProfileInput.Email" data-edit type="email" />
                        </div>

                        <div class="editable">
                            <span>رقم الهوية</span>
                            <strong data-view>@employee.NationalId</strong>
                            <input asp-for="ProfileInput.NationalId" data-edit />
                        </div>

                        <div><span>تاريخ المباشرة</span><strong>@employee.HireDate?.ToString("yyyy-MM-dd")</strong></div>

                        <div class="editable">
                            <span>تاريخ الميلاد</span>
                            <strong data-view>@employee.BirthDate?.ToString("yyyy-MM-dd")</strong>
                            <input asp-for="ProfileInput.BirthDate" data-edit type="date" />
                        </div>

                        <div class="editable">
                            <span>الجنسية</span>
                            <strong data-view>@employee.Nationality</strong>
                            <input asp-for="ProfileInput.Nationality" data-edit />
                        </div>

                        <div class="editable">
                            <span>البلد</span>
                            <strong data-view>@employee.Country</strong>
                            <input asp-for="ProfileInput.Country" data-edit />
                        </div>

                        <div><span>نوع العقد</span><strong>@employee.ContractType</strong></div>
                        <div><span>انتهاء العقد</span><strong>@employee.ContractEndDate?.ToString("yyyy-MM-dd")</strong></div>
                        <div><span>الحالة الوظيفية</span><strong>@employee.EmploymentStatus</strong></div>
                        <div><span>المدير المباشر</span><strong>@employee.DirectManager</strong></div>
                    </div>

                    <div class="my-edit-actions" data-edit-actions>
                        <button type="submit" class="my-btn-primary">حفظ التعديل</button>
                        <button type="button" class="my-btn-secondary" data-cancel-profile-edit>إلغاء</button>
                    </div>
                </form>
            </div>
        </section>

        <section class="my-panel" data-my-panel="attendance">
            <div class="my-card">
                <div class="my-card-head">
                    <div>
                        <h2>الحضور والانصراف</h2>
                        <p>سجل الحضور الخاص بك حسب الفترة المحددة.</p>
                    </div>
                </div>

                <form method="get" class="my-filter">
                    <div class="my-filter-field">
                        <label>من تاريخ</label>
                        <input asp-for="FromDate" type="date" />
                    </div>

                    <div class="my-filter-field">
                        <label>إلى تاريخ</label>
                        <input asp-for="ToDate" type="date" />
                    </div>

                    <div class="my-filter-actions">
                        <button type="submit" class="my-btn-primary">بحث</button>
                        <a asp-page="/MyProfile/Index" class="my-btn-secondary">مسح</a>
                    </div>
                </form>

                <div class="my-table-wrap">
                    <table class="my-table">
                        <thead>
                            <tr>
                                <th>التاريخ</th>
                                <th><span class="stacked-th"><span>بصمة</span><strong>الدخول</strong></span></th>
                                <th><span class="stacked-th"><span>بصمة</span><strong>الخروج</strong></span></th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.AttendanceRows)
                            {
                                <tr>
                                    <td>@row.AttendanceDate?.ToString("yyyy-MM-dd")</td>
                                    <td>@row.CheckIn?.ToString("HH:mm")</td>
                                    <td>@row.CheckOut?.ToString("HH:mm")</td>
                                    <td><span class="my-badge status-@row.Status">@SmartAttendance.Web.Pages.MyProfile.IndexModel.StatusText(row.Status)</span></td>
                                </tr>
                            }

                            @if (!Model.AttendanceRows.Any())
                            {
                                <tr>
                                    <td colspan="4" class="my-empty">لا توجد سجلات حضور ضمن الفترة المحددة.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="my-panel" data-my-panel="requests">
            <div class="my-card">
                <div class="my-card-head">
                    <div>
                        <h2>طلباتي</h2>
                        <p>آخر الطلبات المقدمة من حسابك.</p>
                    </div>
</div>

                <div class="my-table-wrap">
                    <table class="my-table">
                        <thead>
                            <tr>
                                <th>النوع</th>
                                <th>من</th>
                                <th>إلى</th>
                                <th>وقت</th>
                                <th>الحالة</th>
                                <th>المرحلة</th>
                                <th>تاريخ الطلب</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.Requests)
                            {
                                string statusText;

                                if (request.Status == "Pending")
                                {
                                    statusText = "معلق";
                                }
                                else if (request.Status == "Approved")
                                {
                                    statusText = "مقبول";
                                }
                                else if (request.Status == "Rejected")
                                {
                                    statusText = "مرفوض";
                                }
                                else
                                {
                                    statusText = request.Status;
                                }

                                <tr>
                                    <td>@SmartAttendance.Web.Pages.MyProfile.IndexModel.RequestTypeText(request.RequestType)</td>
                                    <td>@request.StartDate?.ToString("yyyy-MM-dd")</td>
                                    <td>@request.EndDate?.ToString("yyyy-MM-dd")</td>
                                    <td>@SmartAttendance.Web.Pages.MyProfile.IndexModel.FormatRequestTime(request.FromTime, request.ToTime)</td>
                                    <td>@Html.Raw(statusText)</td>
                                    <td>@request.ApprovalStage</td>
                                    <td>@request.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }

                            @if (!Model.Requests.Any())
                            {
                                <tr>
                                    <td colspan="7" class="my-empty">لا توجد طلبات.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <div class="my-modal-backdrop" data-request-modal>
            <div class="my-modal">
                <div class="my-modal-head">
                    <h2>تقديم طلب جديد</h2>
                    <button type="button" data-close-request>×</button>
                </div>

                <form method="post" asp-page-handler="SubmitRequest" class="my-request-form">
                    <div class="my-form-grid">
                        <div class="my-filter-field">
                            <label>نوع الطلب</label>
                            <select asp-for="RequestInput.RequestType" data-request-type required>
                                <option value="">-- اختر --</option>
                                <option value="Missing Punch">نسيان بصمة</option>
                                <option value="Exit Permission">مغادرة</option>
                                <option value="Overtime">عمل إضافي</option>
                                <option value="Annual Leave">إجازة سنوية</option>
                                <option value="Unpaid Leave">إجازة بدون راتب</option>
                                <option value="Sick Leave">إجازة مرضية</option>
                                <option value="Work Leave">إجازة عمل</option>
                            </select>
                        </div>

                        <div class="my-filter-field">
                            <label>من تاريخ</label>
                            <input asp-for="RequestInput.StartDate" type="date" required />
                        </div>

                        <div class="my-filter-field">
                            <label>إلى تاريخ</label>
                            <input asp-for="RequestInput.EndDate" type="date" />
                        </div>

                        <div class="my-filter-field">
                            <label>من وقت</label>
                            <input asp-for="RequestInput.FromTime" type="time" />
                        </div>

                        <div class="my-filter-field">
                            <label>إلى وقت</label>
                            <input asp-for="RequestInput.ToTime" type="time" />
                        </div>

                        <div class="my-filter-field full">
                            <label>السبب</label>
                            <textarea asp-for="RequestInput.Reason" rows="3"></textarea>
                            <small data-request-hint>اختر نوع الطلب لإظهار التفاصيل المطلوبة.</small>
                        </div>
                    </div>

                    <div class="my-modal-actions">
                        <button type="submit" class="my-btn-primary">إرسال الطلب</button>
                        <button type="button" class="my-btn-secondary" data-close-request>إلغاء</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else if (Model.AccountNotLinkedToEmployee)
{
    @* حساب نظامي بلا سجل موظف (admin مثلاً): ليست مشكلة صلاحية — تُشرح الحالة *@
    <div class="hrms-page">
        <div class="page-header">
            <div>
                <h1>ملفي الشخصي</h1>
                <p>صفحة الخدمة الذاتية للموظف: بياناته وحضوره وطلباته.</p>
            </div>
        </div>

        <div class="hrms-card" style="text-align:center;padding:48px 24px">
            <h2 style="margin:0 0 10px;font-size:18px;font-weight:1000">حسابك غير مرتبط بسجل موظف</h2>
            <p style="margin:0 0 6px;color:var(--sa-muted,#8FA8BC);font-weight:800">
                هذه الصفحة تعرض بيانات موظف بعينه، وحسابك حساب نظامي لا يقابله سجل في قائمة الموظفين.
            </p>
            <p style="margin:0 0 18px;color:var(--sa-muted,#8FA8BC);font-weight:800">
                لربط الحساب بموظف، افتح «إدارة مستخدمي النظام» واختر الموظف المقابل للحساب.
            </p>
            <a href="/UserAccess" class="hrms-btn-primary">إدارة مستخدمي النظام</a>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/my-profile.js" asp-append-version="true"></script>
    <script src="~/js/my-profile-phase1.js" asp-append-version="true"></script>
}




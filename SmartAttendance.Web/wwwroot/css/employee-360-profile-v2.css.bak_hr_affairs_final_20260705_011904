/* NEXORA Employee 360 Profile V2 */

.employee360v2-page,
.employee360v2-page * {
    box-sizing: border-box;
}

.employee360v2-page {
    direction: rtl;
    display: grid;
    gap: 18px;
    width: 100%;
    max-width: 100%;
}

.employee360v2-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 18px;
}

.employee360v2-eyebrow {
    display: inline-flex;
    margin-bottom: 8px;
    padding: 6px 11px;
    border-radius: 999px;
    border: 1px solid rgba(18,217,227,.28);
    background: rgba(18,217,227,.08);
    color: #12D9E3;
    font-weight: 1000;
    letter-spacing: .03em;
}

.employee360v2-head h1 {
    margin: 0;
    color: var(--sa-text, #E6EAEE);
    font-size: 34px;
    line-height: 1.1;
    font-weight: 1000;
}

.employee360v2-head p,
.employee360v2-card-head p {
    margin: 8px 0 0;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-actions,
.employee360v2-filter {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.employee360v2-btn {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 14px;
    border-radius: 12px;
    border: 1px solid rgba(230,234,238,.14);
    background: rgba(255,255,255,.035);
    color: var(--sa-text, #E6EAEE) !important;
    font-weight: 1000;
    text-decoration: none !important;
    cursor: pointer;
}

.employee360v2-btn.primary {
    color: #07121F !important;
    border-color: rgba(18,217,227,.50);
    background: linear-gradient(135deg, #12D9E3, #7CEAF0);
}

.employee360v2-btn.danger {
    color: #ffd1d1 !important;
    border-color: rgba(239,68,68,.28);
    background: rgba(239,68,68,.12);
}

.employee360v2-hero,
.employee360v2-card,
.employee360v2-kpi,
.employee360v2-alert-strip {
    border: 1px solid rgba(230,234,238,.12);
    border-radius: 22px;
    background:
        linear-gradient(135deg, rgba(18,217,227,.045), rgba(215,178,109,.025)),
        rgba(15,34,51,.88);
    box-shadow: 0 22px 58px rgba(0,0,0,.22);
}

.employee360v2-hero {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 22px;
    position: relative;
    overflow: hidden;
}

.employee360v2-hero::after {
    content: "N";
    position: absolute;
    inset-inline-end: 28px;
    inset-block-end: -76px;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 210px;
    font-weight: 1000;
    color: rgba(230,234,238,.035);
    pointer-events: none;
}

.employee360v2-avatar {
    width: 74px;
    height: 74px;
    display: grid;
    place-items: center;
    border-radius: 24px;
    background: linear-gradient(135deg, #12D9E3, #D7B26D);
    color: #07121F;
    font-size: 34px;
    font-weight: 1000;
    box-shadow: 0 0 30px rgba(18,217,227,.18);
}

.employee360v2-identity {
    min-width: 0;
}

.employee360v2-identity h2 {
    margin: 0;
    color: var(--sa-text, #E6EAEE);
    font-size: clamp(26px, 4vw, 42px);
    line-height: 1.1;
    font-weight: 1000;
}

.employee360v2-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
}

.employee360v2-meta span,
.employee360v2-status,
.employee360v2-badge {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 28px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(18,217,227,.22);
    background: rgba(18,217,227,.07);
    color: #12D9E3;
    font-weight: 1000;
}

.employee360v2-state {
    display: grid;
    gap: 6px;
    justify-items: center;
    position: relative;
    z-index: 1;
}

.employee360v2-state small {
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-status.ok,
.employee360v2-badge.ok {
    color: #07121F;
    background: linear-gradient(135deg, #12D9E3, #7CEAF0);
}

.employee360v2-status.danger,
.employee360v2-badge.danger {
    color: #ffd1d1;
    border-color: rgba(239,68,68,.28);
    background: rgba(239,68,68,.13);
}

.employee360v2-badge.warn,
.employee360v2-badge.gold {
    color: #D7B26D;
    border-color: rgba(215,178,109,.30);
    background: rgba(215,178,109,.09);
}

.employee360v2-alert-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
}

.employee360v2-alert-strip strong {
    color: #D7B26D;
    font-weight: 1000;
}

.employee360v2-alert-strip span {
    color: var(--sa-text, #E6EAEE);
    font-weight: 1000;
}

.employee360v2-alert-strip small {
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-alert-strip.warn {
    border-color: rgba(215,178,109,.32);
    background: rgba(215,178,109,.08);
}

.employee360v2-alert-strip.danger {
    border-color: rgba(239,68,68,.28);
    background: rgba(239,68,68,.10);
}

.employee360v2-kpis {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 12px;
}

.employee360v2-kpi {
    min-height: 110px;
    padding: 16px;
    position: relative;
    overflow: hidden;
}

.employee360v2-kpi span {
    display: block;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 900;
}

.employee360v2-kpi strong {
    display: block;
    margin-top: 10px;
    color: #12D9E3;
    font-size: 30px;
    line-height: 1;
    font-weight: 1000;
}

.employee360v2-kpi.warn strong {
    color: #D7B26D;
}

.employee360v2-kpi.danger strong {
    color: #ff9b9b;
}

.employee360v2-kpi small {
    display: block;
    margin-top: 8px;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 800;
}

.employee360v2-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    padding: 10px;
    border: 1px solid rgba(230,234,238,.10);
    border-radius: 18px;
    background: rgba(15,34,51,.60);
}

.employee360v2-tabs a {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
    border-radius: 999px;
    color: var(--sa-muted, #9FB0BE);
    text-decoration: none;
    font-weight: 1000;
}

.employee360v2-tabs a:hover {
    background: rgba(18,217,227,.10);
    color: #12D9E3;
}

.employee360v2-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
}

.employee360v2-card {
    min-width: 0;
    padding: 18px;
}

.employee360v2-card-head {
    margin-bottom: 14px;
}

.employee360v2-card-head.split {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 14px;
}

.employee360v2-card h3 {
    margin: 0;
    color: var(--sa-text, #E6EAEE);
    font-weight: 1000;
}

.employee360v2-info {
    display: grid;
    gap: 8px;
}

.employee360v2-info div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(230,234,238,.09);
}

.employee360v2-info span {
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-info strong {
    color: var(--sa-text, #E6EAEE);
    font-weight: 1000;
    text-align: end;
}

.employee360v2-filter label {
    display: grid;
    gap: 5px;
    color: var(--sa-muted, #9FB0BE);
    font-size: 12px;
    font-weight: 900;
}

.employee360v2-filter input {
    min-height: 38px;
    min-width: 146px;
    border-radius: 12px !important;
}

.employee360v2-table-wrap {
    width: 100%;
    overflow: auto;
    border-radius: 16px;
    border: 1px solid rgba(230,234,238,.08);
}

.employee360v2-table {
    width: 100%;
    min-width: 820px;
    border-collapse: collapse;
    table-layout: fixed;
}

.employee360v2-table.compact {
    min-width: 620px;
}

.employee360v2-table th,
.employee360v2-table td {
    padding: 12px 10px;
    text-align: center;
    border-bottom: 1px solid rgba(230,234,238,.10);
    color: var(--sa-text, #E6EAEE);
    font-weight: 850;
    line-height: 1.45;
    overflow-wrap: anywhere;
}

.employee360v2-table th {
    color: #D7B26D;
    background: rgba(7,18,31,.35);
    font-weight: 1000;
}

.employee360v2-empty {
    padding: 20px !important;
    color: var(--sa-muted, #9FB0BE) !important;
    font-weight: 1000 !important;
}

.employee360v2-mini-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 9px;
    margin-bottom: 12px;
}

.employee360v2-mini-kpis div {
    padding: 12px;
    border: 1px solid rgba(230,234,238,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.025);
    text-align: center;
}

.employee360v2-mini-kpis span {
    display: block;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 900;
}

.employee360v2-mini-kpis strong {
    display: block;
    margin-top: 5px;
    color: #12D9E3;
    font-size: 24px;
    font-weight: 1000;
}

.employee360v2-alert.danger {
    padding: 14px 16px;
    border-radius: 16px;
    border: 1px solid rgba(239,68,68,.28);
    background: rgba(239,68,68,.10);
    color: #ffd1d1;
    font-weight: 1000;
}

@media (max-width: 1180px) {
    .employee360v2-kpis {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .employee360v2-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 780px) {
    .employee360v2-head,
    .employee360v2-card-head.split {
        flex-direction: column;
        align-items: stretch;
    }

    .employee360v2-hero {
        grid-template-columns: 1fr;
        text-align: center;
    }

    .employee360v2-avatar {
        margin: auto;
    }

    .employee360v2-meta {
        justify-content: center;
    }

    .employee360v2-alert-strip {
        flex-direction: column;
        align-items: flex-start;
    }

    .employee360v2-kpis {
        grid-template-columns: 1fr;
    }
}


/* Employee 360 V1 upgrade */
.employee360v2-readiness-card {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: center;
    padding: 18px;
    border: 1px solid rgba(230,234,238,.12);
    border-radius: 22px;
    background:
        radial-gradient(circle at 12% 12%, rgba(18,217,227,.10), transparent 32%),
        rgba(15,34,51,.82);
    box-shadow: var(--nx-shadow, 0 22px 60px rgba(0,0,0,.24));
}

.employee360v2-readiness-card.ok {
    border-color: rgba(34,197,94,.25);
}

.employee360v2-readiness-card.warn {
    border-color: rgba(215,178,109,.28);
}

.employee360v2-mini-label {
    display: inline-flex;
    margin-bottom: 8px;
    padding: 6px 10px;
    border-radius: 999px;
    color: #07121F;
    background: linear-gradient(135deg, #12D9E3, #7CEAF0);
    font-size: 12px;
    font-weight: 1000;
}

.employee360v2-readiness-card h3 {
    margin: 0;
    color: var(--sa-text, #E6EAEE);
    font-size: 22px;
    font-weight: 1000;
}

.employee360v2-readiness-card p {
    margin: 8px 0 0;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
    line-height: 1.8;
}

.employee360v2-readiness-score {
    min-width: 160px;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 16px;
    border-radius: 20px;
    border: 1px solid rgba(215,178,109,.18);
    background: rgba(7,18,31,.32);
}

.employee360v2-readiness-score strong {
    color: var(--nx-gold, #D7B26D);
    font-size: 44px;
    line-height: 1;
    font-weight: 1000;
}

.employee360v2-readiness-score span {
    margin-top: 8px;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-risk-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
}

.employee360v2-risk-item {
    padding: 14px;
    border-radius: 18px;
    border: 1px solid rgba(230,234,238,.10);
    background: rgba(7,18,31,.30);
}

.employee360v2-risk-item span,
.employee360v2-risk-item small {
    display: block;
    color: var(--sa-muted, #9FB0BE);
    font-weight: 850;
}

.employee360v2-risk-item strong {
    display: block;
    margin: 8px 0;
    color: var(--nx-teal, #12D9E3);
    font-size: 28px;
    font-weight: 1000;
}

.employee360v2-payroll-note {
    margin-top: 14px;
    padding: 12px 14px;
    border-radius: 16px;
    color: var(--sa-muted, #9FB0BE);
    border: 1px solid rgba(18,217,227,.16);
    background: rgba(18,217,227,.05);
    font-weight: 850;
    line-height: 1.8;
}

.employee360v2-payroll-note strong {
    color: var(--nx-gold, #D7B26D);
}

@media (max-width: 1100px) {
    .employee360v2-risk-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 760px) {
    .employee360v2-readiness-card {
        flex-direction: column;
        align-items: stretch;
    }

    .employee360v2-risk-grid {
        grid-template-columns: 1fr;
    }
}

